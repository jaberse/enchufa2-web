      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* ── Hero ── */
    .hero {
      max-width: 780px;
      margin-bottom: clamp(2rem, 5vw, 4rem);
    }
    .eyebrow {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 1rem;
    }
    .hero h1 {
      font-size: clamp(2.25rem, 6vw, 4rem);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1.05;
      margin-bottom: 1rem;
    }
    .deck {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: clamp(1.125rem, 2vw, 1.375rem);
      color: var(--text-secondary);
      line-height: 1.45;
      max-width: 680px;
    }
    .beta-warn {
      margin-top: 1.5rem;
      padding: 0.75rem 1rem;
      border-left: 3px solid var(--yellow);
      background: var(--yellow-glow);
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--text-secondary);
    }
    .beta-warn strong { color: var(--text); }
    .beta-warn code {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.8125rem;
      background: var(--surface-alt);
      padding: 0 0.25rem;
      border-radius: 3px;
    }
    .beta-warn a { color: var(--text); text-decoration: underline; }

    /* ── Controles ── */
    .controles {
      margin-bottom: clamp(2rem, 5vw, 3.5rem);
      padding: clamp(1.5rem, 3vw, 2rem);
      background: var(--surface-alt);
      border-radius: var(--radius);
      border: 1px solid var(--border-subtle);
    }
    .ctrl-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    @media (min-width: 720px) {
      .ctrl-grid {
        grid-template-columns: 1fr 1fr;
      }
      .ctrl-seleccion,
      .ctrl-mix { grid-column: 1 / -1; }
    }
    .ctrl {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    fieldset.ctrl {
      border: none;
      padding: 0;
      margin: 0;
    }
    .ctrl legend,
    .ctrl > label:first-child {
      font-size: 0.875rem;
      font-weight: 500;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 0.25rem;
      gap: 1rem;
    }
    .ctrl output {
      font-variant-numeric: tabular-nums;
      color: var(--text-muted);
      font-weight: 400;
    }
    .ctrl-hint {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* ── Selector multi-coche (Sprint 2 E2 paso 2B) ── */
    .ctrl-seleccion {
      gap: 0.875rem;
      padding: 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .ctrl-seleccion legend {
      font-size: 0.875rem;
      font-weight: 500;
      padding: 0 0.25rem;
      color: var(--text);
    }
    .seleccion-hint {
      font-size: 0.8125rem;
      color: var(--text-muted);
      line-height: 1.5;
      margin: 0;
    }
    .quick-starts {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
      align-items: center;
    }
    .qs-label {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-right: 0.25rem;
    }
    .qs-btn {
      padding: 0.375rem 0.75rem;
      font-size: 0.8125rem;
      font-family: inherit;
      font-weight: 400;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--text-secondary);
      border-radius: 999px;
      cursor: pointer;
      transition: border-color 0.2s var(--ease-out-expo),
                  background 0.2s var(--ease-out-expo),
                  color 0.2s var(--ease-out-expo);
    }
    .qs-btn:hover {
      border-color: var(--yellow);
      color: var(--text);
    }
    .seleccion-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.875rem;
      padding-top: 0.75rem;
      border-top: 1px dashed var(--border);
    }
    @media (min-width: 720px) {
      .seleccion-grid { grid-template-columns: 1fr 1fr; }
    }
    .seleccion-col {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      min-width: 0;
    }
    .col-head {
      margin: 0;
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .col-count {
      margin-left: auto;
      font-weight: 400;
      color: var(--text-muted);
      font-variant-numeric: tabular-nums;
    }
    .col-dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      flex: 0 0 auto;
    }
    .col-dot-bev { background: var(--yellow); }
    .col-dot-ice { background: var(--gray-400); }

    /* Chips estilo Gmail */
    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
      min-height: 2rem;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.25rem 0.25rem 0.25rem 0.625rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 999px;
      font-size: 0.8125rem;
      line-height: 1;
      max-width: 100%;
      transition: border-color 0.2s var(--ease-out-expo),
                  background 0.2s var(--ease-out-expo);
    }
    .chip:hover { border-color: var(--gray-300); }
    .chip-bev { border-left: 3px solid var(--yellow); padding-left: 0.5rem; }
    .chip-ice { border-left: 3px solid var(--gray-400); padding-left: 0.5rem; }
    .chip-focus {
      background: var(--yellow-glow);
      border-color: var(--yellow);
    }
    .chip-name {
      background: none;
      border: none;
      padding: 0.125rem 0.25rem;
      font: inherit;
      color: var(--text);
      cursor: pointer;
      max-width: 20ch;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .chip-name:hover { color: var(--text); }
    .chip-remove {
      background: none;
      border: none;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      cursor: pointer;
      font-size: 1rem;
      line-height: 1;
      padding: 0;
      transition: background 0.15s, color 0.15s;
    }
    .chip-remove:hover {
      background: var(--border);
      color: var(--text);
    }

    /* Combobox */
    .chips-combo {
      position: relative;
      margin-top: 0.25rem;
    }
    .combo-input {
      width: 100%;
      padding: 0.5rem 0.75rem;
      font: inherit;
      font-size: 0.8125rem;
      background: var(--bg);
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      transition: border-color 0.2s var(--ease-out-expo);
    }
    .combo-input::placeholder { color: var(--text-muted); }
    .combo-input:focus-visible {
      outline: 2px solid var(--yellow);
      outline-offset: 2px;
      border-color: var(--yellow);
    }
    .combo-input:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .chips-suggest {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      right: 0;
      margin: 0;
      padding: 0.25rem;
      list-style: none;
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      z-index: 20;
      max-height: 280px;
      overflow-y: auto;
    }
    .suggest-item {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      padding: 0.5rem 0.625rem;
      font-size: 0.8125rem;
      border-radius: calc(var(--radius) * 0.65);
      cursor: pointer;
      transition: background 0.12s;
    }
    .suggest-item:hover {
      background: var(--surface-alt);
    }
    .suggest-name {
      color: var(--text);
      flex: 1 1 auto;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .suggest-seg {
      font-size: 0.6875rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      flex: 0 0 auto;
    }

    /* Pills */
    .pills {
      display: inline-flex;
      gap: 0.25rem;
      padding: 0.25rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 999px;
      width: fit-content;
    }
    .pill {
      position: relative;
      padding: 0.375rem 1rem;
      border-radius: 999px;
      cursor: pointer;
      font-size: 0.875rem;
      color: var(--text-secondary);
      transition: background 0.2s, color 0.2s;
    }
    .pill input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }
    .pill:has(input:checked) {
      background: var(--black);
      color: var(--white);
    }
    [data-theme="dark"] .pill:has(input:checked) {
      background: var(--yellow);
      color: var(--black);
    }

    /* Sliders */
    input[type="range"] {
      -webkit-appearance: none;
      appearance: none;
      width: 100%;
      height: 4px;
      background: var(--border);
      border-radius: 999px;
      outline: none;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--yellow);
      border: 2px solid var(--black);
      cursor: pointer;
      transition: transform 0.15s;
    }
    input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.1); }
    input[type="range"]::-moz-range-thumb {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--yellow);
      border: 2px solid var(--black);
      cursor: pointer;
    }
    input[type="range"]:focus-visible::-webkit-slider-thumb {
      outline: 2px solid var(--yellow);
      outline-offset: 2px;
    }

    /* Checkbox */
    .ctrl-check label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      cursor: pointer;
    }
    .ctrl-check input { width: 18px; height: 18px; accent-color: var(--yellow); }
    .ctrl-check[data-has-ayuda="false"] label {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* ── E1 — Mix de carga casa/pública ── */
    .ctrl-mix {
      gap: 0.75rem;
      padding: 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .ctrl-mix legend {
      font-size: 0.875rem;
      font-weight: 500;
      padding: 0 0.25rem;
      color: var(--text);
    }
    .mix-presets {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }
    .mix-preset {
      padding: 0.375rem 0.75rem;
      font-size: 0.8125rem;
      font-weight: 400;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--text-secondary);
      border-radius: 999px;
      cursor: pointer;
      transition: border-color 0.2s var(--ease-out-expo),
                  background 0.2s var(--ease-out-expo),
                  color 0.2s var(--ease-out-expo);
    }
    .mix-preset:hover {
      border-color: var(--gray-300);
      color: var(--text);
    }
    .mix-preset.active {
      background: var(--black);
      color: var(--white);
      border-color: var(--black);
    }
    [data-theme="dark"] .mix-preset.active {
      background: var(--yellow);
      color: var(--black);
      border-color: var(--yellow);
    }
    .mix-label {
      font-size: 0.875rem;
      font-weight: 500;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
    }
    .mix-label output {
      font-variant-numeric: tabular-nums;
      color: var(--text-muted);
      font-weight: 400;
    }
    .mix-prices {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding-top: 0.5rem;
      border-top: 1px dashed var(--border);
    }
    @media (min-width: 540px) {
      .mix-prices { grid-template-columns: 1fr 1fr; }
    }
    .mix-price {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }
    .mix-price label {
      font-size: 0.8125rem;
      font-weight: 500;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.5rem;
    }
    .mix-price output {
      font-variant-numeric: tabular-nums;
      color: var(--text-muted);
      font-weight: 400;
    }
    .kwh-efectivo {
      margin: 0;
      padding-top: 0.5rem;
      border-top: 1px dashed var(--border);
      font-size: 0.8125rem;
      color: var(--text-secondary);
    }
    .kwh-efectivo strong {
      color: var(--text);
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }

    /* ── Resultado ── */
    .resultado {
      margin-bottom: clamp(2rem, 5vw, 3.5rem);
    }
    .lede {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      line-height: 1.35;
      color: var(--text);
      margin-bottom: 1.5rem;
      max-width: 780px;
    }
    .lede strong {
      font-family: var(--font-sans);
      font-style: normal;
      font-weight: 500;
    }

    /* ── E7 — Sensibilidad ── */
    .sensibilidad {
      margin: 0 0 clamp(1.5rem, 4vw, 2.5rem);
      padding: clamp(1rem, 2.5vw, 1.5rem);
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--yellow);
      border-radius: var(--radius);
      max-width: 780px;
    }
    .sensibilidad h3 {
      margin: 0 0 0.5rem;
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--text);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .sens-intro {
      margin: 0 0 0.875rem;
      font-size: 0.875rem;
      line-height: 1.55;
      color: var(--text-secondary);
    }
    .sens-intro em {
      font-style: italic;
      color: var(--text);
    }
    .sens-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }
    .sens-row {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.375rem;
      padding: 0.75rem 0.875rem;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: calc(var(--radius) * 0.75);
    }
    @media (min-width: 640px) {
      .sens-row {
        grid-template-columns: minmax(180px, 240px) 1fr;
        gap: 1rem;
        align-items: center;
      }
    }
    .sens-ctrl {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
      min-width: 0;
    }
    .sens-ctrl label {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 0.5rem;
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .sens-ctrl output {
      font-variant-numeric: tabular-nums;
      color: var(--text);
      text-transform: none;
      letter-spacing: 0;
      font-weight: 500;
    }
    .sens-out {
      margin: 0;
      font-size: 0.875rem;
      line-height: 1.45;
      color: var(--text-secondary);
    }
    .sens-out strong {
      color: var(--text);
      font-weight: 500;
      font-variant-numeric: tabular-nums;
    }

    .tco-focus-wrap {
      display: block;
    }
    .tco-card {
      padding: clamp(1.25rem, 2.5vw, 2rem);
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      max-width: 680px;
    }
    .tco-focus[data-tren="BEV"] { border-left: 3px solid var(--yellow); }
    .tco-focus[data-tren="ICE"] { border-left: 3px solid var(--gray-400); }
    .focus-hint {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin: 0.375rem 0 0;
      font-style: italic;
    }
    .tco-card header { margin-bottom: 1rem; }
    .tco-tren {
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .tco-card h3 {
      font-size: 1.125rem;
      font-weight: 500;
      margin-top: 0.25rem;
    }
    .tco-big {
      font-size: clamp(2.25rem, 5vw, 3.5rem);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1;
      font-variant-numeric: tabular-nums;
    }
    .tco-range {
      font-size: 0.8125rem;
      color: var(--text-muted);
      font-variant-numeric: tabular-nums;
      margin-top: 0.375rem;
      margin-bottom: 0;
      letter-spacing: 0.01em;
    }
    .tco-sub {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-top: 0.25rem;
      margin-bottom: 1.25rem;
    }
    .tco-breakdown {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.375rem 1rem;
      font-size: 0.9375rem;
      border-top: 1px solid var(--border-subtle);
      padding-top: 1rem;
    }
    .tco-breakdown dt {
      color: var(--text-secondary);
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }
    .tco-breakdown dd {
      font-variant-numeric: tabular-nums;
      font-weight: 500;
      text-align: right;
    }
    /* Puntito de confianza por partida. */
    .conf-dot {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: transparent;
      border: 1px solid var(--border);
      vertical-align: middle;
      cursor: help;
    }
    .conf-dot.conf-alta { background: #3aaa3a; border-color: #3aaa3a; }
    .conf-dot.conf-media { background: var(--yellow); border-color: var(--yellow); }
    .conf-dot.conf-baja { background: #d97706; border-color: #d97706; }
    /* Lede con rango de ahorro. */
    .lede-rango {
      font-size: 0.8125rem;
      color: var(--text-muted);
      font-variant-numeric: tabular-nums;
      display: inline-block;
      margin-left: 0.25rem;
    }
    /* Caveat de la banda bajo el gráfico. */
    .chart-caveat {
      font-size: 0.8125rem;
      color: var(--text-muted);
      line-height: 1.5;
      margin: 0.75rem 0 0;
      max-width: 680px;
    }
    .chart-caveat a {
      color: var(--text-secondary);
      text-decoration: underline;
      text-decoration-color: var(--border);
      text-underline-offset: 2px;
    }
    .chart-caveat a:hover { text-decoration-color: var(--yellow); }

    /* ── Gráfico TCO acumulado ── */
    .tco-chart-fig {
      margin: clamp(1.5rem, 4vw, 2.5rem) 0 0;
      padding: clamp(1.25rem, 2.5vw, 2rem);
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .tco-chart-fig figcaption {
      margin-bottom: 1.25rem;
    }
    .tco-chart-fig h3 {
      font-size: 1.125rem;
      font-weight: 500;
      margin: 0 0 0.375rem;
    }
    .chart-sub {
      font-size: 0.9375rem;
      color: var(--text-secondary);
      line-height: 1.5;
      margin: 0;
      max-width: 640px;
    }
    .chart-sub em {
      font-family: var(--font-serif);
      font-style: italic;
    }
    .chart-wrap {
      width: 100%;
    }
    #tco-chart {
      width: 100%;
      height: auto;
      display: block;
      overflow: visible;
    }
    /* Clases aplicadas a nodos SVG creados por JS (createElementNS).
       Astro no añade data-astro-cid a nodos dinámicos, así que
       usamos :global() para que los estilos los alcancen. */
    #tco-chart :global(.grid-line) {
      stroke: var(--border-subtle);
      stroke-width: 1;
      fill: none;
    }
    #tco-chart :global(.grid-vert) {
      stroke: var(--border-subtle);
      stroke-width: 1;
      stroke-dasharray: 2 4;
      opacity: 0.55;
      fill: none;
    }
    #tco-chart :global(.grid-zero) {
      stroke: var(--border);
      stroke-width: 1;
      fill: none;
    }
    #tco-chart :global(.ax-line) {
      stroke: var(--border);
      stroke-width: 1;
      fill: none;
    }
    #tco-chart :global(.ax-label) {
      font-family: var(--font-sans);
      font-size: 11px;
      fill: var(--text-muted);
      font-variant-numeric: tabular-nums;
    }
    /* Curvas base — trazo común, el grosor lo aporta focus/dim. */
    #tco-chart :global(.curve-bev),
    #tco-chart :global(.curve-ice) {
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    #tco-chart :global(.curve-bev) { stroke: var(--yellow); }
    #tco-chart :global(.curve-ice) {
      stroke: var(--gray-600);
      stroke-dasharray: 6 4;
    }
    [data-theme="dark"] #tco-chart :global(.curve-ice) { stroke: var(--gray-300); }
    #tco-chart :global(.curve-focus) {
      stroke-width: 3;
    }
    #tco-chart :global(.curve-dim) {
      stroke-width: 1.75;
      opacity: 0.38;
      cursor: pointer;
      transition: opacity 0.2s var(--ease-out-expo), stroke-width 0.2s var(--ease-out-expo);
    }
    #tco-chart :global(.curve-dim:hover),
    #tco-chart :global(.curve-dim:focus) {
      opacity: 0.75;
      stroke-width: 2.25;
      outline: none;
    }
    /* Bandas de incertidumbre (§4 metodología). */
    #tco-chart :global(.band-bev) {
      fill: var(--yellow);
      fill-opacity: 0.18;
      stroke: var(--yellow);
      stroke-opacity: 0.35;
      stroke-width: 0.75;
      stroke-dasharray: 2 3;
    }
    #tco-chart :global(.band-ice) {
      fill: var(--gray-600);
      fill-opacity: 0.1;
      stroke: var(--gray-600);
      stroke-opacity: 0.3;
      stroke-width: 0.75;
      stroke-dasharray: 2 3;
    }
    [data-theme="dark"] #tco-chart :global(.band-ice) {
      fill: var(--gray-300);
      stroke: var(--gray-300);
    }
    #tco-chart :global(.dot-bev) {
      fill: var(--yellow);
      stroke: var(--card-bg);
      stroke-width: 1.5;
    }
    #tco-chart :global(.dot-ice) {
      fill: var(--gray-600);
      stroke: var(--card-bg);
      stroke-width: 1.5;
    }
    [data-theme="dark"] #tco-chart :global(.dot-ice) { fill: var(--gray-300); }
    #tco-chart :global(.be-line) {
      stroke: var(--text);
      stroke-width: 1;
      stroke-dasharray: 3 3;
      opacity: 0.55;
      fill: none;
    }
