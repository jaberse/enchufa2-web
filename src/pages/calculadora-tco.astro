      font-size: 1.125rem;
      font-weight: 500;
      margin: 0 0 0.375rem;
    }
    .chart-sub {
      font-size: 0.9375rem;
      color: var(--text-secondary);
      line-height: 1.5;
      margin: 0;
      max-width: 640px;
    }
    .chart-sub em {
      font-family: var(--font-serif);
      font-style: italic;
    }
    .chart-wrap {
      width: 100%;
