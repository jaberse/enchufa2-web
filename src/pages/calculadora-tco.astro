---
// src/pages/calculadora-tco.astro
// Calculadora TCO — beta pública. Los 20 modelos del Top 20 catálogo v1.
// v0.2 — expandido de 3 a 20 pares (Tandas 1-4 completas, 2026-04-14).

import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { bevFromJson, iceFromJson } from '../lib/tco/resolver.mjs';
import { PARAMS_ENCHUFA2_ESTANDAR } from '../lib/tco/params.mjs';
import '../styles/global.css';

const ROOT = process.cwd();
const dataFile = (rel: string) =>
  JSON.parse(fs.readFileSync(path.join(ROOT, rel), 'utf8'));

// ── Pares BEV/ICE disponibles ──────────────────────────────────────────
// Top 20 catálogo v1, ordenados para narrativa (impacto → paridad/delta).
// `piloto` = URL al cálculo manual .md si existe (solo 3 de 20, pilotos 1-3).
// El resto se calcula idénticamente vía pipeline + librería src/lib/tco/.
// Default: tesla-model-3-rwd-highland (caso icónico, ahorro ~47 %).
const PARES = [
  { slug: 'tesla-model-3-rwd-highland',   iceSlug: 'bmw-320i-sedan',        etiqueta: 'Tesla Model 3 RWD · vs · BMW 320i',              comparacion: 'Benchmark D · berlina media premium',  piloto: 'https://github.com/jaberse/enchufa2-web/blob/main/docs/piloto-3-tco-calculo-manual.md' },
  { slug: 'tesla-model-y-rwd-long-range', iceSlug: 'bmw-x3-xdrive20i',      etiqueta: 'Tesla Model Y LR · vs · BMW X3 xDrive20i',       comparacion: 'Benchmark D-SUV · premium familiar' },
  { slug: 'hyundai-kona-electric-65-kwh', iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Hyundai Kona Electric 65 · vs · VW Tiguan',      comparacion: 'Benchmark C-SUV · mainstream' },
  { slug: 'skoda-elroq-60',               iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Škoda Elroq 60 · vs · VW Tiguan',                comparacion: 'Benchmark C-SUV · grupo VAG' },
  { slug: 'kia-ev3-long-range',           iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Kia EV3 Long Range · vs · VW Tiguan',            comparacion: 'Benchmark C-SUV · coreano plataforma E-GMP' },
  { slug: 'bmw-ix1-xdrive30',             iceSlug: 'bmw-x1-sdrive18i',      etiqueta: 'BMW iX1 xDrive30 · vs · X1 sDrive18i',           comparacion: 'Intra-marca · premium C-SUV',           piloto: 'https://github.com/jaberse/enchufa2-web/blob/main/docs/piloto-2-tco-calculo-manual.md' },
  { slug: 'bmw-ix2-xdrive30',             iceSlug: 'bmw-x1-sdrive18i',      etiqueta: 'BMW iX2 xDrive30 · vs · X1 sDrive18i',           comparacion: 'Intra-marca · SAC coupé premium' },
  { slug: 'mercedes-eqa-250+',            iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Mercedes EQA 250+ · vs · VW Tiguan',             comparacion: 'Premium EV vs mainstream ICE · paridad' },
  { slug: 'toyota-bz4x-fwd',              iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Toyota bZ4X FWD · vs · VW Tiguan',               comparacion: 'Benchmark C-SUV · Toyota BEV' },
  { slug: 'byd-atto-3-comfort',           iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'BYD Atto 3 Comfort · vs · VW Tiguan',            comparacion: 'Benchmark C-SUV · BYD LFP Blade' },
  { slug: 'byd-atto-2-comfort',           iceSlug: 'peugeot-2008-puretech', etiqueta: 'BYD Atto 2 · vs · Peugeot 2008 Hybrid',          comparacion: 'Benchmark B-SUV · entrada BYD' },
  { slug: 'byd-seal-awd-excellence',      iceSlug: 'bmw-320i-sedan',        etiqueta: 'BYD Seal AWD · vs · BMW 320i',                   comparacion: 'Benchmark D · berlina performance 530 CV' },
  { slug: 'byd-dolphin-60kwh',            iceSlug: 'dacia-sandero-tce',     etiqueta: 'BYD Dolphin 60 kWh · vs · Dacia Sandero TCe',    comparacion: 'Benchmark B · BEV vs GLP bifuel' },
  { slug: 'jeep-avenger-electric',        iceSlug: 'peugeot-2008-puretech', etiqueta: 'Jeep Avenger BEV · vs · Peugeot 2008 Hybrid',    comparacion: 'Plataforma e-CMP · Stellantis' },
  { slug: 'peugeot-e-2008-allure',        iceSlug: 'peugeot-2008-puretech', etiqueta: 'Peugeot e-2008 · vs · Peugeot 2008 Hybrid',      comparacion: 'Intra-marca · B-SUV Stellantis' },
  { slug: 'renault-5-e-tech-comfort-range', iceSlug: 'dacia-sandero-tce',   etiqueta: 'Renault 5 E-Tech · vs · Dacia Sandero TCe',      comparacion: 'Benchmark B · made in Palencia' },
  { slug: 'citroen-e-c3-you',             iceSlug: 'citroen-c3-puretech-100', etiqueta: 'Citroën ë-C3 · vs · C3 PureTech 100',          comparacion: 'Intra-marca · urbano mass-market',      piloto: 'https://github.com/jaberse/enchufa2-web/blob/main/docs/piloto-1-tco-calculo-manual.md' },
  { slug: 'dacia-spring-essential',       iceSlug: 'hyundai-i10-mpi',       etiqueta: 'Dacia Spring Essential · vs · Hyundai i10 MPI',  comparacion: 'Benchmark A · BEV más barato' },
  { slug: 'byd-dolphin-surf-comfort',     iceSlug: 'hyundai-i10-mpi',       etiqueta: 'BYD Dolphin Surf Comfort · vs · Hyundai i10 MPI', comparacion: 'Benchmark A · BYD entrada' },
  { slug: 'hyundai-inster-long-range',    iceSlug: 'hyundai-i10-mpi',       etiqueta: 'Hyundai Inster LR · vs · Hyundai i10 MPI',       comparacion: 'Intra-marca · A utilitario coreano' }
].map((p) => {
  const bevJson = dataFile(`data/coches/${p.slug}.json`);
  const iceJson = dataFile(`data/referencias/ice-equivalentes/${p.iceSlug}.json`);
  return {
    ...p,
    foto: `/comparador/${p.slug}.webp`,
    bevName: `${bevJson.marca} ${bevJson.modelo}${bevJson.variante ? ' ' + bevJson.variante : ''}`,
    iceName: `${iceJson.marca} ${iceJson.modelo} ${iceJson.variante ?? ''}`.trim(),
  };
});

// Construir payload para el cliente: por cada par, los inputs BEV + ICE
// en cada horizonte disponible (2..10 años, para el slider E6a).
const HORIZONTES_DISPONIBLES = [2, 3, 4, 5, 6, 7, 8, 10];

const payload = PARES.map((par) => {
  const bevJson = dataFile(`data/coches/${par.slug}.json`);
  const iceJson = dataFile(
    `data/referencias/ice-equivalentes/${par.iceSlug}.json`,
  );
  const horizontes: Record<number, { bev: any; ice: any }> = {};
  for (const h of HORIZONTES_DISPONIBLES) {
    horizontes[h] = {
      bev: bevFromJson(bevJson, { horizonte_anios: h, aplicar_ayuda: true }),
      ice: iceFromJson(iceJson, { horizonte_anios: h }),
    };
  }
  return {
    ...par,
    horizontes,
    ayuda_disponible: (horizontes[5].bev.ayuda_eur ?? 0) > 0,
    ayuda_eur: horizontes[5].bev.ayuda_eur ?? 0,
  };
});

// ── Sprint 2 E2 — Paso 1: listas completas de candidatos ──
// El cliente recibe dos listas independientes (BEVs e ICEs) con sus fixtures
// por horizonte ya resueltos. Sigue coexistiendo con `payload` (pares fijos)
// para no romper la UI actual; la UI multi-select del paso 2 consumirá estas.
const bevSlugsUnicos = [...new Set(PARES.map((p) => p.slug))];
const iceSlugsUnicos = [...new Set(PARES.map((p) => p.iceSlug))];

const ALL_BEVS = bevSlugsUnicos.map((slug) => {
  const json = dataFile(`data/coches/${slug}.json`);
  const horizontes: Record<number, any> = {};
  for (const h of HORIZONTES_DISPONIBLES) {
    horizontes[h] = bevFromJson(json, {
      horizonte_anios: h,
      aplicar_ayuda: true,
    });
  }
  const h5 = horizontes[5];
  return {
    slug,
    marca: json.marca,
    modelo: json.modelo,
    variante: json.variante ?? '',
    name: `${json.marca} ${json.modelo}${json.variante ? ' ' + json.variante : ''}`,
    segmento: json.segmento ?? null,
    foto: `/comparador/${slug}.webp`,
    horizontes,
    ayuda_disponible: (h5.ayuda_eur ?? 0) > 0,
    ayuda_eur: h5.ayuda_eur ?? 0,
    pvp_eur: h5.pvp_eur ?? null,
  };
});

const ALL_ICES = iceSlugsUnicos.map((slug) => {
  const json = dataFile(`data/referencias/ice-equivalentes/${slug}.json`);
  const horizontes: Record<number, any> = {};
  for (const h of HORIZONTES_DISPONIBLES) {
    horizontes[h] = iceFromJson(json, { horizonte_anios: h });
  }
  const h5 = horizontes[5];
  return {
    slug,
    marca: json.marca,
    modelo: json.modelo,
    variante: json.variante ?? '',
    name: `${json.marca} ${json.modelo}${json.variante ? ' ' + json.variante : ''}`.trim(),
    segmento: json.segmento ?? null,
    horizontes,
    pvp_eur: h5.pvp_eur ?? null,
  };
});

// Defaults del bloque "Tu uso" — E1 + E6a.
// Precios kWh split en casa (PVPC valle) y pública (mix AC lenta + DC rápida).
const PRECIO_KWH_CASA_DEFAULT = 0.12;     // PVPC valle medio 2026 (€/kWh).
const PRECIO_KWH_PUBLICA_DEFAULT = 0.45;  // Media ponderada AC/DC red pública.
const PCT_CASA_DEFAULT = 70;              // 70 % casa / 30 % pública.
const HORIZONTE_DEFAULT = 5;

const pilotosValidados = payload.filter((p) => p.piloto);
const iniH = HORIZONTE_DEFAULT;
const kwhEfectivoIni =
  (PCT_CASA_DEFAULT / 100) * PRECIO_KWH_CASA_DEFAULT +
  (1 - PCT_CASA_DEFAULT / 100) * PRECIO_KWH_PUBLICA_DEFAULT;
---

<Layout
  title="Calculadora TCO — enchufa2"
  description="Calcula el coste real de un coche eléctrico a 3 o 5 años frente a su equivalente de combustión. Depreciación, energía, mantenimiento, seguro, impuestos y Plan Auto+."
>
  <Header />

  <main id="main" class="calc-tco">
    <section class="hero">
      <p class="eyebrow">Herramienta · beta</p>
      <h1>Calculadora TCO</h1>
      <p class="deck">
        Cuánto cuesta <em>de verdad</em> un coche eléctrico en España comparado
        con su equivalente de combustión. Fórmula canónica ICCT: depreciación,
        energía, mantenimiento, seguro, impuestos y ayudas — validada contra
        tres pilotos manuales.
      </p>
      <div class="beta-warn" role="note">
        <strong>Beta v0.3</strong> — selección libre de hasta 4 eléctricos y
        4 de combustión del catálogo v1 ({ALL_BEVS.length} BEV · {ALL_ICES.length} ICE).
        Datos con <code>confianza=media</code> hasta calibrar depreciación
        con muestras reales de Coches.net y cotizaciones de seguro específicas.
        <a href="#metodologia">Ver metodología</a>.
      </div>
    </section>

    <!-- ────────── CONTROLES ────────── -->
    <section class="controles" aria-labelledby="h-controles">
      <h2 id="h-controles" class="sr-only">Parámetros</h2>

      <div class="ctrl-grid">
        <!-- Selector multi-coche (Sprint 2 E2 paso 2B) -->
        <fieldset class="ctrl ctrl-seleccion">
          <legend>Coches a analizar</legend>
          <p class="seleccion-hint">
            Empieza con un par rápido o añade hasta 4 eléctricos y 4 de
            combustión para comparar. Haz clic en un coche de la lista —
            o en una línea del gráfico — para ver su desglose.
          </p>

          <div class="quick-starts" role="group" aria-label="Pares rápidos">
            <span class="qs-label">Empieza con:</span>
            <button type="button" class="qs-btn" data-bev="dacia-spring-essential" data-ice="hyundai-i10-mpi">A · Urbano barato</button>
            <button type="button" class="qs-btn" data-bev="renault-5-e-tech-comfort-range" data-ice="dacia-sandero-tce">B · Utilitario</button>
            <button type="button" class="qs-btn" data-bev="hyundai-kona-electric-65-kwh" data-ice="volkswagen-tiguan-tsi">C-SUV · Mainstream</button>
            <button type="button" class="qs-btn" data-bev="tesla-model-3-rwd-highland" data-ice="bmw-320i-sedan">D · Berlina premium</button>
            <button type="button" class="qs-btn" data-bev="tesla-model-y-rwd-long-range" data-ice="bmw-x3-xdrive20i">D-SUV · Familiar</button>
          </div>

          <div class="seleccion-grid">
            <div class="seleccion-col" data-tren="BEV">
              <p class="col-head"><span class="col-dot col-dot-bev" aria-hidden="true"></span> Eléctricos <span class="col-count" id="bev-count">0 / 4</span></p>
              <div class="chips" id="chips-bev" role="list" aria-label="Eléctricos seleccionados"></div>
              <div class="chips-combo">
                <input
                  type="text"
                  id="combo-bev"
                  class="combo-input"
                  placeholder="Añadir eléctrico…"
                  autocomplete="off"
                  aria-label="Buscar eléctrico para añadir"
                  aria-autocomplete="list"
                  aria-controls="suggest-bev"
                />
                <ul class="chips-suggest" id="suggest-bev" role="listbox" hidden></ul>
              </div>
            </div>
            <div class="seleccion-col" data-tren="ICE">
              <p class="col-head"><span class="col-dot col-dot-ice" aria-hidden="true"></span> Combustión <span class="col-count" id="ice-count">0 / 4</span></p>
              <div class="chips" id="chips-ice" role="list" aria-label="Combustión seleccionados"></div>
              <div class="chips-combo">
                <input
                  type="text"
                  id="combo-ice"
                  class="combo-input"
                  placeholder="Añadir combustión…"
                  autocomplete="off"
                  aria-label="Buscar combustión para añadir"
                  aria-autocomplete="list"
                  aria-controls="suggest-ice"
                />
                <ul class="chips-suggest" id="suggest-ice" role="listbox" hidden></ul>
              </div>
            </div>
          </div>
        </fieldset>

        <!-- Horizonte (E6a — slider libre 2-10) -->
        <div class="ctrl">
          <label for="horizonte">
            Horizonte
            <output id="horizonte-out">{iniH} años</output>
          </label>
          <input
            id="horizonte"
            type="range"
            min="2"
            max="10"
            step="1"
            value={iniH}
            list="horizonte-ticks"
          />
          <datalist id="horizonte-ticks">
            {HORIZONTES_DISPONIBLES.map((h) => <option value={h}></option>)}
          </datalist>
          <span class="ctrl-hint">De 2 a 10 años de tenencia. Por encima de 5 la banda se amplía: y10 es siempre confianza baja.</span>
        </div>

        <!-- Km/año -->
        <div class="ctrl">
          <label for="km">
            Kilometraje anual
            <output id="km-out">{PARAMS_ENCHUFA2_ESTANDAR.km_anual.toLocaleString('es-ES')} km</output>
          </label>
          <input
            id="km"
            type="range"
            min="5000"
            max="40000"
            step="500"
            value={PARAMS_ENCHUFA2_ESTANDAR.km_anual}
          />
        </div>

        <!-- ── E1 — Mix de carga casa/pública ── -->
        <fieldset class="ctrl ctrl-mix">
          <legend>Cómo cargas habitualmente</legend>
          <div class="mix-presets" role="group" aria-label="Perfiles de carga predefinidos">
            <button type="button" class="mix-preset" data-pct="90">Casa 90 %</button>
            <button type="button" class="mix-preset" data-pct="70">Mixto 70 %</button>
            <button type="button" class="mix-preset" data-pct="20">Sin garaje 20 %</button>
          </div>
          <label for="pct-casa" class="mix-label">
            % carga en casa
            <output id="pct-casa-out">{PCT_CASA_DEFAULT} %</output>
          </label>
          <input
            id="pct-casa"
            type="range"
            min="0"
            max="100"
            step="5"
            value={PCT_CASA_DEFAULT}
            aria-describedby="pct-casa-hint"
          />
          <span class="ctrl-hint" id="pct-casa-hint">
            Palanca #1 del TCO eléctrico: quien carga casi todo en casa ahorra
            mucho más que quien depende de pública, aunque el coche sea el mismo.
          </span>

          <div class="mix-prices">
            <div class="mix-price">
              <label for="kwh-casa">
                €/kWh en casa
                <output id="kwh-casa-out">{PRECIO_KWH_CASA_DEFAULT.toFixed(2)} €</output>
              </label>
              <input
                id="kwh-casa"
                type="range"
                min="0.05"
                max="0.25"
                step="0.01"
                value={PRECIO_KWH_CASA_DEFAULT}
              />
              <span class="ctrl-hint">PVPC valle medio 2026: ~0,12 €/kWh</span>
            </div>
            <div class="mix-price">
              <label for="kwh-publica">
                €/kWh en pública
                <output id="kwh-publica-out">{PRECIO_KWH_PUBLICA_DEFAULT.toFixed(2)} €</output>
              </label>
              <input
                id="kwh-publica"
                type="range"
                min="0.20"
                max="0.80"
                step="0.01"
                value={PRECIO_KWH_PUBLICA_DEFAULT}
              />
              <span class="ctrl-hint">Media ponderada AC lenta + DC rápida</span>
            </div>
          </div>
          <p class="kwh-efectivo" aria-live="polite">
            Precio medio efectivo:
            <strong id="kwh-efectivo-out">{kwhEfectivoIni.toFixed(3)} €/kWh</strong>
          </p>
        </fieldset>

        <!-- Precio gasolina -->
        <div class="ctrl">
          <label for="litro">
            Precio gasolina 95
            <output id="litro-out">{PARAMS_ENCHUFA2_ESTANDAR.precio_litro_eur.toFixed(2)} €/L</output>
          </label>
          <input
            id="litro"
            type="range"
            min="1.20"
            max="2.00"
            step="0.01"
            value={PARAMS_ENCHUFA2_ESTANDAR.precio_litro_eur}
          />
          <span class="ctrl-hint">MITECO abril 2026</span>
        </div>

        <!-- Plan Auto+ (global: aplica a todos los BEVs elegibles) -->
        <div class="ctrl ctrl-check" id="ctrl-ayuda">
          <label>
            <input type="checkbox" id="ayuda" checked />
            <span>
              Aplicar Plan Auto+ cuando sea elegible
              <output id="ayuda-out">(Eléctrico · Económico · Europeo)</output>
            </span>
          </label>
        </div>
      </div>
    </section>

    <!-- ────────── RESULTADO ────────── -->
    <section class="resultado" aria-labelledby="h-resultado" aria-live="polite">
      <h2 id="h-resultado" class="sr-only">Resultado</h2>

      <p class="lede" id="lede">Cargando…</p>

      <!-- ── E7 — Sensibilidad interactiva ── -->
      <aside class="sensibilidad" aria-labelledby="h-sensibilidad">
        <h3 id="h-sensibilidad">¿Y si te equivocas en los inputs?</h3>
        <p class="sens-intro">
          El rango junto al TCO es <em>nuestra</em> incertidumbre metodológica.
          Esta es la <em>tuya</em>: mueve los tres supuestos clave para ver
          cómo se desplaza el ahorro sin tocar el escenario principal.
        </p>
        <ul class="sens-list">
          <li class="sens-row">
            <div class="sens-ctrl">
              <label for="sens-km-slider">
                Km/año
                <output id="sens-km-mul">+20 %</output>
              </label>
              <input
                id="sens-km-slider"
                type="range"
                min="-40"
                max="40"
                step="5"
                value="20"
              />
            </div>
            <p class="sens-out" id="sens-km">—</p>
          </li>
          <li class="sens-row">
            <div class="sens-ctrl">
              <label for="sens-kwh-slider">
                kWh efectivo
                <output id="sens-kwh-mul">+0,05 €</output>
              </label>
              <input
                id="sens-kwh-slider"
                type="range"
                min="-0.20"
                max="0.20"
                step="0.01"
                value="0.05"
              />
            </div>
            <p class="sens-out" id="sens-kwh">—</p>
          </li>
          <li class="sens-row">
            <div class="sens-ctrl">
              <label for="sens-casa-slider">
                % casa
                <output id="sens-casa-mul">−20 pts</output>
              </label>
              <input
                id="sens-casa-slider"
                type="range"
                min="-50"
                max="50"
                step="5"
                value="-20"
              />
            </div>
            <p class="sens-out" id="sens-casa">—</p>
          </li>
        </ul>
      </aside>

      <div class="tco-focus-wrap">
        <article class="tco-card tco-focus" id="tco-focus" data-tren="BEV" aria-live="polite">
          <header>
            <p class="tco-tren" id="focus-tren">Eléctrico</p>
            <h3 id="focus-name">—</h3>
            <p class="focus-hint">Haz clic en otro coche (chip o línea del gráfico) para cambiar el desglose.</p>
          </header>
          <p class="tco-big"><span id="focus-tco">—</span> €</p>
          <p class="tco-range" id="focus-range">—</p>
          <p class="tco-sub"><span id="focus-kmkm">—</span> €/km · <span id="focus-horizonte">—</span> años</p>
          <dl class="tco-breakdown">
            <dt>Depreciación <span class="conf-dot" id="focus-dep-conf" aria-hidden="true"></span></dt><dd><span id="focus-dep">—</span> €</dd>
            <dt>Energía <span class="conf-dot" id="focus-ene-conf" aria-hidden="true"></span></dt><dd><span id="focus-ene">—</span> €</dd>
            <dt>Mantenimiento <span class="conf-dot" id="focus-man-conf" aria-hidden="true"></span></dt><dd><span id="focus-man">—</span> €</dd>
            <dt>Seguro <span class="conf-dot" id="focus-seg-conf" aria-hidden="true"></span></dt><dd><span id="focus-seg">—</span> €</dd>
            <dt>Impuestos</dt><dd><span id="focus-imp">—</span> €</dd>
            <dt id="focus-ayu-dt" hidden>Ayudas</dt><dd id="focus-ayu-dd" hidden>− <span id="focus-ayu">—</span> €</dd>
          </dl>
        </article>
      </div>

      <!-- Gráfico TCO acumulado BEV vs ICE -->
      <figure class="tco-chart-fig" aria-labelledby="chart-title">
        <figcaption>
          <h3 id="chart-title">Coste acumulado año a año</h3>
          <p class="chart-sub">
            Cuánto lleva gastado cada coche en cada punto del horizonte. Si las
            líneas se cruzan, es el <em>break-even</em>: el momento en el que
            el eléctrico pasa a costar menos que el de combustión.
          </p>
        </figcaption>

        <div class="chart-wrap">
          <svg
            id="tco-chart"
            viewBox="0 0 800 420"
            role="img"
            aria-labelledby="chart-title"
            aria-describedby="chart-desc"
            preserveAspectRatio="xMidYMid meet"
          >
            <title id="chart-title-svg">Coste acumulado BEV vs ICE</title>
            <desc id="chart-desc">
              Curvas de coste acumulado del coche eléctrico (amarillo) y del
              coche de combustión (gris discontinuo) desde el año 0 hasta el
              horizonte seleccionado, con indicación del punto de break-even.
            </desc>
            <!-- Contenido renderizado por JS -->
          </svg>
          <table class="sr-only" id="chart-table" aria-label="Datos del gráfico"></table>
          <div class="chart-legend" aria-hidden="true">
            <span class="lg-item lg-bev"><span class="lg-swatch"></span> Eléctrico</span>
            <span class="lg-item lg-ice"><span class="lg-swatch"></span> Combustión</span>
            <span class="lg-item lg-band"><span class="lg-swatch"></span> Banda de incertidumbre</span>
            <span class="lg-item lg-be" id="lg-be-item" hidden>
              <span class="lg-swatch"></span> Break-even
            </span>
          </div>
        </div>
        <p class="chart-caveat">
          La zona sombreada es la <strong>banda de incertidumbre</strong>: ±0 %
          con confianza alta, ±8 % con media, ±15 % con baja. El margen
          agregado es el máximo de las confianzas individuales (depreciación,
          mantenimiento, seguro, consumo). Ver
          <a href="https://github.com/jaberse/enchufa2-web/blob/main/docs/metodologia-tco.md#4-bandas-de-incertidumbre">metodología §4</a>.
        </p>
      </figure>

      <div class="share">
        <button type="button" id="share-btn">Copiar enlace con este escenario</button>
        <span class="share-msg" id="share-msg" role="status"></span>
      </div>
    </section>

    <!-- ────────── METODOLOGÍA ────────── -->
    <section class="metodologia" id="metodologia" aria-labelledby="h-metodologia">
      <h2 id="h-metodologia">Metodología rápida</h2>
      <p>
        La fórmula es canónica ICCT:
        <strong>TCO = depreciación + energía + mantenimiento + seguro + impuestos − ayudas</strong>.
        Cada dato proviene del pipeline verificado del comparador: el PVP del
        configurador oficial, el consumo homologado WLTP corregido por un factor
        real (ICCT + EV Database), la depreciación de Ganvam + muestras reales
        de Coches.net, el mantenimiento del plan oficial del fabricante, y el
        seguro como mediana de 3 cotizaciones con el perfil estándar enchufa2.
      </p>
      <p>
        El Top {payload.length} del catálogo está completo: <strong>20 de 20 modelos</strong>
        tienen <code>specs_tco</code> validado por el auditor del pipeline
        (<code>npm run data:tco-audit</code>, 0 errores) y superan los
        <strong>13 tests de no-regresión</strong> que reproducen los tres
        cálculos manuales ±3 €. Estos son los pilotos que marcan la vara
        metodológica:
      </p>
      <ul class="pilotos">
        {pilotosValidados.map((par) => (
          <li>
            <a href={par.piloto}>{par.etiqueta}</a>
          </li>
        ))}
      </ul>
      <p class="minor">
        El resto de pares (17 de 20) se calculan con la misma librería
        <code>src/lib/tco/</code> y los mismos datos del pipeline. Todos los
        modelos publicados tienen <code>tco_confianza_general=media</code>
        hasta que se calibre la depreciación con muestras reales de
        Coches.net 2023-2024 y se incorporen 3 cotizaciones de seguro
        específicas (Rastreator / Mapfre / Mutua) con el perfil estándar
        enchufa2.
      </p>
      <p class="minor">
        Perfil estándar: {PARAMS_ENCHUFA2_ESTANDAR.km_anual.toLocaleString('es-ES')} km/año,
        5 años, 0,17 €/kWh, 1,55 €/L, IVTM BEV {PARAMS_ENCHUFA2_ESTANDAR.ivtm_bev_eur} €/año ·
        IVTM ICE {PARAMS_ENCHUFA2_ESTANDAR.ivtm_ice_eur} €/año. Todos los
        parámetros son editables en esta página.
      </p>
    </section>
  </main>

  <Footer />

  <!-- Datos server → cliente -->
  <script type="application/json" id="tco-payload" set:html={JSON.stringify(payload)} />
  <!-- Sprint 2 E2 (paso 1): listas completas de candidatos para multi-select. -->
  <script type="application/json" id="tco-all-bevs" set:html={JSON.stringify(ALL_BEVS)} />
  <script type="application/json" id="tco-all-ices" set:html={JSON.stringify(ALL_ICES)} />

  <!-- Lógica interactiva (auto-bundled por Astro) -->
  <script>
    import { calcularTCO, compararTCO, curvaUnTren } from '../lib/tco/calculadora.mjs';

    const eur = (n: number) =>
      new Intl.NumberFormat('es-ES', { maximumFractionDigits: 0 }).format(n);
    const eur2 = (n: number) =>
      new Intl.NumberFormat('es-ES', { maximumFractionDigits: 3, minimumFractionDigits: 2 }).format(n);

    // Sprint 2 E2 (paso 1): listas completas paralelas. El UI actual no las
    // usa todavía — las consumirá el multi-select del paso 2. Mantener aquí
    // garantiza que el build incluya la plomería y se pueda inspeccionar.
    const allBevsEl = document.getElementById('tco-all-bevs')!;
    const allIcesEl = document.getElementById('tco-all-ices')!;
    const ALL_BEVS = JSON.parse(allBevsEl.textContent ?? '[]') as Array<any>;
    const ALL_ICES = JSON.parse(allIcesEl.textContent ?? '[]') as Array<any>;
    // Exponemos a window para inspección en DevTools durante el dev de Sprint 2.
    (window as any).__e2_all_bevs = ALL_BEVS;
    (window as any).__e2_all_ices = ALL_ICES;

    // NOTE: El payload legacy (tco-payload) se mantiene en el SSR por
    // compatibilidad con URLs antiguas (?m=slug), pero el UI Sprint 2 ya
    // no lo consume. Todo el estado se lee de ALL_BEVS / ALL_ICES.

    const $ = <T extends HTMLElement = HTMLElement>(id: string) =>
      document.getElementById(id) as T;

    const DEFAULT_BEV = 'tesla-model-3-rwd-highland';
    const DEFAULT_ICE = 'bmw-320i-sedan';
    const HORIZONTES_VALIDOS = [2, 3, 4, 5, 6, 7, 8, 10];
    const MAX_POR_TREN = 4;

    type FocusKey = { tren: 'BEV' | 'ICE'; slug: string };

    const state = {
      bevSlugs: [DEFAULT_BEV] as string[],
      iceSlugs: [DEFAULT_ICE] as string[],
      focus: { tren: 'BEV', slug: DEFAULT_BEV } as FocusKey,
      horizonte: 5,                 // 2..10 (E6a)
      km: 15000,
      pctCasa: 70,                  // 0..100 (E1)
      kwhCasa: 0.12,                // €/kWh PVPC valle (E1)
      kwhPublica: 0.45,             // €/kWh pública media AC+DC (E1)
      litro: 1.55,
      ayuda: true,
    };

    const focusKeyStr = (k: FocusKey) => `${k.tren}:${k.slug}`;
    const isFocus = (tren: 'BEV'|'ICE', slug: string) =>
      state.focus.tren === tren && state.focus.slug === slug;

    // Estado independiente de los mini-sliders de sensibilidad (E7).
    // Se superponen sobre el escenario principal SIN afectar al lede ni al
    // gráfico. Cada valor es un delta respecto al baseline actual.
    const sensState = {
      kmPct: 20,      // ±% sobre state.km  (−40..+40)
      kwhDelta: 0.05, // € sobre kwhEfectivo (−0,20..+0,20)
      pctPts: -20,    // puntos sobre state.pctCasa (−50..+50)
    };

    // Cache del escenario baseline para recomputar E7 sin rehacer el principal.
    let baselineCache: {
      bevInput: any;
      iceInput: any;
      ahorroActual: number;
    } | null = null;

    // €/kWh efectivo derivado del mix casa/pública (E1).
    const kwhEfectivo = () =>
      (state.pctCasa / 100) * state.kwhCasa +
      (1 - state.pctCasa / 100) * state.kwhPublica;

    // Snap del horizonte al valor válido más cercano (para que 9 → 10, etc.).
    const snapHorizonte = (h: number) => {
      let best = HORIZONTES_VALIDOS[0];
      let dist = Math.abs(h - best);
      for (const v of HORIZONTES_VALIDOS) {
        const d = Math.abs(h - v);
        if (d < dist) { best = v; dist = d; }
      }
      return best;
    };

    const bevSlugSet = new Set(ALL_BEVS.map((b) => b.slug));
    const iceSlugSet = new Set(ALL_ICES.map((c) => c.slug));

    // Lee URL querystring si existe
    function readUrl() {
      const p = new URLSearchParams(location.search);

      // Sprint 2: multi-select via ?bev=a,b&ice=c,d&f=BEV:a
      const bevParam = p.get('bev');
      if (bevParam) {
        const slugs = bevParam
          .split(',')
          .filter((s) => bevSlugSet.has(s))
          .slice(0, MAX_POR_TREN);
        if (slugs.length) state.bevSlugs = slugs;
      } else {
        // Retrocompat: ?m=slug → carga ese BEV (y mantiene el ICE default).
        const legacy = p.get('m');
        if (legacy && bevSlugSet.has(legacy)) state.bevSlugs = [legacy];
      }

      const iceParam = p.get('ice');
      if (iceParam) {
        const slugs = iceParam
          .split(',')
          .filter((s) => iceSlugSet.has(s))
          .slice(0, MAX_POR_TREN);
        if (slugs.length) state.iceSlugs = slugs;
      }

      const f = p.get('f');
      if (f) {
        const [t, s] = f.split(':');
        if (t === 'BEV' && s && state.bevSlugs.includes(s)) {
          state.focus = { tren: 'BEV', slug: s };
        } else if (t === 'ICE' && s && state.iceSlugs.includes(s)) {
          state.focus = { tren: 'ICE', slug: s };
        }
      }
      // Si el focus no es válido, reseteamos al primer BEV (o primer ICE).
      if (
        (state.focus.tren === 'BEV' && !state.bevSlugs.includes(state.focus.slug)) ||
        (state.focus.tren === 'ICE' && !state.iceSlugs.includes(state.focus.slug))
      ) {
        if (state.bevSlugs.length) {
          state.focus = { tren: 'BEV', slug: state.bevSlugs[0] };
        } else if (state.iceSlugs.length) {
          state.focus = { tren: 'ICE', slug: state.iceSlugs[0] };
        }
      }

      const h = Number(p.get('h'));
      if (h >= 2 && h <= 10) state.horizonte = snapHorizonte(h);
      const k = Number(p.get('km'));
      if (k >= 5000 && k <= 40000) state.km = k;
      // Retrocompatibilidad: si llega `kwh` (legacy v0.2), lo usamos como
      // media efectiva y reconstruimos un split plausible (pct=70).
      const eLegacy = Number(p.get('kwh'));
      if (eLegacy >= 0.08 && eLegacy <= 0.55) {
        state.pctCasa = 70;
        state.kwhCasa = Math.max(0.05, Math.min(0.25, eLegacy * 0.7));
        state.kwhPublica = Math.max(0.20, Math.min(0.80, eLegacy * 1.7));
      }
      const pc = Number(p.get('pc'));
      if (pc >= 0 && pc <= 100) state.pctCasa = pc;
      const kc = Number(p.get('kc'));
      if (kc >= 0.05 && kc <= 0.25) state.kwhCasa = kc;
      const kp = Number(p.get('kp'));
      if (kp >= 0.2 && kp <= 0.8) state.kwhPublica = kp;
      const g = Number(p.get('l'));
      if (g >= 1.2 && g <= 2) state.litro = g;
      if (p.get('a') === '0') state.ayuda = false;
    }

    function writeUrl() {
      const p = new URLSearchParams();
      if (state.bevSlugs.length) p.set('bev', state.bevSlugs.join(','));
      if (state.iceSlugs.length) p.set('ice', state.iceSlugs.join(','));
      p.set('f', focusKeyStr(state.focus));
      p.set('h', String(state.horizonte));
      p.set('km', String(state.km));
      p.set('pc', String(state.pctCasa));
      p.set('kc', state.kwhCasa.toFixed(2));
      p.set('kp', state.kwhPublica.toFixed(2));
      p.set('l', state.litro.toFixed(2));
      if (!state.ayuda) p.set('a', '0');
      history.replaceState(null, '', `?${p.toString()}`);
    }

    // Busca el metadata de un coche en ALL_BEVS/ALL_ICES.
    function getMeta(tren: 'BEV'|'ICE', slug: string) {
      return (tren === 'BEV' ? ALL_BEVS : ALL_ICES).find((x) => x.slug === slug);
    }

    // Construye el input canónico (con ayuda aplicada si corresponde) para un
    // coche al horizonte actual. Devuelve null si el slug no existe.
    function getCocheInput(tren: 'BEV'|'ICE', slug: string) {
      const meta = getMeta(tren, slug);
      if (!meta) return null;
      const fix = meta.horizontes[state.horizonte] ?? meta.horizontes[5];
      const input: any = { ...fix };
      if (tren === 'BEV') {
        if (!state.ayuda || !meta.ayuda_disponible) input.ayuda_eur = 0;
      }
      return { input, meta };
    }

    // ── Gráfico TCO acumulado ──
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const VB_W = 800;
    const VB_H = 420;
    const M = { top: 28, right: 24, bottom: 48, left: 72 };
    const PLOT_W = VB_W - M.left - M.right;
    const PLOT_H = VB_H - M.top - M.bottom;

    function niceStep(range: number, ticks: number) {
      const raw = range / ticks;
      const pow = Math.pow(10, Math.floor(Math.log10(Math.abs(raw) || 1)));
      const norm = raw / pow;
      const mult = norm < 1.5 ? 1 : norm < 3 ? 2 : norm < 7 ? 5 : 10;
      return mult * pow;
    }

    function fmtEur(n: number) {
      if (Math.abs(n) >= 1000) {
        return `${eur(n / 1000)} k€`;
      }
      return `${eur(n)} €`;
    }

    function el(tag: string, attrs: Record<string, string | number> = {}, text?: string) {
      const n = document.createElementNS(SVG_NS, tag);
      for (const [k, v] of Object.entries(attrs)) {
        n.setAttribute(k, String(v));
      }
      if (text != null) n.textContent = text;
      return n;
    }

    // ── Sprint 2 E2 paso 2B: gráfico N+M ──
    // Recibe array de curvas (BEV + ICE). Dibuja todas en el mismo espacio,
    // destacando la que está en focus (línea más gruesa, banda visible y el
    // color propio de su tren). Las no-focus se dibujan con opacidad reducida.
    type CurvaData = {
      tren: 'BEV' | 'ICE';
      slug: string;
      name: string;
      puntos: Array<{ anio: number; tco: number; tco_min: number; tco_max: number }>;
      margen: number;
      isFocus: boolean;
    };

    function renderChart(curvas: CurvaData[]) {
      const svg = $('tco-chart');
      const tbl = $('chart-table') as HTMLTableElement;

      // Limpiar
      while (svg.firstChild) svg.removeChild(svg.firstChild);

      if (!curvas.length) {
        tbl.innerHTML = '';
        return;
      }

      const xMin = 0;
      const xMax = curvas[0].puntos[curvas[0].puntos.length - 1]?.anio ?? state.horizonte;

      let yMin = Infinity;
      let yMax = -Infinity;
      for (const c of curvas) {
        for (const p of c.puntos) {
          yMin = Math.min(yMin, p.tco_min);
          yMax = Math.max(yMax, p.tco_max);
        }
      }
      // Colchón visual
      const yRange = yMax - yMin || 1;
      yMin -= yRange * 0.05;
      yMax += yRange * 0.08;
      if (yMin > 0) yMin = 0;

      const x = (a: number) => M.left + ((a - xMin) / (xMax - xMin || 1)) * PLOT_W;
      const y = (t: number) => M.top + (1 - (t - yMin) / (yMax - yMin || 1)) * PLOT_H;

      // Grid horizontal (5 ticks)
      const stepY = niceStep(yMax - yMin, 5);
      const startY = Math.ceil(yMin / stepY) * stepY;
      const yTicks: number[] = [];
      for (let v = startY; v <= yMax; v += stepY) yTicks.push(v);

      for (const v of yTicks) {
        const yy = y(v);
        svg.appendChild(el('line', {
          x1: M.left, x2: M.left + PLOT_W, y1: yy, y2: yy,
          class: v === 0 ? 'grid-zero' : 'grid-line',
        }));
        svg.appendChild(el('text', {
          x: M.left - 10, y: yy + 4,
          class: 'ax-label ax-y',
          'text-anchor': 'end',
        }, fmtEur(v)));
      }

      // X ticks
      const paso = xMax <= 3 ? 0.5 : 1;
      for (let t = 0; t <= xMax + 1e-6; t += paso) {
        const xx = x(t);
        svg.appendChild(el('line', {
          x1: xx, x2: xx, y1: M.top, y2: M.top + PLOT_H,
          class: 'grid-vert',
        }));
        svg.appendChild(el('text', {
          x: xx, y: M.top + PLOT_H + 22,
          class: 'ax-label ax-x',
          'text-anchor': 'middle',
        }, t % 1 === 0 ? `${t} año${t === 1 ? '' : 's'}` : `${t.toFixed(1)}`));
      }

      // Ejes
      svg.appendChild(el('line', {
        x1: M.left, x2: M.left, y1: M.top, y2: M.top + PLOT_H, class: 'ax-line',
      }));
      svg.appendChild(el('line', {
        x1: M.left, x2: M.left + PLOT_W, y1: M.top + PLOT_H, y2: M.top + PLOT_H, class: 'ax-line',
      }));

      const bandPath = (pts: CurvaData['puntos']) => {
        const top = pts.map((p, i) =>
          `${i === 0 ? 'M' : 'L'} ${x(p.anio).toFixed(1)} ${y(p.tco_max).toFixed(1)}`,
        ).join(' ');
        const bot = [...pts].reverse().map((p) =>
          `L ${x(p.anio).toFixed(1)} ${y(p.tco_min).toFixed(1)}`,
        ).join(' ');
        return `${top} ${bot} Z`;
      };

      const linePath = (pts: CurvaData['puntos']) =>
        pts.map((p, i) =>
          `${i === 0 ? 'M' : 'L'} ${x(p.anio).toFixed(1)} ${y(p.tco).toFixed(1)}`,
        ).join(' ');

      // ── Render en 3 capas ──
      // 1) bandas de focus (fondo)
      // 2) líneas no-focus (dim)
      // 3) línea focus (destacada + puntos extremos + label del coche)

      const focusCurva = curvas.find((c) => c.isFocus);

      // 1) Bandas solo para el focus.
      if (focusCurva && focusCurva.margen > 0) {
        svg.appendChild(el('path', {
          d: bandPath(focusCurva.puntos),
          class: focusCurva.tren === 'BEV' ? 'band-bev' : 'band-ice',
        }));
      }

      // 2) Líneas no-focus dim.
      for (const c of curvas) {
        if (c.isFocus) continue;
        const p = el('path', {
          d: linePath(c.puntos),
          class: `curve-dim curve-${c.tren.toLowerCase()}`,
          'data-tren': c.tren,
          'data-slug': c.slug,
          tabindex: 0,
          role: 'button',
          'aria-label': `${c.name} — clic para ver desglose`,
        });
        svg.appendChild(p);
      }

      // 3) Focus encima, destacado.
      if (focusCurva) {
        const p = el('path', {
          d: linePath(focusCurva.puntos),
          class: `curve-focus curve-${focusCurva.tren.toLowerCase()}`,
          'data-tren': focusCurva.tren,
          'data-slug': focusCurva.slug,
        });
        svg.appendChild(p);

        const last = focusCurva.puntos[focusCurva.puntos.length - 1];
        svg.appendChild(el('circle', {
          cx: x(last.anio), cy: y(last.tco), r: 4,
          class: `dot-${focusCurva.tren.toLowerCase()}`,
        }));
      }

      // Tabla sr-only (accesibilidad): valores anuales del focus.
      if (focusCurva) {
        const pts = focusCurva.puntos.filter((p) => p.anio % 1 === 0);
        tbl.innerHTML =
          `<caption>Coste acumulado ${focusCurva.name} (€)</caption>` +
          '<thead><tr><th>Año</th><th>TCO</th></tr></thead>' +
          '<tbody>' +
          pts.map((p) => `<tr><td>${p.anio}</td><td>${Math.round(p.tco)}</td></tr>`).join('') +
          '</tbody>';
      } else {
        tbl.innerHTML = '';
      }

      // Legend "break-even" oculto en el modo multi-select (Sprint 2).
      const beItem = $('lg-be-item');
      beItem.setAttribute('hidden', '');
    }

    // Helper global: rango bajo el TCO grande.
    const rangoTxt = (min: number, max: number, margen: number) => {
      if (margen <= 0) return 'Confianza alta · sin margen';
      return `entre ${eur(min)} – ${eur(max)} € · ±${Math.round(margen * 100)} %`;
    };
    const confDot = (id: string, conf: string | undefined) => {
      const elNode = $(id);
      if (!elNode) return;
      const c = conf || 'alta';
      elNode.className = `conf-dot conf-${c}`;
      elNode.title =
        c === 'alta'
          ? 'Confianza alta (±0 %)'
          : c === 'media'
            ? 'Confianza media (±8 %)'
            : 'Confianza baja (±15 %)';
    };

    function recalc() {
      // 1) Validar focus: si el coche focus ya no está seleccionado,
      //    caer al primer BEV (o primer ICE) disponible.
      if (
        state.focus.tren === 'BEV' &&
        !state.bevSlugs.includes(state.focus.slug)
      ) {
        if (state.bevSlugs.length) {
          state.focus = { tren: 'BEV', slug: state.bevSlugs[0] };
        } else if (state.iceSlugs.length) {
          state.focus = { tren: 'ICE', slug: state.iceSlugs[0] };
        }
      } else if (
        state.focus.tren === 'ICE' &&
        !state.iceSlugs.includes(state.focus.slug)
      ) {
        if (state.iceSlugs.length) {
          state.focus = { tren: 'ICE', slug: state.iceSlugs[0] };
        } else if (state.bevSlugs.length) {
          state.focus = { tren: 'BEV', slug: state.bevSlugs[0] };
        }
      }

      const overrides = {
        km_anual: state.km,
        horizonte_anios: state.horizonte,
        precio_kwh_eur: kwhEfectivo(),
        precio_litro_eur: state.litro,
      };

      // 2) Calcular TCO individual y curvas para cada coche seleccionado.
      type Resolved = {
        tren: 'BEV' | 'ICE';
        slug: string;
        meta: any;
        input: any;
        tco: any;
      };

      const resolvedBev: Resolved[] = state.bevSlugs
        .map((s) => {
          const r = getCocheInput('BEV', s);
          if (!r) return null;
          const tco = calcularTCO(r.input, overrides);
          return { tren: 'BEV' as const, slug: s, meta: r.meta, input: r.input, tco };
        })
        .filter((x): x is Resolved => !!x);

      const resolvedIce: Resolved[] = state.iceSlugs
        .map((s) => {
          const r = getCocheInput('ICE', s);
          if (!r) return null;
          const tco = calcularTCO(r.input, overrides);
          return { tren: 'ICE' as const, slug: s, meta: r.meta, input: r.input, tco };
        })
        .filter((x): x is Resolved => !!x);

      // 3) Construir curvas para el gráfico (una por coche).
      const curvas: CurvaData[] = [];
      for (const r of [...resolvedBev, ...resolvedIce]) {
        const c = curvaUnTren(r.input, overrides, {
          horizonte_max: state.horizonte,
          granularidad_anios: 0.25,
        });
        curvas.push({
          tren: r.tren,
          slug: r.slug,
          name: r.meta.name,
          puntos: c.puntos,
          margen: c.margen,
          isFocus: isFocus(r.tren, r.slug),
        });
      }

      // 4) Lede editorial: cheapest BEV vs cheapest ICE.
      const cheapestBev = resolvedBev.length
        ? resolvedBev.reduce((a, b) =>
            a.tco.tco_total_eur <= b.tco.tco_total_eur ? a : b,
          )
        : null;
      const cheapestIce = resolvedIce.length
        ? resolvedIce.reduce((a, b) =>
            a.tco.tco_total_eur <= b.tco.tco_total_eur ? a : b,
          )
        : null;

      if (cheapestBev && cheapestIce) {
        const diff = cheapestIce.tco.tco_total_eur - cheapestBev.tco.tco_total_eur;
        const sign = diff >= 0 ? 'ahorra' : 'sobrecuesta';
        const abs = Math.abs(diff);
        const base = Math.min(cheapestBev.tco.tco_total_eur, cheapestIce.tco.tco_total_eur);
        const pct = base > 0 ? (abs / cheapestIce.tco.tco_total_eur) * 100 : 0;
        $('lede').innerHTML =
          `A ${state.horizonte} años y ${eur(state.km)} km/año, el ` +
          `<strong>${cheapestBev.meta.name}</strong> es el eléctrico más barato ` +
          `(<strong>${eur(cheapestBev.tco.tco_total_eur)} €</strong>) y el ` +
          `<strong>${cheapestIce.meta.name}</strong> el combustión más barato ` +
          `(<strong>${eur(cheapestIce.tco.tco_total_eur)} €</strong>). ` +
          `El BEV ${sign} <strong>${eur(abs)} €</strong> (${pct.toFixed(1)} %).`;
      } else if (cheapestBev) {
        $('lede').innerHTML =
          `A ${state.horizonte} años y ${eur(state.km)} km/año, el ` +
          `<strong>${cheapestBev.meta.name}</strong> cuesta ` +
          `<strong>${eur(cheapestBev.tco.tco_total_eur)} €</strong>. ` +
          `Añade un coche de combustión para comparar.`;
      } else if (cheapestIce) {
        $('lede').innerHTML =
          `A ${state.horizonte} años y ${eur(state.km)} km/año, el ` +
          `<strong>${cheapestIce.meta.name}</strong> cuesta ` +
          `<strong>${eur(cheapestIce.tco.tco_total_eur)} €</strong>. ` +
          `Añade un eléctrico para comparar.`;
      } else {
        $('lede').innerHTML = 'Selecciona al menos un coche para empezar.';
      }

      // 5) Focus card breakdown.
      const focusResolved =
        [...resolvedBev, ...resolvedIce].find((r) =>
          isFocus(r.tren, r.slug),
        ) ?? null;

      const focusCard = $('tco-focus');
      if (focusResolved) {
        focusCard.dataset.tren = focusResolved.tren;
        $('focus-tren').textContent =
          focusResolved.tren === 'BEV' ? 'Eléctrico · en foco' : 'Combustión · en foco';
        $('focus-name').textContent = focusResolved.meta.name;
        $('focus-tco').textContent = eur(focusResolved.tco.tco_total_eur);
        $('focus-range').textContent = rangoTxt(
          focusResolved.tco.tco_total_min_eur,
          focusResolved.tco.tco_total_max_eur,
          focusResolved.tco.margen_pct,
        );
        $('focus-kmkm').textContent = eur2(focusResolved.tco.tco_por_km_eur);
        $('focus-horizonte').textContent = String(state.horizonte);
        $('focus-dep').textContent = eur(focusResolved.tco.depreciacion_eur);
        $('focus-ene').textContent = eur(focusResolved.tco.energia_eur);
        $('focus-man').textContent = eur(focusResolved.tco.mantenimiento_eur);
        $('focus-seg').textContent = eur(focusResolved.tco.seguro_eur);
        $('focus-imp').textContent = eur(focusResolved.tco.impuestos_eur);
        confDot('focus-dep-conf', focusResolved.input.confianza_depreciacion);
        confDot('focus-ene-conf', focusResolved.input.confianza_consumo);
        confDot('focus-man-conf', focusResolved.input.confianza_mantenimiento);
        confDot('focus-seg-conf', focusResolved.input.confianza_seguro);
        // Fila de ayudas solo si corresponde.
        const ayuDt = $('focus-ayu-dt');
        const ayuDd = $('focus-ayu-dd');
        if (focusResolved.tren === 'BEV' && focusResolved.tco.ayudas_eur > 0) {
          ayuDt.removeAttribute('hidden');
          ayuDd.removeAttribute('hidden');
          $('focus-ayu').textContent = eur(focusResolved.tco.ayudas_eur);
        } else {
          ayuDt.setAttribute('hidden', '');
          ayuDd.setAttribute('hidden', '');
        }
      }

      // 6) Re-pintar chips (conteo + etiquetas).
      renderChips();

      // 7) Baseline E7: usa el focus BEV vs el focus ICE si existen
      //    ambos (para que la sensibilidad sea una comparación válida).
      //    Si no, usa cheapestBev/cheapestIce como proxy.
      const baseBev = cheapestBev;
      const baseIce = cheapestIce;
      if (baseBev && baseIce) {
        const cmp = compararTCO(baseBev.input, baseIce.input, overrides);
        baselineCache = {
          bevInput: baseBev.input,
          iceInput: baseIce.input,
          ahorroActual: cmp.ahorro_bev_eur,
        };
      } else {
        baselineCache = null;
      }
      recalcSens();

      // 8) Gráfico
      renderChart(curvas);

      writeUrl();
    }

    // ── E7 — Sensibilidad interactiva ──
    // Recomputa las 3 líneas del aside en función de sensState, usando el
    // baselineCache ya calculado. No toca lede, gráfico ni breakdown.
    function recalcSens() {
      if (!baselineCache) return;
      const { bevInput, iceInput, ahorroActual } = baselineCache;

      const wiggle = (overrides: { km?: number; kwh?: number; pctCasa?: number }) => {
        const km = overrides.km ?? state.km;
        const pctCasa = overrides.pctCasa ?? state.pctCasa;
        const kwh = overrides.kwh ?? (
          (pctCasa / 100) * state.kwhCasa +
          (1 - pctCasa / 100) * state.kwhPublica
        );
        const c = compararTCO(bevInput, iceInput, {
          km_anual: km,
          horizonte_anios: state.horizonte,
          precio_kwh_eur: kwh,
          precio_litro_eur: state.litro,
        });
        return c.ahorro_bev_eur;
      };

      const fmtDelta = (actual: number, nuevo: number) => {
        const delta = nuevo - actual;
        const verbo = nuevo >= 0 ? 'ahorras' : 'sobrecuesta';
        const abs = Math.abs(nuevo);
        if (Math.abs(delta) < 0.5) {
          return `${verbo} <strong>${eur(abs)} €</strong> (prácticamente igual)`;
        }
        const signoDelta = delta >= 0 ? '+' : '−';
        return `${verbo} <strong>${eur(abs)} €</strong> (${signoDelta}${eur(Math.abs(delta))} € vs escenario actual)`;
      };

      const signoPct = (v: number) => (v >= 0 ? '+' : '−');
      const signoDec = (v: number) =>
        v >= 0 ? `+${v.toFixed(2).replace('.', ',')}` : `−${Math.abs(v).toFixed(2).replace('.', ',')}`;

      // Km/año.
      const kmHipo = Math.max(1000, Math.round(state.km * (1 + sensState.kmPct / 100)));
      const kmAhorro = wiggle({ km: kmHipo });
      $('sens-km-mul').textContent = `${signoPct(sensState.kmPct)}${Math.abs(sensState.kmPct)} %`;
      $('sens-km').innerHTML =
        sensState.kmPct === 0
          ? `Con tus <strong>${eur(state.km)} km/año</strong> → ${fmtDelta(ahorroActual, kmAhorro)}`
          : `Si haces <strong>${eur(kmHipo)} km/año</strong> (${signoPct(sensState.kmPct)}${Math.abs(sensState.kmPct)} %) → ${fmtDelta(ahorroActual, kmAhorro)}`;

      // kWh efectivo.
      const kwhBase = kwhEfectivo();
      const kwhHipo = Math.max(0.05, kwhBase + sensState.kwhDelta);
      const kwhAhorro = wiggle({ kwh: kwhHipo });
      $('sens-kwh-mul').textContent = `${signoDec(sensState.kwhDelta)} €`;
      $('sens-kwh').innerHTML =
        sensState.kwhDelta === 0
          ? `Con el kWh efectivo actual (<strong>${kwhBase.toFixed(3)} €</strong>) → ${fmtDelta(ahorroActual, kwhAhorro)}`
          : `Si el kWh efectivo vale <strong>${kwhHipo.toFixed(3)} €</strong> (${signoDec(sensState.kwhDelta)} €) → ${fmtDelta(ahorroActual, kwhAhorro)}`;

      // % casa.
      const pctHipo = Math.min(100, Math.max(0, state.pctCasa + sensState.pctPts));
      const pctAhorro = wiggle({ pctCasa: pctHipo });
      $('sens-casa-mul').textContent = `${signoPct(sensState.pctPts)}${Math.abs(sensState.pctPts)} pts`;
      $('sens-casa').innerHTML =
        sensState.pctPts === 0
          ? `Con tu <strong>${state.pctCasa} %</strong> en casa → ${fmtDelta(ahorroActual, pctAhorro)}`
          : `Si cargas <strong>${pctHipo} %</strong> en casa (${signoPct(sensState.pctPts)}${Math.abs(sensState.pctPts)} pts) → ${fmtDelta(ahorroActual, pctAhorro)}`;
    }

    // ── Sprint 2 E2 paso 2B — Bindings chips + combobox + quick-starts ──

    // Renderiza los chips para ambos trenes a partir del state.
    function renderChips() {
      renderChipsFor('BEV');
      renderChipsFor('ICE');
      $('bev-count').textContent = `${state.bevSlugs.length} / ${MAX_POR_TREN}`;
      $('ice-count').textContent = `${state.iceSlugs.length} / ${MAX_POR_TREN}`;
      // Deshabilita el input del combobox si está lleno.
      ($('combo-bev') as HTMLInputElement).disabled = state.bevSlugs.length >= MAX_POR_TREN;
      ($('combo-ice') as HTMLInputElement).disabled = state.iceSlugs.length >= MAX_POR_TREN;
    }

    function renderChipsFor(tren: 'BEV' | 'ICE') {
      const container = $(tren === 'BEV' ? 'chips-bev' : 'chips-ice');
      const slugs = tren === 'BEV' ? state.bevSlugs : state.iceSlugs;
      container.innerHTML = '';
      for (const slug of slugs) {
        const meta = getMeta(tren, slug);
        if (!meta) continue;
        const chip = document.createElement('span');
        chip.className = `chip chip-${tren.toLowerCase()}`;
        chip.dataset.tren = tren;
        chip.dataset.slug = slug;
        chip.setAttribute('role', 'listitem');
        if (isFocus(tren, slug)) chip.classList.add('chip-focus');

        const nameBtn = document.createElement('button');
        nameBtn.type = 'button';
        nameBtn.className = 'chip-name';
        nameBtn.textContent = meta.name;
        nameBtn.title = 'Poner en foco';
        nameBtn.addEventListener('click', () => {
          state.focus = { tren, slug };
          recalc();
        });
        chip.appendChild(nameBtn);

        // Solo permitimos quitar si queda más de uno en este tren O
        // si aún queda alguno en el otro tren (nunca dejamos 0 coches).
        const totalSel = state.bevSlugs.length + state.iceSlugs.length;
        if (totalSel > 1) {
          const rm = document.createElement('button');
          rm.type = 'button';
          rm.className = 'chip-remove';
          rm.setAttribute('aria-label', `Quitar ${meta.name}`);
          rm.textContent = '×';
          rm.addEventListener('click', (e) => {
            e.stopPropagation();
            if (tren === 'BEV') {
              state.bevSlugs = state.bevSlugs.filter((s) => s !== slug);
            } else {
              state.iceSlugs = state.iceSlugs.filter((s) => s !== slug);
            }
            recalc();
          });
          chip.appendChild(rm);
        }
        container.appendChild(chip);
      }
    }

    // Combobox: filtrado por marca/modelo/variante, excluye ya seleccionados.
    function buildComboHandlers(tren: 'BEV' | 'ICE') {
      const input = $(tren === 'BEV' ? 'combo-bev' : 'combo-ice') as HTMLInputElement;
      const list = $(tren === 'BEV' ? 'suggest-bev' : 'suggest-ice') as HTMLUListElement;
      const fuente = tren === 'BEV' ? ALL_BEVS : ALL_ICES;

      const filtra = (q: string) => {
        const qq = q.trim().toLowerCase();
        const selected = tren === 'BEV' ? state.bevSlugs : state.iceSlugs;
        return fuente
          .filter((x) => !selected.includes(x.slug))
          .filter((x) => !qq || x.name.toLowerCase().includes(qq))
          .slice(0, 8);
      };

      const pinta = () => {
        const items = filtra(input.value);
        list.innerHTML = '';
        if (!items.length) {
          list.hidden = true;
          return;
        }
        for (const it of items) {
          const li = document.createElement('li');
          li.className = 'suggest-item';
          li.setAttribute('role', 'option');
          li.dataset.slug = it.slug;
          li.innerHTML =
            `<span class="suggest-name">${it.name}</span>` +
            (it.segmento ? `<span class="suggest-seg">${it.segmento}</span>` : '');
          li.addEventListener('mousedown', (e) => {
            e.preventDefault();
            addCoche(tren, it.slug);
            input.value = '';
            list.hidden = true;
          });
          list.appendChild(li);
        }
        list.hidden = false;
      };

      input.addEventListener('input', pinta);
      input.addEventListener('focus', pinta);
      input.addEventListener('blur', () => {
        // Delay para permitir el mousedown.
        setTimeout(() => { list.hidden = true; }, 150);
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          list.hidden = true;
          input.blur();
        } else if (e.key === 'Enter') {
          const first = list.querySelector<HTMLLIElement>('.suggest-item');
          if (first && first.dataset.slug) {
            e.preventDefault();
            addCoche(tren, first.dataset.slug);
            input.value = '';
            list.hidden = true;
          }
        }
      });
    }

    function addCoche(tren: 'BEV' | 'ICE', slug: string) {
      const arr = tren === 'BEV' ? state.bevSlugs : state.iceSlugs;
      if (arr.includes(slug)) return;
      if (arr.length >= MAX_POR_TREN) return;
      arr.push(slug);
      // Primer coche añadido de un tren vacío → lo ponemos en foco.
      if (arr.length === 1 && state.focus.tren !== tren) {
        state.focus = { tren, slug };
      }
      recalc();
    }

    buildComboHandlers('BEV');
    buildComboHandlers('ICE');

    // Quick-starts: sustituyen la selección completa por el par icónico.
    document.querySelectorAll<HTMLButtonElement>('.qs-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const bev = btn.dataset.bev ?? '';
        const ice = btn.dataset.ice ?? '';
        if (!bevSlugSet.has(bev) || !iceSlugSet.has(ice)) return;
        state.bevSlugs = [bev];
        state.iceSlugs = [ice];
        state.focus = { tren: 'BEV', slug: bev };
        recalc();
      });
    });

    // Chart click → cambiar focus.
    $('tco-chart').addEventListener('click', (e) => {
      const target = e.target as Element;
      const path = target.closest('[data-tren][data-slug]') as HTMLElement | null;
      if (!path) return;
      const tren = path.dataset.tren as 'BEV' | 'ICE';
      const slug = path.dataset.slug as string;
      if (!tren || !slug) return;
      state.focus = { tren, slug };
      recalc();
    });

    ($('horizonte') as HTMLInputElement).addEventListener('input', (e) => {
      const raw = Number((e.target as HTMLInputElement).value);
      state.horizonte = snapHorizonte(raw);
      // Snap visual del slider al valor válido.
      (e.target as HTMLInputElement).value = String(state.horizonte);
      $('horizonte-out').textContent = `${state.horizonte} año${state.horizonte === 1 ? '' : 's'}`;
      recalc();
    });

    ($('km') as HTMLInputElement).addEventListener('input', (e) => {
      state.km = Number((e.target as HTMLInputElement).value);
      $('km-out').textContent = `${eur(state.km)} km`;
      recalc();
    });

    // ── E1 — mix casa/pública ──
    const refreshKwhEfectivo = () => {
      $('kwh-efectivo-out').textContent = `${kwhEfectivo().toFixed(3)} €/kWh`;
    };
    ($('pct-casa') as HTMLInputElement).addEventListener('input', (e) => {
      state.pctCasa = Number((e.target as HTMLInputElement).value);
      $('pct-casa-out').textContent = `${state.pctCasa} %`;
      refreshKwhEfectivo();
      recalc();
    });
    ($('kwh-casa') as HTMLInputElement).addEventListener('input', (e) => {
      state.kwhCasa = Number((e.target as HTMLInputElement).value);
      $('kwh-casa-out').textContent = `${state.kwhCasa.toFixed(2)} €`;
      refreshKwhEfectivo();
      recalc();
    });
    ($('kwh-publica') as HTMLInputElement).addEventListener('input', (e) => {
      state.kwhPublica = Number((e.target as HTMLInputElement).value);
      $('kwh-publica-out').textContent = `${state.kwhPublica.toFixed(2)} €`;
      refreshKwhEfectivo();
      recalc();
    });
    document.querySelectorAll<HTMLButtonElement>('.mix-preset').forEach((btn) => {
      btn.addEventListener('click', () => {
        const pct = Number(btn.dataset.pct);
        if (!Number.isFinite(pct)) return;
        state.pctCasa = pct;
        ($('pct-casa') as HTMLInputElement).value = String(pct);
        $('pct-casa-out').textContent = `${pct} %`;
        document.querySelectorAll('.mix-preset').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        refreshKwhEfectivo();
        recalc();
      });
    });

    ($('litro') as HTMLInputElement).addEventListener('input', (e) => {
      state.litro = Number((e.target as HTMLInputElement).value);
      $('litro-out').textContent = `${state.litro.toFixed(2)} €/L`;
      recalc();
    });

    ($('ayuda') as HTMLInputElement).addEventListener('change', (e) => {
      state.ayuda = (e.target as HTMLInputElement).checked;
      $('ayuda-out').textContent = state.ayuda
        ? '(Eléctrico · Económico · Europeo)'
        : '(no aplicada)';
      recalc();
    });

    // ── E7 — Bindings mini-sliders sensibilidad ──
    ($('sens-km-slider') as HTMLInputElement).addEventListener('input', (e) => {
      sensState.kmPct = Number((e.target as HTMLInputElement).value);
      recalcSens();
    });
    ($('sens-kwh-slider') as HTMLInputElement).addEventListener('input', (e) => {
      sensState.kwhDelta = Number((e.target as HTMLInputElement).value);
      recalcSens();
    });
    ($('sens-casa-slider') as HTMLInputElement).addEventListener('input', (e) => {
      sensState.pctPts = Number((e.target as HTMLInputElement).value);
      recalcSens();
    });

    $('share-btn').addEventListener('click', async () => {
      writeUrl();
      try {
        await navigator.clipboard.writeText(location.href);
        $('share-msg').textContent = '¡Enlace copiado!';
      } catch {
        $('share-msg').textContent = 'Selecciona la URL del navegador para copiarla.';
      }
      setTimeout(() => {
        $('share-msg').textContent = '';
      }, 2500);
    });

    // ── Arranque ──
    function hydrateControls() {
      ($('horizonte') as HTMLInputElement).value = String(state.horizonte);
      ($('km') as HTMLInputElement).value = String(state.km);
      ($('pct-casa') as HTMLInputElement).value = String(state.pctCasa);
      ($('kwh-casa') as HTMLInputElement).value = String(state.kwhCasa);
      ($('kwh-publica') as HTMLInputElement).value = String(state.kwhPublica);
      ($('litro') as HTMLInputElement).value = String(state.litro);
      ($('ayuda') as HTMLInputElement).checked = state.ayuda;
      $('horizonte-out').textContent = `${state.horizonte} años`;
      $('km-out').textContent = `${eur(state.km)} km`;
      $('pct-casa-out').textContent = `${state.pctCasa} %`;
      $('kwh-casa-out').textContent = `${state.kwhCasa.toFixed(2)} €`;
      $('kwh-publica-out').textContent = `${state.kwhPublica.toFixed(2)} €`;
      $('litro-out').textContent = `${state.litro.toFixed(2)} €/L`;
      $('kwh-efectivo-out').textContent = `${kwhEfectivo().toFixed(3)} €/kWh`;
      $('ayuda-out').textContent = state.ayuda
        ? '(Eléctrico · Económico · Europeo)'
        : '(no aplicada)';
      // Marca el preset activo si coincide.
      document.querySelectorAll<HTMLButtonElement>('.mix-preset').forEach((b) => {
        b.classList.toggle('active', Number(b.dataset.pct) === state.pctCasa);
      });
    }

    readUrl();
    hydrateControls();
    recalc();
  </script>

  <style>
