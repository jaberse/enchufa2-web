---
// src/pages/calculadora-tco.astro
// Calculadora TCO — beta pública. Los 20 modelos del Top 20 catálogo v1.
// v0.2 — expandido de 3 a 20 pares (Tandas 1-4 completas, 2026-04-14).

import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { bevFromJson, iceFromJson } from '../lib/tco/resolver.mjs';
import { PARAMS_ENCHUFA2_ESTANDAR } from '../lib/tco/params.mjs';
import '../styles/global.css';

const ROOT = process.cwd();
const dataFile = (rel: string) =>
  JSON.parse(fs.readFileSync(path.join(ROOT, rel), 'utf8'));

// ── Pares BEV/ICE disponibles ──────────────────────────────────────────
// Top 20 catálogo v1, ordenados para narrativa (impacto → paridad/delta).
// `piloto` = URL al cálculo manual .md si existe (solo 3 de 20, pilotos 1-3).
// El resto se calcula idénticamente vía pipeline + librería src/lib/tco/.
// Default: tesla-model-3-rwd-highland (caso icónico, ahorro ~47 %).
const PARES = [
  { slug: 'tesla-model-3-rwd-highland',   iceSlug: 'bmw-320i-sedan',        etiqueta: 'Tesla Model 3 RWD · vs · BMW 320i',              comparacion: 'Benchmark D · berlina media premium',  piloto: 'https://github.com/jaberse/enchufa2-web/blob/main/docs/piloto-3-tco-calculo-manual.md' },
  { slug: 'tesla-model-y-rwd-long-range', iceSlug: 'bmw-x3-xdrive20i',      etiqueta: 'Tesla Model Y LR · vs · BMW X3 xDrive20i',       comparacion: 'Benchmark D-SUV · premium familiar' },
  { slug: 'hyundai-kona-electric-65-kwh', iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Hyundai Kona Electric 65 · vs · VW Tiguan',      comparacion: 'Benchmark C-SUV · mainstream' },
  { slug: 'skoda-elroq-60',               iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Škoda Elroq 60 · vs · VW Tiguan',                comparacion: 'Benchmark C-SUV · grupo VAG' },
  { slug: 'kia-ev3-long-range',           iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Kia EV3 Long Range · vs · VW Tiguan',            comparacion: 'Benchmark C-SUV · coreano plataforma E-GMP' },
  { slug: 'bmw-ix1-xdrive30',             iceSlug: 'bmw-x1-sdrive18i',      etiqueta: 'BMW iX1 xDrive30 · vs · X1 sDrive18i',           comparacion: 'Intra-marca · premium C-SUV',           piloto: 'https://github.com/jaberse/enchufa2-web/blob/main/docs/piloto-2-tco-calculo-manual.md' },
  { slug: 'bmw-ix2-xdrive30',             iceSlug: 'bmw-x1-sdrive18i',      etiqueta: 'BMW iX2 xDrive30 · vs · X1 sDrive18i',           comparacion: 'Intra-marca · SAC coupé premium' },
  { slug: 'mercedes-eqa-250+',            iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Mercedes EQA 250+ · vs · VW Tiguan',             comparacion: 'Premium EV vs mainstream ICE · paridad' },
  { slug: 'toyota-bz4x-fwd',              iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'Toyota bZ4X FWD · vs · VW Tiguan',               comparacion: 'Benchmark C-SUV · Toyota BEV' },
  { slug: 'byd-atto-3-comfort',           iceSlug: 'volkswagen-tiguan-tsi', etiqueta: 'BYD Atto 3 Comfort · vs · VW Tiguan',            comparacion: 'Benchmark C-SUV · BYD LFP Blade' },
  { slug: 'byd-atto-2-comfort',           iceSlug: 'peugeot-2008-puretech', etiqueta: 'BYD Atto 2 · vs · Peugeot 2008 Hybrid',          comparacion: 'Benchmark B-SUV · entrada BYD' },
  { slug: 'byd-seal-awd-excellence',      iceSlug: 'bmw-320i-sedan',        etiqueta: 'BYD Seal AWD · vs · BMW 320i',                   comparacion: 'Benchmark D · berlina performance 530 CV' },
  { slug: 'byd-dolphin-60kwh',            iceSlug: 'dacia-sandero-tce',     etiqueta: 'BYD Dolphin 60 kWh · vs · Dacia Sandero TCe',    comparacion: 'Benchmark B · BEV vs GLP bifuel' },
  { slug: 'jeep-avenger-electric',        iceSlug: 'peugeot-2008-puretech', etiqueta: 'Jeep Avenger BEV · vs · Peugeot 2008 Hybrid',    comparacion: 'Plataforma e-CMP · Stellantis' },
  { slug: 'peugeot-e-2008-allure',        iceSlug: 'peugeot-2008-puretech', etiqueta: 'Peugeot e-2008 · vs · Peugeot 2008 Hybrid',      comparacion: 'Intra-marca · B-SUV Stellantis' },
  { slug: 'renault-5-e-tech-comfort-range', iceSlug: 'dacia-sandero-tce',   etiqueta: 'Renault 5 E-Tech · vs · Dacia Sandero TCe',      comparacion: 'Benchmark B · made in Palencia' },
  { slug: 'citroen-e-c3-you',             iceSlug: 'citroen-c3-puretech-100', etiqueta: 'Citroën ë-C3 · vs · C3 PureTech 100',          comparacion: 'Intra-marca · urbano mass-market',      piloto: 'https://github.com/jaberse/enchufa2-web/blob/main/docs/piloto-1-tco-calculo-manual.md' },
  { slug: 'dacia-spring-essential',       iceSlug: 'hyundai-i10-mpi',       etiqueta: 'Dacia Spring Essential · vs · Hyundai i10 MPI',  comparacion: 'Benchmark A · BEV más barato' },
  { slug: 'byd-dolphin-surf-comfort',     iceSlug: 'hyundai-i10-mpi',       etiqueta: 'BYD Dolphin Surf Comfort · vs · Hyundai i10 MPI', comparacion: 'Benchmark A · BYD entrada' },
  { slug: 'hyundai-inster-long-range',    iceSlug: 'hyundai-i10-mpi',       etiqueta: 'Hyundai Inster LR · vs · Hyundai i10 MPI',       comparacion: 'Intra-marca · A utilitario coreano' }
].map((p) => {
  const bevJson = dataFile(`data/coches/${p.slug}.json`);
  const iceJson = dataFile(`data/referencias/ice-equivalentes/${p.iceSlug}.json`);
  return {
    ...p,
    foto: `/comparador/${p.slug}.webp`,
    bevName: `${bevJson.marca} ${bevJson.modelo}${bevJson.variante ? ' ' + bevJson.variante : ''}`,
    iceName: `${iceJson.marca} ${iceJson.modelo} ${iceJson.variante ?? ''}`.trim(),
  };
});

// Construir payload para el cliente: por cada par, los inputs BEV + ICE
// en cada horizonte disponible (2..10 años, para el slider E6a).
const HORIZONTES_DISPONIBLES = [2, 3, 4, 5, 6, 7, 8, 10];

const payload = PARES.map((par) => {
  const bevJson = dataFile(`data/coches/${par.slug}.json`);
  const iceJson = dataFile(
    `data/referencias/ice-equivalentes/${par.iceSlug}.json`,
  );
  const horizontes: Record<number, { bev: any; ice: any }> = {};
  for (const h of HORIZONTES_DISPONIBLES) {
    horizontes[h] = {
      bev: bevFromJson(bevJson, { horizonte_anios: h, aplicar_ayuda: true }),
      ice: iceFromJson(iceJson, { horizonte_anios: h }),
    };
  }
  return {
    ...par,
    horizontes,
    ayuda_disponible: (horizontes[5].bev.ayuda_eur ?? 0) > 0,
    ayuda_eur: horizontes[5].bev.ayuda_eur ?? 0,
  };
});

// ── Sprint 2 E2 — Paso 1: listas completas de candidatos ──
// El cliente recibe dos listas independientes (BEVs e ICEs) con sus fixtures
// por horizonte ya resueltos. Sigue coexistiendo con `payload` (pares fijos)
// para no romper la UI actual; la UI multi-select del paso 2 consumirá estas.
const bevSlugsUnicos = [...new Set(PARES.map((p) => p.slug))];
const iceSlugsUnicos = [...new Set(PARES.map((p) => p.iceSlug))];

const ALL_BEVS = bevSlugsUnicos.map((slug) => {
  const json = dataFile(`data/coches/${slug}.json`);
  const horizontes: Record<number, any> = {};
  for (const h of HORIZONTES_DISPONIBLES) {
    horizontes[h] = bevFromJson(json, {
      horizonte_anios: h,
      aplicar_ayuda: true,
    });
  }
  const h5 = horizontes[5];
  return {
    slug,
    marca: json.marca,
    modelo: json.modelo,
    variante: json.variante ?? '',
    name: `${json.marca} ${json.modelo}${json.variante ? ' ' + json.variante : ''}`,
    segmento: json.segmento ?? null,
    foto: `/comparador/${slug}.webp`,
    horizontes,
    ayuda_disponible: (h5.ayuda_eur ?? 0) > 0,
    ayuda_eur: h5.ayuda_eur ?? 0,
    pvp_eur: h5.pvp_eur ?? null,
  };
});

const ALL_ICES = iceSlugsUnicos.map((slug) => {
  const json = dataFile(`data/referencias/ice-equivalentes/${slug}.json`);
  const horizontes: Record<number, any> = {};
  for (const h of HORIZONTES_DISPONIBLES) {
    horizontes[h] = iceFromJson(json, { horizonte_anios: h });
  }
  const h5 = horizontes[5];
  return {
    slug,
    marca: json.marca,
    modelo: json.modelo,
    variante: json.variante ?? '',
    name: `${json.marca} ${json.modelo}${json.variante ? ' ' + json.variante : ''}`.trim(),
    segmento: json.segmento ?? null,
    horizontes,
    pvp_eur: h5.pvp_eur ?? null,
  };
});

// Defaults del bloque "Tu uso" — E1 + E6a.
// Precios kWh split en casa (PVPC valle) y pública (mix AC lenta + DC rápida).
const PRECIO_KWH_CASA_DEFAULT = 0.12;     // PVPC valle medio 2026 (€/kWh).
const PRECIO_KWH_PUBLICA_DEFAULT = 0.45;  // Media ponderada AC/DC red pública.
const PCT_CASA_DEFAULT = 70;              // 70 % casa / 30 % pública.
const HORIZONTE_DEFAULT = 5;

const pilotosValidados = payload.filter((p) => p.piloto);
const iniH = HORIZONTE_DEFAULT;
const kwhEfectivoIni =
  (PCT_CASA_DEFAULT / 100) * PRECIO_KWH_CASA_DEFAULT +
  (1 - PCT_CASA_DEFAULT / 100) * PRECIO_KWH_PUBLICA_DEFAULT;
---

<Layout
  title="Calculadora TCO — enchufa2"
  description="Calcula el coste real de un coche eléctrico a 3 o 5 años frente a su equivalente de combustión. Depreciación, energía, mantenimiento, seguro, impuestos y Plan Auto+."
>
  <Header />

  <main id="main">
    <!-- ══ HERO narrativo: cat-block pattern (patrón home / guías) ══ -->
    <section class="calc-hero" aria-labelledby="h-hero">
      <div class="calc-hero-band">
        <img
          src="https://images.unsplash.com/photo-1593941707882-a5bba14938c7?w=1800&q=80&auto=format"
          alt=""
          loading="eager"
        />
        <div class="calc-hero-overlay">
          <div class="calc-hero-inner">
            <p class="calc-hero-eyebrow">Herramienta · beta</p>
            <h1 id="h-hero" class="calc-hero-question">
              ¿Cuánto cuesta <em>de verdad</em><br />
              un coche eléctrico?
            </h1>
            <p class="calc-hero-deck">
              Precio de compra, depreciación, energía, mantenimiento, seguro,
              impuestos y Plan Auto+ — todo en un solo número, a 5 años, para
              cualquier coche del Top 20. Elige un escenario y empieza.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="calc-section">
      <div class="calc-outer">

        <!-- ══ ESCENARIOS EDITORIALES — 5 arranques rápidos con foto ══ -->
        <section class="escenarios reveal" aria-labelledby="h-escenarios">
          <div class="escenarios-head">
            <p class="eyebrow">Empieza por un escenario</p>
            <h2 id="h-escenarios">
              Cinco comparativas <em>icónicas</em>
            </h2>
            <p class="escenarios-sub">
              Cada escenario carga una pareja BEV↔ICE de referencia por segmento.
              Después puedes añadir hasta 4 coches de cada tren y ajustar tu uso.
            </p>
          </div>
          <div class="escenarios-grid">
            <button
              type="button"
              class="escenario-card"
              data-scenario="a"
              data-bev="dacia-spring-essential"
              data-ice="hyundai-i10-mpi"
              style={`--card-photo: url('/comparador/dacia-spring-essential.webp')`}
            >
              <span class="escenario-num">01</span>
              <span class="escenario-tag">Segmento A · Urbano</span>
              <span class="escenario-title">
                <span class="escenario-title-main">Dacia Spring</span>
                <span class="escenario-title-vs"><em>vs</em> Hyundai i10</span>
              </span>
              <span class="escenario-footer">
                <span class="escenario-hint">El BEV más barato de España</span>
                <span class="escenario-arrow" aria-hidden="true">→</span>
              </span>
            </button>
            <button
              type="button"
              class="escenario-card"
              data-scenario="b"
              data-bev="renault-5-e-tech-comfort-range"
              data-ice="dacia-sandero-tce"
              style={`--card-photo: url('/comparador/renault-5-e-tech-comfort-range.webp')`}
            >
              <span class="escenario-num">02</span>
              <span class="escenario-tag">Segmento B · Utilitario</span>
              <span class="escenario-title">
                <span class="escenario-title-main">Renault 5 E-Tech</span>
                <span class="escenario-title-vs"><em>vs</em> Sandero TCe</span>
              </span>
              <span class="escenario-footer">
                <span class="escenario-hint">Made in Palencia contra GLP</span>
                <span class="escenario-arrow" aria-hidden="true">→</span>
              </span>
            </button>
            <button
              type="button"
              class="escenario-card"
              data-scenario="c-suv"
              data-bev="hyundai-kona-electric-65-kwh"
              data-ice="volkswagen-tiguan-tsi"
              style={`--card-photo: url('/comparador/hyundai-kona-electric-65-kwh.webp')`}
            >
              <span class="escenario-num">03</span>
              <span class="escenario-tag">C-SUV · Mainstream</span>
              <span class="escenario-title">
                <span class="escenario-title-main">Hyundai Kona 65</span>
                <span class="escenario-title-vs"><em>vs</em> VW Tiguan</span>
              </span>
              <span class="escenario-footer">
                <span class="escenario-hint">El mejor ratio TCO del catálogo</span>
                <span class="escenario-arrow" aria-hidden="true">→</span>
              </span>
            </button>
            <button
              type="button"
              class="escenario-card"
              data-scenario="d"
              data-bev="tesla-model-3-rwd-highland"
              data-ice="bmw-320i-sedan"
              style={`--card-photo: url('/comparador/tesla-model-3-rwd-highland.webp')`}
            >
              <span class="escenario-num">04</span>
              <span class="escenario-tag">Segmento D · Berlina premium</span>
              <span class="escenario-title">
                <span class="escenario-title-main">Tesla Model 3</span>
                <span class="escenario-title-vs"><em>vs</em> BMW 320i</span>
              </span>
              <span class="escenario-footer">
                <span class="escenario-hint">Ahorro icónico: ~47 % a 5 años</span>
                <span class="escenario-arrow" aria-hidden="true">→</span>
              </span>
            </button>
            <button
              type="button"
              class="escenario-card"
              data-scenario="d-suv"
              data-bev="tesla-model-y-rwd-long-range"
              data-ice="bmw-x3-xdrive20i"
              style={`--card-photo: url('/comparador/tesla-model-y-rwd-long-range.webp')`}
            >
              <span class="escenario-num">05</span>
              <span class="escenario-tag">D-SUV · Familiar</span>
              <span class="escenario-title">
                <span class="escenario-title-main">Tesla Model Y</span>
                <span class="escenario-title-vs"><em>vs</em> BMW X3</span>
              </span>
              <span class="escenario-footer">
                <span class="escenario-hint">Premium familiar · 42 % de ahorro</span>
                <span class="escenario-arrow" aria-hidden="true">→</span>
              </span>
            </button>
          </div>
          <!-- Toast de confirmación/undo al cargar un escenario -->
          <div class="escenario-toast" id="escenario-toast" role="status" aria-live="polite" hidden>
            <span class="toast-icon" aria-hidden="true">✓</span>
            <span class="toast-text" id="toast-text">Escenario cargado</span>
            <button type="button" class="toast-undo" id="toast-undo" hidden>Deshacer</button>
          </div>
        </section>

        <!-- Beta warn (discreto, sólo debajo de escenarios) -->
        <div class="beta-warn reveal" role="note">
          <strong>Beta · datos en revisión</strong> — los PVPs oficiales, las
          3 cotizaciones de seguro reales y la depreciación contra Ganvam se
          están calibrando. Úsala como orientación, no como decisión de compra.
          <a href="#metodologia">Ver metodología</a>.
        </div>

    <!-- ────────── CONTROLES ────────── -->
    <section class="controles reveal" aria-labelledby="h-controles">
      <h2 id="h-controles" class="section-head">
        <span class="section-num">02 — Ajusta</span>
        Tu escenario, <em>a tu medida</em>
      </h2>
      <p class="section-sub">
        Añade hasta 4 eléctricos y 4 de combustión. Haz clic en una fila de la
        tabla — o en una línea del gráfico — para ver su desglose completo.
      </p>

      <div class="ctrl-grid">
        <!-- Selector multi-coche (Sprint 2 E2 paso 2B) -->
        <div class="ctrl ctrl-seleccion" role="group" aria-label="Coches a analizar">
          <div class="seleccion-head">
            <p class="ctrl-title">Coches a analizar</p>
            <!-- Pair-switch inline: aparece sólo cuando N(BEV)==N(ICE)>=2. -->
            <div class="pair-switch" id="pair-switch" hidden>
              <label class="pair-switch-lbl">
                <input type="checkbox" id="pair-switch-input" />
                <span class="pair-switch-track" aria-hidden="true"></span>
                <span class="pair-switch-text">
                  Emparejar 1↔1
                  <span class="pair-switch-hint">Compara BEV[i] con ICE[i] en vez de todos contra todos</span>
                </span>
              </label>
            </div>
            <!-- Hidden legacy modo-toggle (kept so existing script bindings don't crash). -->
            <div class="modo-toggle sr-only" role="radiogroup" aria-label="Modo de comparación" aria-hidden="true">
              <button type="button" class="modo-btn is-active" data-modo="listas" role="radio" aria-checked="true" tabindex="-1">Listas paralelas</button>
              <button type="button" class="modo-btn" data-modo="pares" role="radio" aria-checked="false" tabindex="-1">Pares BEV ↔ ICE</button>
            </div>
          </div>
          <p class="seleccion-hint" id="seleccion-hint">
            Tienes un par activo. Añade más coches desde los buscadores para
            comparar hasta 4 vs 4 a la vez.
          </p>

          <!-- Legacy quick-starts hidden — los escenarios editoriales arriba ya cubren este rol. -->
          <div class="quick-starts sr-only" role="group" aria-label="Pares rápidos" aria-hidden="true">
            <button type="button" class="qs-btn" data-bev="dacia-spring-essential" data-ice="hyundai-i10-mpi" tabindex="-1">A</button>
            <button type="button" class="qs-btn" data-bev="renault-5-e-tech-comfort-range" data-ice="dacia-sandero-tce" tabindex="-1">B</button>
            <button type="button" class="qs-btn" data-bev="hyundai-kona-electric-65-kwh" data-ice="volkswagen-tiguan-tsi" tabindex="-1">C</button>
            <button type="button" class="qs-btn" data-bev="tesla-model-3-rwd-highland" data-ice="bmw-320i-sedan" tabindex="-1">D</button>
            <button type="button" class="qs-btn" data-bev="tesla-model-y-rwd-long-range" data-ice="bmw-x3-xdrive20i" tabindex="-1">D2</button>
          </div>

          <div class="seleccion-grid">
            <div class="seleccion-col" data-tren="BEV">
              <p class="col-head"><span class="col-dot col-dot-bev" aria-hidden="true"></span> Eléctricos <span class="col-count" id="bev-count">0 / 4</span></p>
              <div class="chips" id="chips-bev" role="list" aria-label="Eléctricos seleccionados"></div>
              <div class="chips-combo">
                <input
                  type="text"
                  id="combo-bev"
                  class="combo-input"
                  placeholder="Añadir eléctrico…"
                  autocomplete="off"
                  aria-label="Buscar eléctrico para añadir"
                  aria-autocomplete="list"
                  aria-controls="suggest-bev"
                />
                <ul class="chips-suggest" id="suggest-bev" role="listbox" hidden></ul>
              </div>
            </div>
            <div class="seleccion-col" data-tren="ICE">
              <p class="col-head"><span class="col-dot col-dot-ice" aria-hidden="true"></span> Combustión <span class="col-count" id="ice-count">0 / 4</span></p>
              <div class="chips" id="chips-ice" role="list" aria-label="Combustión seleccionados"></div>
              <div class="chips-combo">
                <input
                  type="text"
                  id="combo-ice"
                  class="combo-input"
                  placeholder="Añadir combustión…"
                  autocomplete="off"
                  aria-label="Buscar combustión para añadir"
                  aria-autocomplete="list"
                  aria-controls="suggest-ice"
                />
                <ul class="chips-suggest" id="suggest-ice" role="listbox" hidden></ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Horizonte (E6a — slider libre 2-10) -->
        <div class="ctrl">
          <label for="horizonte">
            Horizonte
            <output id="horizonte-out">{iniH} años</output>
          </label>
          <input
            id="horizonte"
            type="range"
            min="2"
            max="10"
            step="1"
            value={iniH}
            list="horizonte-ticks"
          />
          <datalist id="horizonte-ticks">
            {HORIZONTES_DISPONIBLES.map((h) => <option value={h}></option>)}
          </datalist>
          <span class="ctrl-hint">De 2 a 10 años de tenencia. Por encima de 5 la banda se amplía: y10 es siempre confianza baja.</span>
        </div>

        <!-- Km/año -->
        <div class="ctrl">
          <label for="km">
            Kilometraje anual
            <output id="km-out">{PARAMS_ENCHUFA2_ESTANDAR.km_anual.toLocaleString('es-ES')} km</output>
          </label>
          <input
            id="km"
            type="range"
            min="5000"
            max="40000"
            step="500"
            value={PARAMS_ENCHUFA2_ESTANDAR.km_anual}
          />
        </div>

        <!-- ── E1 — Mix de carga casa/pública ── -->
        <div class="ctrl ctrl-mix" role="group" aria-label="Cómo cargas habitualmente">
          <p class="ctrl-title">Cómo cargas habitualmente</p>
          <div class="mix-presets" role="group" aria-label="Perfiles de carga predefinidos">
            <button type="button" class="mix-preset" data-pct="90">Casa 90 %</button>
            <button type="button" class="mix-preset" data-pct="70">Mixto 70 %</button>
            <button type="button" class="mix-preset" data-pct="20">Sin garaje 20 %</button>
          </div>
          <label for="pct-casa" class="mix-label">
            % carga en casa
