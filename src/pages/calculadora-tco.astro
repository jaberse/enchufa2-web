        var(--gray-600) 8px,
        var(--gray-600) 13px,
        transparent 13px,
        transparent 16px,
        var(--gray-600) 16px,
        var(--gray-600) 18px
      );
    }
    [data-theme="dark"] .lg-ice .lg-swatch {
      background: linear-gradient(
        to right,
        var(--gray-300) 0,
        var(--gray-300) 5px,
        transparent 5px,
        transparent 8px,
        var(--gray-300) 8px,
        var(--gray-300) 13px,
        transparent 13px,
        transparent 16px,
        var(--gray-300) 16px,
        var(--gray-300) 18px
      );
