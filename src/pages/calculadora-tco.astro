    #tco-chart {
      width: 100%;
      height: auto;
      display: block;
      overflow: visible;
    }
    /* Clases aplicadas a nodos SVG creados por JS (createElementNS).
       Astro no añade data-astro-cid a nodos dinámicos, así que
       usamos :global() para que los estilos los alcancen. */
    #tco-chart :global(.grid-line) {
      stroke: var(--border-subtle);
      stroke-width: 1;
      fill: none;
    }
    #tco-chart :global(.grid-vert) {
      stroke: var(--border-subtle);
      stroke-width: 1;
      stroke-dasharray: 2 4;
      opacity: 0.55;
      fill: none;
    }
    #tco-chart :global(.grid-zero) {
      stroke: var(--border);
      stroke-width: 1;
      fill: none;
    }
    #tco-chart :global(.ax-line) {
      stroke: var(--border);
      stroke-width: 1;
      fill: none;
    }
    #tco-chart :global(.ax-label) {
      font-family: var(--font-sans);
      font-size: 11px;
      fill: var(--text-muted);
      font-variant-numeric: tabular-nums;
    }
    #tco-chart :global(.curve-bev) {
      fill: none;
      stroke: var(--yellow);
      stroke-width: 2.5;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    #tco-chart :global(.curve-bev-fill) {
      fill: var(--yellow);
      fill-opacity: 0.12;
      stroke: none;
    }
    /* Bandas de incertidumbre (§4 metodología). */
    #tco-chart :global(.band-bev) {
      fill: var(--yellow);
      fill-opacity: 0.18;
      stroke: var(--yellow);
      stroke-opacity: 0.35;
      stroke-width: 0.75;
      stroke-dasharray: 2 3;
    }
    #tco-chart :global(.band-ice) {
      fill: var(--gray-600);
      fill-opacity: 0.1;
      stroke: var(--gray-600);
      stroke-opacity: 0.3;
      stroke-width: 0.75;
      stroke-dasharray: 2 3;
    }
    [data-theme="dark"] #tco-chart :global(.band-ice) {
      fill: var(--gray-300);
      stroke: var(--gray-300);
    }
    #tco-chart :global(.curve-ice) {
      fill: none;
      stroke: var(--gray-600);
      stroke-width: 2;
      stroke-dasharray: 6 4;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    [data-theme="dark"] #tco-chart :global(.curve-ice) { stroke: var(--gray-300); }
    #tco-chart :global(.dot-bev) {
      fill: var(--yellow);
      stroke: var(--card-bg);
      stroke-width: 1.5;
    }
    #tco-chart :global(.dot-ice) {
      fill: var(--gray-600);
      stroke: var(--card-bg);
      stroke-width: 1.5;
    }
    [data-theme="dark"] #tco-chart :global(.dot-ice) { fill: var(--gray-300); }
    #tco-chart :global(.be-line) {
      stroke: var(--text);
      stroke-width: 1;
      stroke-dasharray: 3 3;
      opacity: 0.55;
      fill: none;
    }
    #tco-chart :global(.be-pill) {
      fill: var(--text);
      stroke: none;
    }
    #tco-chart :global(.be-label) {
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 500;
      fill: var(--card-bg);
      font-variant-numeric: tabular-nums;
