  <Footer />

  <!-- Datos server → cliente: listas completas de candidatos para multi-select. -->
  <script type="application/json" id="tco-all-bevs" set:html={JSON.stringify(ALL_BEVS)} />
  <script type="application/json" id="tco-all-ices" set:html={JSON.stringify(ALL_ICES)} />

  <!-- Lógica interactiva (auto-bundled por Astro) -->
  <script>
    import { calcularTCO, compararTCO, curvaUnTren, curvaTCO } from '../lib/tco/calculadora.mjs';

    // `useGrouping: 'always'` fuerza el separador de millares también en
    // números de 4 cifras (en es-ES por defecto "8055" sale sin punto; con
    // always queda "8.055"). Evita que la tabla se vea como un muro de
    // dígitos sin respirar.
    const eur = (n: number) =>
      new Intl.NumberFormat('es-ES', {
        maximumFractionDigits: 0,
        useGrouping: 'always' as any,
      }).format(n);
    const eur2 = (n: number) =>
      new Intl.NumberFormat('es-ES', {
        maximumFractionDigits: 3,
        minimumFractionDigits: 2,
        useGrouping: 'always' as any,
      }).format(n);

    // Sprint 2 E2 (paso 1): listas completas paralelas. El UI actual no las
    // usa todavía — las consumirá el multi-select del paso 2. Mantener aquí
    // garantiza que el build incluya la plomería y se pueda inspeccionar.
    const allBevsEl = document.getElementById('tco-all-bevs')!;
    const allIcesEl = document.getElementById('tco-all-ices')!;
    const ALL_BEVS = JSON.parse(allBevsEl.textContent ?? '[]') as Array<any>;
    const ALL_ICES = JSON.parse(allIcesEl.textContent ?? '[]') as Array<any>;
    // Exponemos a window para inspección en DevTools.
    (window as any).__e2_all_bevs = ALL_BEVS;
    (window as any).__e2_all_ices = ALL_ICES;

    const $ = <T extends HTMLElement = HTMLElement>(id: string) =>
      document.getElementById(id) as T;

    const DEFAULT_BEV = 'tesla-model-3-rwd-highland';
    const DEFAULT_ICE = 'bmw-320i-sedan';
    const HORIZONTES_VALIDOS = [2, 3, 4, 5, 6, 7, 8, 10];
    const MAX_POR_TREN = 4;

    // Paleta por slot (0..3). El slot 0 siempre es el amarillo enchufa2, que
    // en BEV sale sólido y en ICE discontinuo: así el usuario identifica el
    // coche por color y el tren por la forma. Los tonos 1..3 son desaturados
    // para no competir con la identidad amarilla.
    const PALETA_SLOT = ['#F5C518', '#111111', '#8F3985', '#1F7A8C'];
    const colorSlot = (idx: number) => PALETA_SLOT[idx % PALETA_SLOT.length];

    type FocusKey = { tren: 'BEV' | 'ICE'; slug: string };

    type Modo = 'listas' | 'pares';

    const state = {
      bevSlugs: [DEFAULT_BEV] as string[],
      iceSlugs: [DEFAULT_ICE] as string[],
      focus: { tren: 'BEV', slug: DEFAULT_BEV } as FocusKey,
      horizonte: 5,                 // 2..10 (E6a)
      km: 15000,
      pctCasa: 70,                  // 0..100 (E1)
      kwhCasa: 0.12,                // €/kWh PVPC valle (E1)
      kwhPublica: 0.45,             // €/kWh pública media AC+DC (E1)
      litro: 1.55,
      ayuda: true,
      modo: 'listas' as Modo,       // Fase B.5: 'listas' (paralelo) | 'pares' (BEV[i]↔ICE[i])
    };

    const focusKeyStr = (k: FocusKey) => `${k.tren}:${k.slug}`;
    const isFocus = (tren: 'BEV'|'ICE', slug: string) =>
      state.focus.tren === tren && state.focus.slug === slug;

    // €/kWh efectivo derivado del mix casa/pública (E1).
    const kwhEfectivo = () =>
      (state.pctCasa / 100) * state.kwhCasa +
      (1 - state.pctCasa / 100) * state.kwhPublica;

    // Snap del horizonte al valor válido más cercano (para que 9 → 10, etc.).
    const snapHorizonte = (h: number) => {
      let best = HORIZONTES_VALIDOS[0];
      let dist = Math.abs(h - best);
      for (const v of HORIZONTES_VALIDOS) {
        const d = Math.abs(h - v);
        if (d < dist) { best = v; dist = d; }
      }
      return best;
    };

    const bevSlugSet = new Set(ALL_BEVS.map((b) => b.slug));
    const iceSlugSet = new Set(ALL_ICES.map((c) => c.slug));

    // Lee URL querystring si existe
    function readUrl() {
      const p = new URLSearchParams(location.search);

      // Sprint 2: multi-select via ?bev=a,b&ice=c,d&f=BEV:a
      const bevParam = p.get('bev');
      if (bevParam) {
        const slugs = bevParam
          .split(',')
          .filter((s) => bevSlugSet.has(s))
          .slice(0, MAX_POR_TREN);
        if (slugs.length) state.bevSlugs = slugs;
      } else {
        // Retrocompat: ?m=slug → carga ese BEV (y mantiene el ICE default).
        const legacy = p.get('m');
        if (legacy && bevSlugSet.has(legacy)) state.bevSlugs = [legacy];
      }

      const iceParam = p.get('ice');
      if (iceParam) {
        const slugs = iceParam
          .split(',')
          .filter((s) => iceSlugSet.has(s))
          .slice(0, MAX_POR_TREN);
        if (slugs.length) state.iceSlugs = slugs;
      }

      const f = p.get('f');
      if (f) {
        const [t, s] = f.split(':');
        if (t === 'BEV' && s && state.bevSlugs.includes(s)) {
          state.focus = { tren: 'BEV', slug: s };
        } else if (t === 'ICE' && s && state.iceSlugs.includes(s)) {
          state.focus = { tren: 'ICE', slug: s };
        }
      }
      // Si el focus no es válido, reseteamos al primer BEV (o primer ICE).
      if (
        (state.focus.tren === 'BEV' && !state.bevSlugs.includes(state.focus.slug)) ||
        (state.focus.tren === 'ICE' && !state.iceSlugs.includes(state.focus.slug))
      ) {
        if (state.bevSlugs.length) {
          state.focus = { tren: 'BEV', slug: state.bevSlugs[0] };
        } else if (state.iceSlugs.length) {
          state.focus = { tren: 'ICE', slug: state.iceSlugs[0] };
        }
      }

      const h = Number(p.get('h'));
      if (h >= 2 && h <= 10) state.horizonte = snapHorizonte(h);
      const k = Number(p.get('km'));
      if (k >= 5000 && k <= 40000) state.km = k;
      // Retrocompatibilidad: si llega `kwh` (legacy v0.2), lo usamos como
      // media efectiva y reconstruimos un split plausible (pct=70).
      const eLegacy = Number(p.get('kwh'));
      if (eLegacy >= 0.08 && eLegacy <= 0.55) {
        state.pctCasa = 70;
        state.kwhCasa = Math.max(0.05, Math.min(0.25, eLegacy * 0.7));
        state.kwhPublica = Math.max(0.20, Math.min(0.80, eLegacy * 1.7));
      }
      const pc = Number(p.get('pc'));
      if (pc >= 0 && pc <= 100) state.pctCasa = pc;
      const kc = Number(p.get('kc'));
      if (kc >= 0.05 && kc <= 0.25) state.kwhCasa = kc;
      const kp = Number(p.get('kp'));
      if (kp >= 0.2 && kp <= 0.8) state.kwhPublica = kp;
      const g = Number(p.get('l'));
      if (g >= 1.2 && g <= 2) state.litro = g;
      if (p.get('a') === '0') state.ayuda = false;
      if (p.get('mo') === 'pares') state.modo = 'pares';
    }

    function writeUrl() {
      const p = new URLSearchParams();
      if (state.bevSlugs.length) p.set('bev', state.bevSlugs.join(','));
      if (state.iceSlugs.length) p.set('ice', state.iceSlugs.join(','));
      p.set('f', focusKeyStr(state.focus));
      p.set('h', String(state.horizonte));
      p.set('km', String(state.km));
      p.set('pc', String(state.pctCasa));
      p.set('kc', state.kwhCasa.toFixed(2));
      p.set('kp', state.kwhPublica.toFixed(2));
      p.set('l', state.litro.toFixed(2));
      if (!state.ayuda) p.set('a', '0');
      if (state.modo === 'pares') p.set('mo', 'pares');
      history.replaceState(null, '', `?${p.toString()}`);
    }

    // Busca el metadata de un coche en ALL_BEVS/ALL_ICES.
    function getMeta(tren: 'BEV'|'ICE', slug: string) {
      return (tren === 'BEV' ? ALL_BEVS : ALL_ICES).find((x) => x.slug === slug);
    }

    // Construye el input canónico (con ayuda aplicada si corresponde) para un
    // coche al horizonte actual. Devuelve null si el slug no existe.
    function getCocheInput(tren: 'BEV'|'ICE', slug: string) {
      const meta = getMeta(tren, slug);
      if (!meta) return null;
      const fix = meta.horizontes[state.horizonte] ?? meta.horizontes[5];
      const input: any = { ...fix };
      if (tren === 'BEV') {
        if (!state.ayuda || !meta.ayuda_disponible) input.ayuda_eur = 0;
      }
      return { input, meta };
    }

    // ── Gráfico TCO acumulado ──
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const VB_W = 800;
    const VB_H = 420;
    const M = { top: 28, right: 24, bottom: 48, left: 72 };
    const PLOT_W = VB_W - M.left - M.right;
    const PLOT_H = VB_H - M.top - M.bottom;

    function niceStep(range: number, ticks: number) {
      const raw = range / ticks;
      const pow = Math.pow(10, Math.floor(Math.log10(Math.abs(raw) || 1)));
      const norm = raw / pow;
      const mult = norm < 1.5 ? 1 : norm < 3 ? 2 : norm < 7 ? 5 : 10;
      return mult * pow;
    }

    function fmtEur(n: number) {
      if (Math.abs(n) >= 1000) {
        return `${eur(n / 1000)} k€`;
      }
      return `${eur(n)} €`;
    }

    function el(tag: string, attrs: Record<string, string | number> = {}, text?: string) {
      const n = document.createElementNS(SVG_NS, tag);
      for (const [k, v] of Object.entries(attrs)) {
        n.setAttribute(k, String(v));
      }
      if (text != null) n.textContent = text;
      return n;
    }

    // ── Sprint 2 E2 paso 2B: gráfico N+M ──
    // Recibe array de curvas (BEV + ICE). Dibuja todas en el mismo espacio,
    // destacando la que está en focus (línea más gruesa, banda visible y el
    // color propio de su tren). Las no-focus se dibujan con opacidad reducida.
    type CurvaData = {
      tren: 'BEV' | 'ICE';
      slug: string;
      name: string;
      color: string;
      puntos: Array<{ anio: number; tco: number; tco_min: number; tco_max: number }>;
      margen: number;
      isFocus: boolean;
    };

    type BreakevenInfo = {
      anio: number;
      bevName: string;
      iceName: string;
      rentableDesdeInicio: boolean;
    };

    // Estado publicado por renderChart() para que el handler de tooltip
    // pueda interpolar valores sin redibujar todo en cada mousemove.
    type ChartState = {
      curvas: CurvaData[];
      xMin: number;
      xMax: number;
      plotLeft: number;
      plotTop: number;
      plotW: number;
      plotH: number;
      xFn: (a: number) => number;
      yFn: (t: number) => number;
    };
    let chartStateRef: ChartState | null = null;

    // Flag de primera renderización: las curvas sólo se animan la primera
    // vez que el gráfico aparece en pantalla. En recalculaciones posteriores
    // (cambios de slider) no queremos el "dibujo" distraiga.
    let chartFirstRender = true;

    function renderChart(curvas: CurvaData[], breakevens: BreakevenInfo[] | BreakevenInfo | null = null) {
      // Back-compat: aceptar un único break-even o un array. Internamente
      // usamos siempre un array.
      const beList: BreakevenInfo[] = Array.isArray(breakevens)
        ? breakevens
        : breakevens
          ? [breakevens]
          : [];
      const svg = $('tco-chart');
      const tbl = $('chart-table') as HTMLTableElement;

      // Limpiar
      while (svg.firstChild) svg.removeChild(svg.firstChild);

      if (!curvas.length) {
        tbl.innerHTML = '';
        return;
      }

      // ── Defs: gradient bajo la curva focus (fill suave) ──
      const focusForDefs = curvas.find((c) => c.isFocus);
      const defs = el('defs', {});
      if (focusForDefs) {
        const gradId = 'tco-grad-focus';
        const grad = el('linearGradient', {
          id: gradId,
          x1: '0', y1: '0', x2: '0', y2: '1',
        });
        const stop1 = el('stop', {
          offset: '0%',
          'stop-color': focusForDefs.color,
          'stop-opacity': '0.28',
        });
        const stop2 = el('stop', {
          offset: '100%',
          'stop-color': focusForDefs.color,
          'stop-opacity': '0',
        });
        grad.appendChild(stop1);
        grad.appendChild(stop2);
        defs.appendChild(grad);
      }
      svg.appendChild(defs);

      const xMin = 0;
      const xMax = curvas[0].puntos[curvas[0].puntos.length - 1]?.anio ?? state.horizonte;

      let yMin = Infinity;
      let yMax = -Infinity;
      for (const c of curvas) {
        for (const p of c.puntos) {
          yMin = Math.min(yMin, p.tco_min);
          yMax = Math.max(yMax, p.tco_max);
        }
      }
      // Colchón visual
      const yRange = yMax - yMin || 1;
      yMin -= yRange * 0.05;
      yMax += yRange * 0.08;
      if (yMin > 0) yMin = 0;

      const x = (a: number) => M.left + ((a - xMin) / (xMax - xMin || 1)) * PLOT_W;
      const y = (t: number) => M.top + (1 - (t - yMin) / (yMax - yMin || 1)) * PLOT_H;

      // Grid horizontal (5 ticks)
      const stepY = niceStep(yMax - yMin, 5);
      const startY = Math.ceil(yMin / stepY) * stepY;
      const yTicks: number[] = [];
      for (let v = startY; v <= yMax; v += stepY) yTicks.push(v);

      for (const v of yTicks) {
        const yy = y(v);
        svg.appendChild(el('line', {
          x1: M.left, x2: M.left + PLOT_W, y1: yy, y2: yy,
          class: v === 0 ? 'grid-zero' : 'grid-line',
        }));
        svg.appendChild(el('text', {
          x: M.left - 10, y: yy + 4,
          class: 'ax-label ax-y',
          'text-anchor': 'end',
        }, fmtEur(v)));
      }

      // X ticks
      const paso = xMax <= 3 ? 0.5 : 1;
      for (let t = 0; t <= xMax + 1e-6; t += paso) {
        const xx = x(t);
        svg.appendChild(el('line', {
          x1: xx, x2: xx, y1: M.top, y2: M.top + PLOT_H,
          class: 'grid-vert',
        }));
        svg.appendChild(el('text', {
          x: xx, y: M.top + PLOT_H + 22,
          class: 'ax-label ax-x',
          'text-anchor': 'middle',
        }, t % 1 === 0 ? `${t} año${t === 1 ? '' : 's'}` : `${t.toFixed(1)}`));
      }

      // Ejes
      svg.appendChild(el('line', {
        x1: M.left, x2: M.left, y1: M.top, y2: M.top + PLOT_H, class: 'ax-line',
      }));
      svg.appendChild(el('line', {
        x1: M.left, x2: M.left + PLOT_W, y1: M.top + PLOT_H, y2: M.top + PLOT_H, class: 'ax-line',
      }));

      const bandPath = (pts: CurvaData['puntos']) => {
        const top = pts.map((p, i) =>
          `${i === 0 ? 'M' : 'L'} ${x(p.anio).toFixed(1)} ${y(p.tco_max).toFixed(1)}`,
        ).join(' ');
        const bot = [...pts].reverse().map((p) =>
          `L ${x(p.anio).toFixed(1)} ${y(p.tco_min).toFixed(1)}`,
        ).join(' ');
        return `${top} ${bot} Z`;
      };

      const linePath = (pts: CurvaData['puntos']) =>
        pts.map((p, i) =>
          `${i === 0 ? 'M' : 'L'} ${x(p.anio).toFixed(1)} ${y(p.tco).toFixed(1)}`,
        ).join(' ');

      // ── Render en 4 capas ──
      // 1) banda del focus (fondo)
      // 2) líneas no-focus (dim) — color por slot, sólido BEV / discontinuo ICE
      // 3) línea focus (destacada, mismo color por slot)
      // 4) punto final de CADA curva (facilita identificación)

      const focusCurva = curvas.find((c) => c.isFocus);

      // 0) Área con gradient bajo la curva focus — capa más profunda.
      //    Path cerrado: de p0 bajando al eje X, siguiendo los puntos, y
      //    cerrando al borde derecho en y=baseline. Sólo para el focus para
      //    no ensuciar visualmente cuando hay N coches.
      if (focusCurva) {
        const pts = focusCurva.puntos;
        const baseline = M.top + PLOT_H;
        const areaTop = pts
          .map((p, i) => `${i === 0 ? 'M' : 'L'} ${x(p.anio).toFixed(1)} ${y(p.tco).toFixed(1)}`)
          .join(' ');
        const lastX = x(pts[pts.length - 1].anio).toFixed(1);
        const firstX = x(pts[0].anio).toFixed(1);
        const areaPath = `${areaTop} L ${lastX} ${baseline} L ${firstX} ${baseline} Z`;
        svg.appendChild(el('path', {
          d: areaPath,
          class: 'curve-area',
          fill: 'url(#tco-grad-focus)',
          stroke: 'none',
        }));
      }

      // 1) Banda solo para el focus (ruido visual controlado).
      if (focusCurva && focusCurva.margen > 0) {
        svg.appendChild(el('path', {
          d: bandPath(focusCurva.puntos),
          class: 'band',
          fill: focusCurva.color,
          'fill-opacity': '0.10',
          stroke: focusCurva.color,
          'stroke-opacity': '0.32',
          'stroke-width': '0.75',
          'stroke-dasharray': '2 3',
        }));
      }

      // 2) Líneas no-focus dim.
      for (const c of curvas) {
        if (c.isFocus) continue;
        const attrs: Record<string, string | number> = {
          d: linePath(c.puntos),
          class: `curve curve-dim curve-${c.tren.toLowerCase()}`,
          stroke: c.color,
          fill: 'none',
          'data-tren': c.tren,
          'data-slug': c.slug,
          tabindex: 0,
          role: 'button',
          'aria-label': `${c.name} — clic para ver desglose`,
        };
        if (c.tren === 'ICE') attrs['stroke-dasharray'] = '6 4';
        svg.appendChild(el('path', attrs));
      }

      // 3) Focus encima, destacado. Primera renderización → animación de
      //    "dibujado" con stroke-dasharray (solo BEV, porque ICE usa dashes
      //    permanentes para su semántica visual).
      if (focusCurva) {
        const shouldAnimate = chartFirstRender && focusCurva.tren === 'BEV';
        const animClass = shouldAnimate ? ' curve-anim' : '';
        const attrs: Record<string, string | number> = {
          d: linePath(focusCurva.puntos),
          class: `curve curve-focus curve-${focusCurva.tren.toLowerCase()}${animClass}`,
          stroke: focusCurva.color,
          fill: 'none',
          'data-tren': focusCurva.tren,
          'data-slug': focusCurva.slug,
        };
        if (focusCurva.tren === 'ICE') attrs['stroke-dasharray'] = '6 4';
        svg.appendChild(el('path', attrs));
      }

      // 4) Puntos finales de todas las curvas (ayuda a identificar cada línea
      //    por su color al llegar al borde derecho).
      for (const c of curvas) {
        const last = c.puntos[c.puntos.length - 1];
        svg.appendChild(el('circle', {
          cx: x(last.anio),
          cy: y(last.tco),
          r: c.isFocus ? 4.5 : 3,
          fill: c.color,
          stroke: 'var(--card-bg)',
          'stroke-width': 1.5,
          'data-tren': c.tren,
          'data-slug': c.slug,
        }));
      }

      // 5) Break-even(s). En modo 'listas' habrá como mucho uno (BEV más
      //    barato ↔ ICE más barato). En modo 'pares', uno por pareja
      //    posicional cuyo cruce ocurra dentro del horizonte. Las pills
      //    se apilan en filas para no superponerse cuando hay varias.
      beList.forEach((breakeven, i) => {
        if (!breakeven || breakeven.anio < 0 || breakeven.anio > xMax + 1e-6) return;
        const bx = x(breakeven.anio);
        svg.appendChild(el('line', {
          x1: bx, x2: bx, y1: M.top, y2: M.top + PLOT_H,
          class: 'be-line',
        }));

        // Círculo pulsante sobre el eje X — ancla visual del cruce.
        // Dos círculos: uno estático (fondo amarillo) y otro con animación
        // de halo que se expande. Sólo para el primer break-even en listas;
        // en pares lo añadimos también pero sin halo para no ser ruidoso.
        const beaconCy = M.top + PLOT_H;
        if (i === 0 || beList.length === 1) {
          svg.appendChild(el('circle', {
            cx: bx, cy: beaconCy, r: 7,
            class: 'be-beacon-halo',
            fill: 'var(--yellow)',
            'fill-opacity': '0.35',
          }));
        }
        svg.appendChild(el('circle', {
          cx: bx, cy: beaconCy, r: 4,
          class: 'be-beacon',
          fill: 'var(--yellow)',
          stroke: 'var(--card-bg, #fff)',
          'stroke-width': '1.5',
        }));

        const label = breakeven.rentableDesdeInicio
          ? (beList.length > 1 ? `P${i + 1} · ventaja día 1` : 'Ventaja BEV desde el día 1')
          : breakeven.anio < 1
            ? `${beList.length > 1 ? `P${i + 1} · ` : 'Break-even · '}${(breakeven.anio * 12).toFixed(0)} m`
            : `${beList.length > 1 ? `P${i + 1} · ` : 'Break-even · '}${breakeven.anio.toFixed(breakeven.anio % 1 === 0 ? 0 : 1)} a`;

        // Pill en fila apilada según índice, para evitar solapes con N>1.
        const approxW = 9 + label.length * 6.2;
        const pillY = M.top + 4 + i * 22;
        const pillX = Math.max(
          M.left + 4,
          Math.min(M.left + PLOT_W - approxW - 4, bx - approxW / 2),
        );
        svg.appendChild(el('rect', {
          x: pillX, y: pillY, width: approxW, height: 20, rx: 10, ry: 10,
          class: 'be-pill',
        }));
        svg.appendChild(el('text', {
          x: pillX + approxW / 2, y: pillY + 14,
          class: 'be-label',
          'text-anchor': 'middle',
        }, label));
      });

      // Overlay invisible para capturar hover/mousemove sobre todo el área
      // del plot. Se dibuja al final (última capa) para que reciba los
      // eventos por encima de curvas y grid.
      const overlay = el('rect', {
        x: M.left, y: M.top, width: PLOT_W, height: PLOT_H,
        fill: 'transparent', class: 'chart-overlay',
        'aria-hidden': 'true',
      });
      svg.appendChild(overlay);

      // Publica el estado del gráfico para el handler de tooltip.
      chartStateRef = {
        curvas,
        xMin, xMax,
        plotLeft: M.left, plotTop: M.top, plotW: PLOT_W, plotH: PLOT_H,
        xFn: x, yFn: y,
      };

      // Tabla sr-only (accesibilidad): valores anuales del focus.
      if (focusCurva) {
        const pts = focusCurva.puntos.filter((p) => p.anio % 1 === 0);
        tbl.innerHTML =
          `<caption>Coste acumulado ${focusCurva.name} (€)</caption>` +
          '<thead><tr><th>Año</th><th>TCO</th></tr></thead>' +
          '<tbody>' +
          pts.map((p) => `<tr><td>${p.anio}</td><td>${Math.round(p.tco)}</td></tr>`).join('') +
          '</tbody>';
      } else {
        tbl.innerHTML = '';
      }

      // ── Leyenda dinámica: un item por coche + tren. Clickable para cambiar
      //    foco. El swatch tiene el color del coche + forma según el tren
      //    (sólido = BEV, discontinuo = ICE). Coincide con lo pintado en el
      //    gráfico, así no hay ambigüedad aunque haya 4 BEVs seleccionados.
      const legend = $('chart-legend');
      legend.innerHTML = '';

      for (const c of curvas) {
        const item = document.createElement('button');
        item.type = 'button';
        item.className = `lg-item lg-${c.tren.toLowerCase()}${c.isFocus ? ' lg-focus' : ''}`;
        item.setAttribute('data-tren', c.tren);
        item.setAttribute('data-slug', c.slug);
        item.title = `${c.tren === 'BEV' ? 'Eléctrico' : 'Combustión'} · clic para ver desglose`;

        const swatch = document.createElement('span');
        swatch.className = 'lg-swatch';
        // Sólido para BEV, patrón repetitivo para ICE. Mismo color por slot.
        if (c.tren === 'BEV') {
          swatch.style.background = c.color;
        } else {
          swatch.style.background =
            `repeating-linear-gradient(to right, ${c.color} 0 6px, transparent 6px 10px)`;
        }
        item.appendChild(swatch);

        const label = document.createElement('span');
        label.className = 'lg-label';
        label.textContent = c.name;
        item.appendChild(label);

        if (c.isFocus) {
          const tag = document.createElement('span');
          tag.className = 'lg-tag';
          tag.textContent = 'en foco';
          item.appendChild(tag);
        }

        item.addEventListener('click', () => {
          state.focus = { tren: c.tren, slug: c.slug };
          recalc();
        });

        legend.appendChild(item);
      }

      // Banda de incertidumbre en la leyenda, solo si el focus tiene margen.
      if (focusCurva && focusCurva.margen > 0) {
        const band = document.createElement('span');
        band.className = 'lg-item lg-band';
        band.innerHTML =
          `<span class="lg-swatch" style="background:${focusCurva.color};opacity:.25;border:1px dashed ${focusCurva.color}"></span>` +
          ` Banda ±${Math.round(focusCurva.margen * 100)} % (${focusCurva.name})`;
        legend.appendChild(band);
      }

      // Primera render completada.
      chartFirstRender = false;
    }

    // Helper global: rango bajo el TCO grande.
    const rangoTxt = (min: number, max: number, margen: number) => {
      if (margen <= 0) return 'Confianza alta · sin margen';
      return `entre ${eur(min)} – ${eur(max)} € · ±${Math.round(margen * 100)} %`;
    };
    const confDot = (id: string, conf: string | undefined) => {
      const elNode = $(id);
      if (!elNode) return;
      const c = conf || 'alta';
      elNode.className = `conf-dot conf-${c}`;
      elNode.title =
        c === 'alta'
          ? 'Confianza alta (±0 %)'
          : c === 'media'
            ? 'Confianza media (±8 %)'
            : 'Confianza baja (±15 %)';
    };

    function recalc() {
      // 1) Validar focus: si el coche focus ya no está seleccionado,
      //    caer al primer BEV (o primer ICE) disponible.
      if (
        state.focus.tren === 'BEV' &&
        !state.bevSlugs.includes(state.focus.slug)
      ) {
        if (state.bevSlugs.length) {
          state.focus = { tren: 'BEV', slug: state.bevSlugs[0] };
        } else if (state.iceSlugs.length) {
          state.focus = { tren: 'ICE', slug: state.iceSlugs[0] };
        }
      } else if (
        state.focus.tren === 'ICE' &&
        !state.iceSlugs.includes(state.focus.slug)
      ) {
        if (state.iceSlugs.length) {
          state.focus = { tren: 'ICE', slug: state.iceSlugs[0] };
        } else if (state.bevSlugs.length) {
          state.focus = { tren: 'BEV', slug: state.bevSlugs[0] };
        }
      }

      const overrides = {
        km_anual: state.km,
        horizonte_anios: state.horizonte,
        precio_kwh_eur: kwhEfectivo(),
        precio_litro_eur: state.litro,
      };

      // 2) Calcular TCO individual y curvas para cada coche seleccionado.
      type Resolved = {
        tren: 'BEV' | 'ICE';
        slug: string;
        meta: any;
        input: any;
        tco: any;
      };

      const resolvedBev: Resolved[] = state.bevSlugs
        .map((s) => {
          const r = getCocheInput('BEV', s);
          if (!r) return null;
          const tco = calcularTCO(r.input, overrides);
          return { tren: 'BEV' as const, slug: s, meta: r.meta, input: r.input, tco };
        })
        .filter((x): x is Resolved => !!x);

      const resolvedIce: Resolved[] = state.iceSlugs
        .map((s) => {
          const r = getCocheInput('ICE', s);
          if (!r) return null;
          const tco = calcularTCO(r.input, overrides);
          return { tren: 'ICE' as const, slug: s, meta: r.meta, input: r.input, tco };
        })
        .filter((x): x is Resolved => !!x);

      // 3) Construir curvas para el gráfico (una por coche, color por slot).
      //
      // En modo 'listas': BEV y ICE usan slots independientes, cada tren con
      //   su propia escala de colores (BEV #0..#3 y ICE #0..#3).
      // En modo 'pares': BEV[i] y ICE[i] comparten el mismo slot (mismo
      //   color), así la pareja se identifica por color + forma (BEV sólido,
      //   ICE discontinuo). El emparejamiento es posicional.
      const curvas: CurvaData[] = [];
      resolvedBev.forEach((r, idx) => {
        const c = curvaUnTren(r.input, overrides, {
          horizonte_max: state.horizonte,
          granularidad_anios: 0.25,
        });
        curvas.push({
          tren: 'BEV',
          slug: r.slug,
          name: r.meta.name,
          color: colorSlot(idx),
          puntos: c.puntos,
          margen: c.margen,
          isFocus: isFocus('BEV', r.slug),
        });
      });
      resolvedIce.forEach((r, idx) => {
        const c = curvaUnTren(r.input, overrides, {
          horizonte_max: state.horizonte,
          granularidad_anios: 0.25,
        });
        curvas.push({
          tren: 'ICE',
          slug: r.slug,
          name: r.meta.name,
          color: colorSlot(idx),
          puntos: c.puntos,
          margen: c.margen,
          isFocus: isFocus('ICE', r.slug),
        });
      });

      // 4) Lede editorial: cheapest BEV vs cheapest ICE.
      const cheapestBev = resolvedBev.length
        ? resolvedBev.reduce((a, b) =>
            a.tco.tco_total_eur <= b.tco.tco_total_eur ? a : b,
          )
        : null;
      const cheapestIce = resolvedIce.length
        ? resolvedIce.reduce((a, b) =>
            a.tco.tco_total_eur <= b.tco.tco_total_eur ? a : b,
          )
        : null;

      // Lede multi-coche: en lugar de hablar sólo del más barato, narra el
      // ranking de cada tren (top-3) y cuantifica el delta BEV↔ICE contra
      // el coche rival más caro (que es el que importa cuando decides si el
      // eléctrico "gana" al peor escenario de combustión).
      const topBev = [...resolvedBev].sort(
        (a, b) => a.tco.tco_total_eur - b.tco.tco_total_eur,
      );
      const topIce = [...resolvedIce].sort(
        (a, b) => a.tco.tco_total_eur - b.tco.tco_total_eur,
      );
      const fmtRanking = (items: Resolved[]) =>
        items
          .slice(0, 3)
          .map(
            (r, i) =>
              `${i + 1}. <strong>${r.meta.name}</strong> ` +
              `(${eur(r.tco.tco_total_eur)} €)`,
          )
          .join(' · ');

      if (state.modo === 'pares' && resolvedBev.length && resolvedIce.length) {
        // Modo pares: narrar cada pareja posicional (BEV[i] ↔ ICE[i]).
        const pairs: Array<{
          bev: Resolved;
          ice: Resolved;
          diff: number;
          pct: number;
        }> = [];
        const n = Math.min(resolvedBev.length, resolvedIce.length);
        for (let i = 0; i < n; i++) {
          const bev = resolvedBev[i];
          const ice = resolvedIce[i];
          const diff = ice.tco.tco_total_eur - bev.tco.tco_total_eur;
          const pct = ice.tco.tco_total_eur > 0
            ? Math.abs(diff) / ice.tco.tco_total_eur * 100
            : 0;
          pairs.push({ bev, ice, diff, pct });
        }
        const intro =
          `A ${state.horizonte} años y ${eur(state.km)} km/año, por parejas:`;
        const items = pairs.map((p, i) => {
          const sign = p.diff >= 0 ? 'ahorra' : 'sobrecuesta';
          return `<span class="lede-ranking">` +
            `<span class="lede-ranking-label">Pareja ${i + 1}:</span> ` +
            `<strong>${p.bev.meta.name}</strong> vs ` +
            `<strong>${p.ice.meta.name}</strong> — el BEV ${sign} ` +
            `<strong>${eur(Math.abs(p.diff))} €</strong> ` +
            `(${p.pct.toFixed(1)} %)` +
            `</span>`;
        });
        const leftover = Math.abs(resolvedBev.length - resolvedIce.length);
        const tail = leftover > 0
          ? `<span class="lede-ranking lede-ranking-muted">+${leftover} coche(s) sin pareja asignada</span>`
          : '';
        $('lede').innerHTML = [intro, ...items, tail].filter(Boolean).join(' ');
      } else if (cheapestBev && cheapestIce) {
        const diff = cheapestIce.tco.tco_total_eur - cheapestBev.tco.tco_total_eur;
        const sign = diff >= 0 ? 'ahorra' : 'sobrecuesta';
        const abs = Math.abs(diff);
        const pct =
          cheapestIce.tco.tco_total_eur > 0
            ? (abs / cheapestIce.tco.tco_total_eur) * 100
            : 0;
        const parts: string[] = [
          `A ${state.horizonte} años y ${eur(state.km)} km/año, el eléctrico ` +
            `más barato ${sign} <strong>${eur(abs)} €</strong> ` +
            `(${pct.toFixed(1)} %) frente al combustión más barato.`,
          `<span class="lede-ranking"><span class="lede-ranking-label">Eléctricos:</span> ${fmtRanking(topBev)}${resolvedBev.length > 3 ? ` · +${resolvedBev.length - 3}` : ''}</span>`,
          `<span class="lede-ranking"><span class="lede-ranking-label">Combustión:</span> ${fmtRanking(topIce)}${resolvedIce.length > 3 ? ` · +${resolvedIce.length - 3}` : ''}</span>`,
        ];
        $('lede').innerHTML = parts.join(' ');
      } else if (cheapestBev) {
        $('lede').innerHTML =
          `A ${state.horizonte} años y ${eur(state.km)} km/año, el ` +
          `<strong>${cheapestBev.meta.name}</strong> cuesta ` +
          `<strong>${eur(cheapestBev.tco.tco_total_eur)} €</strong>. ` +
          `Añade un coche de combustión para comparar.`;
      } else if (cheapestIce) {
        $('lede').innerHTML =
          `A ${state.horizonte} años y ${eur(state.km)} km/año, el ` +
          `<strong>${cheapestIce.meta.name}</strong> cuesta ` +
          `<strong>${eur(cheapestIce.tco.tco_total_eur)} €</strong>. ` +
          `Añade un eléctrico para comparar.`;
      } else {
        $('lede').innerHTML = 'Selecciona al menos un coche para empezar.';
      }

      // Actualiza subtítulo y nombre del summary del details.
      const tablaSub = $('tco-table-sub');
      if (tablaSub) {
        tablaSub.textContent =
          `${resolvedBev.length + resolvedIce.length} coches · horizonte ${state.horizonte} años · ` +
          `${eur(state.km)} km/año. Clic en una cabecera para reordenar, ` +
          `clic en una fila para verla en detalle.`;
      }
      $('lede').classList.remove('lede-error');

      // 5) Focus card breakdown.
      const focusResolved =
        [...resolvedBev, ...resolvedIce].find((r) =>
          isFocus(r.tren, r.slug),
        ) ?? null;

      const focusCard = $('tco-focus');
      const focusSummaryName = document.getElementById('focus-summary-name');
      if (focusResolved) {
        focusCard.dataset.tren = focusResolved.tren;
        $('focus-tren').textContent =
          focusResolved.tren === 'BEV' ? 'Eléctrico · en foco' : 'Combustión · en foco';
        $('focus-name').textContent = focusResolved.meta.name;
        if (focusSummaryName) focusSummaryName.textContent = focusResolved.meta.name;
        $('focus-tco').textContent = eur(focusResolved.tco.tco_total_eur);
        $('focus-range').textContent = rangoTxt(
          focusResolved.tco.tco_total_min_eur,
          focusResolved.tco.tco_total_max_eur,
          focusResolved.tco.margen_pct,
        );
        $('focus-kmkm').textContent = eur2(focusResolved.tco.tco_por_km_eur);
        $('focus-horizonte').textContent = String(state.horizonte);
        $('focus-dep').textContent = eur(focusResolved.tco.depreciacion_eur);
        $('focus-ene').textContent = eur(focusResolved.tco.energia_eur);
        $('focus-man').textContent = eur(focusResolved.tco.mantenimiento_eur);
        $('focus-seg').textContent = eur(focusResolved.tco.seguro_eur);
        $('focus-imp').textContent = eur(focusResolved.tco.impuestos_eur);
        confDot('focus-dep-conf', focusResolved.input.confianza_depreciacion);
        confDot('focus-ene-conf', focusResolved.input.confianza_consumo);
        confDot('focus-man-conf', focusResolved.input.confianza_mantenimiento);
        confDot('focus-seg-conf', focusResolved.input.confianza_seguro);
        // Fila de ayudas solo si corresponde.
        const ayuDt = $('focus-ayu-dt');
        const ayuDd = $('focus-ayu-dd');
        if (focusResolved.tren === 'BEV' && focusResolved.tco.ayudas_eur > 0) {
          ayuDt.removeAttribute('hidden');
          ayuDd.removeAttribute('hidden');
          $('focus-ayu').textContent = eur(focusResolved.tco.ayudas_eur);
        } else {
          ayuDt.setAttribute('hidden', '');
          ayuDd.setAttribute('hidden', '');
        }
      }

      // 6) Break-even. En modo 'listas' calculamos solo BEV más barato ↔
      //    ICE más barato (el par que narra el lede). En modo 'pares'
      //    calculamos un break-even por cada pareja posicional.
      const breakevens: BreakevenInfo[] = [];
      const calcBE = (bev: Resolved, ice: Resolved) => {
        const bevInput = { ...bev.input, tren: 'BEV' as const };
        const iceInput = { ...ice.input, tren: 'ICE' as const };
        const cv = curvaTCO(bevInput, iceInput, overrides, {
          horizonte_max: state.horizonte,
          granularidad_anios: 0.25,
        });
        if (cv.breakeven_anio !== null && cv.breakeven_anio <= state.horizonte) {
          breakevens.push({
            anio: cv.breakeven_anio,
            bevName: bev.meta.name,
            iceName: ice.meta.name,
            rentableDesdeInicio: cv.rentable_desde_inicio,
          });
        }
      };

      if (state.modo === 'pares' && resolvedBev.length && resolvedIce.length) {
        const n = Math.min(resolvedBev.length, resolvedIce.length);
        for (let i = 0; i < n; i++) calcBE(resolvedBev[i], resolvedIce[i]);
      } else if (cheapestBev && cheapestIce) {
        calcBE(cheapestBev, cheapestIce);
      }

      // 6.5) Actualizar KPI hero (mejor TCO, ahorro, break-even).
      updateKpiHero([...resolvedBev, ...resolvedIce], breakevens);

      // 6.6) Pair-switch visibility: se muestra sólo cuando tiene sentido
      //      comparar 1↔1 (mismo número de BEV que ICE, y al menos 2).
      updatePairSwitch(resolvedBev.length, resolvedIce.length);

      // 7) Re-pintar chips (conteo + etiquetas).
      renderChips();

      // 8) Tabla comparativa (resultado principal).
      renderTable([...resolvedBev, ...resolvedIce], curvas);

      // 9) Gráfico
      renderChart(curvas, breakevens);

      writeUrl();
    }

    // ── KPI hero: los 3 números que el usuario escanea primero ─────────
    // Mejor TCO · Ahorro vs peor · Break-even (si existe).
    // Usamos nombre corto (marca + modelo) para que no desborde la tarjeta.
    function shortName(meta: any): string {
      if (!meta) return '—';
      if (meta.marca && meta.modelo) return `${meta.marca} ${meta.modelo}`;
      // Fallback: primeras 2 palabras del name.
      const parts = (meta.name ?? '').split(/\s+/);
      return parts.slice(0, 2).join(' ') || '—';
    }

    function updateKpiHero(
      all: Array<{ tren: 'BEV' | 'ICE'; slug: string; meta: any; tco: any }>,
      breakevens: BreakevenInfo[],
    ) {
      const winnerNameEl = $('kpi-winner-name');
      const winnerTcoEl = $('kpi-winner-tco');
      const winnerMetaEl = $('kpi-winner-meta');
      const savNameEl = $('kpi-savings-name');
      const savEurEl = $('kpi-savings-eur');
      const savMetaEl = $('kpi-savings-meta');
      const beNameEl = $('kpi-breakeven-name');
      const beValEl = $('kpi-breakeven-val');
      const beUnitEl = $('kpi-breakeven-unit');
      const beMetaEl = $('kpi-breakeven-meta');
      const winnerCard = $('kpi-winner');
      const savCard = $('kpi-savings');
      const beCard = $('kpi-breakeven');

      if (!all.length) {
        winnerNameEl.textContent = '—';
        winnerTcoEl.textContent = '—';
        winnerMetaEl.textContent = 'Selecciona coches arriba';
        if (savNameEl) savNameEl.textContent = '—';
        savEurEl.textContent = '—';
        savMetaEl.textContent = '—';
        if (beNameEl) beNameEl.textContent = '—';
        beValEl.textContent = '—';
        beMetaEl.textContent = '—';
        winnerCard.dataset.tren = '';
        return;
      }

      // 1) Mejor TCO del conjunto.
      const sorted = [...all].sort(
        (a, b) => a.tco.tco_total_eur - b.tco.tco_total_eur,
      );
      const winner = sorted[0];
      winnerCard.dataset.tren = winner.tren;
      winnerNameEl.textContent = shortName(winner.meta);
      winnerNameEl.title = winner.meta.name;
      animateNumber(winnerTcoEl, winner.tco.tco_total_eur, eur);
      winnerMetaEl.textContent =
        `${winner.tren === 'BEV' ? 'Eléctrico' : 'Combustión'} · ` +
        `${eur2(winner.tco.tco_por_km_eur)} €/km · ${state.horizonte} años`;

      // 2) Ahorro frente al peor del mismo ranking.
      if (sorted.length >= 2) {
        const worst = sorted[sorted.length - 1];
        const diff = worst.tco.tco_total_eur - winner.tco.tco_total_eur;
        const pct = worst.tco.tco_total_eur > 0
          ? (diff / worst.tco.tco_total_eur) * 100
          : 0;
        if (savNameEl) {
          savNameEl.textContent = shortName(winner.meta);
          savNameEl.title = winner.meta.name;
        }
        animateNumber(savEurEl, diff, eur);
        savMetaEl.innerHTML =
          `<strong>${pct.toFixed(1).replace('.', ',')} %</strong> menos que <em>${shortName(worst.meta)}</em>`;
        savCard.dataset.state = 'ok';
      } else {
        if (savNameEl) savNameEl.textContent = '—';
        savEurEl.textContent = '—';
        savMetaEl.textContent = 'Añade un segundo coche para ver el ahorro';
        savCard.dataset.state = 'empty';
      }

      // 3) Break-even.
      //    Regla de coherencia: sólo afirmamos "desde el día 1" si el BEV más
      //    barato del conjunto es de verdad el ganador global. Si el ganador
      //    global es ICE no podemos decir que el eléctrico "sea más barato
      //    desde el día 1" — sería falso y rompería con el KPI de al lado.
      const cheapestBev = sorted.find((x) => x.tren === 'BEV') ?? null;
      const cheapestIce = sorted.find((x) => x.tren === 'ICE') ?? null;
      const bevGlobalWin =
        !!cheapestBev &&
        !!cheapestIce &&
        cheapestBev.tco.tco_total_eur < cheapestIce.tco.tco_total_eur;

      if (breakevens.length) {
        const be = [...breakevens].sort((a, b) => a.anio - b.anio)[0];
        if (be.rentableDesdeInicio && bevGlobalWin) {
          if (beNameEl) {
            beNameEl.textContent = shortName(cheapestBev!.meta);
            beNameEl.title = cheapestBev!.meta.name;
          }
          beValEl.textContent = '0';
          beUnitEl.textContent = 'años';
          beMetaEl.innerHTML =
            `<em>${shortName(cheapestBev!.meta)}</em> ya es más barato desde el día 1`;
          beCard.dataset.state = 'ok';
        } else if (be.rentableDesdeInicio && !bevGlobalWin) {
          // El BEV gana a su pareja pero otro ICE del conjunto está por delante.
          if (beNameEl) {
            beNameEl.textContent = shortName(cheapestIce!.meta);
            beNameEl.title = cheapestIce!.meta.name;
          }
          beValEl.textContent = '—';
          beUnitEl.textContent = '';
          beMetaEl.innerHTML =
            `<em>${shortName(cheapestIce!.meta)}</em> queda por delante en el conjunto`;
          beCard.dataset.state = 'empty';
        } else {
          const anios = be.anio;
          if (beNameEl) {
            beNameEl.textContent = shortName({ name: be.bevName });
            beNameEl.title = be.bevName;
          }
          beValEl.textContent = anios % 1 === 0
            ? String(anios)
            : anios.toFixed(1).replace('.', ',');
          beUnitEl.textContent = anios === 1 ? 'año' : 'años';
          beMetaEl.innerHTML =
            `pasa a costar menos que <em>${shortName({ name: be.iceName })}</em>`;
          beCard.dataset.state = 'ok';
        }
      } else {
        // Sin cruce en el horizonte — distinguimos quién manda.
        if (bevGlobalWin) {
          if (beNameEl) {
            beNameEl.textContent = shortName(cheapestBev!.meta);
            beNameEl.title = cheapestBev!.meta.name;
          }
          beValEl.textContent = '0';
          beUnitEl.textContent = 'años';
          beMetaEl.innerHTML =
            `<em>${shortName(cheapestBev!.meta)}</em> lidera sin necesidad de cruce`;
          beCard.dataset.state = 'ok';
        } else if (cheapestIce) {
          if (beNameEl) {
            beNameEl.textContent = shortName(cheapestIce.meta);
            beNameEl.title = cheapestIce.meta.name;
          }
          beValEl.textContent = '—';
          beUnitEl.textContent = '';
          beMetaEl.innerHTML =
            `<em>${shortName(cheapestIce.meta)}</em> mantiene la ventaja`;
          beCard.dataset.state = 'empty';
        } else {
          if (beNameEl) beNameEl.textContent = '—';
          beValEl.textContent = '—';
          beUnitEl.textContent = '';
          beMetaEl.textContent = 'Sin cruce en el horizonte elegido';
          beCard.dataset.state = 'empty';
        }
      }
    }

    // Pequeño tween numérico para que el KPI se sienta vivo sin ser ruidoso.
    function animateNumber(
      target: HTMLElement,
      to: number,
      fmt: (n: number) => string,
    ) {
      // Si había un RAF anterior en curso, cancélalo para evitar que dos
      // animaciones compitan por textContent y lo dejen a medias.
      const prevRaf = Number(target.dataset.rafId ?? '0');
      if (prevRaf) {
        cancelAnimationFrame(prevRaf);
        target.dataset.rafId = '0';
      }

      // prev puede venir como '' o como el placeholder '—' si el markup no
      // lleva dataset.v. Normalizamos a 0 en ese caso.
      const raw = target.dataset.v;
      const prev = raw == null || raw === '' ? 0 : Number(raw);
      const prevNum = Number.isFinite(prev) ? prev : 0;

      target.dataset.v = String(to);

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced || Math.abs(to - prevNum) < 1) {
        target.textContent = fmt(to);
        return;
      }

      const start = performance.now();
      const dur = 420;
      const step = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        const ease = 1 - Math.pow(1 - t, 3);
        if (t < 1) {
          target.textContent = fmt(prevNum + (to - prevNum) * ease);
          target.dataset.rafId = String(requestAnimationFrame(step));
        } else {
          // Aseguramos que el estado final sea siempre exacto.
          target.textContent = fmt(to);
          target.dataset.rafId = '0';
        }
      };
      target.dataset.rafId = String(requestAnimationFrame(step));
    }

    // Pair-switch: visible sólo si counts BEV == ICE y >= 2.
    // Refleja state.modo en el checkbox sin tocar el legacy toggle.
    function updatePairSwitch(nBev: number, nIce: number) {
      const wrap = document.getElementById('pair-switch') as HTMLElement | null;
      const input = document.getElementById('pair-switch-input') as HTMLInputElement | null;
      if (!wrap || !input) return;
      if (nBev === nIce && nBev >= 2) {
        wrap.hidden = false;
        input.checked = state.modo === 'pares';
      } else {
        wrap.hidden = true;
        // Si salimos de la zona válida, forzamos listas (sin loops: comprobamos).
        if (state.modo === 'pares' && (nBev !== nIce || nBev < 2)) {
          state.modo = 'listas';
        }
      }
    }

    // ── Tabla comparativa (Fase B) ──────────────────────────────────────
    // Estado de ordenación persistente entre recalc(). Por defecto TCO asc.
    type TableSort = {
      key: 'name' | 'tco' | 'kmkm' | 'dep' | 'ene' | 'man' | 'seg' | 'imp' | 'ayu';
      dir: 'asc' | 'desc';
    };
    let tableSort: TableSort = { key: 'tco', dir: 'asc' };

    function renderTable(items: Array<{
      tren: 'BEV' | 'ICE';
      slug: string;
      meta: any;
      input: any;
      tco: any;
    }>, curvas: CurvaData[]) {
      const tbody = $('tco-table-body');
      const thead = document.querySelectorAll<HTMLTableCellElement>(
        '#tco-table thead th',
      );
      if (!tbody) return;

      // Mapa slug→color: el color lo decide el gráfico (por slot dentro del
      // tren). Aquí lo reutilizamos para que la fila casse visualmente con
      // la curva y el chip.
      const colorBySlug = new Map<string, string>();
      curvas.forEach((c) => {
        colorBySlug.set(`${c.tren}:${c.slug}`, c.color);
      });

      // Extraer valor por columna.
      const value = (r: typeof items[number], k: TableSort['key']) => {
        switch (k) {
          case 'name':
            return r.meta.name.toLowerCase();
          case 'tco':
            return r.tco.tco_total_eur;
          case 'kmkm':
            return r.tco.tco_por_km_eur;
          case 'dep':
            return r.tco.depreciacion_eur;
          case 'ene':
            return r.tco.energia_eur;
          case 'man':
            return r.tco.mantenimiento_eur;
          case 'seg':
            return r.tco.seguro_eur;
          case 'imp':
            return r.tco.impuestos_eur;
          case 'ayu':
            return r.tren === 'BEV' ? r.tco.ayudas_eur ?? 0 : 0;
        }
      };

      const sorted = [...items].sort((a, b) => {
        const va = value(a, tableSort.key);
        const vb = value(b, tableSort.key);
        if (va < vb) return tableSort.dir === 'asc' ? -1 : 1;
        if (va > vb) return tableSort.dir === 'asc' ? 1 : -1;
        return 0;
      });

      // Baseline para el delta de la columna TCO: el BEV más barato.
      const bevMin = items
        .filter((r) => r.tren === 'BEV')
        .reduce<number | null>(
          (m, r) => (m === null || r.tco.tco_total_eur < m ? r.tco.tco_total_eur : m),
          null,
        );

      // En pares mode, calcular el índice de pareja de cada coche por su
      // posición dentro de su tren (BEV[i] ↔ ICE[i]).
      const pairIdxFor = new Map<string, number>();
      if (state.modo === 'pares') {
        const bevOrder = state.bevSlugs;
        const iceOrder = state.iceSlugs;
        const n = Math.min(bevOrder.length, iceOrder.length);
        for (let i = 0; i < n; i++) {
          pairIdxFor.set(`BEV:${bevOrder[i]}`, i);
          pairIdxFor.set(`ICE:${iceOrder[i]}`, i);
        }
      }

      // Render filas.
      tbody.innerHTML = '';
      sorted.forEach((r) => {
        const key = `${r.tren}:${r.slug}`;
        const isF = isFocus(r.tren, r.slug);
        const color = colorBySlug.get(key) ?? 'var(--gray-400)';
        const tr = document.createElement('tr');
        tr.dataset.tren = r.tren;
        tr.dataset.slug = r.slug;
        if (isF) tr.classList.add('row-focus');
        tr.setAttribute('role', 'button');
        tr.setAttribute('tabindex', '0');
        tr.setAttribute(
          'aria-label',
          `${r.meta.name} — ${eur(r.tco.tco_total_eur)} euros · clic para ver desglose`,
        );

        // Columna 1: marcador de color + nombre + badge tren + badge pareja.
        const tdName = document.createElement('td');
        tdName.className = 'cell-name';
        const dot = document.createElement('span');
        dot.className = 'row-dot';
        dot.style.background =
          r.tren === 'BEV'
            ? color
            : `repeating-linear-gradient(to right, ${color} 0 6px, transparent 6px 10px)`;
        tdName.appendChild(dot);
        const nameSpan = document.createElement('span');
        nameSpan.className = 'row-name';
        nameSpan.textContent = r.meta.name;
        tdName.appendChild(nameSpan);
        const trenBadge = document.createElement('span');
        trenBadge.className = `row-tren row-tren-${r.tren.toLowerCase()}`;
        trenBadge.textContent = r.tren === 'BEV' ? 'BEV' : 'ICE';
        tdName.appendChild(trenBadge);
        const pIdx = pairIdxFor.get(key);
        if (state.modo === 'pares' && pIdx !== undefined) {
          const pairBadge = document.createElement('span');
          pairBadge.className = 'row-pair';
          pairBadge.textContent = `Pareja ${pIdx + 1}`;
          tdName.appendChild(pairBadge);
        }
        tr.appendChild(tdName);

        // Columna 2: TCO total + delta vs BEV más barato.
        const tdTco = document.createElement('td');
        tdTco.className = 'num cell-tco';
        const tcoMain = document.createElement('span');
        tcoMain.className = 'cell-tco-main';
        tcoMain.textContent = `${eur(r.tco.tco_total_eur)} €`;
        tdTco.appendChild(tcoMain);
        if (bevMin !== null) {
          const delta = r.tco.tco_total_eur - bevMin;
          if (Math.abs(delta) > 1) {
            const deltaSpan = document.createElement('span');
            deltaSpan.className = `cell-tco-delta ${delta >= 0 ? 'd-pos' : 'd-neg'}`;
            deltaSpan.textContent = `${delta >= 0 ? '+' : '−'}${eur(Math.abs(delta))} €`;
            tdTco.appendChild(deltaSpan);
          }
        }
        tr.appendChild(tdTco);

        // Resto de columnas numéricas.
        const numCells: Array<[string, number | null]> = [
          ['kmkm', r.tco.tco_por_km_eur],
          ['dep', r.tco.depreciacion_eur],
          ['ene', r.tco.energia_eur],
          ['man', r.tco.mantenimiento_eur],
          ['seg', r.tco.seguro_eur],
          ['imp', r.tco.impuestos_eur],
          ['ayu', r.tren === 'BEV' ? r.tco.ayudas_eur ?? 0 : null],
        ];
        numCells.forEach(([key, val]) => {
          const td = document.createElement('td');
          td.className = `num cell-${key}`;
          if (val === null) {
            td.textContent = '—';
            td.classList.add('cell-empty');
          } else if (key === 'kmkm') {
            td.textContent = `${eur2(val)} €`;
          } else if (key === 'ayu' && val === 0) {
            td.textContent = '—';
            td.classList.add('cell-empty');
          } else {
            td.textContent = `${key === 'ayu' ? '−' : ''}${eur(val)} €`;
          }
          tr.appendChild(td);
        });

        // Click o Enter sobre la fila: pasa a foco ese coche.
        const activate = () => {
          state.focus = { tren: r.tren, slug: r.slug };
          recalc();
        };
        tr.addEventListener('click', activate);
        tr.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            activate();
          }
        });

        tbody.appendChild(tr);
      });

      // Estado visual de ordenación en las cabeceras.
      thead.forEach((th) => {
        const k = th.dataset.sort as TableSort['key'] | undefined;
        if (!k) return;
        if (k === tableSort.key) {
          th.setAttribute('aria-sort', tableSort.dir === 'asc' ? 'ascending' : 'descending');
        } else {
          th.removeAttribute('aria-sort');
        }
      });
    }

    // Click en cabecera: cambia la clave de orden (o invierte dir si ya era esa).
    document.querySelectorAll<HTMLTableCellElement>('#tco-table thead th').forEach((th) => {
      const key = th.dataset.sort as TableSort['key'] | undefined;
      if (!key) return;
      th.setAttribute('tabindex', '0');
      th.setAttribute('role', 'button');
      const toggle = () => {
        if (tableSort.key === key) {
          tableSort.dir = tableSort.dir === 'asc' ? 'desc' : 'asc';
        } else {
          tableSort = { key, dir: key === 'name' ? 'asc' : 'asc' };
        }
        recalc();
      };
      th.addEventListener('click', toggle);
      th.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggle();
        }
      });
    });

    // ── Sprint 2 E2 paso 2B — Bindings chips + combobox + quick-starts ──

    // Renderiza los chips para ambos trenes a partir del state.
    function renderChips() {
      renderChipsFor('BEV');
      renderChipsFor('ICE');
      $('bev-count').textContent = `${state.bevSlugs.length} / ${MAX_POR_TREN}`;
      $('ice-count').textContent = `${state.iceSlugs.length} / ${MAX_POR_TREN}`;
      // Deshabilita el input del combobox si está lleno.
      ($('combo-bev') as HTMLInputElement).disabled = state.bevSlugs.length >= MAX_POR_TREN;
      ($('combo-ice') as HTMLInputElement).disabled = state.iceSlugs.length >= MAX_POR_TREN;
    }

    function renderChipsFor(tren: 'BEV' | 'ICE') {
      const container = $(tren === 'BEV' ? 'chips-bev' : 'chips-ice');
      const slugs = tren === 'BEV' ? state.bevSlugs : state.iceSlugs;
      container.innerHTML = '';
      slugs.forEach((slug, idx) => {
        const meta = getMeta(tren, slug);
        if (!meta) return;
        const color = colorSlot(idx);
        const chip = document.createElement('span');
        chip.className = `chip chip-${tren.toLowerCase()}`;
        chip.dataset.tren = tren;
        chip.dataset.slug = slug;
        chip.setAttribute('role', 'listitem');
        // Barrita de color a la izquierda: misma paleta que el gráfico. Sólido
        // para BEV, repite patrón para ICE (consistencia visual con las curvas).
        chip.style.borderLeft = `3px solid ${color}`;
        chip.style.paddingLeft = '0.5rem';
        if (tren === 'ICE') {
          chip.style.borderLeftStyle = 'dashed';
        }
        if (isFocus(tren, slug)) chip.classList.add('chip-focus');

        const nameBtn = document.createElement('button');
        nameBtn.type = 'button';
        nameBtn.className = 'chip-name';
        nameBtn.textContent = meta.name;
        nameBtn.title = 'Poner en foco';
        nameBtn.addEventListener('click', () => {
          state.focus = { tren, slug };
          recalc();
        });
        chip.appendChild(nameBtn);

        // Solo permitimos quitar si queda más de uno en este tren O
        // si aún queda alguno en el otro tren (nunca dejamos 0 coches).
        const totalSel = state.bevSlugs.length + state.iceSlugs.length;
        if (totalSel > 1) {
          const rm = document.createElement('button');
          rm.type = 'button';
          rm.className = 'chip-remove';
          rm.setAttribute('aria-label', `Quitar ${meta.name}`);
          rm.textContent = '×';
          rm.addEventListener('click', (e) => {
            e.stopPropagation();
            if (tren === 'BEV') {
              state.bevSlugs = state.bevSlugs.filter((s) => s !== slug);
            } else {
              state.iceSlugs = state.iceSlugs.filter((s) => s !== slug);
            }
            recalc();
          });
          chip.appendChild(rm);
        }
        container.appendChild(chip);
      });
    }

    // Combobox: filtrado por marca/modelo/variante, excluye ya seleccionados.
    function buildComboHandlers(tren: 'BEV' | 'ICE') {
      const input = $(tren === 'BEV' ? 'combo-bev' : 'combo-ice') as HTMLInputElement;
      const list = $(tren === 'BEV' ? 'suggest-bev' : 'suggest-ice') as HTMLUListElement;
      const fuente = tren === 'BEV' ? ALL_BEVS : ALL_ICES;

      const filtra = (q: string) => {
        const qq = q.trim().toLowerCase();
        const selected = tren === 'BEV' ? state.bevSlugs : state.iceSlugs;
        return fuente
          .filter((x) => !selected.includes(x.slug))
          .filter((x) => !qq || x.name.toLowerCase().includes(qq))
          .slice(0, 8);
      };

      const pinta = () => {
        const items = filtra(input.value);
        list.innerHTML = '';
        if (!items.length) {
          list.hidden = true;
          return;
        }
        for (const it of items) {
          const li = document.createElement('li');
          li.className = 'suggest-item';
          li.setAttribute('role', 'option');
          li.dataset.slug = it.slug;
          li.innerHTML =
            `<span class="suggest-name">${it.name}</span>` +
            (it.segmento ? `<span class="suggest-seg">${it.segmento}</span>` : '');
          li.addEventListener('mousedown', (e) => {
            e.preventDefault();
            addCoche(tren, it.slug);
            input.value = '';
            list.hidden = true;
          });
          list.appendChild(li);
        }
        list.hidden = false;
      };

      input.addEventListener('input', pinta);
      input.addEventListener('focus', pinta);
      input.addEventListener('blur', () => {
        // Delay para permitir el mousedown.
        setTimeout(() => { list.hidden = true; }, 150);
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          list.hidden = true;
          input.blur();
        } else if (e.key === 'Enter') {
          const first = list.querySelector<HTMLLIElement>('.suggest-item');
          if (first && first.dataset.slug) {
            e.preventDefault();
            addCoche(tren, first.dataset.slug);
            input.value = '';
            list.hidden = true;
          }
        }
      });
    }

    function addCoche(tren: 'BEV' | 'ICE', slug: string) {
      const arr = tren === 'BEV' ? state.bevSlugs : state.iceSlugs;
      if (arr.includes(slug)) return;
      if (arr.length >= MAX_POR_TREN) return;
      arr.push(slug);
      // Primer coche añadido de un tren vacío → lo ponemos en foco.
      if (arr.length === 1 && state.focus.tren !== tren) {
        state.focus = { tren, slug };
      }
      recalc();
    }

    buildComboHandlers('BEV');
    buildComboHandlers('ICE');

    // Quick-starts: sustituyen la selección completa por el par icónico.
    document.querySelectorAll<HTMLButtonElement>('.qs-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const bev = btn.dataset.bev ?? '';
        const ice = btn.dataset.ice ?? '';
        if (!bevSlugSet.has(bev) || !iceSlugSet.has(ice)) return;
        state.bevSlugs = [bev];
        state.iceSlugs = [ice];
        state.focus = { tren: 'BEV', slug: bev };
        recalc();
      });
    });

    // ── Escenarios editoriales (photo cards) + toast undo ──
    type EscenarioSnapshot = {
      bevSlugs: string[];
      iceSlugs: string[];
      focus: FocusKey;
    };
    let escenarioPrev: EscenarioSnapshot | null = null;
    let toastHideTimer: ReturnType<typeof setTimeout> | null = null;

    const showToast = (text: string, withUndo: boolean) => {
      const toast = document.getElementById('escenario-toast');
      const txt = document.getElementById('toast-text');
      const undo = document.getElementById('toast-undo');
      if (!toast || !txt || !undo) return;
      txt.textContent = text;
      if (withUndo) undo.removeAttribute('hidden');
      else undo.setAttribute('hidden', '');
      toast.removeAttribute('hidden');
      // Reflow + add is-visible for CSS transition.
      void toast.offsetWidth;
      toast.classList.add('is-visible');
      if (toastHideTimer) clearTimeout(toastHideTimer);
      toastHideTimer = setTimeout(() => {
        toast.classList.remove('is-visible');
        setTimeout(() => toast.setAttribute('hidden', ''), 300);
      }, 4000);
    };

    document.querySelectorAll<HTMLButtonElement>('.escenario-card').forEach((card) => {
      card.addEventListener('click', () => {
        const bev = card.dataset.bev ?? '';
        const ice = card.dataset.ice ?? '';
        if (!bevSlugSet.has(bev) || !iceSlugSet.has(ice)) return;
        // Snapshot previo para deshacer.
        escenarioPrev = {
          bevSlugs: [...state.bevSlugs],
          iceSlugs: [...state.iceSlugs],
          focus: { ...state.focus },
        };
        state.bevSlugs = [bev];
        state.iceSlugs = [ice];
        state.focus = { tren: 'BEV', slug: bev };
        state.modo = 'listas';
        // Feedback visual: pulso amarillo en la tarjeta.
        card.classList.remove('is-pulse');
        void card.offsetWidth;
        card.classList.add('is-pulse');
        // Scroll suave al resultado después de cargar.
        const title = card.querySelector('.escenario-title')?.textContent?.replace(/\s+/g, ' ').trim() ?? 'escenario';
        showToast(`Escenario cargado · ${title}`, true);
        recalc();
        // Delay para que la tabla ya esté renderizada.
        setTimeout(() => {
          const target = document.getElementById('h-resultado');
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 120);
      });
    });

    document.getElementById('toast-undo')?.addEventListener('click', () => {
      if (!escenarioPrev) return;
      state.bevSlugs = [...escenarioPrev.bevSlugs];
      state.iceSlugs = [...escenarioPrev.iceSlugs];
      state.focus = { ...escenarioPrev.focus };
      escenarioPrev = null;
      const toast = document.getElementById('escenario-toast');
      if (toast) {
        toast.classList.remove('is-visible');
        setTimeout(() => toast.setAttribute('hidden', ''), 200);
      }
      recalc();
    });

    // ── Pair-switch inline (reemplaza modo-toggle) ──
    document.getElementById('pair-switch-input')?.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      state.modo = checked ? 'pares' : 'listas';
      // Mantenemos el legacy modo-btn sync (aria-checked/is-active) para que
      // nada en el script antiguo se sienta incoherente si lo inspecciona.
      document.querySelectorAll<HTMLButtonElement>('.modo-btn').forEach((b) => {
        const isActive = b.dataset.modo === state.modo;
        b.classList.toggle('is-active', isActive);
        b.setAttribute('aria-checked', isActive ? 'true' : 'false');
      });
      recalc();
    });

    // Chart click → cambiar focus.
    $('tco-chart').addEventListener('click', (e) => {
      const target = e.target as Element;
      const path = target.closest('[data-tren][data-slug]') as HTMLElement | null;
      if (!path) return;
      const tren = path.dataset.tren as 'BEV' | 'ICE';
      const slug = path.dataset.slug as string;
      if (!tren || !slug) return;
      state.focus = { tren, slug };
      recalc();
    });

    // ── Tooltip del gráfico ──────────────────────────────────────────
    // Sobre el overlay (último layer del SVG) seguimos la posición del
    // ratón, interpolamos el TCO de cada curva en ese año, pintamos una
    // línea vertical con puntos por coche, y rellenamos el tooltip DOM.
    (function setupChartTooltip() {
      const chart = document.getElementById('tco-chart') as SVGSVGElement | null;
      const tooltip = document.getElementById('chart-tooltip') as HTMLElement | null;
      const tYear = document.getElementById('tt-year') as HTMLElement | null;
      const tList = document.getElementById('tt-list') as HTMLElement | null;
      const wrap = chart?.parentElement as HTMLElement | null;
      if (!chart || !tooltip || !tYear || !tList || !wrap) return;

      // Namespace SVG para el cursor (se limpia en cada mousemove).
      const SVGNS = 'http://www.w3.org/2000/svg';
      let cursorGroup: SVGGElement | null = null;

      const clearCursor = () => {
        if (cursorGroup && cursorGroup.parentNode) {
          cursorGroup.parentNode.removeChild(cursorGroup);
        }
        cursorGroup = null;
      };

      // Interpolación lineal de TCO en un año dado a partir de los puntos.
      const interp = (pts: Array<{ anio: number; tco: number }>, a: number) => {
        if (!pts.length) return null;
        if (a <= pts[0].anio) return pts[0].tco;
        if (a >= pts[pts.length - 1].anio) return pts[pts.length - 1].tco;
        for (let i = 1; i < pts.length; i++) {
          if (pts[i].anio >= a) {
            const p0 = pts[i - 1];
            const p1 = pts[i];
            const t = (a - p0.anio) / (p1.anio - p0.anio || 1);
            return p0.tco + (p1.tco - p0.tco) * t;
          }
        }
        return pts[pts.length - 1].tco;
      };

      // Convierte un evento de puntero a coords SVG (viewBox) usando CTM.
      const svgPoint = (evt: MouseEvent | PointerEvent) => {
        const pt = chart.createSVGPoint();
        pt.x = evt.clientX;
        pt.y = evt.clientY;
        const ctm = chart.getScreenCTM();
        if (!ctm) return null;
        return pt.matrixTransform(ctm.inverse());
      };

      const hide = () => {
        tooltip.classList.remove('is-visible');
        tooltip.setAttribute('aria-hidden', 'true');
        clearCursor();
      };

      chart.addEventListener('mousemove', (evt) => {
        const st = chartStateRef;
        if (!st || !st.curvas.length) return hide();

        const p = svgPoint(evt);
        if (!p) return;

        // Dentro del área de plot?
        if (p.x < st.plotLeft || p.x > st.plotLeft + st.plotW ||
            p.y < st.plotTop || p.y > st.plotTop + st.plotH) {
          return hide();
        }

        // SVG x → año
        const xRange = st.xMax - st.xMin || 1;
        const anio = st.xMin + ((p.x - st.plotLeft) / st.plotW) * xRange;

        // Interpolar TCO de cada curva y construir lista.
        const rows = st.curvas.map((c) => {
          const t = interp(c.puntos, anio);
          return { tren: c.tren, slug: c.slug, name: c.name, color: c.color, tco: t ?? 0, isFocus: c.isFocus };
        }).sort((a, b) => a.tco - b.tco);

        // Redibujar cursor (línea vertical + dots).
        clearCursor();
        cursorGroup = document.createElementNS(SVGNS, 'g');
        cursorGroup.setAttribute('class', 'chart-cursor');
        cursorGroup.setAttribute('aria-hidden', 'true');

        const line = document.createElementNS(SVGNS, 'line');
        line.setAttribute('x1', String(p.x));
        line.setAttribute('x2', String(p.x));
        line.setAttribute('y1', String(st.plotTop));
        line.setAttribute('y2', String(st.plotTop + st.plotH));
        line.setAttribute('class', 'cursor-line');
        cursorGroup.appendChild(line);

        for (const r of rows) {
          const cy = st.yFn(r.tco);
          const dot = document.createElementNS(SVGNS, 'circle');
          dot.setAttribute('cx', String(p.x));
          dot.setAttribute('cy', String(cy));
          dot.setAttribute('r', r.isFocus ? '5' : '3.5');
          dot.setAttribute('fill', r.color);
          dot.setAttribute('stroke', 'var(--card-bg, #fff)');
          dot.setAttribute('stroke-width', '1.5');
          dot.setAttribute('class', 'cursor-dot');
          cursorGroup.appendChild(dot);
        }
        chart.appendChild(cursorGroup);

        // Rellenar tooltip DOM.
        const anioLabel = anio >= 1
          ? `Año ${anio.toFixed(anio % 1 === 0 ? 0 : 1)}`
          : `Mes ${(anio * 12).toFixed(0)}`;
        tYear.textContent = anioLabel;
        tList.innerHTML = '';
        rows.forEach((r) => {
          const li = document.createElement('li');
          li.className = 'tt-row' + (r.isFocus ? ' tt-row-focus' : '');
          const dot = document.createElement('span');
          dot.className = 'tt-dot';
          if (r.tren === 'BEV') {
            dot.style.background = r.color;
          } else {
            dot.style.background =
              `repeating-linear-gradient(to right, ${r.color} 0 4px, transparent 4px 7px)`;
          }
          const name = document.createElement('span');
          name.className = 'tt-name';
          name.textContent = r.name;
          const val = document.createElement('span');
          val.className = 'tt-val';
          val.textContent = `${eur(r.tco)} €`;
          li.appendChild(dot);
          li.appendChild(name);
          li.appendChild(val);
          tList.appendChild(li);
        });

        // Posicionar tooltip: coord SVG → % del contenedor.
        // El SVG ocupa todo wrap (con padding-bottom para aspect), así que
        // usamos offsetWidth/offsetHeight.
        const rect = chart.getBoundingClientRect();
        const wrapRect = wrap.getBoundingClientRect();
        const relX = evt.clientX - wrapRect.left;
        const relY = evt.clientY - wrapRect.top;

        // Por defecto a la derecha del cursor; si se sale, a la izquierda.
        tooltip.classList.add('is-visible');
        tooltip.setAttribute('aria-hidden', 'false');
        tooltip.style.visibility = 'hidden';  // medir sin parpadeo
        const ttW = tooltip.offsetWidth;
        const ttH = tooltip.offsetHeight;
        let left = relX + 14;
        if (left + ttW > wrapRect.width - 4) left = relX - ttW - 14;
        if (left < 4) left = 4;
        let top = relY - ttH / 2;
        if (top < 4) top = 4;
        if (top + ttH > wrapRect.height - 4) top = wrapRect.height - ttH - 4;
        tooltip.style.left = `${left}px`;
        tooltip.style.top = `${top}px`;
        tooltip.style.visibility = 'visible';

        void rect; // silencia TS si no se usa
      });

      chart.addEventListener('mouseleave', hide);
      chart.addEventListener('blur', hide, true);
    })();

    ($('horizonte') as HTMLInputElement).addEventListener('input', (e) => {
      const raw = Number((e.target as HTMLInputElement).value);
      state.horizonte = snapHorizonte(raw);
      // Snap visual del slider al valor válido.
      (e.target as HTMLInputElement).value = String(state.horizonte);
      $('horizonte-out').textContent = `${state.horizonte} año${state.horizonte === 1 ? '' : 's'}`;
      recalc();
    });

    ($('km') as HTMLInputElement).addEventListener('input', (e) => {
      state.km = Number((e.target as HTMLInputElement).value);
      $('km-out').textContent = `${eur(state.km)} km`;
      recalc();
    });

    // ── E1 — mix casa/pública ──
    const refreshKwhEfectivo = () => {
      $('kwh-efectivo-out').textContent = `${kwhEfectivo().toFixed(3)} €/kWh`;
    };
    ($('pct-casa') as HTMLInputElement).addEventListener('input', (e) => {
      state.pctCasa = Number((e.target as HTMLInputElement).value);
      $('pct-casa-out').textContent = `${state.pctCasa} %`;
      refreshKwhEfectivo();
      recalc();
    });
    ($('kwh-casa') as HTMLInputElement).addEventListener('input', (e) => {
      state.kwhCasa = Number((e.target as HTMLInputElement).value);
      $('kwh-casa-out').textContent = `${state.kwhCasa.toFixed(2)} €`;
      refreshKwhEfectivo();
      recalc();
    });
    ($('kwh-publica') as HTMLInputElement).addEventListener('input', (e) => {
      state.kwhPublica = Number((e.target as HTMLInputElement).value);
      $('kwh-publica-out').textContent = `${state.kwhPublica.toFixed(2)} €`;
      refreshKwhEfectivo();
      recalc();
    });
    document.querySelectorAll<HTMLButtonElement>('.mix-preset').forEach((btn) => {
      btn.addEventListener('click', () => {
        const pct = Number(btn.dataset.pct);
        if (!Number.isFinite(pct)) return;
        state.pctCasa = pct;
        ($('pct-casa') as HTMLInputElement).value = String(pct);
        $('pct-casa-out').textContent = `${pct} %`;
        document.querySelectorAll('.mix-preset').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        refreshKwhEfectivo();
        recalc();
      });
    });

    ($('litro') as HTMLInputElement).addEventListener('input', (e) => {
      state.litro = Number((e.target as HTMLInputElement).value);
      $('litro-out').textContent = `${state.litro.toFixed(2)} €/L`;
      recalc();
    });

    ($('ayuda') as HTMLInputElement).addEventListener('change', (e) => {
      state.ayuda = (e.target as HTMLInputElement).checked;
      $('ayuda-out').textContent = state.ayuda
        ? '(Eléctrico · Económico · Europeo)'
        : '(no aplicada)';
      recalc();
    });


    $('share-btn').addEventListener('click', async () => {
      writeUrl();
      try {
        await navigator.clipboard.writeText(location.href);
        $('share-msg').textContent = '¡Enlace copiado!';
      } catch {
        $('share-msg').textContent = 'Selecciona la URL del navegador para copiarla.';
      }
      setTimeout(() => {
        $('share-msg').textContent = '';
      }, 2500);
    });

    // ── Arranque ──
    function hydrateControls() {
      ($('horizonte') as HTMLInputElement).value = String(state.horizonte);
      ($('km') as HTMLInputElement).value = String(state.km);
      ($('pct-casa') as HTMLInputElement).value = String(state.pctCasa);
      ($('kwh-casa') as HTMLInputElement).value = String(state.kwhCasa);
      ($('kwh-publica') as HTMLInputElement).value = String(state.kwhPublica);
      ($('litro') as HTMLInputElement).value = String(state.litro);
      ($('ayuda') as HTMLInputElement).checked = state.ayuda;
      $('horizonte-out').textContent = `${state.horizonte} años`;
      $('km-out').textContent = `${eur(state.km)} km`;
      $('pct-casa-out').textContent = `${state.pctCasa} %`;
      $('kwh-casa-out').textContent = `${state.kwhCasa.toFixed(2)} €`;
      $('kwh-publica-out').textContent = `${state.kwhPublica.toFixed(2)} €`;
      $('litro-out').textContent = `${state.litro.toFixed(2)} €/L`;
      $('kwh-efectivo-out').textContent = `${kwhEfectivo().toFixed(3)} €/kWh`;
      $('ayuda-out').textContent = state.ayuda
        ? '(Eléctrico · Económico · Europeo)'
        : '(no aplicada)';
      // Marca el preset activo si coincide.
      document.querySelectorAll<HTMLButtonElement>('.mix-preset').forEach((b) => {
        b.classList.toggle('active', Number(b.dataset.pct) === state.pctCasa);
      });
      // Toggle de modo (listas/pares).
      document.querySelectorAll<HTMLButtonElement>('.modo-btn').forEach((b) => {
        const on = b.dataset.modo === state.modo;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-checked', on ? 'true' : 'false');
      });
      // Hint contextual según modo.
      const hint = document.getElementById('seleccion-hint');
      if (hint) {
        hint.textContent = state.modo === 'pares'
          ? 'Modo pares: cada eléctrico se empareja con el combustión de la misma posición (BEV #1 ↔ ICE #1, BEV #2 ↔ ICE #2, …). Cada pareja comparte color y tiene su propio break-even.'
          : 'Empieza con un par rápido o añade hasta 4 eléctricos y 4 de combustión. Haz clic en un coche (chip, fila o línea) para ver su desglose.';
      }
      document.body.dataset.tcoModo = state.modo;
    }

    // Click en el toggle de modo.
    document.querySelectorAll<HTMLButtonElement>('.modo-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const m = btn.dataset.modo as Modo | undefined;
        if (!m || m === state.modo) return;
        state.modo = m;
        hydrateControls();
        recalc();
      });
    });

    // Fallback visible si la inicialización revienta: en lugar de dejar
    // "Cargando…" pegado, muestra un error accionable en el lede y deja
    // traza en consola. No afecta a handlers posteriores de sliders/chips.
    function safeInit() {
      try {
        readUrl();
        hydrateControls();
        recalc();
      } catch (err) {
        console.error('[calculadora-tco] Fallo al inicializar:', err);
        const lede = document.getElementById('lede');
        if (lede) {
          lede.innerHTML =
            'No hemos podido calcular este escenario. ' +
