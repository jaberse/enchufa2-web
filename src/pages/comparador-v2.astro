---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import data from '../data/comparador.json';

const modelos = data.modelos;
const marcas = [...new Set(modelos.map(m => m.marca))].sort();
const tipos = [...new Set(modelos.map(m => m.tipo).filter(Boolean))].sort();
const tracciones = [...new Set(modelos.map(m => m.traccion).filter(Boolean))].sort();
const quimicas = [...new Set(modelos.map(m => m.quimica).filter(Boolean))].sort();
const voltajes = [...new Set(modelos.map(m => m.voltaje).filter(Boolean))].sort((a,b) => a - b);
const bombaOpts = [...new Set(modelos.map(m => m.bomba_calor).filter(Boolean))].sort();
---

<Layout
  title="Comparador de coches eléctricos — enchufa2"
  description="Compara los 37 coches eléctricos más vendidos en Europa. Filtra por autonomía, potencia, maletero, tracción y más."
>
  <Header />

  <!-- HERO BAND -->
  <div class="hero-band">
    <img src="https://images.unsplash.com/photo-1593941707882-a5bba14938c7?w=1600&q=80&auto=format" alt="Estación de carga eléctrica" loading="eager">
  </div>

  <main>
    <!-- Continuous panel: same pattern as homepage guias-section → cat-blocks -->
    <section class="comp-section">
      <div class="comp-outer">

        <!-- Block 1: Intro (overlaps hero, rounded top) -->
        <div class="comp-intro">
          <div class="comp-intro-inner">
            <h2>Comparador de <em>eléctricos</em></h2>
            <p>Dinos qué necesitas. Nosotros te decimos qué coches lo cumplen. <strong>{data.total_modelos} modelos</strong> con datos verificados.</p>
          </div>
        </div>

        <!-- Block 2: Top bar (count + sort + view) -->
        <div class="comp-topbar" id="filter-bar">
          <div class="result-count-bar"><span id="count">{data.total_modelos}</span> de {data.total_modelos}</div>
          <span class="topbar-sep"></span>
          <div class="search-wrap" id="search-wrap">
            <input type="text" id="model-search" class="model-search" placeholder="Buscar modelo..." autocomplete="off" />
            <div class="search-results" id="search-results"></div>
          </div>
          <span class="topbar-sep"></span>
          <div class="sort-control" id="sort-control">
            <label for="sort-select" class="sort-label">Ordenar</label>
            <select id="sort-select" class="sort-select">
              <option value="">Autonomía ↓</option>
              <option value="pvp-asc">Precio ↑</option>
              <option value="pvp-desc">Precio ↓</option>
              <option value="potencia_cv-desc">Potencia ↓</option>
              <option value="carga_dc-desc">Carga DC ↓</option>
              <option value="aceleracion-asc">0-100 ↑</option>
              <option value="consumo-asc">Consumo ↑</option>
              <option value="peso-asc">Peso ↑</option>
              <option value="maletero-desc">Maletero ↓</option>
            </select>
          </div>
          <button class="reset-btn" id="btn-reset" style="display:none;">Limpiar</button>
          <div class="topbar-spacer"></div>
          <div class="view-toggle" id="view-toggle">
            <button class="view-btn active" data-view="fichas">Fichas</button>
            <button class="view-btn" data-view="listado">Listado</button>
          </div>
        </div>

        <!-- Block 3: Fields grid (fixed layout, all fields visible) -->
        <div class="comp-fields-panel">
          <div class="panel-section-label">Categorías</div>
          <div class="panel-cats-row" id="panel-cats"></div>
          <div class="panel-section-label panel-section-label-num">
            <span>Campos numéricos</span>
            <span class="panel-section-hint">Click activa columna · expande para filtrar</span>
            <button class="panel-advanced-btn" id="panel-advanced-btn" type="button" aria-pressed="false">
              <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M1 3h10M3 6h6M5 9h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/></svg>
              Filtros avanzados
            </button>
            <button class="panel-select-all-btn" id="panel-select-all-btn" type="button">Seleccionar todos</button>
          </div>
          <div class="panel-grid" id="panel-grid"></div>
          <div class="panel-applied" id="panel-applied" style="display:none;">
            <span class="panel-applied-label">Filtrando</span>
            <div class="panel-applied-chips" id="panel-applied-chips"></div>
          </div>
        </div>

        <!-- Separator bar between filters and results -->
        <div class="comp-panel-separator"></div>

        <!-- Block 4: Results -->
        <div class="comp-results">
          <div class="fichas-view active" id="fichas-view">
            <div class="fichas-grid" id="results-grid"></div>
          </div>

          <div class="listado-view" id="listado-view" style="display:none;">
            <div class="results-table-outer" id="results-table-outer">
              <div class="scroll-nav" id="scroll-nav">
                <span class="scroll-nav-hint">Desliza para ver más columnas</span>
                <button class="scroll-btn" id="scroll-left" aria-label="Scroll izquierda">←</button>
                <button class="scroll-btn" id="scroll-right" aria-label="Scroll derecha">→</button>
              </div>
              <div class="results-table-wrap" id="results-table-wrap">
                <table class="listado-table" id="results-table">
                  <thead id="results-thead"></thead>
                  <tbody id="results-tbody"></tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Comparison view (side-by-side table · 1·B) -->
          <div class="compare-view" id="compare-view" style="display:none;">
            <div class="compare-wrap" id="compare-wrap"></div>
          </div>

          <p class="results-empty" id="no-results" style="display:none;">
            Ningún modelo cumple todos tus requisitos. Prueba a relajar algún filtro.
          </p>
        </div>

        <!-- Sticky selection footer (3·A) -->
        <div class="sel-footer" id="compare-bar" style="display:none;">
          <div class="sel-footer-inner">
            <div class="sel-footer-label">
              <span class="sel-footer-count"><span id="compare-count-num">0</span></span>
              <span class="sel-footer-text">seleccionados</span>
            </div>
            <div class="sel-footer-thumbs" id="sel-thumbs" aria-label="Modelos seleccionados"></div>
            <div class="sel-footer-actions">
              <button class="sel-footer-clear" id="compare-clear" type="button">Limpiar</button>
              <button class="sel-footer-cta" id="compare-btn" type="button">
                <span class="sel-footer-cta-text">Comparar</span>
                <span class="sel-footer-cta-arrow" aria-hidden="true">→</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Block 4: Methodology (rounded bottom = closes panel) -->
        <div class="comp-methodology">
          <p class="meth-label">Sobre estos datos</p>
          <p>
            Todos los datos provienen de las fichas técnicas oficiales de cada fabricante
            para el mercado español. Cuando no hay dato oficial disponible, se usa
            ev-database.org como fuente de referencia. Las cifras de autonomía corresponden al ciclo WLTP combinado.
            Los precios (PVP) son orientativos, corresponden al mes indicado y pueden variar
            según configuración, promociones o actualizaciones del fabricante. Consulta siempre
            la web oficial del fabricante para el precio vigente.
            Última actualización: abril 2026.
          </p>
        </div>

      </div>
    </section>
  </main>

  <Footer />

  <script define:vars={{
    modelos: data.modelos,
    marcasData: marcas,
    tiposData: tipos,
    traccionesData: tracciones,
    quimicasData: quimicas,
    voltajesData: voltajes,
    bombaOptsData: bombaOpts
  }}>
    // ═══════════════════════════════════════════════════════
    // FIELD DEFINITIONS
    // ═══════════════════════════════════════════════════════
    const FIELDS = [
      { id:'autonomia',     label:'Autonomía',      shortLabel:'Auton.',  unit:'km',        key:'autonomia_wltp_km',       dflt:false, sortAsc:false, filterType:'min' },
      { id:'potencia_cv',   label:'Potencia',        shortLabel:'Pot.',    unit:'CV',        key:'potencia_cv',             dflt:true,  sortAsc:false, filterType:'min' },
      { id:'potencia_kw',   label:'Potencia (kW)',   shortLabel:'Pot.kW',  unit:'kW',        key:'potencia_kw',             dflt:false, sortAsc:false, filterType:'min' },
      { id:'par',           label:'Par motor',       shortLabel:'Par',     unit:'Nm',        key:'par_nm',                  dflt:false, sortAsc:false, filterType:'min' },
      { id:'carga_dc',      label:'Carga DC',        shortLabel:'DC',      unit:'kW',        key:'carga_dc_max_kw',         dflt:true,  sortAsc:false, filterType:'min' },
      { id:'carga_ac',      label:'Carga AC',        shortLabel:'AC',      unit:'kW',        key:'carga_ac_max_kw',         dflt:false, sortAsc:false, filterType:'min' },
      { id:'t_10_80',       label:'T 10→80%',        shortLabel:'10→80',   unit:'min',       key:'t_10_80_min',             dflt:false, sortAsc:true,  filterType:'max' },
      { id:'bateria_neta',  label:'Batería neta',    shortLabel:'Bat.',    unit:'kWh',       key:'bateria_neta_kwh',        dflt:true,  sortAsc:false, filterType:'min', dec:1 },
      { id:'bateria_bruta', label:'Batería bruta',   shortLabel:'Bat.br',  unit:'kWh',       key:'bateria_bruta_kwh',       dflt:false, sortAsc:false, filterType:'min' },
      { id:'maletero',      label:'Maletero',        shortLabel:'Malet.',  unit:'L',         key:'maletero_l',              dflt:true,  sortAsc:false, filterType:'min' },
      { id:'aceleracion',   label:'0-100',           shortLabel:'0-100',   unit:'s',         key:'aceleracion_0_100_s',     dflt:true,  sortAsc:true,  filterType:'max', dec:1 },
      { id:'vel_max',       label:'Vel. máx',        shortLabel:'Vmáx',    unit:'km/h',      key:'velocidad_max_kmh',       dflt:false, sortAsc:false, filterType:'min' },
      { id:'consumo',       label:'Consumo',         shortLabel:'Cons.',   unit:'kWh/100',   key:'consumo_wltp_kwh100km',   dflt:true,  sortAsc:true,  filterType:'max', dec:1 },
      { id:'peso',          label:'Peso',            shortLabel:'Peso',    unit:'kg',        key:'peso_kg',                 dflt:true,  sortAsc:true,  filterType:'max' },
      { id:'pvp',           label:'PVP',             shortLabel:'PVP',     unit:'€',         key:'pvp',                     dflt:true,  sortAsc:true,  filterType:'max', fmt:'eur' },
      { id:'cx',            label:'Cx',              shortLabel:'Cx',      unit:'',          key:'cx',                      dflt:false, sortAsc:true,  filterType:'max', dec:3 },
      { id:'largo',         label:'Largo',           shortLabel:'Largo',   unit:'mm',        key:'largo_mm',                dflt:false, sortAsc:false, filterType:'min' },
      { id:'ancho',         label:'Ancho',           shortLabel:'Ancho',   unit:'mm',        key:'ancho_mm',                dflt:false, sortAsc:false, filterType:'min' },
      { id:'alto',          label:'Alto',            shortLabel:'Alto',    unit:'mm',        key:'alto_mm',                 dflt:false, sortAsc:false, filterType:'min' },
      { id:'batalla',       label:'Batalla',         shortLabel:'Bat.mm',  unit:'mm',        key:'batalla_mm',              dflt:false, sortAsc:false, filterType:'min' },
      { id:'diametro_giro', label:'Diám. giro',      shortLabel:'D.giro',  unit:'m',         key:'diametro_giro_m',         dflt:false, sortAsc:true,  filterType:'max', dec:1 },
      { id:'frunk',         label:'Frunk',           shortLabel:'Frunk',   unit:'L',         key:'frunk_l',                 dflt:false, sortAsc:false, filterType:'min' },
      { id:'remolque',      label:'Remolque',        shortLabel:'Remolq.', unit:'kg',        key:'capacidad_remolque_kg',   dflt:false, sortAsc:false, filterType:'min' },
      { id:'garantia_anos', label:'Garantía años',   shortLabel:'Gar.años', unit:'años',     key:'garantia_bateria',        dflt:false, sortAsc:false, filterType:'min', derive: (m) => { const s = m.garantia_bateria; if (!s) return null; const x = String(s).match(/(\d+)\s*año/i); return x ? parseInt(x[1], 10) : null; } },
      { id:'garantia_km',   label:'Garantía km',     shortLabel:'Gar.km',  unit:'km',        key:'garantia_bateria',        dflt:false, sortAsc:false, filterType:'min', derive: (m) => { const s = m.garantia_bateria; if (!s) return null; const x = String(s).match(/([\d.]+)\s*km/i); return x ? parseInt(x[1].replace(/\./g, ''), 10) : null; }, fmt:'mmDot' },
    ];

    const CATS = [
      { id:'tipo',     label:'Tipo',       key:'tipo',         options: tiposData },
      { id:'traccion', label:'Tracción',    key:'traccion',     options: traccionesData },
      { id:'marca',    label:'Marca',       key:'marca',        options: marcasData },
      { id:'quimica',  label:'Química',     key:'quimica',      options: quimicasData },
      { id:'voltaje',  label:'Voltaje',     key:'voltaje',      options: voltajesData, suffix:' V' },
      { id:'bomba',    label:'B. calor',    key:'bomba_calor',  options: bombaOptsData },
    ];

    const DEFAULT_IDS = FIELDS.filter(f => f.dflt).map(f => f.id);
    let selectedFields = [...DEFAULT_IDS];
    let filterRanges = {}; // { fieldId: {min: Number|null, max: Number|null} }
    let catVals = {};      // { catId: ['val1','val2',...] }
    let openPopover = null; // id of currently open popover
    let advancedMode = false; // histograma + dual slider expandido
    let allFieldsOn = false; // track select-all state
    let pickedIds = new Set();  // IDs of models picked for comparison
    let compareMode = false;    // true = show only picked models

    // ═══════════════════════════════════════════════════════
    // DOM REFS
    // ═══════════════════════════════════════════════════════
    const allModelos = modelos;
    let currentView = 'fichas';
    let tableSortId = null;
    let tableSortAsc = true;

    const grid = document.getElementById('results-grid');
    const compareView = document.getElementById('compare-view');
    const compareWrap = document.getElementById('compare-wrap');
    const fichasView = document.getElementById('fichas-view');
    const listadoView = document.getElementById('listado-view');
    const tableOuter = document.getElementById('results-table-outer');
    const tableWrap = document.getElementById('results-table-wrap');
    const thead = document.getElementById('results-thead');
    const tbody = document.getElementById('results-tbody');
    const countEl = document.getElementById('count');
    const noResults = document.getElementById('no-results');
    const btnReset = document.getElementById('btn-reset');
    const panelGrid = document.getElementById('panel-grid');
    const panelCats = document.getElementById('panel-cats');
    const panelApplied = document.getElementById('panel-applied');
    const panelAppliedChips = document.getElementById('panel-applied-chips');
    const panelAdvancedBtn = document.getElementById('panel-advanced-btn');
    if (panelAdvancedBtn) {
      panelAdvancedBtn.addEventListener('click', () => {
        advancedMode = !advancedMode;
        panelAdvancedBtn.classList.toggle('active', advancedMode);
        panelAdvancedBtn.setAttribute('aria-pressed', advancedMode ? 'true' : 'false');
        renderPanel();
      });
    }
    const panelSelectAllBtn = document.getElementById('panel-select-all-btn');
    if (panelSelectAllBtn) {
      panelSelectAllBtn.addEventListener('click', () => {
        const allOn = selectedFields.length === FIELDS.length;
        if (allOn) {
          selectedFields = [...DEFAULT_IDS];
          FIELDS.forEach(f => { if (!DEFAULT_IDS.includes(f.id)) delete filterRanges[f.id]; });
        } else {
          selectedFields = FIELDS.map(f => f.id);
        }
        allFieldsOn = !allOn;
        panelSelectAllBtn.textContent = allOn ? 'Seleccionar todos' : 'Volver a predefinidos';
        btnReset.style.display = hasAnyFilter() ? '' : 'none';
        renderPanel();
        update();
      });
    }
    const scrollNav = document.getElementById('scroll-nav');
    const scrollLeftBtn = document.getElementById('scroll-left');
    const scrollRightBtn = document.getElementById('scroll-right');
    const searchInput = document.getElementById('model-search');
    const searchResultsEl = document.getElementById('search-results');
    const compareBar = document.getElementById('compare-bar');
    // compareCountEl no longer used (replaced by sticky footer thumbs)
    const compareBtn = document.getElementById('compare-btn');
    const compareClear = document.getElementById('compare-clear');

    // ═══════════════════════════════════════════════════════
    // HELPERS
    // ═══════════════════════════════════════════════════════
    function fmtField(val, field) {
      if (val === null || val === undefined) return '\u2014';
      if (field.fmt === 'eur') return val.toLocaleString('es-ES') + '\u00a0\u20ac';
      if (field.isText) return val;
      if (field.dec !== undefined) return val.toFixed(field.dec);
      if (typeof val === 'number') return val.toLocaleString('es-ES');
      return val;
    }

    function fmtCompact(val, field) {
      if (val === null || val === undefined) return '\u2014';
      if (field.fmt === 'eur') return (val / 1000).toFixed(1) + 'k';
      if (field.dec !== undefined) return val.toFixed(field.dec);
      if (typeof val === 'number') return val.toLocaleString('es-ES');
      return val;
    }

    function fmt(val) {
      if (val === null || val === undefined) return '\u2014';
      return val.toLocaleString('es-ES');
    }

    function makeBadgesHtml(m, small) {
      const s = small ? 'badge badge-sm' : 'badge';
      let html = '';
      if (m.tipo)              html += '<span class="' + s + ' badge-tipo">' + m.tipo + '</span>';
      if (m.traccion)          html += '<span class="' + s + ' badge-traccion">' + m.traccion + '</span>';
      if (m.quimica === 'LFP') html += '<span class="' + s + ' badge-lfp">LFP</span>';
      if (m.quimica === 'NMC') html += '<span class="' + s + ' badge-nmc">NMC</span>';
      if (m.quimica === 'NCA') html += '<span class="' + s + ' badge-nca">NCA</span>';
      if (m.voltaje === 800)   html += '<span class="' + s + ' badge-800v">800V</span>';
      return html;
    }

    function photoSrc(m) {
      return m.foto ? '/comparador/' + m.slug + '.png?v=11' : '/comparador/placeholder.svg';
    }

    function rangeIsActive(r) {
      return r && (r.min != null || r.max != null);
    }
    function hasAnyFilter() {
      return Object.values(filterRanges).some(rangeIsActive) || Object.values(catVals).some(v => v && v.length > 0);
    }

    // ═══════════════════════════════════════════════════════
    // CLOSE POPOVERS ON OUTSIDE CLICK
    // ═══════════════════════════════════════════════════════
    document.addEventListener('mousedown', (e) => {
      if (openPopover && !e.target.closest('.cat-chip')) {
        openPopover = null;
        renderPanel();
      }
    });

    // Format a filter value for display in the applied-chips strip
    function formatFilterDisplayVal(f, val) {
      const n = parseFloat(val);
      if (isNaN(n)) return val;
      if (f.fmt === 'eur') return n.toLocaleString('es-ES') + ' €';
      return n.toLocaleString('es-ES') + (f.unit ? ' ' + f.unit : '');
    }

    // ═══════════════════════════════════════════════════════
    // HISTOGRAM + DUAL RANGE SLIDER (advanced filter UI)
    // ═══════════════════════════════════════════════════════
    // Cross-filter: models passing every filter EXCEPT the one on fieldId
    function modelsExceptFilter(fieldId) {
      return allModelos.filter(m => {
        // categories
        for (const [id, vals] of Object.entries(catVals)) {
          if (!vals || vals.length === 0) continue;
          const c = CATS.find(x => x.id === id);
          if (!c) continue;
          if (!vals.includes(String(m[c.key]))) return false;
        }
        // numeric ranges, skipping fieldId
        for (const [id, r] of Object.entries(filterRanges)) {
          if (id === fieldId) continue;
          if (!rangeIsActive(r)) continue;
          const f2 = FIELDS.find(x => x.id === id);
          if (!f2) continue;
          const mv = getFieldVal(m, f2);
          if (r.min != null && (mv == null ? 0 : mv) < r.min) return false;
          if (r.max != null && (mv == null ? Infinity : mv) > r.max) return false;
        }
        return true;
      });
    }

    function computeFieldDomain(f) {
      const vals = modelsExceptFilter(f.id)
        .map(m => getFieldVal(m, f))
        .filter(v => v != null && !isNaN(Number(v)))
        .map(Number);
      if (vals.length === 0) return null;
      const mn = Math.min(...vals), mx = Math.max(...vals);
      return { min: mn, max: mx, vals };
    }

    function buildHistogram(vals, mn, mx, nBins) {
      if (mx === mn) return [{ count: vals.length, lo: mn, hi: mx }];
      const width = (mx - mn) / nBins;
      const bins = [];
      for (let i = 0; i < nBins; i++) {
        bins.push({ count: 0, lo: mn + i * width, hi: mn + (i + 1) * width });
      }
      vals.forEach(v => {
        let idx = Math.floor((v - mn) / width);
        if (idx >= nBins) idx = nBins - 1;
        if (idx < 0) idx = 0;
        bins[idx].count++;
      });
      return bins;
    }

    // Smart "nice" rounding for slider step
    function niceStep(range) {
      if (range <= 0) return 1;
      const mag = Math.pow(10, Math.floor(Math.log10(range)));
      const norm = range / mag;
      let step;
      if (norm < 2) step = mag / 100;
      else if (norm < 5) step = mag / 50;
      else step = mag / 20;
      return step;
    }

    function formatSliderVal(f, v) {
      if (v == null || isNaN(v)) return '—';
      if (f.fmt === 'mmDot') return Math.round(v).toLocaleString('es-ES').replace(/,/g, '.');
      if (f.unit === '€' || f.fmt === 'eur') return Math.round(v).toLocaleString('es-ES');
      const dec = (f.unit === 's' || f.id === 'cx') ? 2 : 0;
      return Number(v).toFixed(dec);
    }

    function buildAdvancedFilter(f) {
      const domain = computeFieldDomain(f);
      if (!domain) return null;
      const { min: dMin, max: dMax, vals } = domain;

      const wrap = document.createElement('div');
      wrap.className = 'field-adv';
      wrap.addEventListener('click', (e) => e.stopPropagation());

      const current = filterRanges[f.id] || {};
      const selMin = current.min != null ? Math.max(current.min, dMin) : dMin;
      const selMax = current.max != null ? Math.min(current.max, dMax) : dMax;

      // Histogram (12 bins)
      const nBins = 12;
      const bins = buildHistogram(vals, dMin, dMax, nBins);
      const maxCount = Math.max(...bins.map(b => b.count), 1);

      const histo = document.createElement('div');
      histo.className = 'field-adv-histo';
      bins.forEach(b => {
        const bar = document.createElement('div');
        bar.className = 'field-adv-bar';
        // determine if bin overlaps selected range
        const inRange = b.hi >= selMin && b.lo <= selMax;
        if (inRange) bar.classList.add('in-range');
        bar.style.height = Math.max(4, Math.round((b.count / maxCount) * 100)) + '%';
        bar.title = b.count + ' modelos';
        histo.appendChild(bar);
      });
      wrap.appendChild(histo);

      // Dual range slider
      if (dMax > dMin) {
        const step = niceStep(dMax - dMin);
        const slider = document.createElement('div');
        slider.className = 'field-adv-slider';
        slider.innerHTML =
          '<div class="slider-track"></div>' +
          '<div class="slider-track-active"></div>' +
          '<input type="range" class="slider-input slider-min" min="' + dMin + '" max="' + dMax + '" step="' + step + '" value="' + selMin + '">' +
          '<input type="range" class="slider-input slider-max" min="' + dMin + '" max="' + dMax + '" step="' + step + '" value="' + selMax + '">';
        const inMin = slider.querySelector('.slider-min');
        const inMax = slider.querySelector('.slider-max');
        const activeTrack = slider.querySelector('.slider-track-active');
        const pct = (v) => ((v - dMin) / (dMax - dMin)) * 100;
        const refreshTrack = () => {
          activeTrack.style.left = pct(parseFloat(inMin.value)) + '%';
          activeTrack.style.right = (100 - pct(parseFloat(inMax.value))) + '%';
        };
        refreshTrack();
        let debounceT = null;
        const commit = () => {
          let mn = parseFloat(inMin.value), mx = parseFloat(inMax.value);
          if (mn > mx) { const t = mn; mn = mx; mx = t; }
          // Store only if different from domain
          const r = { min: null, max: null };
          if (mn > dMin + 1e-9) r.min = mn;
          if (mx < dMax - 1e-9) r.max = mx;
          if (r.min == null && r.max == null) delete filterRanges[f.id];
          else filterRanges[f.id] = r;
          if (!selectedFields.includes(f.id)) selectedFields.push(f.id);
          btnReset.style.display = hasAnyFilter() ? '' : 'none';
          clearTimeout(debounceT);
          debounceT = setTimeout(() => { renderPanel(); update(); }, 180);
        };
        const onSlide = () => {
          // live feedback on track + histogram shading
          if (parseFloat(inMin.value) > parseFloat(inMax.value)) {
            const t = inMin.value; inMin.value = inMax.value; inMax.value = t;
          }
          refreshTrack();
          // update histogram bar states
          const mn = parseFloat(inMin.value), mx = parseFloat(inMax.value);
          Array.from(histo.children).forEach((bar, i) => {
            const b = bins[i];
            const inR = b.hi >= mn && b.lo <= mx;
            bar.classList.toggle('in-range', inR);
          });
          // update value labels
          valMin.textContent = formatSliderVal(f, mn);
          valMax.textContent = formatSliderVal(f, mx);
        };
        inMin.addEventListener('input', onSlide);
        inMax.addEventListener('input', onSlide);
        inMin.addEventListener('change', commit);
        inMax.addEventListener('change', commit);
        // Prevent chip toggle when clicking/dragging slider
        ['click','mousedown','touchstart','keydown'].forEach(ev => {
          inMin.addEventListener(ev, (e) => e.stopPropagation());
          inMax.addEventListener(ev, (e) => e.stopPropagation());
        });
        wrap.appendChild(slider);

        // Value labels
        const labels = document.createElement('div');
        labels.className = 'field-adv-labels';
        const valMin = document.createElement('span');
        valMin.className = 'field-adv-val field-adv-val-min';
        valMin.textContent = formatSliderVal(f, selMin);
        const unit = document.createElement('span');
        unit.className = 'field-adv-unit';
        unit.textContent = f.unit || '';
        const sep = document.createElement('span');
        sep.className = 'field-adv-sep';
        sep.textContent = '—';
        const valMax = document.createElement('span');
        valMax.className = 'field-adv-val field-adv-val-max';
        valMax.textContent = formatSliderVal(f, selMax);
        labels.appendChild(valMin);
        labels.appendChild(unit.cloneNode(true));
        labels.appendChild(sep);
        labels.appendChild(valMax);
        labels.appendChild(unit);
        wrap.appendChild(labels);
      }

      return wrap;
    }

    // ═══════════════════════════════════════════════════════
    // RENDER PANEL (unified grid: locked cats + toggleable fields)
    // ═══════════════════════════════════════════════════════
    function renderPanel() {
      // ── Category chips (render into panelCats row) ──
      panelCats.innerHTML = '';
      CATS.forEach(c => {
        const vals = catVals[c.id] || [];
        const hasF = vals.length > 0;
        const isOpen = openPopover === c.id;

        const chip = document.createElement('div');
        chip.className = 'cat-chip' + (hasF ? ' is-filtering' : '');

        const btn = document.createElement('button');
        btn.className = 'cat-chip-btn';
        btn.type = 'button';

        let valueText;
        if (hasF) {
          valueText = vals.length === 1 ? vals[0] + (c.suffix || '') : vals.join(', ') + (c.suffix || '');
        } else {
          valueText = 'Todos';
        }
        const rightEl = hasF
          ? '<span class="cat-chip-badge">' + vals.length + '</span>'
          : '<span class="cat-chip-caret"><svg width="7" height="4" viewBox="0 0 7 4"><path d="M.5.5l3 3 3-3" stroke="currentColor" stroke-width="1" fill="none" stroke-linecap="round"/></svg></span>';
        btn.innerHTML = '<div class="cat-chip-top"><span class="cat-chip-label">' + c.label + '</span>' + rightEl + '</div><span class="cat-chip-value">' + valueText + '</span>';

        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          openPopover = isOpen ? null : c.id;
          renderPanel();
        });
        chip.appendChild(btn);

        if (isOpen) {
          const pop = document.createElement('div');
          pop.className = 'cat-popover';
          let html = '<div class="pop-options">';
          c.options.forEach(o => {
            const sel = vals.includes(String(o));
            html += '<button class="pop-option' + (sel ? ' pop-option-sel' : '') + '" data-val="' + o + '">' + (sel ? '\u2713 ' : '') + o + (c.suffix || '') + '</button>';
          });
          html += '</div>';
          if (hasF) html += '<button class="pop-clear">Limpiar</button>';
          pop.innerHTML = html;
          pop.addEventListener('mousedown', e => e.stopPropagation());
          chip.appendChild(pop);

          requestAnimationFrame(() => {
            pop.querySelectorAll('.pop-option').forEach(optBtn => {
              optBtn.addEventListener('click', () => {
                const clicked = String(optBtn.dataset.val);
                const cur = catVals[c.id] || [];
                if (cur.includes(clicked)) {
                  catVals[c.id] = cur.filter(v => v !== clicked);
                } else {
                  catVals[c.id] = [...cur, clicked];
                }
                btnReset.style.display = hasAnyFilter() ? '' : 'none';
                renderPanel();
                update();
              });
            });
            const clrBtn = pop.querySelector('.pop-clear');
            if (clrBtn) {
              clrBtn.addEventListener('click', () => {
                catVals[c.id] = [];
                openPopover = null;
                btnReset.style.display = hasAnyFilter() ? '' : 'none';
                renderPanel();
                update();
              });
            }
          });
        }

        panelCats.appendChild(chip);
      });

      // ── Numeric chips (render into panel-grid) ──
      const container = panelGrid;
      container.innerHTML = '';

      FIELDS.forEach(f => {
        const isActive = selectedFields.includes(f.id);
        const range = filterRanges[f.id];
        const isFiltering = rangeIsActive(range);

        const item = document.createElement('div');
        item.className = 'field-item' + (isActive ? ' active' : '') + (isFiltering ? ' is-filtering' : '') + (advancedMode && f.filterType ? ' advanced' : '');
        item.setAttribute('role', 'button');
        item.setAttribute('tabindex', '0');
        item.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        // Whole-chip click toggles column visibility (inner controls use stopPropagation)
        const toggleColumn = () => {
          if (isActive) {
            selectedFields = selectedFields.filter(x => x !== f.id);
            delete filterRanges[f.id];
          } else {
            selectedFields.push(f.id);
          }
          btnReset.style.display = hasAnyFilter() ? '' : 'none';
          renderPanel();
          update();
        };
        item.addEventListener('click', toggleColumn);
        item.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleColumn(); }
        });

        // Head row: label + contextual action (× when filtering, sort otherwise)
        const head = document.createElement('div');
        head.className = 'field-chip-head';

        const label = document.createElement('span');
        label.className = 'field-label';
        label.textContent = f.label;

        // Contextual action
        let actionBtn;
        if (isFiltering) {
          actionBtn = document.createElement('button');
          actionBtn.className = 'field-action field-action-clear';
          actionBtn.type = 'button';
          actionBtn.title = 'Quitar filtro';
          actionBtn.setAttribute('aria-label', 'Quitar filtro de ' + f.label);
          actionBtn.innerHTML = '<svg width="10" height="10" viewBox="0 0 10 10"><path d="M2 2l6 6M8 2l-6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/></svg>';
          actionBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            delete filterRanges[f.id];
            btnReset.style.display = hasAnyFilter() ? '' : 'none';
            renderPanel();
            update();
          });
        } else {
          const isSorted = tableSortId === f.id;
          actionBtn = document.createElement('button');
          actionBtn.className = 'field-action field-action-sort' + (isSorted ? ' sort-active' : '');
          actionBtn.type = 'button';
          actionBtn.title = 'Ordenar por ' + f.label;
          if (isSorted) {
            actionBtn.innerHTML = tableSortAsc
              ? '<svg width="8" height="6" viewBox="0 0 8 6"><path d="M4 0L8 6H0z" fill="currentColor"/></svg>'
              : '<svg width="8" height="6" viewBox="0 0 8 6"><path d="M4 6L0 0h8z" fill="currentColor"/></svg>';
          } else {
            actionBtn.innerHTML = '<svg width="8" height="10" viewBox="0 0 8 10"><path d="M4 0L7 3H1z" fill="currentColor"/><path d="M4 10L1 7h6z" fill="currentColor"/></svg>';
          }
          actionBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            handleSort(f.id);
            const selVal = f.id + '-' + (tableSortAsc ? 'asc' : 'desc');
            const sortSel = document.getElementById('sort-select');
            const optMatch = Array.from(sortSel.options).find(o => o.value === selVal);
            if (optMatch) sortSel.value = selVal; else sortSel.value = '';
            renderPanel();
          });
        }

        head.appendChild(label);
        head.appendChild(actionBtn);
        item.appendChild(head);

        // Advanced expanded block: histograma + dual range slider
        if (advancedMode && f.filterType) {
          const advBlock = buildAdvancedFilter(f);
          if (advBlock) item.appendChild(advBlock);
        }

        container.appendChild(item);
      });

      // ── Applied filters strip ──
      renderAppliedStrip();
    }

    function renderAppliedStrip() {
      const parts = [];
      // Category filters
      CATS.forEach(c => {
        const vals = catVals[c.id] || [];
        if (!vals.length) return;
        const valText = vals.length <= 2
          ? vals.join(', ') + (c.suffix || '')
          : vals.length + ' opciones';
        parts.push({ kind: 'cat', id: c.id, text: c.label + ': ' + valText });
      });
      // Numeric range filters
      FIELDS.forEach(f => {
        const r = filterRanges[f.id];
        if (!rangeIsActive(r)) return;
        let txt;
        if (r.min != null && r.max != null) txt = f.label + ' ' + formatFilterDisplayVal(f, r.min) + '–' + formatFilterDisplayVal(f, r.max);
        else if (r.min != null) txt = f.label + ' ≥ ' + formatFilterDisplayVal(f, r.min);
        else txt = f.label + ' ≤ ' + formatFilterDisplayVal(f, r.max);
        parts.push({ kind: 'num', id: f.id, text: txt });
      });

      if (!parts.length) {
        panelApplied.style.display = 'none';
        return;
      }
      panelApplied.style.display = '';
      panelAppliedChips.innerHTML = '';
      parts.forEach(p => {
        const btn = document.createElement('button');
        btn.className = 'applied-chip';
        btn.type = 'button';
        btn.title = 'Quitar este filtro';
        btn.innerHTML = '<span>' + p.text + '</span><span class="applied-chip-x" aria-hidden="true">×</span>';
        btn.addEventListener('click', () => {
          if (p.kind === 'cat') {
            catVals[p.id] = [];
          } else {
            delete filterRanges[p.id];
          }
          btnReset.style.display = hasAnyFilter() ? '' : 'none';
          renderPanel();
          update();
        });
        panelAppliedChips.appendChild(btn);
      });
    }

    // ═══════════════════════════════════════════════════════
    // VIEW TOGGLE
    // ═══════════════════════════════════════════════════════
    document.querySelectorAll('.view-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentView = btn.dataset.view;

        // Show/hide views
        const fichasView = document.getElementById('fichas-view');
        const listadoView = document.getElementById('listado-view');
        if (currentView === 'fichas') {
          fichasView.style.display = 'block';
          fichasView.classList.add('active');
          listadoView.style.display = 'none';
          listadoView.classList.remove('active');
        } else {
          fichasView.style.display = 'none';
          fichasView.classList.remove('active');
          listadoView.style.display = 'block';
          listadoView.classList.add('active');
        }

        update();
      });
    });

    // ═══════════════════════════════════════════════════════
    // FILTERING
    // ═══════════════════════════════════════════════════════
    // Read numeric value from a model for a field — supports derived values
    function getFieldVal(m, f) {
      return f.derive ? f.derive(m) : m[f.key];
    }

    function passesFilter(m) {
      // Numeric range filters (dual slider: min+max)
      for (const [id, r] of Object.entries(filterRanges)) {
        if (!rangeIsActive(r)) continue;
        const f = FIELDS.find(x => x.id === id);
        if (!f) continue;
        const mval = getFieldVal(m, f);
        if (r.min != null && (mval == null ? 0 : mval) < r.min) return false;
        if (r.max != null && (mval == null ? Infinity : mval) > r.max) return false;
      }
      // Category filters (multi-select: model must match ANY of the selected values)
      for (const [id, vals] of Object.entries(catVals)) {
        if (!vals || vals.length === 0) continue;
        const c = CATS.find(x => x.id === id);
        if (!c) continue;
        if (!vals.includes(String(m[c.key]))) return false;
      }
      return true;
    }

    // ═══════════════════════════════════════════════════════
    // SORTING
    // ═══════════════════════════════════════════════════════
    function sortModelos(arr) {
      if (tableSortId) {
        const f = FIELDS.find(x => x.id === tableSortId);
        if (f) {
          arr.sort((a, b) => {
            const va = getFieldVal(a, f), vb = getFieldVal(b, f);
            if (va == null) return 1;
            if (vb == null) return -1;
            return tableSortAsc ? va - vb : vb - va;
          });
          return;
        }
      }
      arr.sort((a, b) => (b.autonomia_wltp_km || 0) - (a.autonomia_wltp_km || 0));
    }

    function handleSort(fieldId) {
      const f = FIELDS.find(x => x.id === fieldId);
      if (tableSortId === fieldId) {
        tableSortAsc = !tableSortAsc;
      } else {
        tableSortId = fieldId;
        tableSortAsc = f ? f.sortAsc : true;
      }
      update();
    }

    // ═══════════════════════════════════════════════════════
    // COMPUTE BEST VALUES (for compare mode highlights)
    // ═══════════════════════════════════════════════════════
    let bestValues = {};  // { fieldId: bestNumericValue }
    function computeBestValues() {
      bestValues = {};
      if (!compareMode || pickedIds.size < 2) return;
      const pickedModels = modelos.filter(m => pickedIds.has(modelId(m)));
      FIELDS.forEach(f => {
        if (f.isText) return;
        const vals = pickedModels.map(m => getFieldVal(m, f)).filter(v => v != null && !isNaN(v));
        if (vals.length < 2) return;
        bestValues[f.id] = f.sortAsc ? Math.min(...vals) : Math.max(...vals);
      });
    }

    // ═══════════════════════════════════════════════════════
    // RENDER CARD (FICHAS)
    // ═══════════════════════════════════════════════════════
    function renderCard(m) {
      const card = document.createElement('article');
      const isPicked = pickedIds.has(modelId(m));
      card.className = 'ev-card' + (isPicked ? ' ev-card-picked' : '');
      card.addEventListener('click', () => togglePick(m));

      const activeFields = FIELDS.filter(f => selectedFields.includes(f.id));
      const showBest = compareMode && pickedIds.size >= 2;

      // All fields as clean detail rows (no stats grid)
      let detailsHtml = '';
      activeFields.forEach(f => {
        const val = getFieldVal(m, f);
        let display = fmtField(val, f);
        if (f.unit && !f.fmt && !f.isText && val != null) display += '\u00a0' + f.unit;
        const isPrice = f.id === 'pvp';
        const isBest = showBest && val != null && bestValues[f.id] != null && val === bestValues[f.id];
        const cls = 'ev-detail' + (isPrice ? ' ev-detail-price' : '') + (isBest ? ' ev-detail-best' : '');
        detailsHtml += '<div class="' + cls + '"><span>' + f.label + '</span><span>' + display + (isBest ? ' <em class="best-mark" title="Mejor valor del grupo">★</em>' : '') + '</span></div>';
      });

      card.innerHTML =
        '<div class="ev-card-photo">' +
          (isPicked ? '<div class="pick-badge">✓</div>' : '') +
          '<img src="' + photoSrc(m) + '" alt="' + m.marca + ' ' + m.modelo + '" loading="lazy" />' +
        '</div>' +
        '<div class="ev-card-body">' +
          '<div class="ev-card-header">' +
            '<div class="ev-card-title">' +
              '<span class="ev-marca">' + m.marca + '</span>' +
              '<span class="ev-modelo">' + m.modelo + '</span>' +
              '<span class="ev-variante">' + m.variante + '</span>' +
            '</div>' +
            '<div class="ev-autonomia-inline">' +
              '<span class="val">' + fmt(m.autonomia_wltp_km) + '</span>' +
              '<span class="unit">km</span>' +
            '</div>' +
          '</div>' +
          '<div class="ev-badges">' + makeBadgesHtml(m) + '</div>' +
          (detailsHtml ? '<div class="ev-card-details">' + detailsHtml + '</div>' : '') +
        '</div>';
      return card;
    }

    // ═══════════════════════════════════════════════════════
    // RENDER COMPARE TABLE (4 categorías · card-on-card · 1·B)
    // ═══════════════════════════════════════════════════════
    // Fixed comparison structure — always shows these fields regardless of filter selection
    const COMPARE_GROUPS = [
      { num:'01', name:'Batería y carga', rows:[
        { label:'Batería neta',         key:'bateria_neta_kwh',    unit:'kWh', dir:'max', dec:0 },
        { label:'Batería bruta',        key:'bateria_bruta_kwh',   unit:'kWh', dir:'max', dec:0 },
        { label:'Química',              key:'quimica',             isText:true },
        { label:'Voltaje arquitectura', key:'voltaje',             unit:'V',   isText:true },
        { label:'Carga DC máx',         key:'carga_dc_max_kw',     unit:'kW',  dir:'max', dec:0 },
        { label:'Carga AC máx',         key:'carga_ac_max_kw',     unit:'kW',  dir:'max', dec:0 },
        { label:'10 → 80% DC',          key:'t_10_80_min',         unit:'min', dir:'min', dec:0 },
      ]},
      { num:'02', name:'Prestaciones', rows:[
        { label:'Potencia',             key:'potencia_cv',         unit:'CV',  dir:'max', dec:0 },
        { label:'Par motor',            key:'par_nm',              unit:'Nm',  dir:'max', dec:0 },
        { label:'Tracción',             key:'traccion',            isText:true },
        { label:'0-100',                key:'aceleracion_0_100_s', unit:'s',   dir:'min', dec:1 },
        { label:'Velocidad máxima',     key:'velocidad_max_kmh',   unit:'km/h', dir:'max', dec:0 },
        { label:'Autonomía WLTP',       key:'autonomia_wltp_km',   unit:'km',  dir:'max', dec:0 },
        { label:'Consumo WLTP',         key:'consumo_wltp_kwh100km', unit:'kWh/100', dir:'min', dec:1 },
      ]},
      { num:'03', name:'Dimensiones', rows:[
        { label:'Largo',                key:'largo_mm',            unit:'mm',  dir:'max', dec:0, fmt:'mmDot' },
        { label:'Ancho',                key:'ancho_mm',            unit:'mm',  dir:'min', dec:0, fmt:'mmDot' },
        { label:'Alto',                 key:'alto_mm',             unit:'mm',  dir:'min', dec:0, fmt:'mmDot' },
        { label:'Batalla',              key:'batalla_mm',          unit:'mm',  dir:'max', dec:0, fmt:'mmDot' },
        { label:'Diámetro de giro',     key:'diametro_giro_m',     unit:'m',   dir:'min', dec:1 },
        { label:'Cx',                   key:'cx',                  dir:'min',  dec:3 },
        { label:'Maletero',             key:'maletero_l',          unit:'L',   dir:'max', dec:0 },
        { label:'Frunk',                key:'frunk_l',             unit:'L',   dir:'max', dec:0 },
        { label:'Capacidad remolque',   key:'capacidad_remolque_kg', unit:'kg', dir:'max', dec:0, fmt:'mmDot' },
        { label:'Peso',                 key:'peso_kg',             unit:'kg',  dir:'min', dec:0, fmt:'mmDot' },
      ]},
      { num:'04', name:'Economía', rows:[
        { label:'PVP',                  key:'pvp',                 fmt:'eur',  dir:'min' },
        { label:'Garantía batería (años)', key:'garantia_bateria', unit:'años', dir:'max', dec:0, derive:(m)=>{ const s=m.garantia_bateria; if(!s) return null; const x=String(s).match(/(\d+)\s*año/i); return x?parseInt(x[1],10):null; } },
        { label:'Garantía batería (km)',   key:'garantia_bateria', unit:'km',  dir:'max', dec:0, fmt:'mmDot', derive:(m)=>{ const s=m.garantia_bateria; if(!s) return null; const x=String(s).match(/([\d.]+)\s*km/i); return x?parseInt(x[1].replace(/\./g,''),10):null; } },
        { label:'Garantía vehículo',    key:'garantia_vehiculo',   isText:true, placeholder:'por verificar' },
        { label:'Plan Auto+ 2026',      key:'plan_auto_2026',      isText:true, placeholder:'por calcular' },
      ]},
    ];

    function formatCellVal(m, row) {
      const val = row.derive ? row.derive(m) : m[row.key];
      if (val == null || val === '') {
        return '<span class="cmp-placeholder">' + (row.placeholder || '—') + '</span>';
      }
      if (row.isText) {
        return String(val) + (row.unit ? '\u00a0' + row.unit : '');
      }
      let numStr;
      if (row.fmt === 'eur') {
        numStr = Number(val).toLocaleString('es-ES') + '\u00a0€';
      } else if (row.fmt === 'mmDot') {
        numStr = Number(val).toLocaleString('es-ES').replace(/,/g,'.') + (row.unit ? '\u00a0' + row.unit : '');
      } else {
        const n = Number(val);
        numStr = (row.dec != null ? n.toFixed(row.dec) : n.toString()) + (row.unit ? '\u00a0' + row.unit : '');
      }
      return numStr;
    }

    function computeRowBest(picked, row) {
      if (row.isText || !row.dir) return null;
      const vals = picked.map(m => row.derive ? row.derive(m) : m[row.key]).filter(v => v != null && !isNaN(Number(v))).map(Number);
      if (vals.length === 0) return null;
      return row.dir === 'max' ? Math.max(...vals) : Math.min(...vals);
    }

    function renderCompareTable(picked) {
      const n = picked.length;
      // ≤4: flex equal columns · ≥5: fixed-width with horizontal scroll
      const colWidth = n <= 4 ? 'minmax(0, 1fr)' : '175px';
      const labelWidth = n <= 4 ? '200px' : '170px';
      const cols = labelWidth + ' repeat(' + n + ', ' + colWidth + ')';
      const wrapClass = n >= 5 ? 'cmp-table cmp-table-scroll' : 'cmp-table';
      let html = '<div class="' + wrapClass + '" style="grid-template-columns:' + cols + '">';

      // Card headers row
      html += '<div class="cmp-label cmp-label-head"></div>';
      picked.forEach(m => {
        html += '<div class="cmp-head">' +
          '<div class="cmp-head-photo">' +
            '<img src="' + photoSrc(m) + '" alt="' + m.marca + ' ' + m.modelo + '" loading="lazy">' +
          '</div>' +
          '<div class="cmp-head-title">' +
            '<span class="cmp-head-marca">' + m.marca + '</span>' +
            '<span class="cmp-head-modelo">' + m.modelo + '</span>' +
            '<span class="cmp-head-variante">' + (m.variante || '') + '</span>' +
          '</div>' +
          '<div class="cmp-head-badges">' + makeBadgesHtml(m) + '</div>' +
        '</div>';
      });

      // Render 4 groups
      COMPARE_GROUPS.forEach(g => {
        html += '<div class="cmp-group">' +
          '<div class="cmp-group-inner">' +
            '<span class="cmp-group-num">' + g.num + '</span>' +
            '<span class="cmp-group-sep">—</span>' +
            '<span class="cmp-group-name">' + g.name + '</span>' +
          '</div>' +
        '</div>';
        g.rows.forEach(row => {
          const best = computeRowBest(picked, row);
          html += '<div class="cmp-label">' + row.label + '</div>';
          picked.forEach(m => {
            const val = row.derive ? row.derive(m) : m[row.key];
            const isBest = best != null && Number(val) === best;
            html += '<div class="cmp-cell' + (isBest ? ' cmp-cell-best' : '') + '">' +
              formatCellVal(m, row) +
              (isBest ? ' <em class="best-mark">★</em>' : '') +
            '</div>';
          });
        });
      });

      html += '</div>';
      compareWrap.innerHTML = html;
    }

    // ═══════════════════════════════════════════════════════
    // RENDER TABLE (LISTADO) — adaptive layout
    // ═══════════════════════════════════════════════════════
    const MOBILE_BP = 768;
    const MIN_COL_W = 100;  // minimum data-column width (px)
    let computedColW = MIN_COL_W;

    function isMobile() { return window.innerWidth <= MOBILE_BP; }

    function renderTableHeaders() {
      const activeFields = FIELDS.filter(f => selectedFields.includes(f.id));
      const table = document.getElementById('results-table');
      const wrap = document.getElementById('results-table-wrap');
      const mobile = isMobile();

      // Remove old colgroup
      let existingColgroup = table.querySelector('colgroup');
      if (existingColgroup) existingColgroup.remove();

      table.style.tableLayout = 'fixed';
      wrap.classList.add('scroll-mode');

      const modeloW = mobile ? 160 : 260;
      const nCols = activeFields.length;

      // 2px for border (1px each side)
      const containerW = wrap.clientWidth;
      const availW = containerW - modeloW;

      // How many full columns fit at minimum width?
      const fitCols = Math.max(1, Math.floor(availW / MIN_COL_W));

      // Column width = exact division of available space by visible columns
      // This guarantees fitCols columns fill the viewport perfectly
      if (nCols <= fitCols) {
        // All columns fit — each gets equal share, no scroll needed
        computedColW = availW / nCols;
      } else {
        // More columns than fit — size so visible ones fill exactly
        computedColW = availW / fitCols;
      }

      // Total table width = modelo + all data columns at computed width
      const totalW = modeloW + (nCols * computedColW);
      table.style.width = totalW + 'px';

      const colgroup = document.createElement('colgroup');
      colgroup.innerHTML = '<col style="width:' + modeloW + 'px" />';
      activeFields.forEach(() => {
        colgroup.innerHTML += '<col style="width:' + computedColW + 'px" />';
      });
      table.prepend(colgroup);

      let html = '<tr>';
      html += '<th class="col-modelo col-sticky">Modelo</th>';
      activeFields.forEach(f => {
        const isSorted = tableSortId === f.id;
        const arrow = isSorted ? (tableSortAsc ? ' \u25B2' : ' \u25BC') : '';
        const thText = mobile ? f.shortLabel : f.label;
        html += '<th class="col-num col-sortable' + (isSorted ? ' th-sorted' : '') + '" data-sort-id="' + f.id + '">' + thText + arrow + '</th>';
      });
      html += '</tr>';
      thead.innerHTML = html;

      thead.querySelectorAll('.col-sortable').forEach(th => {
        th.addEventListener('click', () => handleSort(th.dataset.sortId));
      });

      updateScrollNav();
    }

    // ── Scroll navigation helpers ──
    function updateScrollNav() {
      // Show scroll nav when table overflows its container
      requestAnimationFrame(() => {
        const overflows = tableWrap.scrollWidth > tableWrap.clientWidth;
        if (overflows) {
          scrollNav.classList.add('visible');
          updateScrollBtnState();
        } else {
          scrollNav.classList.remove('visible');
        }
      });
    }

    function updateScrollBtnState() {
      const sl = tableWrap.scrollLeft;
      const maxScroll = tableWrap.scrollWidth - tableWrap.clientWidth;
      scrollLeftBtn.disabled = sl <= 2;
      scrollRightBtn.disabled = sl >= maxScroll - 2;
    }

    scrollLeftBtn.addEventListener('click', () => {
      // Snap scroll: move by exactly N columns so edges always align
      const step = computedColW * 2;
      const sl = tableWrap.scrollLeft;
      // Round down to nearest column boundary
      const target = Math.max(0, Math.round((sl - step) / computedColW) * computedColW);
      tableWrap.scrollTo({ left: target, behavior: 'smooth' });
    });
    scrollRightBtn.addEventListener('click', () => {
      const step = computedColW * 2;
      const sl = tableWrap.scrollLeft;
      const maxScroll = tableWrap.scrollWidth - tableWrap.clientWidth;
      const target = Math.min(maxScroll, Math.round((sl + step) / computedColW) * computedColW);
      tableWrap.scrollTo({ left: target, behavior: 'smooth' });
    });
    tableWrap.addEventListener('scroll', () => {
      if (scrollNav.classList.contains('visible')) updateScrollBtnState();
    });

    function renderRow(m) {
      const tr = document.createElement('tr');
      const isPicked = pickedIds.has(modelId(m));
      tr.className = 'ev-row' + (isPicked ? ' ev-row-picked' : '');
      tr.style.cursor = 'pointer';
      tr.addEventListener('click', () => togglePick(m));
      const activeFields = FIELDS.filter(f => selectedFields.includes(f.id));

      let html = '<td class="col-modelo col-sticky">' +
        '<div class="row-modelo-wrap">' +
          '<div class="row-photo"><img src="' + photoSrc(m) + '" alt="' + m.marca + ' ' + m.modelo + '" loading="lazy" /></div>' +
          '<div class="row-modelo-info">' +
            '<span class="row-marca">' + m.marca + '</span>' +
            '<span class="row-nombre">' + m.modelo + ' ' + m.variante + '</span>' +
            '<div class="row-badges">' + makeBadgesHtml(m, true) + '</div>' +
          '</div>' +
        '</div></td>';

      activeFields.forEach(f => {
        const val = getFieldVal(m, f);
        let display = fmtField(val, f);
        let unitHtml = '';
        if (f.unit && !f.fmt && !f.isText && val != null) {
          unitHtml = ' <small>' + f.unit + '</small>';
        }
        const isAuto = f.id === 'autonomia';
        const isPrice = f.id === 'pvp';
        html += '<td class="col-num' + (isPrice ? ' col-precio' : '') + (isAuto ? ' col-autonomia' : '') + '">' +
          (isAuto ? '<strong>' : '') + display + (isAuto ? '</strong>' : '') + unitHtml + '</td>';
      });

      tr.innerHTML = html;
      return tr;
    }

    // ═══════════════════════════════════════════════════════
    // MAIN UPDATE
    // ═══════════════════════════════════════════════════════
    function update() {
      let filtered = allModelos.filter(m => passesFilter(m));
      if (compareMode) filtered = filtered.filter(m => pickedIds.has(modelId(m)));
      sortModelos(filtered);

      const hasResults = filtered.length > 0;
      countEl.textContent = filtered.length;
      noResults.style.display = hasResults ? 'none' : 'block';

      computeBestValues();

      // Active comparison mode with 2+ cars → show comparative table (1·B)
      const useCompareTable = compareMode && filtered.length >= 2;
      if (useCompareTable) {
        fichasView.style.display = 'none';
        listadoView.style.display = 'none';
        compareView.style.display = '';
        renderCompareTable(filtered);
      } else {
        compareView.style.display = 'none';
        if (currentView === 'fichas') {
          fichasView.style.display = '';
          listadoView.style.display = 'none';
          grid.innerHTML = '';
          filtered.forEach(m => grid.appendChild(renderCard(m)));
        } else {
          fichasView.style.display = 'none';
          listadoView.style.display = '';
          renderTableHeaders();
          tbody.innerHTML = '';
          filtered.forEach(m => tbody.appendChild(renderRow(m)));
          updateScrollNav();
        }
      }
    }

    // ═══════════════════════════════════════════════════════
    // RESET
    // ═══════════════════════════════════════════════════════
    btnReset.addEventListener('click', () => {
      filterRanges = {};
      catVals = {};
      selectedFields = [...DEFAULT_IDS];
      tableSortId = null;
      tableSortAsc = true;
      allFieldsOn = false;
      pickedIds.clear();
      compareMode = false;
      updateCompareBar();
      document.getElementById('sort-select').value = '';
      btnReset.style.display = 'none';
      openPopover = null;
      renderPanel();
      update();
    });

    // ═══════════════════════════════════════════════════════
    // SORT SELECT (Fichas + Listado)
    // ═══════════════════════════════════════════════════════
    const sortSelect = document.getElementById('sort-select');
    sortSelect.addEventListener('change', () => {
      const v = sortSelect.value;
      if (!v) { tableSortId = null; tableSortAsc = true; }
      else {
        const parts = v.split('-');
        const dir = parts.pop();
        const fid = parts.join('-');
        tableSortId = fid;
        tableSortAsc = dir === 'asc';
      }
      update();
    });

    // ═══════════════════════════════════════════════════════
    // MODEL SELECTION & COMPARE
    // ═══════════════════════════════════════════════════════
    function modelId(m) { return m.marca + '|' + m.modelo + '|' + m.variante; }

    function togglePick(m) {
      const id = modelId(m);
      if (pickedIds.has(id)) pickedIds.delete(id);
      else pickedIds.add(id);
      updateCompareBar();
      update();
    }

    function updateCompareBar() {
      const n = pickedIds.size;
      compareBar.style.display = n > 0 ? '' : 'none';
      compareBar.classList.toggle('is-compare-mode', compareMode);
      // Update count number
      const countNum = document.getElementById('compare-count-num');
      if (countNum) countNum.textContent = n;
      // Update CTA label
      compareBtn.disabled = n < 2;
      const ctaText = compareBtn.querySelector('.sel-footer-cta-text');
      if (ctaText) ctaText.textContent = compareMode ? 'Ver todos' : 'Comparar';
      // Populate thumbnails
      const thumbsEl = document.getElementById('sel-thumbs');
      if (thumbsEl) {
        thumbsEl.innerHTML = '';
        modelos.forEach(m => {
          if (!pickedIds.has(modelId(m))) return;
          const thumb = document.createElement('div');
          thumb.className = 'sel-thumb';
          thumb.title = m.marca + ' ' + m.modelo + (m.variante ? ' ' + m.variante : '');
          thumb.innerHTML =
            '<div class="sel-thumb-img">' +
              '<img src="' + photoSrc(m) + '" alt="' + m.marca + ' ' + m.modelo + '" loading="lazy">' +
            '</div>' +
            '<button class="sel-thumb-remove" type="button" aria-label="Quitar ' + m.marca + ' ' + m.modelo + '">×</button>' +
            '<span class="sel-thumb-brand">' + m.marca + '</span>' +
            '<span class="sel-thumb-name">' + m.modelo + '</span>';
          thumb.querySelector('.sel-thumb-remove').addEventListener('click', (e) => {
            e.stopPropagation();
            pickedIds.delete(modelId(m));
            if (pickedIds.size < 2 && compareMode) compareMode = false;
            updateCompareBar();
            update();
          });
          thumbsEl.appendChild(thumb);
        });
      }
    }

    compareBtn.addEventListener('click', () => {
      if (compareMode) {
        compareMode = false;
        pickedIds.clear();
      } else {
        compareMode = true;
      }
      updateCompareBar();
      update();
    });

    compareClear.addEventListener('click', () => {
      pickedIds.clear();
      compareMode = false;
      updateCompareBar();
      update();
    });

    // ═══════════════════════════════════════════════════════
    // SEARCH
    // ═══════════════════════════════════════════════════════
    let searchDebounce = null;
    searchInput.addEventListener('input', () => {
      clearTimeout(searchDebounce);
      searchDebounce = setTimeout(() => {
        const q = searchInput.value.trim().toLowerCase();
        if (q.length < 2) { searchResultsEl.style.display = 'none'; searchResultsEl.innerHTML = ''; return; }
        const matches = allModelos.filter(m => {
          const full = (m.marca + ' ' + m.modelo + ' ' + m.variante).toLowerCase();
          return q.split(/\s+/).every(w => full.includes(w));
        }).slice(0, 8);
        if (matches.length === 0) { searchResultsEl.style.display = 'none'; searchResultsEl.innerHTML = ''; return; }
        searchResultsEl.innerHTML = matches.map(m => {
          const id = modelId(m);
          const picked = pickedIds.has(id);
          return '<button class="search-item' + (picked ? ' picked' : '') + '" data-mid="' + id + '">' +
            '<span class="si-marca">' + m.marca + '</span> ' +
            '<span class="si-modelo">' + m.modelo + ' ' + m.variante + '</span>' +
            (picked ? '<span class="si-check">✓</span>' : '') +
            '</button>';
        }).join('');
        searchResultsEl.style.display = 'block';
        searchResultsEl.querySelectorAll('.search-item').forEach(btn => {
          btn.addEventListener('mousedown', (e) => {
            e.preventDefault();
            const mid = btn.dataset.mid;
            const m = allModelos.find(x => modelId(x) === mid);
            if (m) togglePick(m);
            searchInput.dispatchEvent(new Event('input'));
          });
        });
      }, 150);
    });

    searchInput.addEventListener('blur', () => {
      setTimeout(() => { searchResultsEl.style.display = 'none'; }, 200);
    });
    searchInput.addEventListener('focus', () => {
      if (searchInput.value.trim().length >= 2) searchInput.dispatchEvent(new Event('input'));
    });

    // ═══════════════════════════════════════════════════════
    // INIT
    // ═══════════════════════════════════════════════════════
    renderPanel();
    update();

    // Recalculate table on resize (mobile ↔ desktop)
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (currentView === 'listado') update();
      }, 200);
    });

    // Top bar shadow when stuck
    const compTopbar = document.getElementById('filter-bar');
    if (compTopbar) {
      const sentinel = document.createElement('div');
      sentinel.style.height = '1px';
      compTopbar.parentNode.insertBefore(sentinel, compTopbar);
      const obs = new IntersectionObserver(([e]) => {
        compTopbar.classList.toggle('scrolled', !e.isIntersecting);
      }, { threshold: [0] });
      obs.observe(sentinel);
    }
  </script>
</Layout>

<!-- Use is:global so styles apply to JS-rendered elements -->
<style is:global>
  /* ══════════════════════════════════════════
     COMPARADOR TOKENS (scoped — do NOT put in global.css)
     ══════════════════════════════════════════ */
  :root {
    --photo-bg: linear-gradient(180deg, #0E0E0E, #1A1A1A);

    /* Panel zone — warm off-white, distinct from page cream */
