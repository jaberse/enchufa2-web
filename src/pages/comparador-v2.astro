    --panel-border: #D5D4CF;
    --panel-separator: #D5D4CF;

    /* Comparador-specific shadows */
    --card-shadow: none;
    --card-hover-shadow: 0 4px 16px rgba(0,0,0,0.08);
    --sticky-shadow: 0 0 0 1px rgba(0,0,0,0.08);
    --pop-shadow: 0 4px 20px rgba(0,0,0,0.12);
    --panel-locked-bg: rgba(245,197,24,0.05);
    --toggle-off-bg: #D0D0D0;
    --toggle-off-border: #BBBBBB;

    /* Badge tokens — Editorial High Contrast */
    --badge-nmc-bg: transparent;
    --badge-nmc-border: #4A7FBD;
    --badge-nmc-text: #2E5E8E;
    --badge-nca-bg: transparent;
    --badge-nca-border: #7B5FC8;
    --badge-nca-text: #5A3FA8;
    --badge-800v-bg: transparent;
    --badge-800v-border: #C87834;
    --badge-800v-text: #A06028;
    --badge-bcalor-bg: transparent;
    --badge-bcalor-border: #3A8C5A;
    --badge-bcalor-text: #2A6C44;
    --badge-lfp-bg: var(--yellow);
    --badge-lfp-border: var(--yellow);
    --badge-lfp-text: #111111;
    --badge-tipo-bg: transparent;
    --badge-tipo-border: #C0BFB9;
    --badge-tipo-text: #76756F;
    --badge-traccion-bg: #111111;
    --badge-traccion-border: #111111;
    --badge-traccion-text: #FAFAF8;
  }
  [data-theme="dark"] {
    --photo-bg: linear-gradient(180deg, #0A0A0A, #141414);
    --panel-bg: #111111;
    --panel-border: #1E1E1E;
    --panel-separator: #1E1E1E;

    --card-shadow: none;
    --card-hover-shadow: 0 4px 16px rgba(255,255,255,0.04);
    --sticky-shadow: 0 0 0 1px rgba(255,255,255,0.06);
    --pop-shadow: 0 4px 20px rgba(0,0,0,0.50);
    --panel-locked-bg: rgba(245,197,24,0.06);
    --toggle-off-bg: #333333;
    --toggle-off-border: #444444;

    /* Badge tokens dark */
    --badge-nmc-border: #6B9BD4;
    --badge-nmc-text: #8BB4E0;
    --badge-nca-border: #9B8AE0;
    --badge-nca-text: #B3A4F0;
    --badge-800v-border: #D4944A;
    --badge-800v-text: #E0A85E;
    --badge-bcalor-border: #5BBD7A;
    --badge-bcalor-text: #80D098;
    --badge-lfp-text: #111111;
    --badge-tipo-border: #444444;
    --badge-tipo-text: #808080;
    --badge-traccion-bg: #F0F0F0;
    --badge-traccion-border: #F0F0F0;
    --badge-traccion-text: #111111;
  }

  /* ══════════════════════════════════════════
     HERO BAND
     ══════════════════════════════════════════ */
  .hero-band {
    position: relative;
    width: 100%;
    height: clamp(200px, 30vh, 360px);
    overflow: hidden;
    background: var(--black);
  }
  .hero-band img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }
  .hero-band::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(to bottom, transparent 40%, rgba(17,17,17,.15) 70%, rgba(17,17,17,.5) 100%);
    pointer-events: none;
  }
  [data-theme="dark"] .hero-band::after {
    background: linear-gradient(to bottom, transparent 40%, rgba(13,15,20,.2) 70%, rgba(13,15,20,.7) 100%);
  }

  /* ══════════════════════════════════════════
     COMP SECTION — continuous panel, same as homepage
     ══════════════════════════════════════════ */
  .comp-section {
    position: relative;
    z-index: 10;
    margin-top: -4rem;
  }

  .comp-outer {
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: var(--hub-gutter);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }

  /* Block 1: Intro — rounded top, overlaps hero */
  .comp-intro {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px 12px 0 0;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 2vw, 1.75rem);
    box-shadow: 0 -8px 40px rgba(0,0,0,.12);
  }
  .comp-intro h2 {
    font-size: clamp(1.5rem, 2.8vw, 2.2rem);
    font-weight: 200;
    letter-spacing: -.03em;
    line-height: 1.1;
    margin-bottom: .4rem;
  }
  .comp-intro h2 em {
    font-family: var(--font-serif);
    font-style: italic;
  }
  .comp-intro p {
    font-size: .85rem;
    color: var(--text-secondary);
    max-width: 60ch;
    line-height: 1.6;
  }
  .comp-intro p strong {
    color: var(--yellow);
    font-weight: 600;
  }

  /* Block 2: Top bar — single row, sticky */
  .comp-topbar {
    background: var(--panel-bg);
