---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Search from '../components/Search.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

/*
  Articles ordered by publish date (newest first).
  When publishing a new article, add it to the top of this array.
  The first entry becomes the hero; entries 1-3 become the "previous" grid;
  the rest become the compact "older" row.
*/
const articles = [
  {
    slug: 'subvenciones-ayudas-ev-2026',
    title: 'Subvenciones y ayudas para eléctricos en 2026',
    description: 'Plan Auto+, ayudas autonómicas, etiqueta CERO, deducciones IRPF y exenciones fiscales. Todo lo que puedes pedir y cómo hacerlo.',
    category: 'Costes y Ahorro',
    categorySlug: 'costes-y-ahorro',
    date: 'Marzo 2026',
    readingTime: '10 min de lectura',
    image: '/articulos/subvenciones-ayudas-ev-2026/hero.webp?v=2',
    alt: 'Calculadora y documentos financieros sobre un escritorio — foto Unsplash',
  },
  {
    slug: 'neumaticos-coche-electrico',
    title: 'Neumáticos para coche eléctrico',
    description: 'Por qué los neumáticos importan más en un eléctrico: desgaste, autonomía, ruido y qué modelos elegir.',
    category: 'Mantenimiento',
    categorySlug: 'mantenimiento',
    date: 'Marzo 2026',
    readingTime: '10 min de lectura',
    image: '/articulos/neumaticos-coche-electrico/hero.webp',
    alt: 'Primer plano de rueda y neumático en coche deportivo — foto Unsplash',
  },
  {
    slug: 'coste-real-electrico',
    title: 'Cuánto cuesta realmente tener un eléctrico en España',
    description: 'TCO completo: electricidad, seguro, mantenimiento, impuestos y depreciación a 5 años.',
    category: 'Costes y Ahorro',
    categorySlug: 'costes-y-ahorro',
    date: 'Marzo 2026',
    readingTime: '12 min de lectura',
    image: '/articulos/coste-real-electrico/hero.webp',
    alt: 'Coche Tesla negro conduciendo por la carretera — foto Unsplash',
  },
  {
    slug: 'mantenimiento-ev-vs-combustion',
    title: 'Mantenimiento real de un EV vs combustión',
    description: 'Qué se cambia, cada cuánto y cuánto cuesta. Con datos de fabricantes, AAA y LeasePlan.',
    category: 'Mantenimiento',
    categorySlug: 'mantenimiento',
    date: 'Marzo 2026',
    readingTime: '11 min de lectura',
    image: '/articulos/mantenimiento-ev-vs-combustion/hero.webp',
    alt: 'Mecánico trabajando en un coche en un taller — foto Unsplash',
  },
  {
    slug: 'carga-rapida-espana',
    title: 'Carga rápida en España: la guía técnica definitiva',
    description: 'Redes, precios, compatibilidad y estrategia de carga rápida en España.',
    category: 'Carga',
    categorySlug: 'carga',
    date: 'Marzo 2026',
    readingTime: '12 min de lectura',
    image: '/articulos/carga-rapida-espana/hero.webp',
    alt: 'Coche amarillo enchufado a una estación de carga rápida — foto Unsplash',
  },
  {
    slug: 'tarifas-carga-casa',
    title: 'Cuánto cuesta cargar un coche eléctrico en casa en 2026',
    description: 'Tarifas eléctricas, franjas horarias, wallbox y paneles solares.',
    category: 'Carga',
    categorySlug: 'carga',
    date: 'Marzo 2026',
    readingTime: '11 min de lectura',
    image: '/articulos/tarifas-carga-casa/hero.webp',
    alt: 'Mujer enchufando coche eléctrico en cargador de pared doméstico — foto Unsplash',
  },
  {
    slug: 'vida-bateria-ev',
    title: 'La guía para cargar la batería de tu eléctrico sin acortarle la vida',
    description: 'NMC vs LFP, temperatura, carga rápida y datos reales de degradación.',
    category: 'Tecnología',
    categorySlug: 'tecnologia',
    date: 'Marzo 2026',
    readingTime: '14 min de lectura',
    image: '/articulos/vida-bateria-ev/hero.webp',
    alt: 'Motor de coche eléctrico con cableado visible y componentes de batería — foto Unsplash',
  },
];

const latest = articles[0];
const previous = articles.slice(1, 4);
const older = articles.slice(4);
---

<Layout
  title="enchufa2 — Movilidad eléctrica con rigor"
  description="La referencia técnica en español sobre movilidad eléctrica. Guías basadas en datos y estudios científicos para propietarios de coches eléctricos."
>
  <Header />
  <Search />
  <main>

    <!-- ═══ HERO: Último artículo publicado (overlay, contained) ═══ -->
    <div class="hero-wrapper">
      <section class="hero-overlay">
        <a href={`/articulos/${latest.slug}`} class="hero-image-link">
          <img src={latest.image} alt={latest.alt} loading="eager" />
        </a>
        <div class="hero-overlay-content">
          <div class="hero-label">
            <span class="hero-label-line" aria-hidden="true"></span>
            Último artículo
          </div>
          <h1><a href={`/articulos/${latest.slug}`}>{latest.title}</a></h1>
          <p class="hero-desc">{latest.description}</p>
          <div class="hero-meta">{latest.category} · {latest.date} · {latest.readingTime}</div>
          <a href={`/articulos/${latest.slug}`} class="hero-cta">Leer artículo &rarr;</a>
        </div>
      </section>
    </div>

    <!-- ═══ ARTÍCULOS ANTERIORES (con imagen) ═══ -->
    <section class="prev-section">
      <div class="hub-width">
        <div class="section-header">
          <h2>Artículos anteriores</h2>
          <a href="/categoria/tecnologia" class="section-link">Ver todos &rarr;</a>
        </div>
        <div class="prev-grid">
          {previous.map((a) => (
            <a href={`/articulos/${a.slug}`} class="prev-card">
              <div class="prev-image">
                <img src={a.image} alt={a.alt} loading="lazy" />
              </div>
              <div class="prev-body">
                <span class="prev-badge">{a.category}</span>
                <h3>{a.title}</h3>
                <p>{a.description}</p>
                <div class="prev-meta">{a.date} · {a.readingTime}</div>
              </div>
            </a>
          ))}
        </div>

        <!-- Older articles (compact, no image) -->
        <div class="older-grid">
          {older.map((a) => (
            <a href={`/articulos/${a.slug}`} class="older-card">
              <span class="prev-badge">{a.category}</span>
              <h3>{a.title}</h3>
              <div class="older-meta">{a.date} · {a.readingTime}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ CATEGORY TILES ═══ -->
    <section class="categories">
      <div class="hub-width">
        <div class="section-header">
          <h2>Explora por tema</h2>
        </div>
        <div class="cat-grid">
          <a href="/categoria/antes-de-comprar" class="cat-card">
            <div class="cat-icon">&#128269;</div>
            <h3>Antes de comprar</h3>
            <div class="cat-count">Próximamente</div>
            <div class="cat-arrow">&rarr;</div>
          </a>
          <a href="/categoria/tecnologia" class="cat-card">
            <div class="cat-icon">&#9889;</div>
            <h3>Tecnología</h3>
            <div class="cat-count">1 artículo</div>
            <div class="cat-arrow">&rarr;</div>
          </a>
          <a href="/categoria/carga" class="cat-card">
            <div class="cat-icon">&#128268;</div>
            <h3>Carga</h3>
            <div class="cat-count">2 artículos</div>
            <div class="cat-arrow">&rarr;</div>
          </a>
          <a href="/categoria/costes-y-ahorro" class="cat-card">
            <div class="cat-icon">&#128176;</div>
            <h3>Costes y Ahorro</h3>
            <div class="cat-count">2 artículos</div>
            <div class="cat-arrow">&rarr;</div>
          </a>
          <a href="/categoria/mantenimiento" class="cat-card">
            <div class="cat-icon">&#128295;</div>
            <h3>Mantenimiento</h3>
            <div class="cat-count">2 artículos</div>
            <div class="cat-arrow">&rarr;</div>
          </a>
          <a href="/categoria/en-ruta" class="cat-card">
            <div class="cat-icon">&#128663;</div>
            <h3>En ruta</h3>
            <div class="cat-count">Próximamente</div>
            <div class="cat-arrow">&rarr;</div>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══ NEWSLETTER ═══ -->
    <section class="newsletter" id="newsletter">
      <div class="nl-inner">
        <h2>Cada artículo nuevo, <em>en tu bandeja</em></h2>
        <p>Sin spam, sin relleno. Solo te escribimos cuando publicamos algo que merece tu tiempo.</p>
        <form class="nl-form" action="#" method="post">
          <input type="email" placeholder="tu@email.com" required aria-label="Tu email" />
          <button type="submit">Suscribir</button>
        </form>
        <div class="nl-note">1-2 emails al mes. Baja en un click.</div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ═══ HERO — Overlay (text on image, contained) ═══ */
  .hero-wrapper {
    background: var(--black);
    padding: clamp(1rem, 2vw, 2rem) clamp(1rem, 3vw, 2.5rem) clamp(1.5rem, 2.5vw, 2.5rem);
  }

  .hero-overlay {
    position: relative;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    height: clamp(380px, 48vh, 540px);
    overflow: hidden;
    border-radius: 10px;
  }

  .hero-image-link {
    display: block;
    width: 100%;
    height: 100%;
  }
  .hero-image-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .hero-overlay:hover .hero-image-link img {
    transform: scale(1.04);
  }

  /* Dark gradient: transparent left → dark right for text readability */
  .hero-overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(17,17,17,0.15) 0%,
      rgba(17,17,17,0.5) 40%,
      rgba(17,17,17,0.88) 70%,
      rgba(17,17,17,0.95) 100%
    );
    pointer-events: none;
  }

  .hero-overlay-content {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 50%;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem clamp(2rem, 5vw, 4rem) 3rem 2rem;
    z-index: 2;
    color: var(--white);
  }

  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--yellow);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .hero-label-line {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--yellow);
  }

  .hero-overlay-content h1 {
    font-family: var(--font-sans);
    font-weight: 200;
    font-size: clamp(1.6rem, 3.2vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }
  .hero-overlay-content h1 a {
    color: inherit;
    transition: opacity 0.2s;
  }
  .hero-overlay-content h1 a:hover { opacity: 0.85; }

  .hero-desc {
    font-size: clamp(0.85rem, 1.2vw, 0.95rem);
    color: rgba(250, 250, 248, 0.55);
    line-height: 1.7;
    font-weight: 300;
    margin-bottom: 1.25rem;
    max-width: 38ch;
  }

  .hero-meta {
    font-size: 0.68rem;
    color: rgba(250, 250, 248, 0.25);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--black);
    padding: 0.7rem 1.5rem;
    background: var(--yellow);
    border-radius: 4px;
    width: fit-content;
    transition: all 0.2s;
  }
  .hero-cta:hover {
    filter: brightness(1.05);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(245, 197, 24, 0.3);
  }

  /* ═══ PREVIOUS ARTICLES ═══ */
  .prev-section {
    padding: clamp(2rem, 4vw, 3rem) 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
  }
  .section-header h2 {
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .section-link {
    font-size: 0.72rem;
    color: var(--gray-400);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 0.2s;
  }
  .section-link:hover {
    color: var(--yellow);
  }

  .prev-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .prev-card {
    background: var(--surface);
    border-radius: var(--radius);
    overflow: hidden;
    border-bottom: 3px solid var(--gray-200);
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .prev-card:hover {
    border-bottom-color: var(--yellow);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .prev-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .prev-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .prev-card:hover .prev-image img {
    transform: scale(1.04);
  }

  .prev-body {
    padding: 1.25rem;
  }

  .prev-badge {
    display: inline-block;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    padding: 0.2em 0.55em;
    background: var(--yellow-glow);
    color: var(--yellow-text);
    border-radius: 3px;
    margin-bottom: 0.4rem;
  }

  .prev-body h3 {
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin-bottom: 0.35rem;
  }
  .prev-body p {
    font-size: 0.8rem;
    color: var(--gray-500);
    line-height: 1.55;
    font-weight: 300;
  }
  .prev-meta {
    font-size: 0.65rem;
    color: var(--gray-400);
    margin-top: 0.5rem;
  }

  /* ═══ OLDER ARTICLES (compact) ═══ */
  .older-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .older-card {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 1.25rem;
    border-bottom: 3px solid var(--gray-200);
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .older-card:hover {
    border-bottom-color: var(--yellow);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }
  .older-card h3 {
    font-size: 0.88rem;
    font-weight: 400;
    line-height: 1.35;
  }
  .older-meta {
    font-size: 0.65rem;
    color: var(--gray-400);
    margin-top: 0.35rem;
  }

  /* ═══ CATEGORY TILES ═══ */
  .categories {
    padding: 0.5rem 0 clamp(2rem, 4vw, 3rem);
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(175px, 1fr));
    gap: 0.75rem;
  }
  .cat-card {
    background: var(--surface);
    border-radius: var(--radius);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    cursor: pointer;
    position: relative;
    border-bottom: 3px solid var(--gray-200);
  }
  .cat-card:hover {
    border-bottom-color: var(--yellow);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }
  .cat-card:hover .cat-icon { transform: scale(1.08); }
  .cat-card:hover .cat-arrow { opacity: 1; transform: translateX(0); }
  .cat-icon {
    font-size: 1.6rem;
    margin-bottom: 0.3rem;
    transition: transform 0.3s;
  }
  .cat-card h3 { font-size: 0.88rem; font-weight: 500; }
  .cat-count { font-size: 0.68rem; color: var(--gray-400); }
  .cat-arrow {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 0.85rem;
    opacity: 0;
    color: var(--yellow);
    transition: all 0.25s;
    transform: translateX(-4px);
  }

  /* ═══ NEWSLETTER ═══ */
  .newsletter {
    padding: clamp(3rem, 6vw, 4.5rem) var(--hub-gutter);
    background: var(--black);
    color: var(--white);
    text-align: center;
  }
  .nl-inner {
    max-width: 460px;
    margin: 0 auto;
  }
  .newsletter h2 {
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .newsletter h2 em {
    font-family: var(--font-serif);
    font-style: italic;
  }
  .newsletter p {
    color: var(--gray-500);
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .nl-form {
    display: flex;
    gap: 0;
    max-width: 380px;
    margin: 0 auto;
  }
  .nl-form input {
    flex: 1;
    padding: 0.75rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 300;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-right: none;
    color: var(--white);
    outline: none;
    border-radius: 6px 0 0 6px;
  }
  .nl-form input::placeholder { color: var(--gray-600); }
  .nl-form input:focus { border-color: var(--yellow); }
  .nl-form button {
    padding: 0.75rem 1.25rem;
    background: var(--yellow);
    color: var(--black);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 1px solid var(--yellow);
    cursor: pointer;
    border-radius: 0 6px 6px 0;
    transition: filter 0.2s;
  }
  .nl-form button:hover { filter: brightness(1.05); }
  .nl-note {
    font-size: 0.68rem;
    color: var(--gray-600);
    margin-top: 0.6rem;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 860px) {
    .hero-wrapper { padding: 0.75rem; }
    .hero-overlay { height: auto; min-height: 420px; border-radius: 8px; }
    .hero-overlay::after {
      background: linear-gradient(
        0deg,
        rgba(17,17,17,0.95) 0%,
        rgba(17,17,17,0.8) 50%,
        rgba(17,17,17,0.2) 100%
      );
    }
    .hero-overlay-content {
      width: 100%;
      max-width: none;
      top: auto;
      bottom: 0;
      padding: 2rem 1.5rem;
    }
    .prev-grid { grid-template-columns: 1fr; }
    .older-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
    .older-grid { grid-template-columns: 1fr; }
    .nl-form { flex-direction: column; }
    .nl-form input {
      border-right: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 6px;
    }
    .nl-form button {
      border-radius: 6px;
      margin-top: 0.5rem;
    }
  }
</style>
