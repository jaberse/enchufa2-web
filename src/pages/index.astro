const totalGuides = categories.reduce((sum, cat) => sum + cat.guides.length, 0);
---

<Layout
  title="enchufa2 — Movilidad eléctrica con rigor"
  description="La referencia técnica en español sobre movilidad eléctrica. Guías basadas en datos y estudios científicos para propietarios de coches eléctricos."
>
  <Header />
  <Search />
  <main>

    <!-- ═══ HERO BAND ═══ -->
    <div class="hero-band">
      <div class="hero-band-light">
        <img src="/hero-light.png" alt="Espacio con logo enchufa2 en relieve, cargador amarillo y cable enrollado" loading="eager"/>
      </div>
      <div class="hero-band-dark">
        <img src="/hero-dark.png" alt="Espacio con logo enchufa2 en relieve — modo oscuro" loading="eager"/>
      </div>
    </div>

    <!-- ═══ GUÍAS SECTION (solapado sobre hero) ═══ -->
    <section class="guias-section">

      <!-- Cabecera solapada -->
      <div class="guias-intro">
        <div class="guias-intro-card reveal">
          <div class="guias-intro-text">
            <h2>Todo lo que necesitas saber<br>sobre tu <em>eléctrico</em></h2>
            <p>{totalGuides} guías organizadas por las 5 dudas reales que frenan a los conductores. Basadas en datos, con fuentes citadas, sin rodeos.</p>
          </div>
          <div class="guias-pills">
            <span class="guias-pill"><strong>{totalGuides}</strong>&nbsp;guías</span>
            <span class="guias-pill"><strong>141</strong>&nbsp;preguntas</span>
            <span class="guias-pill"><strong>47</strong>&nbsp;fuentes</span>
          </div>
        </div>
      </div>

      <!-- 5 bloques de categoría -->
      <div class="cat-blocks">
        {categories.map((cat) => (
          <div class="cat-block reveal" id={cat.id}>
            <div class="cat-band">
              <img src={cat.photo} alt="" loading="lazy"/>
              <div class="cat-band-overlay dark-bg">
                <div>
                  <div class="cat-num">{cat.num} — {cat.label}</div>
                  <div class="cat-question" set:html={cat.question}></div>
                </div>
              </div>
            </div>
            <div class="cat-body">
              <div class="cat-sidebar">
                <div class="cat-sidebar-label">Barrera de adopción</div>
                <div class="cat-barrier-block">
                  <div class="cat-barrier-pct">{cat.barrierpct}</div>
                  <div class="cat-barrier-desc">{cat.barrierdesc}<small>{cat.barriersource}</small></div>
                </div>
                <p class="cat-sidebar-text">{cat.sidebarbio}</p>
              </div>
              <div class="cat-guides">
                <div class="guide-list">
                  {cat.guides.map((guide) => (
                    <a href="#" class="guide-card" style={`--card-photo: url('${guide.photo}')`}>
                      <span class="guide-num">{guide.num}</span>
                      <span class="guide-tag">{guide.tag}</span>
                      <h3 class="guide-title">{guide.title}</h3>
                      <div class="guide-footer">
                        <span class="guide-reading">{guide.time}</span>
                        <span class="guide-arrow">→</span>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            </div>
            <div class="cat-see-all"><a href={`/guias/${cat.id}`}>Ver las {cat.guides.length} guías →</a></div>
          </div>
        ))}
      </div><!-- /cat-blocks -->
    </section>

    <!-- ═══ NEWSLETTER ═══ -->
    <section class="newsletter" id="newsletter">
      <div class="nl-inner">
        <h2>Cada guía nueva, <em>en tu bandeja</em></h2>
        <p>Sin spam, sin relleno. Solo te escribimos cuando publicamos algo que merece tu tiempo.</p>
        <form class="nl-form" action="#" method="post">
          <input type="email" placeholder="tu@email.com" required aria-label="Tu email" />
          <button type="submit">Suscribir</button>
        </form>
        <div class="nl-note">1-2 emails al mes. Baja en un click.</div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script is:inline>
  (function() {
    // Scroll reveal with IntersectionObserver
    const revealElements = document.querySelectorAll('.reveal');
    if (revealElements.length > 0) {
      const observerOptions = {
        threshold: 0.06,
        rootMargin: '0px 0px -20px 0px'
      };
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);
      revealElements.forEach((el) => observer.observe(el));
    }

    // Scroll progress bar at top
    const scrollProgress = document.createElement('div');
    scrollProgress.className = 'scroll-progress';
    scrollProgress.id = 'scrollProgress';
    document.body.prepend(scrollProgress);

    window.addEventListener('scroll', () => {
      const scrollTop = window.scrollY;
      const totalHeight = document.body.scrollHeight - window.innerHeight;
      if (totalHeight > 0) {
        const progress = (scrollTop / totalHeight) * 100;
        scrollProgress.style.width = progress + '%';
      }
    }, { passive: true });

    // Subtle parallax on hero band
    const heroBand = document.querySelector('.hero-band');
    if (heroBand) {
      const heroImages = heroBand.querySelectorAll('img');
      window.addEventListener('scroll', () => {
        const rect = heroBand.getBoundingClientRect();
        if (rect.bottom < 0 || rect.top > window.innerHeight) return;
        const progress = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
        const offset = (progress - 0.5) * 24;
        heroImages.forEach((img) => {
          img.style.transform = `translateY(${offset}px) scale(1.04)`;
        });
      }, { passive: true });
    }
  })();
</script>

<style>
  /* Scroll progress bar */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--yellow);
    z-index: 300;
    box-shadow: 0 0 8px rgba(245, 197, 24, 0.4);
    transition: width 0.1s linear;
  }
</style>

<style>
  /* ═══ HERO BAND — full-width image with dark/light theme crossfade ═══ */
  .hero-band {
    position: relative;
    width: 100%;
    height: clamp(180px, 38vh, 420px);
    overflow: hidden;
    background: var(--black);
  }

  .hero-band img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
    transition: opacity 0.6s ease;
    will-change: transform;
  }

  .hero-band-light {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
  }

  .hero-band-dark {
    position: absolute;
    inset: 0;
    z-index: 2;
    opacity: 0;
  }

  :global([data-theme="dark"]) .hero-band-dark {
    opacity: 1;
  }

  :global([data-theme="dark"]) .hero-band-light img {
    opacity: 0;
  }

  /* Gradient overlay at bottom */
  .hero-band::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(17, 17, 17, 0.15) 70%,
      rgba(17, 17, 17, 0.5) 100%
    );
    pointer-events: none;
  }

  :global([data-theme="dark"]) .hero-band::after {
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(13, 15, 20, 0.2) 70%,
      rgba(13, 15, 20, 0.7) 100%
    );
  }

  /* ═══ GUÍAS SECTION — Negative margin to overlap hero ═══ */
  .guias-section {
    position: relative;
    z-index: 10;
    margin-top: -4rem;
  }

  .guias-intro {
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: var(--hub-gutter);
    margin-bottom: 0;
  }

  .guias-intro-card {
    background: var(--surface);
    border-radius: 12px 12px 0 0;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 2.5vw, 2rem);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    box-shadow: 0 -8px 40px rgba(0, 0, 0, 0.12);
  }

  .guias-intro-text h2 {
    font-size: clamp(1.5rem, 2.8vw, 2.2rem);
    font-weight: 200;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .guias-intro-text h2 em {
    font-family: var(--font-serif);
    font-style: italic;
  }

  .guias-intro-text p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    max-width: 50ch;
    line-height: 1.65;
  }

  .guias-pills {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .guias-pill {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.4rem 0.9rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .guias-pill strong {
    color: var(--yellow);
    font-weight: 600;
    font-size: 0.8rem;
  }

  /* ═══ CATEGORY BLOCKS ═══ */
  .cat-blocks {
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: var(--hub-gutter);
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .cat-block {
    border: 1px solid var(--border);
    border-top: none;
    background: var(--surface);
    overflow: hidden;
  }

  .cat-block:last-child {
    border-radius: 0 0 12px 12px;
  }

  /* Photo band per category */
  .cat-band {
    position: relative;
    height: 180px;
    overflow: hidden;
    cursor: default;
  }

  .cat-band img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .cat-block:hover .cat-band img {
    transform: scale(1.03);
  }

  .cat-band-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1.5rem clamp(1.25rem, 3vw, 2rem);
  }

  .cat-band-overlay.dark-bg {
    background: linear-gradient(90deg, rgba(17, 17, 17, 0.82) 0%, rgba(17, 17, 17, 0.4) 55%, transparent 100%);
  }

  .cat-band-overlay.light-bg {
    background: linear-gradient(90deg, rgba(248, 246, 241, 0.9) 0%, rgba(248, 246, 241, 0.5) 55%, transparent 100%);
  }

  .cat-num {
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.7;
    margin-bottom: 0.3rem;
  }

  .cat-question {
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 200;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .cat-question em {
    font-family: var(--font-serif);
    font-style: italic;
  }

  .dark-bg .cat-num,
  .dark-bg .cat-question {
    color: var(--white);
  }

  .light-bg .cat-num,
  .light-bg .cat-question {
    color: var(--black);
  }

  /* Category body */
  .cat-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    border-top: 1px solid var(--border);
  }

  .cat-sidebar {
    padding: 1.5rem clamp(1rem, 2.5vw, 1.75rem);
    border-right: 1px solid var(--border);
    background: #2A2A28;
    color: #F0EFEB;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .cat-sidebar .cat-sidebar-label {
    color: #A5A49E;
  }
  .cat-sidebar .cat-sidebar-text {
    color: #D5D4CF;
  }
  .cat-sidebar .cat-barrier-desc {
    color: #C0BFB9;
  }
  .cat-sidebar .cat-barrier-desc small {
    color: #8A8985;
  }

  .cat-sidebar-label {
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 500;
  }

  .cat-barrier-block {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .cat-barrier-pct {
    font-size: 2.2rem;
    font-weight: 200;
    letter-spacing: -0.04em;
    color: var(--yellow);
    line-height: 1;
  }

  .cat-barrier-desc {
    font-size: 0.72rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .cat-barrier-desc small {
    font-size: 0.58rem;
    color: var(--text-muted);
    display: block;
    margin-top: 0.2rem;
  }

  .cat-sidebar-text {
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.65;
    font-weight: 300;
  }

  .cat-guides {
    padding: 1.25rem clamp(1rem, 2.5vw, 1.75rem);
  }

  /* Guide cards — hover reveals photo */
  .guide-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
    gap: 0.6rem;
  }

  .guide-card {
    position: relative;
    overflow: hidden;
