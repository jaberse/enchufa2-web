    function renderStars(val, size) {
      if (val == null) return '<span class="stars-na">Sin datos</span>';
      const sz = size || '';
      const full = Math.floor(val);
      const half = (val % 1) >= 0.25 && (val % 1) < 0.75 ? 1 : 0;
      const adjustedFull = (val % 1) >= 0.75 ? full + 1 : full;
      const empty = 5 - adjustedFull - half;
      let html = '<span class="stars' + (sz ? ' stars-' + sz : '') + '" data-rating="' + val + '">';
      for (let i = 0; i < adjustedFull; i++) html += '<span class="star star-full">★</span>';
      for (let i = 0; i < half; i++) html += '<span class="star star-half">★</span>';
      for (let i = 0; i < empty; i++) html += '<span class="star star-empty">★</span>';
      html += '</span>';
      return html;
    }

