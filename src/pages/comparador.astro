        { label:'Ayuda Plan Auto+',        key:'ayuda_plan_auto_eur',   fmt:'eur',  dir:'max' },
        { label:'PVP con Plan Auto+',      key:'pvp_con_plan_auto_eur', fmt:'eur',  dir:'min' },
        { label:'Elegibilidad Auto+',      key:'plan_auto_elegible',    isText:true },
        { label:'Ensamblaje',              key:'pais_ensamblaje',       isText:true },
        { label:'Batería UE',              key:'bateria_ensamblaje_ue', isText:true, derive:(m)=>{ const v=m.bateria_ensamblaje_ue; return v===true?'Sí':v===false?'No':null; } },
        { label:'Garantía batería (años)', key:'garantia_bateria',      unit:'años', dir:'max', dec:0, derive:(m)=>{ const s=m.garantia_bateria; if(!s) return null; const x=String(s).match(/(\d+)\s*año/i); return x?parseInt(x[1],10):null; } },
        { label:'Garantía batería (km)',   key:'garantia_bateria',      unit:'km',  dir:'max', dec:0, fmt:'mmDot', derive:(m)=>{ const s=m.garantia_bateria; if(!s) return null; const x=String(s).match(/([\d.]+)\s*km/i); return x?parseInt(x[1].replace(/\./g,''),10):null; } },
        { label:'Garantía vehículo',       key:'garantia_vehiculo',     isText:true, placeholder:'por verificar' },
      ]},
      { num:'05', name:'Fiabilidad y garantía', rows:[
        { label:'Fiabilidad',              key:'fiabilidad_estrellas',          dir:'max', dec:1, isStars:true },
        { label:'Garantía (valoración)',   key:'garantia_estrellas',            dir:'max', dec:1, isStars:true },
        { label:'TÜV Report',             key:'fiabilidad_tuv_pct',            unit:'% defectos', dir:'min', dec:1 },
        { label:'ADAC Pannenstatistik',    key:'fiabilidad_adac_idx',           unit:'averías/1k', dir:'min', dec:1 },
        { label:'Garantía vehículo (años)',key:'garantia_vehiculo_anos',        unit:'años', dir:'max', dec:0 },
        { label:'Garantía vehículo (km)',  key:'garantia_vehiculo_km',          unit:'km', dir:'max', dec:0, fmt:'mmDot' },
        { label:'Garantía batería (%SoH)', key:'garantia_bateria_pct',          unit:'%', dir:'max', dec:0 },
      ]},
    ];

    function formatCellVal(m, row) {
      const val = row.derive ? row.derive(m) : m[row.key];
      if (val == null || val === '') {
        if (row.key === 'fiabilidad_estrellas') {
          return '<span class="pending-data" title="Modelo sin datos en TÜV Report 2026 / ADAC 2025">Pendiente TÜV 2027</span>';
        }
        return '<span class="cmp-placeholder">' + (row.placeholder || '—') + '</span>';
      }
      if (row.isStars) {
        return renderStars(Number(val), 'sm');
      }
      if (row.isText) {
        return String(val) + (row.unit ? '\u00a0' + row.unit : '');
      }
      let numStr;
      if (row.fmt === 'eur') {
        numStr = Number(val).toLocaleString('es-ES') + '\u00a0€';
      } else if (row.fmt === 'mmDot') {
        numStr = Number(val).toLocaleString('es-ES').replace(/,/g,'.') + (row.unit ? '\u00a0' + row.unit : '');
      } else {
        const n = Number(val);
        numStr = (row.dec != null ? n.toFixed(row.dec) : n.toString()) + (row.unit ? '\u00a0' + row.unit : '');
      }
      return numStr;
    }

    function computeRowBest(picked, row) {
      if (row.isText || !row.dir) return null;
      const vals = picked.map(m => row.derive ? row.derive(m) : m[row.key]).filter(v => v != null && !isNaN(Number(v))).map(Number);
      if (vals.length === 0) return null;
      return row.dir === 'max' ? Math.max(...vals) : Math.min(...vals);
    }

