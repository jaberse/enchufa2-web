---
// src/pages/comparador.astro
// Comparador unificado: especificaciones técnicas + coste de propiedad (TCO).
//
// Una sola página con toggle Specs ↔ TCO (thumb amarillo animado). Selector
// de garaje (hasta 4 coches) con modal buscable, barra de escenario editable
// (km/año, años, €/kWh casa/fuera, % casa) y recálculo TCO en vivo sobre el
// motor canónico del repo (src/lib/tco/calculadora.mjs).
//
// La URL admite ?mode=tco o ?mode=specs para entrar directo en una vista —
// lo resuelve el cliente (client.mjs) leyendo window.location.search.
//
// Selección inicial hardcoded con 4 coches que cubren la narrativa
// "del utilitario al premium" y tienen TCO disponible. El usuario puede
// añadir/quitar coches desde el garaje.

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ComparadorHeader from '../components/comparador/ComparadorHeader.astro';
import CatalogView from '../components/comparador/CatalogView.astro';
import SelectionBar from '../components/comparador/SelectionBar.astro';
import ScenarioBar from '../components/comparador/ScenarioBar.astro';
import SpecsTable from '../components/comparador/SpecsTable.astro';
import SummaryStrip from '../components/comparador/SummaryStrip.astro';
import TCOGrid from '../components/comparador/TCOGrid.astro';
import TCOCard from '../components/comparador/TCOCard.astro';
import {
  cargarCatalogoSpecs,
  cargarParesTCO,
  cargarDatosCliente,
  PERFIL_ESTANDAR,
} from '../lib/comparador/loader.mjs';
import { calcularTCO } from '../lib/tco/calculadora.mjs';
import '../styles/global.css';

// Payload JSON para el cliente: catálogo specs + pares TCO pre-computados
// por horizonte, más perfil estándar. Se serializa inline en la página y
// lo consume client.mjs via #cmp-data.
const datosCliente = cargarDatosCliente();

// ──────────────────────────────────────────────────────────────────────
// Selección narrativa inicial: 4 coches con TCO disponible que cuentan la
// historia "el precio no es el TCO". Del utilitario A al SUV premium.
// El usuario los puede cambiar desde el garaje.
// ──────────────────────────────────────────────────────────────────────
const SELECCION = [
  'tesla-model-3-rwd-highland',
  'bmw-ix1-xdrive30',
  'citroen-e-c3-you',
  'hyundai-inster-long-range',
];

const paresTCO = cargarParesTCO();
const catalogoSpecs = cargarCatalogoSpecs();

const parsSeleccionados = SELECCION.map((slug) => {
  const p = paresTCO.find((x) => x.slug === slug);
  if (!p) throw new Error(`Comparador: par TCO no encontrado para ${slug}`);
  return p;
});

// ── Cálculo TCO SSR (perfil estándar 5 años, 15.000 km/año) ───────────
const cartas = parsSeleccionados.map((par) => {
  const bev = par.horizontes[5].bev;
  const ice = par.horizontes[5].ice;
  const brBev = calcularTCO(bev);
  const brIce = calcularTCO(ice);
  return {
    par,
    bev,
    ice,
    totalBev: brBev.tco_total_eur,
    totalIce: brIce.tco_total_eur,
  };
});

const totales = cartas.map((c) => c.totalBev);
const minTotal = Math.min(...totales);
const ganadoraIdx = totales.indexOf(minTotal);

const totalsForStrip = cartas.map((c) => ({
  id: c.par.slug,
  nombre: c.par.nombreBev,
  total: c.totalBev,
  tren: 'BEV' as const,
}));

// ── Specs cars ────────────────────────────────────────────────────────
const specsCars = SELECCION.map((slug) => {
  const c = catalogoSpecs.find((x) => x.slug === slug);
  if (!c) throw new Error(`Comparador: specs no encontradas para ${slug}`);
  return c;
});

const escenarioMeta = `${PERFIL_ESTANDAR.horizonte_anios} años · ${PERFIL_ESTANDAR.km_anual.toLocaleString('es-ES')} km/año · Madrid`;

const title = 'Comparador de coches eléctricos — enchufa2';
const description =
  'Compara 63 coches eléctricos con sus specs y el coste real a 5 años. Edita km/año, años y €/kWh y recalcula el TCO en vivo.';
---

<Layout {title} {description}>
  <Header />
  <main id="main">
    <div class="dirA">
      <!-- Arrancamos en modo catálogo por defecto (landing con el listado
           visible); si la URL trae ?mode=specs o ?mode=tco el cliente lo
           conmuta al cargar. -->
      <ComparadorHeader modo="catalogo" />

      <!-- ScenarioBar solo se muestra en vista TCO; el cliente controla la
           visibilidad a través de data-show-when-mode. -->
      <div class="dirA__scen" data-show-when-mode="tco" style="display: none;">
        <ScenarioBar
          kmAnual={PERFIL_ESTANDAR.km_anual}
          anios={PERFIL_ESTANDAR.horizonte_anios}
          precioKwhCasa={PERFIL_ESTANDAR.precio_kwh_eur}
          precioKwhFuera={0.45}
          pctCasa={80}
        />
      </div>

      <!-- ── Panel CATÁLOGO (modo por defecto) ── -->
      <section
        class="dirA__panel"
        id="panel-catalogo"
        role="tabpanel"
        aria-labelledby="tab-catalogo"
        data-panel="catalogo"
      >
        <CatalogView />
      </section>

      <!-- ── Panel SPECS (modo por defecto) ── -->
      <section
        class="dirA__panel"
        id="panel-specs"
        role="tabpanel"
        aria-labelledby="tab-specs"
        data-panel="specs"
      >
        <!-- Toolbar "Datos y vista": abre drawer con toggle de filas extra. -->
        <div class="dirA__specs-toolbar">
          <div class="dirA__specs-toolbar-left">
            <button
              type="button"
              class="vistabtn"
              data-specs-vistabtn
              aria-expanded="false"
              aria-controls="specs-vistadrawer"
            >
              <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
                <circle cx="4" cy="3.5" r="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                <line x1="5.5" y1="3.5" x2="13" y2="3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="1" y1="3.5" x2="2.5" y2="3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="10" cy="7" r="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                <line x1="1" y1="7" x2="8.5" y2="7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="11.5" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="5.5" cy="10.5" r="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/>
                <line x1="7" y1="10.5" x2="13" y2="10.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                <line x1="1" y1="10.5" x2="4" y2="10.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
              <span>Datos y vista</span>
              <span class="vistabtn__count" data-specs-vistacount></span>
            </button>
          </div>
          <div class="dirA__specs-toolbar-right">
            <span class="dirA__specs-hint">12 filas · toca para añadir más</span>
          </div>
        </div>

        <!-- Drawer oculto por defecto; lo rellena client.mjs con checkboxes. -->
        <div
          id="specs-vistadrawer"
          class="dirA__specs-drawer"
          data-specs-vistadrawer
          hidden
        ></div>

        <!-- Wrapper aislado: client.mjs re-renderiza solo este div. -->
        <div data-specs-table-wrap>
          <SpecsTable cars={specsCars} />
        </div>
      </section>

      <!-- ── Panel TCO ── -->
      <section
        class="dirA__panel"
        id="panel-tco"
        role="tabpanel"
        aria-labelledby="tab-tco"
        data-panel="tco"
        hidden
      >
        <SummaryStrip
          totals={totalsForStrip}
          anios={PERFIL_ESTANDAR.horizonte_anios}
          escenarioMeta={escenarioMeta}
        />

        <TCOGrid cols={cartas.length}>
          {cartas.map((c, i) => (
            <TCOCard
              tren="BEV"
              nombre={`${c.par.marca} ${c.par.modelo}`}
              variante={c.par.variante}
              input={c.bev}
              rivalTotal={c.totalIce}
              rivalNombre={c.par.nombreIce}
              isWinner={i === ganadoraIdx}
              stagger={i}
              slug={c.par.slug}
              foto={c.par.foto}
            />
          ))}
        </TCOGrid>
      </section>
    </div>

    <!-- Barra inferior sticky con los 4 slots de selección y el botón
         "Comparar". Solo visible en modo catálogo (lo controla client.mjs). -->
    <SelectionBar />

    <!-- Payload JSON con catálogo + pares TCO pre-computados por horizonte.
         Lo lee client.mjs vía #cmp-data en initComparador(). -->
    <script
      type="application/json"
      id="cmp-data"
      set:html={JSON.stringify(datosCliente)}
    ></script>

    <!-- Selección inicial (slugs en orden de slot). El cliente la lee al
         arrancar si no hay chips SSR. -->
    <script
      type="application/json"
      data-cmp-initial-selection
      set:html={JSON.stringify(SELECCION)}
    ></script>
  </main>
  <Footer />
</Layout>

<style>
  .dirA {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 2.5rem) var(--hub-gutter) 5rem;
  }

  .dirA__selectors {
    margin-bottom: 1rem;
  }

  .dirA__scen { margin-bottom: 0; }

  .dirA__panel {
    padding: 0;
    background: transparent;
  }

  /* ── Toolbar "Datos y vista" arriba de la tabla de specs ─────────── */
  .dirA__specs-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }
  .dirA__specs-toolbar-left,
  .dirA__specs-toolbar-right {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .dirA__specs-hint {
    font-size: 0.76rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .vistabtn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.85rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    transition: background 140ms, border-color 140ms;
  }
  .vistabtn:hover {
    border-color: var(--border-strong);
    background: var(--bg);
  }
  .vistabtn[aria-expanded="true"] {
    background: var(--yellow-fade, rgba(245, 197, 24, 0.12));
    border-color: var(--yellow);
    color: var(--text);
  }
  .vistabtn:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 2px;
  }
  .vistabtn__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 0.35rem;
    background: var(--text);
    color: var(--bg);
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 500;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .vistabtn__count:empty { display: none; }

  .dirA__specs-drawer {
    margin-bottom: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .dirA__specs-drawer[hidden] { display: none; }
</style>

<!-- Estilos globales para el contenido inyectado por client.mjs en el
     drawer de "Datos y vista". -->
<style is:global>
  .vistadrawer__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }
  .vistadrawer__title {
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
  }
  .vistadrawer__actions {
    display: inline-flex;
    gap: 0.35rem;
  }
  .vistadrawer__actbtn {
    padding: 0.25rem 0.65rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-soft);
    cursor: pointer;
    transition: border-color 140ms, color 140ms;
  }
  .vistadrawer__actbtn:hover {
    border-color: var(--text);
    color: var(--text);
  }
  .vistadrawer__actbtn:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 2px;
  }

  .vistadrawer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.35rem 0.75rem;
  }
  .vistadrawer__group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .vistadrawer__grouplbl {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--text-mute);
    text-transform: uppercase;
    margin-top: 0.3rem;
  }
  .vistadrawer__chk {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    color: var(--text);
    cursor: pointer;
    padding: 0.2rem 0.25rem;
    border-radius: 4px;
  }
  .vistadrawer__chk:hover { background: var(--surface); }
  .vistadrawer__chk input {
    accent-color: var(--yellow);
    width: 14px;
    height: 14px;
  }
  .vistadrawer__chk input:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 2px;
  }
</style>

<script>
  // Lógica cliente: modal del garaje, scenario interactivo, recomputación
  // TCO en vivo, toggle Specs/TCO. El motor TCO canónico se importa en
  // client.mjs y Vite lo bundlea automáticamente.
  import { initComparador } from '../lib/comparador/client.mjs';
  initComparador();
</script>
