    cursor: pointer;
    white-space: nowrap;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }
  .cat-filter-btn:hover { border-color: var(--text-muted); }
  .cat-filter-btn.has-val {
    background: var(--yellow-glow);
    border-color: var(--yellow);
    color: var(--text);
    font-weight: 500;
  }
  .cat-filter-btn svg { opacity: 0.5; flex-shrink: 0; }
  .cat-filter-btn.has-val svg { opacity: 0.8; }

  /* Category popover */
  .cat-popover {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.6rem;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    z-index: 200;
    min-width: 140px;
  }

  /* ══════════════════════════════════════════
     POPOVER SHARED STYLES (sidebar)
     ══════════════════════════════════════════ */
  .pop-input-wrap {
    display: flex;
    align-items: center;
    background: var(--surface);
    border-radius: 6px;
    border: 1px solid var(--border);
    padding: 0 .5rem;
  }
  .pop-prefix {
    font-family: var(--font-sans);
    font-size: .6rem;
    color: var(--text-muted);
    flex-shrink: 0;
    margin-right: .3rem;
  }
  .pop-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: var(--font-sans);
    font-size: .8rem;
    padding: .4rem 0;
    outline: none;
    width: 50px;
    color: var(--text);
  }
  .pop-unit {
    font-family: var(--font-sans);
    font-size: .6rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }
  .pop-clear {
    font-family: var(--font-sans);
    font-size: .6rem;
    color: #c33;
    background: none;
    border: none;
    cursor: pointer;
    margin-top: .35rem;
    padding: 0;
    display: block;
  }
  .pop-options {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pop-option {
    font-family: var(--font-sans);
    font-size: .7rem;
    padding: .3rem .5rem;
    border-radius: 5px;
    border: none;
    cursor: pointer;
    text-align: left;
    background: var(--surface);
    color: var(--text-secondary);
    font-weight: 400;
    transition: all 0.1s;
  }
  .pop-option:hover { background: var(--bg); }
  .pop-option-sel {
    background: var(--yellow) !important;
    color: var(--black) !important;
    font-weight: 600 !important;
  }

  /* Separator bar between filters and results */
  .comp-panel-separator {
    height: 3px;
    background: var(--panel-separator);
    border-left: 1px solid var(--panel-border);
    border-right: 1px solid var(--panel-border);
  }

  /* ── Results ─────────────────────────── */
  .comp-results {
    padding: 1.5rem clamp(1.5rem, 3vw, 2.5rem);
    background: var(--surface);
    min-height: 60vh;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
  }
  [data-theme="dark"] .comp-results {
    background: var(--surface);
  }
  .results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .results-count {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
  }
  .results-count span { font-weight: 500; color: var(--text); }

  /* View toggle */
  .view-toggle {
    display: flex;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  .view-btn {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 400;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    padding: 0.4rem 0.85rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .view-btn:not(:last-child) { border-right: 1px solid var(--border); }
  .view-btn.active {
    background: var(--yellow);
    color: var(--black);
    font-weight: 600;
  }

  .results-empty {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--text-secondary);
    text-align: center;
    padding: 4rem 0;
  }

  /* ══════════════════════════════════════════
     FICHAS GRID
     ══════════════════════════════════════════ */
  .fichas-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    padding: 0;
  }

  /* ══════════════════════════════════════════
     EV CARD — profile photo + data below
     Photo area is a controlled 16:7 ratio
     dark bg, car centered, never cropped.
     ══════════════════════════════════════════ */
  .ev-card {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border-radius: 12px;
    border: 1px solid var(--border);
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.07), 0 8px 24px rgba(0,0,0,.05);
    transition: transform .35s cubic-bezier(.25,.46,.45,.94), box-shadow .35s;
    cursor: pointer;
  }
  [data-theme="dark"] .ev-card {
    background: var(--surface-alt);
    box-shadow: 0 2px 8px rgba(0,0,0,.25), 0 8px 24px rgba(0,0,0,.18);
  }
  .ev-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(0,0,0,.12), 0 2px 8px rgba(0,0,0,.06);
  }
  [data-theme="dark"] .ev-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,.45), 0 2px 8px rgba(0,0,0,.25);
  }

  /* Photo area — neutral gray gradient bg, yellow accent line */
  .ev-card-photo {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
    background: linear-gradient(180deg, #e2e0db 0%, #d0cec8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  [data-theme="dark"] .ev-card-photo {
    background: linear-gradient(180deg, #2a2a2e 0%, #1e1e22 100%);
  }
  /* Yellow accent line separating photo from body */
  .ev-card-photo::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--yellow), rgba(245,197,24,.25));
    z-index: 2;
  }
  .ev-card-photo img {
    width: 90%;
    height: 82%;
    object-fit: contain;
    display: block;
    position: relative;
    z-index: 1;
    transition: transform .5s cubic-bezier(.25,.46,.45,.94);
    filter: drop-shadow(0 4px 12px rgba(0,0,0,.18));
  }
  .ev-card:hover .ev-card-photo img {
    transform: scale(1.05);
  }

  /* Autonomy badge — now in card body, not on photo */
  .ev-photo-badge {
    display: none; /* Hidden — autonomy now shown in card header */
  }
  .ev-autonomia-inline {
    display: flex;
    align-items: baseline;
    gap: 3px;
    margin-left: auto;
    flex-shrink: 0;
  }
  .ev-autonomia-inline .val {
    font-size: 1rem;
    font-weight: 600;
    color: var(--yellow);
    line-height: 1;
    letter-spacing: -.02em;
  }
  .ev-autonomia-inline .unit {
    font-size: .55rem;
    font-weight: 400;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  /* Card body */
  .ev-card-body {
    padding: 1.1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .55rem;
    flex: 1;
    position: relative;
    z-index: 1;
  }

  .ev-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: .5rem;
  }
  .ev-card-title {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .ev-marca {
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: .1rem;
  }
  .ev-modelo {
    font-size: .95rem;
    font-weight: 600;
    letter-spacing: -.01em;
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ev-variante {
    font-size: .68rem;
    color: var(--text-secondary);
    font-weight: 300;
    line-height: 1.3;
    margin-top: .1rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ev-card-autonomia {
    font-size: .78rem;
    font-weight: 500;
    color: var(--text);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .ev-autonomia-value {
    font-size: .95rem;
    font-weight: 600;
    color: var(--text);
  }
  .ev-autonomia-unit {
    font-size: .65rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  /* Badges */
  .ev-badges {
    display: flex;
    gap: .4rem;
    flex-wrap: wrap;
    margin-top: .35rem;
  }
  .badge {
    font-size: .5rem;
    padding: .18rem .45rem;
    border-radius: 4px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .04em;
    white-space: nowrap;
    line-height: 1.3;
  }
  /* Badge colors — each type has its own tint */
  .badge-tipo {
    background: #E8F0FE;
    color: #1A56DB;
    border: 1px solid #C3DAFE;
  }
  .badge-traccion {
    background: #F0FDF4;
    color: #15803D;
    border: 1px solid #BBF7D0;
  }
  .badge-nmc {
    background: #FEF3C7;
    color: #92400E;
    border: 1px solid #FDE68A;
  }
  .badge-nca {
    background: #FEE2E2;
    color: #991B1B;
    border: 1px solid #FECACA;
  }
  .badge-lfp {
    background: #F0F9FF;
    color: #075985;
    border: 1px solid #BAE6FD;
  }
  .badge-800v {
    background: #EDE9FE;
    color: #6B21A8;
    border: 1px solid #DDD6FE;
  }
  .badge-bcalor {
    background: #E0F2FE;
    color: #0369A1;
    border: 1px solid #BAE6FD;
  }
  /* Dark mode — same hues, adapted for dark backgrounds */
  [data-theme="dark"] .badge-tipo {
    background: rgba(59,130,246,.15);
    color: #93B8F8;
    border-color: rgba(59,130,246,.25);
  }
  [data-theme="dark"] .badge-traccion {
    background: rgba(34,197,94,.12);
    color: #6EE7A0;
    border-color: rgba(34,197,94,.2);
  }
  [data-theme="dark"] .badge-nmc {
    background: rgba(245,197,24,.1);
    color: #FCD34D;
    border-color: rgba(245,197,24,.2);
  }
  [data-theme="dark"] .badge-nca {
    background: rgba(239,68,68,.12);
    color: #FCA5A5;
    border-color: rgba(239,68,68,.2);
  }
  [data-theme="dark"] .badge-800v {
    background: rgba(139,92,246,.15);
    color: #C4B5FD;
    border-color: rgba(139,92,246,.25);
  }
  [data-theme="dark"] .badge-lfp {
    background: rgba(14,165,233,.12);
    color: #7DD3FC;
    border-color: rgba(14,165,233,.2);
  }
  [data-theme="dark"] .badge-bcalor {
    background: rgba(14,165,233,.12);
    color: #7DD3FC;
    border-color: rgba(14,165,233,.2);
  }

  /* Detail rows — clean, readable */
  .ev-card-details {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: .75rem;
    padding-top: .7rem;
    border-top: 1px solid var(--border);
  }
  .ev-detail {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--text-muted);
    padding: .35rem 0;
    line-height: 1.4;
  }
  .ev-detail span:last-child {
    font-weight: 500;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .ev-detail-price span:last-child {
    font-weight: 600;
    color: var(--text);
  }

  /* View control */
  .fichas-view { display: block; }
  .fichas-view:not(.active) { display: none; }
  .listado-view { display: none; }
  .listado-view.active { display: block; }

  /* ══════════════════════════════════════════
     LISTADO VIEW (Table)
     ══════════════════════════════════════════ */
  .listado-wrap {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow-x: auto;
    background: var(--surface);
  }

  .listado-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .82rem;
    min-width: 1100px;
  }

  .listado-table thead {
    position: sticky;
    top: 0;
    background: var(--black);
    color: var(--white);
    z-index: 20;
  }

  .listado-table th {
    padding: .65rem .75rem;
    text-align: left;
    font-weight: 500;
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    white-space: nowrap;
  }
  .listado-table th.col-num { text-align: right; }

  .listado-table th:first-child {
    position: sticky;
    left: 0;
    background: var(--black);
    z-index: 21;
    min-width: 220px;
  }

  .listado-table td {
    padding: .6rem .75rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-weight: 400;
    white-space: nowrap;
  }
  .listado-table td.col-num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .listado-table td small {
    font-size: .55rem;
    color: var(--text-muted);
    margin-left: .1rem;
  }

  .listado-table td:first-child {
    position: sticky;
    left: 0;
    background: var(--surface);
    z-index: 10;
    min-width: 220px;
  }
  .listado-table td:first-child::after {
    content: '';
    position: absolute;
    top: 0;
    right: -6px;
    bottom: 0;
    width: 6px;
    background: linear-gradient(to right, rgba(0,0,0,.06), transparent);
    pointer-events: none;
  }

  .listado-table tbody tr:nth-child(even) td { background: var(--bg); }
  .listado-table tbody tr:nth-child(even) td:first-child { background: var(--bg); }
  .listado-table tbody tr:hover td { background: #E8E9ED; }
  [data-theme="dark"] .listado-table tbody tr:hover td { background: #1E2028; }
  .listado-table tbody tr:hover td:first-child { background: #E8E9ED; }
  [data-theme="dark"] .listado-table tbody tr:hover td:first-child { background: #1E2028; }

  .table-modelo-wrap {
    display: flex;
    align-items: center;
    gap: .6rem;
  }
  .table-photo {
    width: 56px;
    height: 32px;
    border-radius: 4px;
    overflow: hidden;
    background: var(--photo-bg);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2px 4px;
  }
  .table-photo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .table-modelo { font-weight: 600; color: var(--text); font-size: .78rem; }
  .table-variante { font-size: .62rem; color: var(--text-secondary); }
  .table-badges { display: flex; gap: .15rem; flex-wrap: wrap; margin-top: .15rem; }
  .table-badges .badge { font-size: .45rem; padding: .08rem .25rem; }
  .table-autonomia { color: var(--yellow) !important; font-weight: 600 !important; }

  /* Scroll nav */
  .results-table-outer { position: relative; }
  .scroll-nav {
    display: none;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .scroll-nav.visible { display: flex; }
  .scroll-nav-hint {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-right: auto;
  }
  .scroll-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--surface);
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, border-color 0.15s;
    color: var(--text);
    flex-shrink: 0;
  }
  .scroll-btn:hover { background: var(--surface-alt); border-color: var(--border); }
  .scroll-btn:disabled { opacity: 0.3; cursor: default; }

  .results-table-wrap {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    overflow: hidden;
  }
  .results-table-wrap.scroll-mode {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* Sticky first column in scroll mode */
  .scroll-mode .col-sticky {
    position: sticky;
    left: 0;
    z-index: 1;
    background: var(--surface);
  }
  .scroll-mode thead .col-sticky {
    z-index: 3;
    background: var(--table-header-bg);
  }
  .scroll-mode .ev-row:nth-child(even) .col-sticky {
    background: var(--table-row-even);
  }
  .scroll-mode .ev-row:hover .col-sticky {
    background: #E8E9ED;
  }
  [data-theme="dark"] .scroll-mode .ev-row:hover .col-sticky {
    background: #1E2028;
  }
  .scroll-mode .col-sticky::after {
    content: '';
    position: absolute;
    top: 0;
    right: -6px;
    bottom: 0;
    width: 6px;
    background: linear-gradient(to right, rgba(0,0,0,0.06), transparent);
    pointer-events: none;
  }
  .results-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
  }
  .results-table thead {
    position: sticky;
    top: 0;
    z-index: 2;
  }
  .results-table th {
    background: var(--table-header-bg);
    color: var(--header-text);
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.6rem 0.5rem;
    text-align: left;
    border: none;
  }
  .results-table th.col-num { text-align: right; }
  .results-table th.col-sortable {
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
  }
  .results-table th.col-sortable:hover { background: rgba(255,255,255,0.1); }
  .results-table th.th-sorted {
    background: var(--yellow) !important;
    color: var(--black) !important;
  }

  .results-table td {
    padding: 0.55rem 0.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-weight: 400;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .results-table td.col-num {
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .results-table td small {
    font-size: 0.5625rem;
    color: var(--text-muted);
    margin-left: 0.1rem;
  }

  .col-autonomia strong {
    color: var(--yellow);
    font-weight: 600;
  }
  .col-precio { font-weight: 500 !important; }

  .ev-row:nth-child(even) td { background: var(--table-row-even); }

  /* Row with photo */
  .row-modelo-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .row-photo {
    width: 56px;
    height: 32px;
    border-radius: 4px;
    overflow: hidden;
    background: linear-gradient(180deg, #e2e0db 0%, #d0cec8 100%);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2px 4px;
  }
  [data-theme="dark"] .row-photo {
    background: linear-gradient(180deg, #2a2a2e 0%, #1e1e22 100%);
  }
  .row-photo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,.12));
  }
  .row-modelo-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .row-marca {
    font-size: 0.5625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    line-height: 1.2;
  }
  .row-nombre {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .row-badges {
    display: flex;
    gap: 0.15rem;
    flex-wrap: nowrap;
    margin-top: 0.15rem;
    overflow: hidden;
  }

  /* ── Methodology ────────────────────── */
  /* ══════════════════════════════════════════
     METHODOLOGY
     ══════════════════════════════════════════ */
  /* Block 4: Methodology — closes the panel, rounded bottom */
  .comp-methodology {
    padding: clamp(1.5rem, 3vw, 2rem) clamp(1.5rem, 3vw, 2.5rem);
    border: 1px solid var(--border);
    border-top: none;
    background: var(--surface);
    border-radius: 0 0 12px 12px;
  }
  .comp-methodology .meth-label {
    font-size: .6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text-muted);
    margin-bottom: .5rem;
  }
  .comp-methodology p {
    font-size: .82rem;
