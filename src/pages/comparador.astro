---
// src/pages/comparador.astro
// Comparador unificado: especificaciones técnicas + coste de propiedad (TCO).
//
// Arquitectura en 2 modos (no dos áreas apiladas):
//   - modo "explore"  → se ve el catálogo, oculta el área de comparación
//   - modo "compare"  → se ve la comparación (Specs / Coste), oculta catálogo
// La SelectionBar fija inferior muestra los chips seleccionados y alterna
// entre modos. Escuchamos CustomEvents (cmp:set-mode, cmp:selection-change)
// para desacoplar catálogo, barra y shell.
//
// La URL admite ?mode=tco o ?mode=specs para entrar directo en una vista —
// lo resuelve el cliente (client.mjs) leyendo window.location.search.

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ComparadorHeader from '../components/comparador/ComparadorHeader.astro';
import CatalogoPanel from '../components/comparador/CatalogoPanel.astro';
import SelectionBar from '../components/comparador/SelectionBar.astro';
import GarageChipsRow from '../components/comparador/GarageChipsRow.astro';
import GarageModal from '../components/comparador/GarageModal.astro';
import ScenarioBar from '../components/comparador/ScenarioBar.astro';
import SpecsTable from '../components/comparador/SpecsTable.astro';
import SummaryStrip from '../components/comparador/SummaryStrip.astro';
import TCOGrid from '../components/comparador/TCOGrid.astro';
import TCOCard from '../components/comparador/TCOCard.astro';
import {
  cargarCatalogoSpecs,
  cargarParesTCO,
  cargarDatosCliente,
  PERFIL_ESTANDAR,
} from '../lib/comparador/loader.mjs';
import { calcularTCO } from '../lib/tco/calculadora.mjs';
import '../styles/global.css';

// Payload JSON para el cliente: catálogo specs + pares TCO pre-computados
// por horizonte, más perfil estándar. Se serializa inline en la página y
// lo consume client.mjs via #cmp-data.
const datosCliente = cargarDatosCliente();

// ──────────────────────────────────────────────────────────────────────
// Selección narrativa inicial: 4 coches con TCO disponible que cuentan la
// historia "el precio no es el TCO". Del utilitario A al SUV premium.
// El usuario los puede cambiar desde el garaje.
// ──────────────────────────────────────────────────────────────────────
const SELECCION = [
  'tesla-model-3-rwd-highland',
  'bmw-ix1-xdrive30',
  'citroen-e-c3-you',
  'hyundai-inster-long-range',
];

const paresTCO = cargarParesTCO();
const catalogoSpecs = cargarCatalogoSpecs();

const parsSeleccionados = SELECCION.map((slug) => {
  const p = paresTCO.find((x) => x.slug === slug);
  if (!p) throw new Error(`Comparador: par TCO no encontrado para ${slug}`);
  return p;
});

// ── Cálculo TCO SSR (perfil estándar 5 años, 15.000 km/año) ───────────
const cartas = parsSeleccionados.map((par) => {
  const bev = par.horizontes[5].bev;
  const ice = par.horizontes[5].ice;
  const brBev = calcularTCO(bev);
  const brIce = calcularTCO(ice);
  return {
    par,
    bev,
    ice,
    totalBev: brBev.tco_total_eur,
    totalIce: brIce.tco_total_eur,
  };
});

const totales = cartas.map((c) => c.totalBev);
const minTotal = Math.min(...totales);
const ganadoraIdx = totales.indexOf(minTotal);

const totalsForStrip = cartas.map((c) => ({
  id: c.par.slug,
  nombre: c.par.nombreBev,
  total: c.totalBev,
  tren: 'BEV' as const,
}));

// ── Slots para la fila de garaje ──────────────────────────────────────
const garageSlots = parsSeleccionados.map((p) => ({
  slug: p.slug,
  nombre: `${p.marca} ${p.modelo}`,
  variante: p.variante,
  tren: 'BEV' as const,
  pvp_eur: p.horizontes[5].bev.pvp_eur,
}));

// ── Specs cars ────────────────────────────────────────────────────────
const specsCars = SELECCION.map((slug) => {
  const c = catalogoSpecs.find((x) => x.slug === slug);
  if (!c) throw new Error(`Comparador: specs no encontradas para ${slug}`);
  return c;
});

const escenarioMeta = `${PERFIL_ESTANDAR.horizonte_anios} años · ${PERFIL_ESTANDAR.km_anual.toLocaleString('es-ES')} km/año · Madrid`;

const title = 'Comparador de coches eléctricos — enchufa2';
const description =
  'Compara 63 coches eléctricos con sus specs y el coste real a 5 años. Edita km/año, años y €/kWh y recalcula el TCO en vivo.';
---

<Layout {title} {description}>
  <Header />
  <main id="main">
    <div class="cmp-shell" data-mode="explore" data-cmp-shell>
      <CatalogoPanel cars={catalogoSpecs} initial={SELECCION} max={4} />

      <div class="dirA" data-cmp-compare-area>
        <!-- Arrancamos en modo specs por defecto; si la URL trae ?mode=tco
             el cliente lo conmuta al cargar. -->
        <ComparadorHeader modo="specs" />

        <section class="dirA__selectors" aria-label="Selector de coches">
          <GarageChipsRow slots={garageSlots} />
        </section>

        <!-- ScenarioBar solo se muestra en vista TCO; el cliente controla la
             visibilidad a través de data-show-when-mode. -->
        <div class="dirA__scen" data-show-when-mode="tco" style="display: none;">
          <ScenarioBar
            kmAnual={PERFIL_ESTANDAR.km_anual}
            anios={PERFIL_ESTANDAR.horizonte_anios}
            precioKwhCasa={PERFIL_ESTANDAR.precio_kwh_eur}
            precioKwhFuera={0.45}
            pctCasa={80}
          />
        </div>

        <!-- ── Panel SPECS (modo por defecto) ── -->
        <section
          class="dirA__panel"
          id="panel-specs"
          role="tabpanel"
          aria-labelledby="tab-specs"
          data-panel="specs"
        >
          <SpecsTable cars={specsCars} />
        </section>

        <!-- ── Panel TCO ── -->
        <section
          class="dirA__panel"
          id="panel-tco"
          role="tabpanel"
          aria-labelledby="tab-tco"
          data-panel="tco"
          hidden
        >
          <SummaryStrip
            totals={totalsForStrip}
            anios={PERFIL_ESTANDAR.horizonte_anios}
            escenarioMeta={escenarioMeta}
          />

          <TCOGrid cols={cartas.length}>
            {cartas.map((c, i) => (
              <TCOCard
                tren="BEV"
                nombre={`${c.par.marca} ${c.par.modelo}`}
                variante={c.par.variante}
                input={c.bev}
                rivalTotal={c.totalIce}
                rivalNombre={c.par.nombreIce}
                isWinner={i === ganadoraIdx}
                stagger={i}
                slug={c.par.slug}
              />
            ))}
          </TCOGrid>
        </section>
      </div>
    </div>

    <!-- Barra fija inferior con chips + toggle Explorar/Comparar -->
    <SelectionBar cars={catalogoSpecs} initial={SELECCION} max={4} />

    <!-- Modal del garaje: oculto por defecto, lo abre/cierra client.mjs. -->
    <GarageModal />

    <!-- Payload JSON con catálogo + pares TCO pre-computados por horizonte.
         Lo lee client.mjs vía #cmp-data en initComparador(). -->
    <script
      type="application/json"
      id="cmp-data"
      set:html={JSON.stringify(datosCliente)}
    ></script>
  </main>
  <Footer />
</Layout>

<style is:global>
  .cmp-shell {
    position: relative;
  }
  .cmp-shell[data-mode="explore"] [data-cmp-compare-area] {
    display: none;
  }
  .cmp-shell[data-mode="compare"] .catpanel {
    display: none;
  }
</style>

<style>
  .dirA {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 2.5rem) var(--hub-gutter) 2rem;
  }

  .dirA__selectors {
    margin-bottom: 1rem;
  }

  .dirA__scen { margin-bottom: 0; }

  .dirA__panel {
    padding: 0;
    background: transparent;
  }
</style>

<script>
  // Shell de modos Explorar / Comparar. Vive aquí porque sólo coordina —
  // CatalogoPanel y SelectionBar se comunican via CustomEvents.
  (function initCmpShell() {
    const shell = document.querySelector('[data-cmp-shell]');
    if (!shell) return;

    let mode = 'explore';
    let lastSelection: string[] = [];

    document.addEventListener('cmp:selection-change', (e: any) => {
      lastSelection = (e && e.detail && e.detail.slugs) || [];
    });

    document.addEventListener('cmp:set-mode', (e: any) => {
      const next = (e && e.detail && e.detail.mode) || 'explore';
      if (next === mode) return;
      if (next === 'compare' && lastSelection.length < 2) return; // guard
      mode = next;
      shell.setAttribute('data-mode', mode);

      // Al entrar en comparar, empujamos la selección al motor del comparador
      if (mode === 'compare') {
        const w = window as any;
        if (w.__cmpBridge && typeof w.__cmpBridge.setSelection === 'function') {
          try { w.__cmpBridge.setSelection(lastSelection.slice()); } catch (_) {}
        }
      }

      // Scroll suave al top del shell para que el cambio de vista se vea limpio
      try {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (_) {}

      document.dispatchEvent(new CustomEvent('cmp:mode-change', { detail: { mode } }));
    });

    // Emitimos el modo inicial para que SelectionBar sepa el label del botón
    requestAnimationFrame(() => {
      document.dispatchEvent(new CustomEvent('cmp:mode-change', { detail: { mode } }));
    });
  })();
</script>

<script>
  // Lógica cliente: modal del garaje, scenario interactivo, recomputación
  // TCO en vivo, toggle Specs/TCO. El motor TCO canónico se importa en
  // client.mjs y Vite lo bundlea automáticamente.
  import { initComparador } from '../lib/comparador/client.mjs';
  initComparador();
</script>
