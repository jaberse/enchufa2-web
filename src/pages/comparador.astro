---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import data from '../data/comparador.json';
import { cargarDatosCliente } from '../lib/comparador/loader.mjs';

const datosCliente = cargarDatosCliente();
const modelos = data.modelos;
const marcas = [...new Set(modelos.map(m => m.marca))].sort();
const tipos = [...new Set(modelos.map(m => m.tipo).filter(Boolean))].sort();
const tracciones = [...new Set(modelos.map(m => m.traccion).filter(Boolean))].sort();
const quimicas = [...new Set(modelos.map(m => m.quimica).filter(Boolean))].sort();
const voltajes = [...new Set(modelos.map(m => m.voltaje).filter(Boolean))].sort((a,b) => a - b);
const bombaOpts = [...new Set(modelos.map(m => m.bomba_calor).filter(Boolean))].sort();
const planAutoOpts = [...new Set(modelos.map(m => m.plan_auto_elegible).filter(Boolean))].sort();
---

<Layout
  title="Comparador de coches eléctricos — enchufa2"
  description="Compara los 37 coches eléctricos más vendidos en Europa. Filtra por autonomía, potencia, maletero, tracción y más."
>
  <Header />

  <!-- HERO BAND -->
  <div class="hero-band">
    <img src="https://images.unsplash.com/photo-1593941707882-a5bba14938c7?w=1600&q=80&auto=format" alt="Estación de carga eléctrica" loading="eager">
  </div>

  <main id="main">
    <!-- Continuous panel: same pattern as homepage guias-section → cat-blocks -->
    <section class="comp-section">
      <div class="comp-outer">

        <!-- Block 1: Intro (overlaps hero, rounded top) -->
        <div class="comp-intro">
          <div class="comp-intro-inner">
            <h2>Comparador de <em>eléctricos</em></h2>
            <p>Dinos qué necesitas. Nosotros te decimos qué coches lo cumplen. <strong>{data.total_modelos} modelos</strong> con datos verificados.</p>
          </div>
        </div>

        <!-- Block 2: Top bar (count + sort + view) -->
        <div class="comp-topbar" id="filter-bar">
          <div class="result-count-bar"><span id="count">{data.total_modelos}</span> de {data.total_modelos}</div>
          <span class="topbar-sep"></span>
          <div class="search-wrap" id="search-wrap">
            <input type="text" id="model-search" class="model-search" placeholder="Buscar modelo..." autocomplete="off" />
            <div class="search-results" id="search-results"></div>
          </div>
          <span class="topbar-sep"></span>
          <div class="sort-control" id="sort-control">
            <label for="sort-select" class="sort-label">Ordenar</label>
            <select id="sort-select" class="sort-select">
              <option value="">Autonomía ↓</option>
              <option value="pvp-asc">Precio ↑</option>
              <option value="pvp-desc">Precio ↓</option>
              <option value="pvp_efectivo-asc">PVP con Auto+ ↑</option>
              <option value="ayuda_auto-desc">Ayuda Auto+ ↓</option>
              <option value="potencia_cv-desc">Potencia ↓</option>
              <option value="carga_dc-desc">Carga DC ↓</option>
              <option value="aceleracion-asc">0-100 ↑</option>
              <option value="consumo-asc">Consumo ↑</option>
              <option value="peso-asc">Peso ↑</option>
              <option value="maletero-desc">Maletero ↓</option>
            </select>
          </div>
          <div class="topbar-spacer"></div>
          <div class="view-toggle" id="view-toggle">
            <button class="view-btn active" data-view="fichas">Fichas</button>
            <button class="view-btn" data-view="listado">Listado</button>
          </div>
        </div>

        <!-- Block 3: Unified filter panel -->
        <div class="comp-fields-panel">
          <!-- Filter pills + customize button (single row) -->
          <div class="panel-cats-bar">
            <div class="panel-cats-row" id="panel-cats"></div>
            <button class="panel-customize-btn" id="panel-customize-btn" type="button">
              <svg class="customize-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><circle cx="4" cy="3.5" r="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/><line x1="5.5" y1="3.5" x2="13" y2="3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="1" y1="3.5" x2="2.5" y2="3.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="10" cy="7" r="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/><line x1="1" y1="7" x2="8.5" y2="7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="11.5" y1="7" x2="13" y2="7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="5.5" cy="10.5" r="1.5" stroke="currentColor" stroke-width="1.2" fill="none"/><line x1="7" y1="10.5" x2="13" y2="10.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="1" y1="10.5" x2="4" y2="10.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
              <span class="customize-label">Datos y vista</span>
              <span class="customize-badge" id="customize-badge"></span>
              <svg class="customize-caret" width="8" height="5" viewBox="0 0 8 5" aria-hidden="true"><path d="M1 1l3 3 3-3" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/></svg>
            </button>
          </div>

          <!-- Collapsible: Field groups + advanced filters -->
          <div class="panel-customize-drawer" id="panel-customize-drawer" style="display:none;">
            <div class="drawer-header">
              <span class="drawer-title">Datos y filtros avanzados</span>
              <span class="panel-cols-count" id="panel-cols-count"></span>
              <button class="panel-advanced-btn" id="panel-advanced-btn" type="button" aria-pressed="false">
                <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M1 3h10M3 6h6M5 9h2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/></svg>
                Rangos numéricos
              </button>
              <button class="panel-select-all-btn" id="panel-select-all-btn" type="button">Seleccionar todos</button>
            </div>
            <div class="panel-grid" id="panel-grid"></div>
          </div>

          <!-- Applied filters strip -->
          <div class="panel-applied" id="panel-applied" style="display:none;">
            <span class="panel-applied-label">Filtros activos</span>
            <div class="panel-applied-chips" id="panel-applied-chips"></div>
            <button class="reset-btn" id="btn-reset" type="button">Limpiar todo</button>
          </div>
        </div>

        <!-- Separator bar between filters and results -->
        <div class="comp-panel-separator"></div>

        <!-- Topbar: 3 tabs (Catalogo / Especificaciones / Coste 5 anyos) -->
        <nav class="comp-tabbar" role="tablist" aria-label="Vista del comparador">
          <button type="button" class="comp-tab is-active" data-tab="catalogo" role="tab" aria-selected="true">
            <span class="comp-tab-label">Catálogo</span>
            <span class="comp-tab-hint">Filtra y selecciona</span>
          </button>
          <button type="button" class="comp-tab" data-tab="specs" role="tab" aria-selected="false" disabled>
            <span class="comp-tab-label">Especificaciones</span>
            <span class="comp-tab-hint" data-tab-hint="specs">Selecciona 2 o más</span>
          </button>
          <button type="button" class="comp-tab" data-tab="tco" role="tab" aria-selected="false" disabled>
            <span class="comp-tab-label">Coste 5 años</span>
            <span class="comp-tab-hint" data-tab-hint="tco">Selecciona 2 o más</span>
          </button>
        </nav>

        <!-- Block 4: Results -->
        <div class="comp-results comp-tab-panel is-active" data-tab-panel="catalogo">
          <div class="fichas-view active" id="fichas-view">
            <div class="fichas-grid" id="results-grid"></div>
          </div>

          <div class="listado-view" id="listado-view" style="display:none;">
            <div class="results-table-outer" id="results-table-outer">
              <div class="scroll-nav" id="scroll-nav">
                <span class="scroll-nav-hint">Desliza para ver más columnas</span>
                <button class="scroll-btn" id="scroll-left" aria-label="Scroll izquierda">←</button>
                <button class="scroll-btn" id="scroll-right" aria-label="Scroll derecha">→</button>
              </div>
              <div class="results-table-wrap" id="results-table-wrap">
                <table class="listado-table" id="results-table">
                  <thead id="results-thead"></thead>
                  <tbody id="results-tbody"></tbody>
                </table>
              </div>
            </div>
          </div>


          <p class="results-empty" id="no-results" style="display:none;">
            Ningún modelo cumple todos tus requisitos. Prueba a relajar algún filtro.
          </p>
        </div>

        <!-- Specs panel (renderizado por client.mjs) -->
        <div class="comp-tab-panel" data-tab-panel="specs" hidden>
          <div class="tab-empty" data-tab-empty="specs" hidden>
            <h3>Elige al menos 2 coches</h3>
            <p>Vuelve a <button type="button" class="inline-link" data-go-catalogo>Catálogo</button> y selecciona los coches que quieras comparar.</p>
          </div>
          <div data-specs-table-wrap></div>
        </div>

        <!-- TCO panel (renderizado por client.mjs) -->
        <div class="comp-tab-panel" data-tab-panel="tco" hidden>
          <div class="tab-empty" data-tab-empty="tco" hidden>
            <h3>Elige al menos 2 coches</h3>
            <p>Vuelve a <button type="button" class="inline-link" data-go-catalogo>Catálogo</button> y selecciona los coches que quieras comparar.</p>
          </div>
          <div class="tco-panel-inner">
            <div data-summary></div>
            <div class="tcogrid"></div>
          </div>
        </div>

        <!-- Sticky selection footer (3·A) -->
        <div class="sel-footer" id="compare-bar" style="display:none;">
          <div class="sel-footer-inner">
            <div class="sel-footer-label">
              <span class="sel-footer-count"><span id="compare-count-num">0</span></span>
              <span class="sel-footer-text">seleccionados</span>
            </div>
            <div class="sel-footer-thumbs" id="sel-thumbs" aria-label="Modelos seleccionados"></div>
            <div class="sel-footer-actions">
              <button class="sel-footer-clear" id="compare-clear" type="button">Limpiar</button>
              <button class="sel-footer-cta" id="compare-btn" type="button">
                <span class="sel-footer-cta-text">Comparar</span>
                <span class="sel-footer-cta-arrow" aria-hidden="true">→</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Block 4: Methodology (rounded bottom = closes panel) -->
        <div class="comp-methodology">
          <p class="meth-label">Sobre estos datos</p>
          <p>
            Todos los datos provienen de las fichas técnicas oficiales de cada fabricante
            para el mercado español. Cuando no hay dato oficial disponible, se usa
            ev-database.org como fuente de referencia. Las cifras de autonomía corresponden al ciclo WLTP combinado.
            Los precios (PVP) son orientativos, corresponden al mes indicado y pueden variar
            según configuración, promociones o actualizaciones del fabricante. Consulta siempre
            la web oficial del fabricante para el precio vigente.
            Última actualización: abril 2026.
          </p>
          <p class="meth-label" style="margin-top: .8rem;">Sobre las ayudas Plan Auto+ 2026</p>
          <p>
            Las ayudas mostradas corresponden a la <strong>variante concreta listada</strong> de cada modelo
            y se calculan según la fórmula EEE (Eléctrico + Económico + Europeo) del programa
            Plan Auto+ 2026 para particulares (categoría M1). El importe puede variar entre variantes
            del mismo modelo si difieren en precio, país de ensamblaje u origen de la batería.
            Verifica siempre la ayuda aplicable a tu configuración concreta en el punto de venta.
            Datos de ensamblaje basados en fuentes de fabricante y registros de homologación a fecha de abril 2026.
          </p>
        </div>

      </div>
    </section>
  </main>

  <Footer />

  <script type="application/json" id="cmp-data" is:inline set:html={JSON.stringify(datosCliente)}></script>

  <script>
    import { initComparador } from '../lib/comparador/client.mjs';
    initComparador();
  </script>

  <script define:vars={{
    modelos: data.modelos,
    marcasData: marcas,
    tiposData: tipos,
    traccionesData: tracciones,
    quimicasData: quimicas,
    voltajesData: voltajes,
    bombaOptsData: bombaOpts,
    planAutoOptsData: planAutoOpts
  }}>
    // ═══════════════════════════════════════════════════════
    // FIELD DEFINITIONS (organized by category)
    // ═══════════════════════════════════════════════════════
    const FIELD_GROUPS = [
      { id: 'precio',       label: 'Precio y garantía',      icon: '💰' },
      { id: 'autonomia',    label: 'Autonomía y eficiencia',  icon: '⚡' },
      { id: 'bateria',      label: 'Batería y carga',         icon: '🔋' },
      { id: 'rendimiento',  label: 'Rendimiento',             icon: '🏎️' },
      { id: 'dimensiones',  label: 'Dimensiones y espacio',   icon: '📐' },
      { id: 'fiabilidad',   label: 'Fiabilidad y garantía',   icon: '🛡️' },
    ];

    const FIELDS = [
      // ── Precio y garantía ──
      { id:'pvp',           label:'PVP',             shortLabel:'PVP',     unit:'€',         key:'pvp',                     dflt:true,  sortAsc:true,  filterType:'max', fmt:'eur',  group:'precio' },
      { id:'ayuda_auto',    label:'Ayuda Auto+',     shortLabel:'Auto+',   unit:'€',         key:'ayuda_plan_auto_eur',     dflt:false, sortAsc:false, filterType:'min', fmt:'eur',  group:'precio' },
      { id:'pvp_efectivo',  label:'PVP efectivo',    shortLabel:'PVP ef.', unit:'€',         key:'pvp_con_plan_auto_eur',   dflt:false, sortAsc:true,  filterType:'max', fmt:'eur',  group:'precio' },
      { id:'garantia_anos', label:'Garantía años',   shortLabel:'Gar.años', unit:'años',     key:'garantia_bateria',        dflt:false, sortAsc:false, filterType:'min', group:'precio', derive: (m) => { const s = m.garantia_bateria; if (!s) return null; const x = String(s).match(/(\d+)\s*año/i); return x ? parseInt(x[1], 10) : null; } },
      { id:'garantia_km',   label:'Garantía km',     shortLabel:'Gar.km',  unit:'km',        key:'garantia_bateria',        dflt:false, sortAsc:false, filterType:'min', group:'precio', derive: (m) => { const s = m.garantia_bateria; if (!s) return null; const x = String(s).match(/([\d.]+)\s*km/i); return x ? parseInt(x[1].replace(/\./g, ''), 10) : null; }, fmt:'mmDot' },
      // ── Autonomía y eficiencia ──
      { id:'autonomia',     label:'Autonomía',       shortLabel:'Auton.',  unit:'km',        key:'autonomia_wltp_km',       dflt:false, sortAsc:false, filterType:'min', group:'autonomia' },
      { id:'consumo',       label:'Consumo',         shortLabel:'Cons.',   unit:'kWh/100',   key:'consumo_wltp_kwh100km',   dflt:true,  sortAsc:true,  filterType:'max', dec:1,      group:'autonomia' },
      { id:'cx',            label:'Cx',              shortLabel:'Cx',      unit:'',          key:'cx',                      dflt:false, sortAsc:true,  filterType:'max', dec:3,      group:'autonomia' },
      // ── Batería y carga ──
      { id:'bateria_neta',  label:'Batería neta',    shortLabel:'Bat.',    unit:'kWh',       key:'bateria_neta_kwh',        dflt:true,  sortAsc:false, filterType:'min', dec:1,      group:'bateria' },
      { id:'bateria_bruta', label:'Batería bruta',   shortLabel:'Bat.br',  unit:'kWh',       key:'bateria_bruta_kwh',       dflt:false, sortAsc:false, filterType:'min',             group:'bateria' },
      { id:'carga_dc',      label:'Carga DC',        shortLabel:'DC',      unit:'kW',        key:'carga_dc_max_kw',         dflt:true,  sortAsc:false, filterType:'min',             group:'bateria' },
      { id:'carga_ac',      label:'Carga AC',        shortLabel:'AC',      unit:'kW',        key:'carga_ac_max_kw',         dflt:false, sortAsc:false, filterType:'min',             group:'bateria' },
      { id:'t_10_80',       label:'T 10→80%',        shortLabel:'10→80',   unit:'min',       key:'t_10_80_min',             dflt:false, sortAsc:true,  filterType:'max',             group:'bateria' },
      // ── Rendimiento ──
      { id:'potencia_cv',   label:'Potencia',        shortLabel:'Pot.',    unit:'CV',        key:'potencia_cv',             dflt:true,  sortAsc:false, filterType:'min',             group:'rendimiento' },
      { id:'potencia_kw',   label:'Potencia (kW)',   shortLabel:'Pot.kW',  unit:'kW',        key:'potencia_kw',             dflt:false, sortAsc:false, filterType:'min',             group:'rendimiento' },
      { id:'par',           label:'Par motor',       shortLabel:'Par',     unit:'Nm',        key:'par_nm',                  dflt:false, sortAsc:false, filterType:'min',             group:'rendimiento' },
      { id:'aceleracion',   label:'0-100',           shortLabel:'0-100',   unit:'s',         key:'aceleracion_0_100_s',     dflt:true,  sortAsc:true,  filterType:'max', dec:1,      group:'rendimiento' },
      { id:'vel_max',       label:'Vel. máx',        shortLabel:'Vmáx',    unit:'km/h',      key:'velocidad_max_kmh',       dflt:false, sortAsc:false, filterType:'min',             group:'rendimiento' },
      // ── Dimensiones y espacio ──
      { id:'peso',          label:'Peso',            shortLabel:'Peso',    unit:'kg',        key:'peso_kg',                 dflt:true,  sortAsc:true,  filterType:'max',             group:'dimensiones' },
      { id:'maletero',      label:'Maletero',        shortLabel:'Malet.',  unit:'L',         key:'maletero_l',              dflt:true,  sortAsc:false, filterType:'min',             group:'dimensiones' },
      { id:'frunk',         label:'Frunk',           shortLabel:'Frunk',   unit:'L',         key:'frunk_l',                 dflt:false, sortAsc:false, filterType:'min',             group:'dimensiones' },
      { id:'remolque',      label:'Remolque',        shortLabel:'Remolq.', unit:'kg',        key:'capacidad_remolque_kg',   dflt:false, sortAsc:false, filterType:'min',             group:'dimensiones' },
      { id:'largo',         label:'Largo',           shortLabel:'Largo',   unit:'mm',        key:'largo_mm',                dflt:false, sortAsc:false, filterType:'min',             group:'dimensiones' },
      { id:'ancho',         label:'Ancho',           shortLabel:'Ancho',   unit:'mm',        key:'ancho_mm',                dflt:false, sortAsc:false, filterType:'min',             group:'dimensiones' },
      { id:'alto',          label:'Alto',            shortLabel:'Alto',    unit:'mm',        key:'alto_mm',                 dflt:false, sortAsc:false, filterType:'min',             group:'dimensiones' },
      { id:'batalla',       label:'Batalla',         shortLabel:'Bat.mm',  unit:'mm',        key:'batalla_mm',              dflt:false, sortAsc:false, filterType:'min',             group:'dimensiones' },
      { id:'diametro_giro', label:'Diám. giro',      shortLabel:'D.giro',  unit:'m',         key:'diametro_giro_m',         dflt:false, sortAsc:true,  filterType:'max', dec:1,      group:'dimensiones' },
      // ── Fiabilidad y garantía ──
      { id:'fiab_stars',    label:'Fiabilidad',      shortLabel:'Fiab.',   unit:'★',         key:'fiabilidad_estrellas',     dflt:false, sortAsc:false, filterType:'min', dec:1,      group:'fiabilidad', isStars:true },
      { id:'gar_stars',     label:'Garantía',        shortLabel:'Gar.',    unit:'★',         key:'garantia_estrellas',       dflt:false, sortAsc:false, filterType:'min', dec:1,      group:'fiabilidad', isStars:true },
    ];

    const CAT_GROUPS = [
      { label: 'Vehículo', cats: ['marca','tipo','traccion'] },
      { label: 'Batería',  cats: ['quimica','voltaje','bomba'] },
      { label: 'Ayudas',   cats: ['plan_auto'] },
    ];

    const CATS = [
      { id:'marca',      label:'Marca',       key:'marca',              options: marcasData },
      { id:'tipo',       label:'Tipo',         key:'tipo',              options: tiposData },
      { id:'traccion',   label:'Tracción',     key:'traccion',          options: traccionesData },
      { id:'quimica',    label:'Química',      key:'quimica',           options: quimicasData },
      { id:'voltaje',    label:'Voltaje',     key:'voltaje',           options: voltajesData, suffix:' V' },
      { id:'bomba',      label:'B. calor',    key:'bomba_calor',       options: bombaOptsData },
      { id:'plan_auto',  label:'Plan Auto+',  key:'plan_auto_elegible', options: planAutoOptsData },
    ];

    const DEFAULT_IDS = FIELDS.filter(f => f.dflt).map(f => f.id);
    let selectedFields = [...DEFAULT_IDS];
    let filterRanges = {}; // { fieldId: {min: Number|null, max: Number|null} }
    let catVals = {};      // { catId: ['val1','val2',...] }
    let openPopover = null; // id of currently open popover
    let advancedMode = false; // histograma + dual slider expandido
    let expandedFieldGroup = null; // id of currently expanded field group accordion
    let allFieldsOn = false; // track select-all state
    let pickedIds = new Set();  // IDs of models picked for comparison
    let compareMode = false;    // true = show only picked models

    // ═══════════════════════════════════════════════════════
    // DOM REFS
    // ═══════════════════════════════════════════════════════
    const allModelos = modelos;
    let currentView = 'fichas';
    let tableSortId = null;
    let tableSortAsc = true;

    const grid = document.getElementById('results-grid');
    const tabbar = document.querySelector('.comp-tabbar');
    const tabButtons = Array.from(document.querySelectorAll('.comp-tab'));
    const tabPanels = Array.from(document.querySelectorAll('.comp-tab-panel'));
    let activeTab = 'catalogo';
    const fichasView = document.getElementById('fichas-view');
    const listadoView = document.getElementById('listado-view');
    const tableOuter = document.getElementById('results-table-outer');
    const tableWrap = document.getElementById('results-table-wrap');
    const thead = document.getElementById('results-thead');
    const tbody = document.getElementById('results-tbody');
    const countEl = document.getElementById('count');
    const noResults = document.getElementById('no-results');
    const btnReset = document.getElementById('btn-reset');
    const panelGrid = document.getElementById('panel-grid');
    const panelCats = document.getElementById('panel-cats');
    const panelApplied = document.getElementById('panel-applied');
    const panelAppliedChips = document.getElementById('panel-applied-chips');
    const panelAdvancedBtn = document.getElementById('panel-advanced-btn');
    if (panelAdvancedBtn) {
      panelAdvancedBtn.addEventListener('click', () => {
        advancedMode = !advancedMode;
        panelAdvancedBtn.classList.toggle('active', advancedMode);
        panelAdvancedBtn.setAttribute('aria-pressed', advancedMode ? 'true' : 'false');
        renderPanel();
      });
    }
    const panelSelectAllBtn = document.getElementById('panel-select-all-btn');
    if (panelSelectAllBtn) {
      panelSelectAllBtn.addEventListener('click', () => {
        const allOn = selectedFields.length === FIELDS.length;
        if (allOn) {
          selectedFields = [...DEFAULT_IDS];
          FIELDS.forEach(f => { if (!DEFAULT_IDS.includes(f.id)) delete filterRanges[f.id]; });
        } else {
          selectedFields = FIELDS.map(f => f.id);
        }
        allFieldsOn = !allOn;
        panelSelectAllBtn.textContent = allOn ? 'Seleccionar todos' : 'Volver a predefinidos';
        btnReset.style.display = hasAnyFilter() ? '' : 'none';
        renderPanel();
        update();
      });
    }
    // Customize drawer toggle
    const customizeBtn = document.getElementById('panel-customize-btn');
    const customizeDrawer = document.getElementById('panel-customize-drawer');
    let drawerOpen = false;
    if (customizeBtn && customizeDrawer) {
