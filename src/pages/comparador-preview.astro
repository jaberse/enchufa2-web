---
// src/pages/comparador-preview.astro
// Preview de la nueva experiencia comparador+TCO unificada.
// Porta la composición DirectionA completa del export de Claude Design:
//   Header (eyebrow + título serif + toggle) → GarageChipsRow → [ScenarioBar]
//   → panel Specs (SpecsTable) / panel TCO (SummaryStrip + TCOGrid).
//
// Selección inicial hardcoded con 4 coches que existen en cargarParesTCO()
// para que la vista TCO renderice cifras reales y la Specs las mismas 4
// variantes. Al pulsar una tarjeta vacía o el control ↻, el script cliente
// abre el modal del garaje (fase 3).

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ComparadorHeader from '../components/comparador/ComparadorHeader.astro';
import GarageChipsRow from '../components/comparador/GarageChipsRow.astro';
import ScenarioBar from '../components/comparador/ScenarioBar.astro';
import SpecsTable from '../components/comparador/SpecsTable.astro';
import SummaryStrip from '../components/comparador/SummaryStrip.astro';
import TCOGrid from '../components/comparador/TCOGrid.astro';
import TCOCard from '../components/comparador/TCOCard.astro';
import {
  cargarCatalogoSpecs,
  cargarParesTCO,
  PERFIL_ESTANDAR,
} from '../lib/comparador/loader.mjs';
import { calcularTCO } from '../lib/tco/calculadora.mjs';
import '../styles/global.css';

// ──────────────────────────────────────────────────────────────────────
// Selección narrativa: 4 coches con TCO disponible que cuentan la historia
// "el precio no es el TCO". Del utilitario A al SUV premium.
// ──────────────────────────────────────────────────────────────────────
const SELECCION = [
  'tesla-model-3-rwd-highland',
  'bmw-ix1-xdrive30',
  'citroen-e-c3-you',
  'hyundai-inster-long-range',
];

const paresTCO = cargarParesTCO();
const catalogoSpecs = cargarCatalogoSpecs();

const parsSeleccionados = SELECCION.map((slug) => {
  const p = paresTCO.find((x) => x.slug === slug);
  if (!p) throw new Error(`Preview: par TCO no encontrado para ${slug}`);
  return p;
});

// ── Cálculo TCO (perfil estándar 5 años, 15.000 km/año) ───────────────
const cartas = parsSeleccionados.map((par) => {
  const bev = par.horizontes[5].bev;
  const ice = par.horizontes[5].ice;
  const brBev = calcularTCO(bev);
  const brIce = calcularTCO(ice);
  return {
    par,
    bev,
    ice,
    totalBev: brBev.tco_total_eur,
    totalIce: brIce.tco_total_eur,
  };
});

const totales = cartas.map((c) => c.totalBev);
const minTotal = Math.min(...totales);
const ganadoraIdx = totales.indexOf(minTotal);

const totalsForStrip = cartas.map((c) => ({
  id: c.par.slug,
  nombre: c.par.nombreBev,
  total: c.totalBev,
  tren: 'BEV' as const,
}));

// ── Slots para la fila de garaje (misma fuente que las tarjetas TCO) ──
const garageSlots = parsSeleccionados.map((p) => ({
  slug: p.slug,
  nombre: `${p.marca} ${p.modelo}`,
  variante: p.variante,
  tren: 'BEV' as const,
  pvp_eur: p.horizontes[5].bev.pvp_eur,
}));

// ── Specs cars (reutilizan el catálogo completo ya cargado) ───────────
const specsCars = SELECCION.map((slug) => {
  const c = catalogoSpecs.find((x) => x.slug === slug);
  if (!c) throw new Error(`Preview: specs no encontradas para ${slug}`);
  return c;
});

// ── Meta del escenario (mismo string que irá dentro de SummaryStrip) ──
const escenarioMeta = `${PERFIL_ESTANDAR.horizonte_anios} años · ${PERFIL_ESTANDAR.km_anual.toLocaleString('es-ES')} km/año · Madrid`;

const title = 'Comparador EV — preview (DirectionA)';
const description =
  'Preview del comparador unificado enchufa2: specs técnicas + coste total a 5 años.';
---

<Layout {title} {description}>
  <Header />
  <main id="main">
    <!-- Contenedor dirA: max-width + hub-gutter (más estrecho que page-gutter
         del site para que la tabla respire). -->
    <div class="dirA">
      <ComparadorHeader modo="tco" />

      <section class="dirA__selectors" aria-label="Selector de coches">
        <GarageChipsRow slots={garageSlots} />
      </section>

      <!-- ScenarioBar solo se muestra en vista TCO (y la ocultamos por CSS
           según data-mode en .dirA; por defecto arrancamos en modo TCO). -->
      <div class="dirA__scen" data-show-when-mode="tco">
        <ScenarioBar
          kmAnual={PERFIL_ESTANDAR.km_anual}
          anios={PERFIL_ESTANDAR.horizonte_anios}
          precioKwhCasa={PERFIL_ESTANDAR.precio_kwh_eur}
          precioKwhFuera={0.45}
          pctCasa={80}
        />
      </div>

      <!-- ── Panel SPECS ── -->
      <section
        class="dirA__panel"
        id="panel-specs"
        role="tabpanel"
        aria-labelledby="tab-specs"
        data-panel="specs"
        hidden
      >
        <SpecsTable cars={specsCars} />
      </section>

      <!-- ── Panel TCO ── -->
      <section
        class="dirA__panel"
        id="panel-tco"
        role="tabpanel"
        aria-labelledby="tab-tco"
        data-panel="tco"
      >
        <SummaryStrip
          totals={totalsForStrip}
          anios={PERFIL_ESTANDAR.horizonte_anios}
          escenarioMeta={escenarioMeta}
        />

        <TCOGrid cols={cartas.length}>
          {cartas.map((c, i) => (
            <TCOCard
              tren="BEV"
              nombre={`${c.par.marca} ${c.par.modelo}`}
              variante={c.par.variante}
              input={c.bev}
              rivalTotal={c.totalIce}
              rivalNombre={c.par.nombreIce}
              isWinner={i === ganadoraIdx}
              stagger={i}
              slug={c.par.slug}
            />
          ))}
        </TCOGrid>
      </section>

      <aside class="dirA__note">
        <p>
          Preview en <code>/comparador-preview</code>. Los 4 coches están fijos;
          en fase 3 llega el selector con modal y la barra de escenario
          interactiva. Cifras calculadas con el motor TCO canónico del repo.
        </p>
      </aside>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .dirA {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 2.5rem) var(--hub-gutter) 5rem;
  }

  .dirA__selectors {
    margin-bottom: 1rem;
  }

  .dirA__scen { margin-bottom: 0; }

  .dirA__panel {
    padding: 0;
    background: transparent;
  }

  .dirA__note {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.82rem;
    color: var(--text-mute);
    line-height: 1.6;
  }
  .dirA__note code {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    background: var(--surface-alt);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    font-size: 0.78rem;
  }
</style>

<script>
  // Lógica cliente mínima para que el toggle Specs/TCO funcione en el
  // preview. El comparador final tendrá un script más rico (modal del
  // garaje, recomputación TCO en vivo, etc.) — fase 3.
  (function () {
    const root = document.querySelector('[data-cmp-header]')?.closest('main');
    if (!root) return;

    const toggle = root.querySelector('[data-cmp-toggle]');
    const tabs = root.querySelectorAll('[data-cmp-toggle] [role="tab"]');
    const thumb = root.querySelector('.modetoggle__thumb');
    const panels = root.querySelectorAll('[data-panel]');
    const scenSlots = root.querySelectorAll('[data-show-when-mode]');

    function setMode(mode) {
      tabs.forEach((btn) => {
        const on = btn.getAttribute('data-mode') === mode;
        btn.setAttribute('aria-selected', on ? 'true' : 'false');
        btn.classList.toggle('is-on', on);
      });
      if (thumb) {
        thumb.style.transform = mode === 'tco' ? 'translateX(100%)' : 'translateX(0)';
      }
      panels.forEach((p) => {
        const show = p.getAttribute('data-panel') === mode;
        if (show) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
      scenSlots.forEach((s) => {
        const show = s.getAttribute('data-show-when-mode') === mode;
        s.style.display = show ? '' : 'none';
      });
    }

    tabs.forEach((btn) => {
      btn.addEventListener('click', () => {
        setMode(btn.getAttribute('data-mode'));
      });
    });

    // Estado inicial: lo que diga el primer tab con aria-selected=true.
    const initial = root.querySelector('[role="tab"][aria-selected="true"]')
      ?.getAttribute('data-mode') || 'tco';
    setMode(initial);
  })();
</script>
