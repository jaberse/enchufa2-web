---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';
const isComparador = currentPath.startsWith('/comparador');
const isCalculadora = currentPath.startsWith('/calculadora-tco');
---
<a href="#main" class="skip-link">Saltar al contenido</a>
<header class="site-header" id="site-header">

  <div class="header-top hub-width">

    <!-- Logo: symbol (inline SVG) + wordmark text -->
    <a href="/" class="logo" aria-label="enchufa2 inicio">

      <!-- Symbol — always visible. The "2" inside (.num2) fades in on scroll -->
      <svg class="logo-symbol" viewBox="-5 -5 75 108" overflow="visible" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M28.9885 0V54.2171C28.9885 54.2171 0 54.2977 0 54.2171C0 54.1365 28.9885 0 28.9885 0Z" fill="currentColor"/>
        <path d="M37.0826 98L37.0575 46.2613H65L37.0826 98Z" fill="currentColor"/>
        <path class="num2" d="M36.9959 38.8948V35.6134L47.2923 25.0953C48.3917 23.9527 49.298 22.9516 50.0112 22.0922C50.7343 21.223 51.2741 20.3978 51.6307 19.6165C51.9873 18.8352 52.1656 18.0051 52.1656 17.1262C52.1656 16.13 51.9278 15.2706 51.4524 14.5479C50.9769 13.8154 50.3282 13.2539 49.506 12.8632C48.6839 12.4628 47.7578 12.2626 46.7277 12.2626C45.6381 12.2626 44.6872 12.4824 43.875 12.9218C43.0628 13.3613 42.4388 13.9815 42.0029 14.7823C41.5671 15.5831 41.3492 16.5207 41.3492 17.5949H36.9662C36.9662 15.7687 37.3921 14.1719 38.244 12.8046C39.0958 11.4374 40.2646 10.3778 41.7504 9.62577C43.2361 8.86401 44.9249 8.48313 46.8168 8.48313C48.7285 8.48313 50.4124 8.85913 51.8684 9.61112C53.3344 10.3533 54.4784 11.369 55.3005 12.6582C56.1226 13.9375 56.5337 15.3829 56.5337 16.9943C56.5337 18.1077 56.3207 19.1966 55.8948 20.2611C55.4788 21.3256 54.7508 22.5122 53.7108 23.8208C52.6707 25.1197 51.2246 26.697 49.3723 28.5525L43.3253 34.7931V35.0128H57.024V38.8948H36.9959Z" fill="var(--yellow)"/>
        <path d="M28.6897 46.2613H39.4483V54.2171H28.6897V46.2613Z" fill="currentColor"/>
        <path d="M5.08046 63.9408H28.9885V69.5393H5.08046V63.9408Z" fill="currentColor"/>
        <path d="M2.98851 66.74L5.08046 63.9408V69.5393L2.98851 66.74Z" fill="currentColor"/>
        <path d="M5.08046 79.263H28.9885V84.8615H5.08046V79.263Z" fill="currentColor"/>
        <path d="M2.98851 82.0622L5.08046 79.263V84.8615L2.98851 82.0622Z" fill="currentColor"/>
      </svg>

      <!-- Wordmark text — slides left and collapses on scroll -->
      <span class="logo-wordmark-wrap">
        <span class="logo-wordmark">enchufa<span class="logo-two">2</span></span>
      </span>

    </a>

    <!-- Header actions -->
    <div class="header-actions">
      <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar tema">
        <svg class="theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <div class="search-toggle" role="button" tabindex="0" aria-label="Buscar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <span>Buscar</span>
      </div>
      <a href="#newsletter" class="nl-btn">Newsletter</a>
    </div>

  </div>

  <!-- Category navigation bar (yellow) -->
  <nav class="cat-nav" aria-label="Categorías">
    <div class="cat-nav-inner hub-width">
      <a href="/" class={isHome ? 'active' : ''}>Inicio</a>
      <a href={isHome ? '#compra' : '/#compra'}>¿Me compensa?</a>
      <a href={isHome ? '#carga' : '/#carga'}>¿Cómo cargo?</a>
      <a href={isHome ? '#autonomia' : '/#autonomia'}>¿Puedo viajar?</a>
      <a href={isHome ? '#tecnologia' : '/#tecnologia'}>¿Cómo funciona?</a>
      <a href="/comparador" class={isComparador ? 'active' : ''}>Comparador</a>
      <a href="/calculadora-tco" class={isCalculadora ? 'active' : ''}>Calculadora</a>
    </div>
  </nav>

  <!-- Black separator between yellow bar and hero -->
  <div class="header-separator"></div>
</header>

<style>
  /* Skip link — visible only on focus for keyboard nav */
  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
    z-index: 999;
    background: var(--yellow);
    color: var(--black);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-weight: 500;
    font-size: 0.875rem;
    text-decoration: none;
  }
  .skip-link:focus {
    left: 1rem;
    top: 0.5rem;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--black);
    color: var(--white);
    transition: background 0.3s ease;
  }
  .site-header.scrolled {
    background: rgba(17, 17, 17, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1rem;
  }

  /* ─── Logo assembly ─── */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 2rem;
    color: var(--white);
    transition: opacity 0.2s ease;
    overflow: visible;
  }
  .logo:hover { opacity: 0.8; }

  .logo-symbol {
    flex-shrink: 0;
    height: 1.75rem;
    width: auto;
    overflow: visible;
    position: relative;
    z-index: 2;
  }

  /* The "2" — hidden by default, pops in on scroll */
  .logo-symbol .num2 {
    opacity: 0;
    transform-origin: center center;
    transform: scale(1);
    transition: opacity .15s ease .2s,
                transform .4s cubic-bezier(.34, 1.56, .64, 1) .2s,
                filter .6s ease .35s;
  }
  .site-header.scrolled .logo-symbol .num2 {
    opacity: 1;
    transform: scale(1.35);
    filter: brightness(1.4) drop-shadow(0 0 3px rgba(245, 197, 24, 0.5));
  }

  @keyframes num2-settle {
    0% {
      transform: scale(1.35);
      filter: brightness(1.4) drop-shadow(0 0 3px rgba(245, 197, 24, 0.5));
    }
    100% {
      transform: scale(1);
      filter: brightness(1) drop-shadow(0 0 0 transparent);
    }
  }

  /* Wordmark — slides left and collapses */
  .logo-wordmark-wrap {
    overflow: hidden;
    display: flex;
    align-items: center;
    transition: width 0.55s cubic-bezier(.25, .1, .25, 1);
    width: 7.5rem;
  }
  .site-header.scrolled .logo-wordmark-wrap { width: 0; }

  .logo-wordmark {
    display: inline-block;
    white-space: nowrap;
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    transition: transform 0.55s cubic-bezier(.25, .1, .25, 1),
                opacity 0.4s ease 0.1s;
    transform: translateX(0);
  }
  .site-header.scrolled .logo-wordmark {
    transform: translateX(-7.5rem);
    opacity: 0;
  }

  .logo-two { color: var(--yellow); }

  /* ─── Header actions ─── */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .search-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.45rem 0.9rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .search-toggle:hover {
    background: rgba(255,255,255,0.1);
    color: var(--white);
  }
  .search-toggle svg { width: 14px; height: 14px; opacity: 0.5; }

  .nl-btn {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--black);
    background: var(--yellow);
    padding: 0.5rem 1rem;
    font-weight: 500;
    border-radius: 5px;
    transition: all 0.2s;
  }
  .nl-btn:hover { filter: brightness(1.05); }

  /* ─── Category nav (yellow bar) ─── */
  .cat-nav {
    background: var(--yellow);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cat-nav::-webkit-scrollbar { display: none; }

  .cat-nav-inner {
    display: flex;
    gap: 0;
  }

  .cat-nav a {
    padding: 0.55rem 1.3rem;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--black);
    white-space: nowrap;
    transition: background 0.25s ease, color 0.25s ease;
  }
  .cat-nav a:hover {
    background: var(--black);
    color: var(--yellow);
  }
  .cat-nav a.active {
    background: var(--black);
    color: var(--yellow);
  }

  /* ─── Black separator strip ─── */
  .header-separator {
    background: var(--black);
    height: 6px;
  }

  /* ─── Theme toggle ─── */
  .theme-toggle {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1.5px solid rgba(255,255,255,.15);
    background: rgba(255,255,255,.06);
    cursor: pointer;
    padding: 0;
    outline: none;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .3s cubic-bezier(.16,1,.3,1);
  }
  .theme-toggle:hover {
    background: rgba(255,255,255,.12);
    border-color: rgba(255,255,255,.25);
  }
  :global([data-theme="dark"]) .theme-toggle {
    border-color: rgba(245,197,24,.25);
    background: rgba(245,197,24,.08);
  }
  :global([data-theme="dark"]) .theme-toggle:hover {
    background: rgba(245,197,24,.15);
    border-color: rgba(245,197,24,.4);
  }
  .theme-toggle svg {
    width: 18px;
    height: 18px;
    transition: opacity .3s, transform .4s cubic-bezier(.16,1,.3,1);
  }
  .theme-icon-sun {
    stroke: #fff;
    opacity: 1;
    transform: rotate(0deg);
  }
  .theme-icon-moon {
    stroke: var(--yellow);
    position: absolute;
    opacity: 0;
    transform: rotate(-90deg);
  }
  :global([data-theme="dark"]) .theme-icon-sun {
    opacity: 0;
    transform: rotate(90deg);
  }
  :global([data-theme="dark"]) .theme-icon-moon {
    opacity: 1;
    transform: rotate(0deg);
  }

  /* ─── Mobile ─── */
  @media (max-width: 640px) {
    .logo-wordmark-wrap { width: 7rem; }
    .logo-wordmark { font-size: 1.1rem; }
    .search-toggle span { display: none; }
    .nl-btn { font-size: 0.65rem; padding: 0.4rem 0.75rem; }
  }
</style>

<script is:inline>
  // ── Theme toggle ──
  (function() {
    var themeBtn = document.getElementById('theme-toggle');
    if (!themeBtn) return;
    themeBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (isDark) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
      }
    });
  })();
</script>

<script>
  // ── Scroll header ──
  const header = document.getElementById('site-header');
  const num2 = document.querySelector('.logo-symbol .num2') as SVGPathElement | null;
  let wasScrolled = false;
  let ticking = false;

  function updateHeader() {
    const scrolled = window.scrollY > 80;

    if (scrolled) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }

    if (scrolled && !wasScrolled && num2) {
      setTimeout(() => {
        num2.style.animation = 'num2-settle .35s ease-out forwards';
      }, 550);
    }
    if (!scrolled && wasScrolled && num2) {
      num2.style.animation = 'none';
    }

    wasScrolled = scrolled;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateHeader);
      ticking = true;
    }
  }, { passive: true });
</script>