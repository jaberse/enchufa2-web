---
---
<section class="hero" id="hero" aria-label="Portada">

  <!-- Background grid -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Ambient glow -->
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="hero-content page-width">

    <!-- Eyebrow -->
    <p class="hero-eyebrow t-small reveal-char" aria-hidden="true">
      <span class="eyebrow-line"></span>
      Movilidad eléctrica
    </p>

    <!-- Main headline — split into lines for GSAP -->
    <h1 class="hero-headline t-display">
      <span class="line" data-line="0">Carga el</span>
      <span class="line" data-line="1">futuro<span class="accent">.</span></span>
    </h1>

    <!-- Sub-headline in serif italic -->
    <p class="hero-sub t-serif reveal-up">
      Conectamos personas y empresas<br/>con la energía que mueve el mundo.
    </p>

    <!-- CTA -->
    <div class="hero-cta reveal-up">
      <a href="#contacto" class="btn-primary">Hablemos</a>
      <a href="#nosotros" class="btn-ghost">Quiénes somos</a>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint reveal-up" aria-hidden="true">
    <span class="t-small">Scroll</span>
    <div class="scroll-line"></div>
  </div>

  <!-- Decorative plug SVG -->
  <svg class="hero-deco" viewBox="0 0 200 240" aria-hidden="true"
       xmlns="http://www.w3.org/2000/svg">
    <polygon points="70,10 130,10 130,80 90,80" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
    <rect x="88" y="80" width="8" height="30" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
    <rect x="110" y="80" width="8" height="30" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
    <rect x="55" y="88" width="33" height="7" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
    <rect x="55" y="103" width="33" height="7" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
    <polygon points="88,118 118,118 100,145" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
    <text x="134" y="50" font-family="Inter, sans-serif" font-size="32" font-weight="200"
          fill="none" stroke="currentColor" stroke-width="1" opacity="0.12">2</text>
  </svg>

</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    background: var(--black);
    color: var(--white);
    overflow: hidden;
  }

  /* Subtle dot-grid texture */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  /* Ambient glow bottom-center */
  .hero-glow {
    position: absolute;
    bottom: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 60vw;
    height: 40vw;
    background: radial-gradient(ellipse at center,
      rgba(245, 197, 24, 0.06) 0%,
      transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 7rem;
    padding-bottom: 5rem;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: rgba(250,250,248,0.45);
    margin-bottom: 2rem;
    opacity: 0;
  }
  .eyebrow-line {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--yellow);
    flex-shrink: 0;
  }

  /* Headline */
  .hero-headline {
    color: var(--white);
    margin-bottom: 2rem;
  }
  .hero-headline .line {
    display: block;
    overflow: hidden;
  }
  .hero-headline .line > span,
  .hero-headline .line-inner {
    display: block;
  }

  .hero-sub {
    color: rgba(250,250,248,0.6);
    max-width: 38ch;
    margin-bottom: 3rem;
    opacity: 0;
  }

  /* CTAs */
  .hero-cta {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    align-items: center;
    opacity: 0;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2.25rem;
    background: var(--yellow);
    color: var(--black);
    font-weight: 400;
    font-size: 0.9375rem;
    letter-spacing: 0.01em;
    border-radius: 2px;
    transition: transform 0.25s var(--ease-out-expo),
                box-shadow 0.25s ease,
                opacity 0.2s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(245,197,24,0.25);
  }
  .btn-primary:active { transform: translateY(0); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 0;
    color: rgba(250,250,248,0.55);
    font-size: 0.9375rem;
    font-weight: 300;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .btn-ghost:hover {
    color: var(--white);
    border-color: rgba(255,255,255,0.5);
  }
  .btn-ghost::after {
    content: '→';
    transition: transform 0.25s var(--ease-out-expo);
  }
  .btn-ghost:hover::after {
    transform: translateX(4px);
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: var(--page-gutter);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    color: rgba(250,250,248,0.3);
    opacity: 0;
  }
  .scroll-line {
    width: 1px;
    height: 3rem;
    background: linear-gradient(to bottom, rgba(245,197,24,0.5), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.1); }
  }

  /* Decorative SVG */
  .hero-deco {
    position: absolute;
    right: max(var(--page-gutter), 5vw);
    top: 50%;
    transform: translateY(-50%);
    width: clamp(120px, 15vw, 220px);
    height: auto;
    color: var(--white);
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .hero-deco { display: none; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  // 1. Eyebrow
  tl.to('.hero-eyebrow', { opacity: 1, duration: 0.6 }, 0.2);

  // 2. Headline lines — mask-reveal from below
  const lines = document.querySelectorAll('.hero-headline .line');
  lines.forEach((line, i) => {
    // Wrap content in inner span for clip reveal
    const inner = document.createElement('span');
    inner.className = 'line-inner';
    inner.style.cssText = 'display:block;transform:translateY(105%)';
    while (line.firstChild) inner.appendChild(line.firstChild);
    line.appendChild(inner);

    tl.to(inner, {
      y: '0%',
      duration: 0.9,
      ease: 'power4.out',
    }, 0.35 + i * 0.12);
  });

  // 3. Sub-headline, CTA, scroll hint, deco
  tl.to('.hero-sub',    { opacity: 1, y: 0, duration: 0.7 }, 0.7);
  tl.to('.hero-cta',    { opacity: 1, y: 0, duration: 0.7 }, 0.85);
  tl.to('.scroll-hint', { opacity: 1, y: 0, duration: 0.5 }, 1.1);
  tl.to('.hero-deco',   { opacity: 1, duration: 1.2 }, 0.5);
</script>
