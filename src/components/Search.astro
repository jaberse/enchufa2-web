---
/* Search overlay — client-side article search */
---

<div class="search-overlay" id="search-overlay" role="dialog" aria-label="Buscar artículos" aria-hidden="true">
  <div class="search-backdrop" id="search-backdrop"></div>
  <div class="search-panel">
    <div class="search-header">
      <div class="search-input-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <input
          type="text"
          id="search-input"
          class="search-input"
          placeholder="Buscar artículos..."
          autocomplete="off"
          autofocus
        />
        <button class="search-close" id="search-close" aria-label="Cerrar búsqueda">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
    <div class="search-results" id="search-results">
      <div class="search-hint" id="search-hint">Escribe para buscar entre todos los artículos de enchufa2</div>
    </div>
  </div>
</div>

<style>
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: clamp(4rem, 12vh, 8rem);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s;
  }

  .search-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(17, 17, 17, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .search-panel {
    position: relative;
    width: min(620px, 90vw);
    background: var(--surface);
    border-radius: 12px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    max-height: 70vh;
    display: flex;
    flex-direction: column;
    transform: translateY(-8px);
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .search-overlay.active .search-panel {
    transform: translateY(0);
  }

  .search-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--gray-100);
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .search-icon {
    width: 20px;
    height: 20px;
    color: var(--gray-400);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 300;
    color: var(--text);
    border: none;
    outline: none;
    background: transparent;
    padding: 0.5rem 0;
  }

  .search-input::placeholder {
    color: var(--gray-400);
  }

  .search-close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: var(--gray-400);
    transition: color 0.15s;
  }

  .search-close:hover {
    color: var(--text);
  }

  .search-close svg {
    width: 20px;
    height: 20px;
  }

  .search-results {
    overflow-y: auto;
    padding: 0.5rem;
    max-height: calc(70vh - 4rem);
  }

  .search-hint {
    padding: 2rem 1rem;
    text-align: center;
    font-size: 0.88rem;
    color: var(--gray-400);
    font-weight: 300;
  }

  /* Result items — rendered by JS */
  .search-results :global(.sr-item) {
    display: block;
    padding: 1rem 1rem;
    border-radius: 8px;
    transition: background 0.15s;
    text-decoration: none;
    color: inherit;
  }

  .search-results :global(.sr-item:hover),
  .search-results :global(.sr-item.active) {
    background: var(--gray-50);
  }

  .search-results :global(.sr-cat) {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    color: var(--yellow-text);
  }

  .search-results :global(.sr-title) {
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.35;
    margin-top: 0.15rem;
    color: var(--text);
  }

  .search-results :global(.sr-desc) {
    font-size: 0.82rem;
    color: var(--gray-500);
    line-height: 1.5;
    margin-top: 0.2rem;
    font-weight: 300;
  }

  .search-results :global(.sr-meta) {
    font-size: 0.68rem;
    color: var(--gray-400);
    margin-top: 0.3rem;
  }

  .search-results :global(.sr-empty) {
    padding: 2rem 1rem;
    text-align: center;
    font-size: 0.88rem;
    color: var(--gray-400);
    font-weight: 300;
  }
</style>

<script>
  // Article index for client-side search
  const articles = [
    {
      slug: 'vida-bateria-ev',
      title: 'La guía para cargar la batería de tu eléctrico sin acortarle la vida',
      description: 'NMC vs LFP, temperatura, carga rápida y datos reales de degradación.',
      category: 'Tecnología',
      categorySlug: 'tecnologia',
      readingTime: '14 min',
      date: 'Marzo 2026',
    },
    {
      slug: 'carga-rapida-espana',
      title: 'Carga rápida en España: la guía técnica definitiva',
      description: 'Redes, precios, compatibilidad y estrategia de carga rápida en España.',
      category: 'Carga',
      categorySlug: 'carga',
      readingTime: '12 min',
      date: 'Marzo 2026',
    },
    {
      slug: 'tarifas-carga-casa',
      title: 'Cuánto cuesta cargar un coche eléctrico en casa en 2026',
      description: 'Tarifas eléctricas, franjas horarias, wallbox y paneles solares.',
      category: 'Carga',
      categorySlug: 'carga',
      readingTime: '11 min',
      date: 'Marzo 2026',
    },
    {
      slug: 'coste-real-electrico',
      title: 'Cuánto cuesta realmente tener un eléctrico en España',
      description: 'TCO completo: electricidad, seguro, mantenimiento, impuestos y depreciación.',
      category: 'Costes y Ahorro',
      categorySlug: 'costes-y-ahorro',
      readingTime: '12 min',
      date: 'Marzo 2026',
    },
    {
      slug: 'subvenciones-ayudas-ev-2026',
      title: 'Subvenciones y ayudas para eléctricos en 2026',
      description: 'Plan Auto+, ayudas autonómicas, etiqueta CERO, deducciones IRPF.',
      category: 'Costes y Ahorro',
      categorySlug: 'costes-y-ahorro',
      readingTime: '10 min',
      date: 'Marzo 2026',
    },
    {
      slug: 'mantenimiento-ev-vs-combustion',
      title: 'Mantenimiento real de un EV vs combustión',
      description: 'Qué se cambia, cada cuánto y cuánto cuesta mantener un eléctrico.',
      category: 'Mantenimiento',
      categorySlug: 'mantenimiento',
      readingTime: '11 min',
      date: 'Marzo 2026',
    },
    {
      slug: 'neumaticos-coche-electrico',
      title: 'Neumáticos para coche eléctrico',
      description: 'Desgaste, autonomía, ruido y qué modelos elegir para tu EV.',
      category: 'Mantenimiento',
      categorySlug: 'mantenimiento',
      readingTime: '10 min',
      date: 'Marzo 2026',
    },
  ];

  const overlay = document.getElementById('search-overlay')!;
  const backdrop = document.getElementById('search-backdrop')!;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results')!;
  const hint = document.getElementById('search-hint')!;
  const closeBtn = document.getElementById('search-close')!;

  // Open search
  function openSearch() {
    overlay.classList.add('active');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => input.focus(), 100);
  }

  // Close search
  function closeSearch() {
    overlay.classList.remove('active');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    input.value = '';
    results.innerHTML = '';
    results.appendChild(hint);
    hint.style.display = '';
  }

  // Wire up open triggers
  document.querySelectorAll('.search-toggle').forEach((el) => {
    el.addEventListener('click', openSearch);
    el.addEventListener('keydown', (e: Event) => {
      if ((e as KeyboardEvent).key === 'Enter') openSearch();
    });
  });

  // Wire up close
  closeBtn.addEventListener('click', closeSearch);
  backdrop.addEventListener('click', closeSearch);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('active')) closeSearch();
    // Cmd/Ctrl+K shortcut
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      overlay.classList.contains('active') ? closeSearch() : openSearch();
    }
  });

  // Normalize for search (remove diacritics)
  function normalize(str: string): string {
    return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
  }

  // Search logic
  input.addEventListener('input', () => {
    const query = normalize(input.value.trim());

    if (!query) {
      results.innerHTML = '';
      results.appendChild(hint);
      hint.style.display = '';
      return;
    }

    hint.style.display = 'none';

    const matched = articles.filter((a) => {
      const haystack = normalize(`${a.title} ${a.description} ${a.category}`);
      return query.split(/\s+/).every((word) => haystack.includes(word));
    });

    if (matched.length === 0) {
      results.innerHTML = '<div class="sr-empty">No hemos encontrado artículos con esa búsqueda</div>';
      return;
    }

    results.innerHTML = matched
      .map(
        (a) => `
        <a href="/articulos/${a.slug}" class="sr-item">
          <div class="sr-cat">${a.category}</div>
          <div class="sr-title">${a.title}</div>
          <div class="sr-desc">${a.description}</div>
          <div class="sr-meta">${a.date} · ${a.readingTime}</div>
        </a>
      `
      )
      .join('');
  });
</script>
