---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="page-width footer-inner">

    <a href="/" aria-label="enchufa2">
      <img src="/logo.svg" alt="enchufa2" class="footer-logo" />
    </a>

    <p class="footer-copy t-small">
      © {year} enchufa2. Todos los derechos reservados.
    </p>

    <nav class="footer-nav" aria-label="Pie de página">
      <a href="#nosotros">Nosotros</a>
      <a href="#contacto">Contacto</a>
    </nav>

  </div>
</footer>

<style>
  .site-footer {
    background: var(--black);
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-block: 2rem;
    color: rgba(250,250,248,0.3);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-logo {
    height: 22px;
    width: auto;
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }
  a:hover .footer-logo { opacity: 0.8; }

  .footer-copy {
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }

  .footer-nav {
    display: flex;
    gap: 1.75rem;
  }

  .footer-nav a {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  .footer-nav a:hover { color: rgba(250,250,248,0.7); }
</style>
