---
// src/components/comparador/GarageChipsRow.astro
// Fila de 4 "garage chips" del selector paradigma Garaje (DirectionA).
// Cada chip muestra: marca + modelo, train-dot + tren, variante serif y PVP.
// Al hover aparecen los controles ↻ (cambiar) y × (quitar).
//
// Este componente es estático: recibe las 4 entradas por props y pinta.
// La interactividad (abrir modal, quitar coche) la añade el script cliente
// del comparador leyendo [data-garage-chip] y [data-garage-slot].

export interface Slot {
  slug: string;
  nombre: string;      // marca + modelo (ej. "Tesla Model 3")
  variante: string;    // ej. "RWD Highland"
  tren: 'BEV' | 'PHEV' | 'HEV' | 'MHEV' | 'ICE';
  pvp_eur: number;
}

interface Props {
  slots: (Slot | null)[]; // longitud 4
}

const { slots } = Astro.props;

const TREN_LABEL: Record<string, string> = {
  BEV: 'Eléctrico',
  PHEV: 'PHEV',
  HEV: 'Híbrido',
  MHEV: 'Mild-hybrid',
  ICE: 'Combustión',
};

const fmtEur = (n: number) =>
  new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
    maximumFractionDigits: 0,
  }).format(Math.round(n));
---

<section class="sel-garage" aria-label="Coches seleccionados">
  <div class="sel-garage__row" data-garage-row>
    {slots.map((car, i) => car ? (
      <div
        class="garage-chip"
        data-garage-chip
        data-garage-slot={i}
        data-garage-slug={car.slug}
      >
        <div class="garage-chip__name">{car.nombre}</div>
        <span class="garage-chip__train-inline">
          <span class="garage-chip__train-dot" data-train={car.tren}></span>
          {TREN_LABEL[car.tren] ?? car.tren}
        </span>
        <div class="garage-chip__meta">
          <span class="garage-chip__var serif">{car.variante}</span>
          <span class="garage-chip__price tabular">{fmtEur(car.pvp_eur)}</span>
        </div>
        <div class="garage-chip__controls">
          <button
            type="button"
            class="garage-chip__swap"
            data-garage-swap
            title="Cambiar"
            aria-label={`Cambiar ${car.nombre}`}
          >↻</button>
          <button
            type="button"
            class="garage-chip__x"
            data-garage-remove
            aria-label={`Quitar ${car.nombre}`}
          >×</button>
        </div>
      </div>
    ) : (
      <button
        type="button"
        class="garage-chip garage-chip--empty"
        data-garage-chip
        data-garage-slot={i}
        data-garage-add
      >
        <span class="garage-chip__plus">+</span>
        <span>Añadir coche</span>
      </button>
    ))}
  </div>
</section>

<style is:global>
  .sel-garage { margin: 0 0 1rem; }

  .sel-garage__row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }
  @media (max-width: 900px) {
    .sel-garage__row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .sel-garage__row { grid-template-columns: 1fr; }
  }

  .garage-chip {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    column-gap: 0.5rem;
    row-gap: 0.1rem;
    align-items: baseline;
    padding: 0.5rem 0.65rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    min-width: 0;
    transition: border-color 160ms, background 160ms;
    font-family: var(--font-sans);
    text-align: left;
  }
  .garage-chip:hover { border-color: var(--border-strong); }

  .garage-chip__name {
    grid-column: 1;
    grid-row: 1;
    font-size: 0.98rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .garage-chip__train-inline {
    grid-column: 2;
    grid-row: 1;
    align-self: center;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-mute);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    white-space: nowrap;
  }
  .garage-chip__train-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    display: inline-block;
    background: var(--text);
  }
  .garage-chip__train-dot[data-train='BEV']  { background: var(--yellow); }
  .garage-chip__train-dot[data-train='PHEV'] { background: var(--phev-green); }
  .garage-chip__train-dot[data-train='HEV']  {
    background: transparent;
    box-shadow: inset 0 0 0 1px var(--phev-green);
  }
  .garage-chip__train-dot[data-train='MHEV'] { background: var(--text-mute); }
  .garage-chip__train-dot[data-train='ICE']  { background: var(--text); }

  .garage-chip__meta {
    grid-column: 1 / -1;
    grid-row: 2;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    font-size: 0.76rem;
    color: var(--text-soft);
    min-width: 0;
  }
  .garage-chip__var {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .garage-chip__price {
    font-size: 0.74rem;
    color: var(--text-mute);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .garage-chip__controls {
    position: absolute;
    right: 4px;
    top: 4px;
    display: flex;
    gap: 2px;
    opacity: 0;
    transition: opacity 140ms;
  }
  .garage-chip:hover .garage-chip__controls,
  .garage-chip:focus-within .garage-chip__controls {
    opacity: 1;
  }
  .garage-chip__swap,
  .garage-chip__x {
    width: 22px;
    height: 22px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-mute);
    font-size: 0.85rem;
    background: var(--surface);
    border: 1px solid var(--border);
    cursor: pointer;
  }
  .garage-chip__swap:hover {
    color: var(--accent-text);
    border-color: var(--yellow);
  }
  .garage-chip__x:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }

  .garage-chip--empty {
    grid-template-columns: auto 1fr;
    grid-template-rows: 1fr;
    align-items: center;
    border: 1px dashed var(--border-strong);
    color: var(--text-mute);
    background: transparent;
    cursor: pointer;
    padding: 0.65rem 0.75rem;
    gap: 0.45rem;
  }
  .garage-chip--empty:hover {
    color: var(--accent-text);
    border-color: var(--yellow);
    background: var(--yellow-glow);
  }
  .garage-chip__plus {
    font-size: 1rem;
    line-height: 1;
    font-weight: 200;
    grid-column: 1;
    grid-row: 1;
  }
  .garage-chip--