---
// src/components/comparador/TCOGrid.astro
// Grid de tarjetas TCO — portado del .tcogrid de directionA.css.
// Usa `repeat(var(--cols), minmax(0, 1fr))` para que 4 tarjetas ocupen
// exactamente 4 columnas (sin expansión) y se repliegue a 2 en tablet y 1
// en móvil.

interface Props {
  cols?: number;
}

const { cols = 4 } = Astro.props;
---

<div class="tcogrid" style={`--cols: ${cols};`}>
  <slot />
</div>

<style is:global>
  .tcogrid {
    display: grid;
    grid-template-columns: repeat(var(--cols), minmax(0, 1fr));
    gap: 1rem;
  }
  @media (max-width: 960px) {
    .tcogrid { grid-template-columns: repeat(2, 1fr); }
  }
