---
// src/components/comparador/TCOCard.astro
// Tarjeta canónica de TCO a 5 años. Portada desde el export de Claude Design,
// adaptada a Astro + tokens de enchufa2 y al motor TCO del repo
// (src/lib/tco/calculadora.mjs). Winner sutil: puntito amarillo 6px en la
// fila ganadora y borde amarillo en la tarjeta global ganadora.
//
// Las cifras se pintan en el servidor con los parámetros estándar. El
// cliente (public/comparador/comparador.js) podrá recalcular y rescribir
// los nodos marcados con data-tco-key al cambiar el escenario.

import { calcularTCO } from '../../lib/tco/calculadora.mjs';

interface InputCoche {
  tren: 'BEV' | 'ICE';
  pvp_eur: number;
  ayuda_eur?: number;
  consumo_wltp: number;
  consumo_real_factor: number;
  depreciacion_pct: number;
  mantenimiento_anual_eur: number;
  seguro_anual_eur: number;
  confianza_depreciacion?: 'alta' | 'media' | 'baja';
  confianza_mantenimiento?: 'alta' | 'media' | 'baja';
  confianza_seguro?: 'alta' | 'media' | 'baja';
  confianza_consumo?: 'alta' | 'media' | 'baja';
}

interface Props {
  /** Tipo de tren — gobierna el badge y la copia (€/kWh vs €/L). */
  tren: 'BEV' | 'ICE' | 'PHEV' | 'HEV' | 'MHEV';
  /** Marca + modelo (Inter 300, una línea). */
  nombre: string;
  /** Variante (Instrument Serif italic). */
  variante?: string;
  /** InputCoche canónico — alimenta calcularTCO(). */
  input: InputCoche;
  /** TCO total del rival (para mostrar delta editorial). */
  rivalTotal?: number | null;
  /** Nombre del rival (para la copia del delta). */
  rivalNombre?: string;
  /** Marca como tarjeta ganadora del grupo (borde amarillo sutil). */
  isWinner?: boolean;
  /** 0..3 — stagger de la animación de entrada (80ms por paso). */
  stagger?: number;
  /** Slug para telemetría/selectors (data-tco-card). */
  slug?: string;
  /** Fecha de los parámetros (mostrada en footer). */
  datosFecha?: string;
}

const {
  tren,
  nombre,
  variante = '',
  input,
  rivalTotal = null,
  rivalNombre = '',
  isWinner = false,
  stagger = 0,
  slug = '',
  datosFecha = '2026-04',
} = Astro.props;

// SSR: cálculo con perfil estándar (overrides = {} usa PARAMS_ENCHUFA2_ESTANDAR).
const br = calcularTCO(input);

// Formatters (español, sin decimales, con minus unicode para negativos).
const fmtEur = (n: number) =>
  new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
    maximumFractionDigits: 0,
  })
    .format(Math.round(n))
    .replace('-', '\u2212');

const fmtEurSigned = (n: number) => (n >= 0 ? '+' : '\u2212') + fmtEur(Math.abs(n));

// Etiquetas de badge por tren (HÍBRIDO con tilde, bug del export).
const BADGE: Record<string, { label: string; cls: string }> = {
  BEV:  { label: 'ELÉCTRICO', cls: 'badge--yellow' },
  ICE:  { label: 'GASOLINA',  cls: 'badge--black' },
  PHEV: { label: 'HÍBRIDO ENCHUFABLE', cls: 'badge--green' },
  HEV:  { label: 'HÍBRIDO',   cls: 'badge--outlineGreen' },
  MHEV: { label: 'MILD-HYBRID', cls: 'badge--outline' },
};
const badge = BADGE[tren] ?? BADGE.BEV;

// Delta editorial (serif) — solo si hay rival y es distinto del propio total.
const delta = rivalTotal != null ? br.tco_total_eur - rivalTotal : null;

// Filas de breakdown. `ayudas_eur` se muestra negativo (es un crédito).
// Las BEV siempre pintan 6 filas (con la última como "—" si no aplica Plan
// Auto+) para que las tarjetas del grid queden alineadas horizontalmente.
// Los ICE siguen con 5 filas porque nunca tienen ayudas.
const tieneAyudas = tren === 'BEV' && br.ayudas_eur > 0;
const filas = [
  { key: 'depreciacion',   label: 'Depreciación',                               valor: br.depreciacion_eur, empty: false },
  { key: 'energia',        label: tren === 'BEV' ? 'Energía' : 'Combustible',   valor: br.energia_eur,      empty: false },
  { key: 'mantenimiento',  label: 'Mantenimiento',                              valor: br.mantenimiento_eur, empty: false },
  { key: 'seguro',         label: 'Seguro',                                     valor: br.seguro_eur,       empty: false },
  { key: 'impuestos',      label: 'Impuestos',                                  valor: br.impuestos_eur,    empty: false },
];
if (tren === 'BEV') {
  filas.push({
    key: 'ayudas',
    label: 'Ayudas Plan Auto+',
    valor: tieneAyudas ? -br.ayudas_eur : 0,
    empty: !tieneAyudas,
  });
}

// Confianza agregada (peor de las 4) — ya viene en br.margen_pct.
const confianzaLabel =
  br.margen_pct === 0 ? 'Alta' : br.margen_pct <= 0.08 ? 'Media' : 'Baja';
const confianzaCls =
  br.margen_pct === 0 ? 'pill-conf--alta'
  : br.margen_pct <= 0.08 ? 'pill-conf--media'
  : 'pill-conf--baja';
---

<article
  class:list={['tco-card', isWinner && 'tco-card--win']}
  data-tco-card
  data-tco-slug={slug}
  data-tco-tren={tren}
  style={`--stagger: ${stagger * 80}ms;`}
>
  <header class="tco-card__head">
    <div class="tco-card__title">
      <div class="tco-card__brand">{nombre}</div>
      <div class="tco-card__variant">{variante || '\u00A0'}</div>
    </div>
    <span class:list={['badge', badge.cls]}>{badge.label}</span>
  </header>

  <div class="tco-card__total">
    <p class="eyebrow">Coste total a 5 años</p>
    <div class="tco-card__num" data-tco-key="total">
      {fmtEur(br.tco_total_eur)}
    </div>
    {delta != null && (
      <p class="tco-card__edit" data-tco-key="delta">
        {delta < 0 ? (
          <>
            Ahorras <strong>{fmtEur(Math.abs(delta))}</strong>
            {rivalNombre && <> frente al {rivalNombre}.</>}
          </>
        ) : delta > 0 ? (
          <>
            Paga <strong>{fmtEur(delta)}</strong> más
            {rivalNombre && <> que el {rivalNombre}.</>}
          </>
        ) : (
          <>Empate con el {rivalNombre || 'rival'}.</>
        )}
      </p>
    )}
  </div>

  <div class="tco-card__sep" aria-hidden="true"></div>

  <div class="tco-rows">
    {filas.map((f) => (
      <div
        class:list={['tco-row', f.empty && 'tco-row--empty']}
        data-tco-row={f.key}
      >
        <div class="tco-row__main">
          <div class="tco-row__label">
            <span>{f.label}</span>
          </div>
          <div class="tco-row__val">
            <div class="tco-row__num" data-tco-key={f.key}>
              {f.empty
                ? '—'
                : f.key === 'ayudas' && f.valor < 0
                ? fmtEurSigned(f.valor)
                : fmtEur(f.valor)}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <footer class="tco-card__foot">
    <button
      type="button"
      class:list={['pill-conf', confianzaCls]}
      data-pop="conf"
      data-tco-slug={slug}
      aria-label="Ver cómo se calcula la confianza y el rango de coste"
    >Confianza {confianzaLabel}</button>
    <button
      type="button"
      class="tco-card__method"
      data-pop="tco-method"
    >Metodología completa →</button>
  </footer>
</article>

<style is:global>
  /* ── Badge base (escopado a la tarjeta) ────────────────────────────── */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
    white-space: nowrap;
  }
  .badge--yellow      { background: var(--yellow); color: var(--black); }
  .badge--green       { background: var(--phev-green); color: #fff; }
  .badge--black       { background: var(--text); color: var(--bg); }
  .badge--outlineGreen {
    background: var(--surface);
    color: var(--phev-green);
    box-shadow: inset 0 0 0 1px var(--phev-green);
  }
  .badge--outline {
    background: var(--surface);
    color: var(--text-secondary);
    box-shadow: inset 0 0 0 1px var(--gray-200);
  }

  /* ── Card ──────────────────────────────────────────────────────────── */
  .tco-card {
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: clamp(1.25rem, 1.8vw, 1.75rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    will-change: transform, opacity;
    opacity: 0;
    transform: translateY(24px);
    animation: card-in 700ms var(--ease-out-expo) var(--stagger, 0ms) forwards;
  }
  @keyframes card-in {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .tco-card { animation: none; opacity: 1; transform: none; }
  }
  .tco-card--win {
    border-color: var(--yellow);
    box-shadow:
      0 0 0 1px var(--yellow),
      0 10px 40px -18px var(--yellow-glow),
      0 2px 12px -4px var(--yellow-glow);
  }

  /* ── Head ──────────────────────────────────────────────────────────── */
  .tco-card__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    /* Reserva 2 líneas de título (marca + variante) para alinear las 4
       tarjetas del grid aunque alguna no tenga variante. */
    min-height: 2.75rem;
  }
  .tco-card__title { text-align: left; min-width: 0; flex: 1; }
  .tco-card__brand {
    font-weight: 300;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tco-card__variant {
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 300;
    letter-spacing: 0;
    margin-top: 0.15rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: 1.15rem;
  }
  .serif {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
  }

  /* Eyebrow local (la clase .eyebrow no existe en global.css; se define aquí
     para que el componente sea auto-contenido). */
  .eyebrow {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
  }

  /* ── Total block ───────────────────────────────────────────────────── */
  .tco-card__total { margin-top: 0.25rem; }
  .tco-card__num {
    font-size: clamp(2.4rem, 3.6vw, 3rem);
    font-weight: 200;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    margin-top: 0.3rem;
    line-height: 1;
    color: var(--text);
  }
  .tco-card__edit {
    margin-top: 0.65rem;
    font-family: var(--font-sans);
    font-style: normal;
    font-weight: 400;
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.45;
    /* Reserva 2 líneas para que las tarjetas del grid queden alineadas
       incluso cuando el nombre del rival produce un wrap. */
    min-height: 2.6em;
  }
  .tco-card__edit strong {
    font-weight: 500;
    color: var(--yellow-text);
  }

  .tco-card__sep {
    height: 1px;
    background: var(--border);
    margin: 0.4rem 0 0.25rem;
  }

  /* ── Rival (selector de ICE a comparar) ────────────────────────────── */
  .tco-card__rival {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-top: 0.1rem;
  }
  .tco-card__rivalLbl {
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .tco-card__rivalSel {
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.4rem 1.85rem 0.4rem 0.6rem;
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 0.86rem;
    color: var(--text);
    cursor: pointer;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%23666'><path d='M4 6l4 4 4-4'/></svg>");
    background-repeat: no-repeat;
    background-position: right 0.55rem center;
    background-size: 12px 12px;
    transition: border-color 180ms, box-shadow 180ms;
  }
  .tco-card__rivalSel:hover { border-color: var(--text-secondary); }
  .tco-card__rivalSel:focus-visible {
    outline: none;
    border-color: var(--yellow);
    box-shadow: 0 0 0 2px var(--yellow-glow, rgba(245, 197, 24, 0.25));
  }

  /* ── Rows ──────────────────────────────────────────────────────────── */
  .tco-rows { display: flex; flex-direction: column; }
  .tco-row {
    border-top: 1px solid var(--border);
    padding: 0.65rem 0;
  }
  .tco-row:first-child { border-top: 0; padding-top: 0.25rem; }
  .tco-row__main {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .tco-row__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    color: var(--text);
    min-width: 0;
  }
  .tco-row__label > span:first-child {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  .tco-row__val { text-align: right; }
  .tco-row__num {
    font-size: 1rem;
    font-weight: 400;
    font-variant-numeric: tabular-nums;
    color: var(--text);
  }
  /* Fila vacía: cuando el BEV no aplica al Plan Auto+, la fila se pinta
     con guión y color atenuado para que el desglose de las 4 tarjetas
     siempre tenga las mismas 6 líneas. */
  .tco-row--empty .tco-row__label,
  .tco-row--empty .tco-row__num { color: var(--text-muted); }

  /* ── Pills ─────────────────────────────────────────────────────────── */
  .pill-conf {
    display: inline-block;
    padding: 0.12rem 0.5rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    border: 1px solid var(--gray-200);
    color: var(--text-secondary);
    background: transparent;
    font-family: inherit;
    cursor: pointer;
    transition: border-color 180ms, color 180ms, background 180ms;
  }
  .pill-conf:hover {
    border-color: var(--yellow);
    color: var(--yellow-text);
    background: var(--yellow-glow);
  }
  .pill-conf--alta  { border-color: var(--yellow); color: var(--yellow-text); }
  .pill-conf--media { color: var(--text-secondary); }
  .pill-conf--baja  { color: var(--text-muted); }

  /* ── Footer ────────────────────────────────────────────────────────── */
  .tco-card__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
    margin-top: 0.25rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }
  .tco-card__method {
    text-decoration: none;
    color: var(--text-secondary);
    border: 0;
    border-bottom: 1px solid var(--gray-200);
    padding: 0 0 1px 0;
    background: transparent;
    font-family: inherit;
    font-size: inherit;
    cursor: pointer;
    transition: color 180ms, border-color 180ms;
  }
  .tco-card__method:hover {
    color: var(--yellow-text);
    border-color: var(--yellow);
  }

  /* ── Help button (fiabilidad en la tabla de specs) ───────────────────── */
  .stbl__helpbtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.15em;
    height: 1.15em;
    margin-left: 0.4em;
    padding: 0;
    border-radius: 999px;
    border: 1px solid var(--gray-200);
    background: transparent;
    color: var(--text-muted);
    font-size: 0.7em;
    font-weight: 500;
    font-family: inherit;
    line-height: 1;
    cursor: pointer;
    vertical-align: middle;
    transition: border-color 180ms, color 180ms, background 180ms;
  }
  .stbl__helpbtn:hover {
    border-color: var(--yellow);
    color: var(--yellow-text);
    background: var(--yellow-glow);
  }

  /* ──────────────────────────────────────────────────────────────────────
     POPOVER — panel flotante usado por confianza / metodología / fiabilidad
     El host es <div id="cmp-popover" class="pop"> inyectado en <body> por
     popover.mjs. Estilos marcados is:global para aplicar fuera del scope.
     ────────────────────────────────────────────────────────────────────── */
  .pop {
    position: fixed;
    z-index: 2000;
    width: clamp(280px, 92vw, 360px);
    max-height: calc(100vh - 24px);
    overflow: auto;
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border-strong);
    border-radius: 10px;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 12px 36px rgba(0, 0, 0, 0.18);
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.5;
    animation: pop-in 180ms var(--ease-out-quart, ease-out);
  }
  @keyframes pop-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pop { animation: none; }
  }
  .pop[hidden] { display: none; }

  .pop__head {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.9rem 1rem 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .pop__title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--text);
    line-height: 1.3;
    flex: 1;
  }
  .pop__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.8rem;
    height: 1.8rem;
    margin: -0.2rem -0.3rem -0.2rem 0;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 6px;
    color: var(--text-muted);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    transition: background 150ms, color 150ms;
  }
  .pop__close:hover {
    background: var(--surface-alt);
    color: var(--text);
  }

  .pop__body {
    padding: 0.85rem 1rem 0.9rem 1rem;
    color: var(--text-secondary);
  }
  .pop__body p { margin: 0 0 0.7rem 0; }
  .pop__body p:last-child { margin-bottom: 0; }
  .pop__body strong { color: var(--text); font-weight: 500; }
  .pop__body em { color: var(--text); font-style: italic; }

  .pop__lead {
    font-size: 0.82rem;
    color: var(--text-muted);
    letter-spacing: 0.01em;
    text-transform: none;
    margin-bottom: 0.6rem !important;
  }

  .pop__formula {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.55rem 0.7rem;
    color: var(--text);
    line-height: 1.4;
    margin: 0 0 0.75rem 0 !important;
  }

  .pop__list {
    margin: 0 0 0.7rem 0;
    padding-left: 1.1rem;
    font-size: 0.85rem;
  }
  .pop__list li { margin-bottom: 0.35rem; }
  .pop__list li:last-child { margin-bottom: 0; }

  .pop__partidas-hdr {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0.5rem 0 0.4rem 0 !important;
  }

  .pop__partidas {
    list-style: none;
    margin: 0 0 0.7rem 0;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  .pop__partida {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.65rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.82rem;
  }
  .pop__partida:last-child { border-bottom: 0; }
  .pop__partida-lbl { color: var(--text-secondary); }
  .pop__partida-val {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text);
    font-weight: 400;
    font-variant-numeric: tabular-nums;
  }

  .pop__dot {
    display: inline-block;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--gray-300);
  }
  .pop__dot--alta  { background: var(--yellow); }
  .pop__dot--media { background: #d8a41a; }
  .pop__dot--baja  { background: var(--gray-400); }

  .pop__range {
    display: grid;
    grid-template-columns: auto 1fr;
    row-gap: 0.2rem;
    column-gap: 0.75rem;
    padding: 0.6rem 0.7rem;
    background: var(--surface-alt);
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: 0.75rem;
  }
  .pop__range-lbl {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    align-self: center;
  }
  .pop__range-val {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .pop__range-sep { color: var(--text-muted); }
  .pop__range-center {
