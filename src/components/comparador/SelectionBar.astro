---
// src/components/comparador/SelectionBar.astro
// Barra fija inferior con chips de los coches seleccionados y toggle de
// modo Explorar / Comparar. Escucha y emite CustomEvents en `document`
// para desacoplarse de CatalogoPanel y del shell.

interface CarRef {
  slug: string;
  marca: string;
  modelo: string;
  foto: string;
}
interface Props { cars: CarRef[]; initial?: string[]; max?: number; }
const { cars, initial = [], max = 4 } = Astro.props;

// Mapa compacto para el script cliente. Solo lo mínimo para pintar chips.
const lookup = Object.fromEntries(
  cars.map((c) => [c.slug, { m: c.marca || '', md: c.modelo || '', p: c.foto || '' }]),
);
---

<div class="selbar" data-selbar data-count="0" role="region" aria-label="Selección de coches">
  <div class="selbar__inner">
    <div class="selbar__left">
      <button type="button" class="selbar__clear" data-selbar-clear hidden>
        Limpiar
      </button>
      <div class="selbar__chips" data-selbar-chips aria-live="polite"></div>
    </div>
    <div class="selbar__right">
      <span class="selbar__count" data-selbar-count>0 / {max}</span>
      <button type="button" class="selbar__toggle" data-selbar-toggle disabled>
        <span data-selbar-toggle-label>Comparar</span>
        <svg
          class="selbar__arrow"
          width="14"
          height="14"
          viewBox="0 0 14 14"
          aria-hidden="true"
        ><path d="M2 7h9M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"></path></svg>
      </button>
    </div>
  </div>
</div>

<script define:vars={{ lookup, max }}>
  (function initSelBar() {
    const bar = document.querySelector('[data-selbar]');
    if (!bar) return;

    const chipsEl = bar.querySelector('[data-selbar-chips]');
    const clearBtn = bar.querySelector('[data-selbar-clear]');
    const toggleBtn = bar.querySelector('[data-selbar-toggle]');
    const toggleLabel = bar.querySelector('[data-selbar-toggle-label]');
    const countEl = bar.querySelector('[data-selbar-count]');

    let mode = 'explore';

    function readSelection() {
      return Array.from(document.querySelectorAll('.catcard[aria-pressed="true"]'))
        .map((c) => c.getAttribute('data-slug'))
        .filter(Boolean);
    }

    function render() {
      const slugs = readSelection();
      const n = slugs.length;

      chipsEl.innerHTML = '';
      if (n === 0) {
        const empty = document.createElement('span');
        empty.className = 'selbar__empty';
        empty.textContent = 'Elige hasta ' + max + ' coches del catálogo';
        chipsEl.appendChild(empty);
      } else {
        slugs.forEach((slug) => {
          const info = lookup[slug] || { m: '', md: slug, p: '' };
          const chip = document.createElement('span');
          chip.className = 'selchip';
          chip.innerHTML =
            (info.p ? '<img class="selchip__photo" src="' + info.p + '" alt="" loading="lazy">' : '') +
            '<span class="selchip__name">' + info.m + ' ' + info.md + '</span>' +
            '<button type="button" class="selchip__x" aria-label="Quitar ' + info.m + ' ' + info.md +
              '" data-selchip-x="' + slug + '">' +
              '<svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><path d="M2 2l6 6M8 2l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>' +
              '</button>';
          chipsEl.appendChild(chip);
        });
      }

      if (countEl) countEl.textContent = n + ' / ' + max;
      if (clearBtn) clearBtn.hidden = n === 0;

      if (toggleBtn) {
        if (mode === 'explore') toggleBtn.disabled = n < 2;
        else toggleBtn.disabled = false;
      }
      if (toggleLabel) {
        toggleLabel.textContent = mode === 'explore'
          ? (n >= 2 ? 'Comparar ' + n : 'Comparar')
          : 'Volver al catálogo';
      }
      bar.setAttribute('data-count', String(n));
      bar.setAttribute('data-mode', mode);
    }

    chipsEl.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-selchip-x]');
      if (!btn) return;
      const slug = btn.getAttribute('data-selchip-x');
      if (!slug) return;
      document.dispatchEvent(new CustomEvent('cmp:external-toggle', { detail: { slug } }));
    });

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('cmp:external-clear'));
      });
    }

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const next = mode === 'explore' ? 'compare' : 'explore';
        document.dispatchEvent(new CustomEvent('cmp:set-mode', { detail: { mode: next } }));
      });
    }

    document.addEventListener('cmp:selection-change', render);
    document.addEventListener('cmp:mode-change', (e) => {
      mode = (e && e.detail && e.detail.mode) || 'explore';
      render();
    });

    // Primer pintado tras el paint para que CatalogoPanel haya establecido
    // los aria-pressed iniciales.
    requestAnimationFrame(render);
  })();
</script>

<style is:global>
  .selbar {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 90;
    padding: 0.6rem clamp(0.75rem, 3vw, 1.5rem);
    background: var(--black);
    color: var(--white);
    border-top: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 -10px 28px -14px rgba(0,0,0,0.45);
  }
  .selbar__inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .selbar__left {
    display: flex; align-items: center; gap: 0.55rem;
    flex: 1; min-width: 0;
  }
  .selbar__right {
    flex-shrink: 0;
    display: flex; align-items: center; gap: 0.6rem;
  }
  .selbar__chips {
    display: flex; gap: 0.4rem;
    overflow-x: auto;
    scrollbar-width: none;
    min-width: 0;
    flex: 1;
    padding: 2px 0;
  }
  .selbar__chips::-webkit-scrollbar { display: none; }
  .selbar__empty {
    font-size: 0.82rem;
    color: var(--gray-400);
    white-space: nowrap;
  }

  .selchip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.2rem 0.35rem 0.2rem 0.25rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 999px;
    font-size: 0.78rem;
    color: var(--white);
    white-space: nowrap;
    flex-shrink: 0;
    max-width: 230px;
  }
  .selchip__photo {
    width: 28px; height: 28px; border-radius: 50%;
    object-fit: cover;
    background: var(--gray-100);
    flex-shrink: 0;
  }
  .selchip__name {
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .selchip__x {
    background: transparent;
    border: 0;
    color: var(--gray-400);
    width: 22px; height: 22px;
    border-radius: 50%;
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 140ms, color 140ms;
  }
  .selchip__x:hover {
    background: rgba(255,255,255,0.14);
    color: var(--white);
  }
  .selchip__x:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 1px;
  }

  .selbar__clear {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    color: var(--gray-400);
    font-family: var(--font-sans);
    font-size: 0.76rem;
    padding: 0.32rem 0.72rem;
    border-radius: 999px;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: color 160ms, border-color 160ms;
  }
  .selbar__clear:hover {
    color: var(--white);
    border-color: rgba(255,255,255,0.45);
  }
  .selbar__clear:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 2px;
  }

  .selbar__count {
    font-size: 0.76rem;
    color: var(--gray-400);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .selbar__toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1.05rem;
    background: var(--yellow);
    color: var(--black);
    border: 0;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.88rem;
    letter-spacing: -0.005em;
    cursor: pointer;
    transition: transform 180ms, filter 180ms, opacity 180ms;
  }
  .selbar__toggle:hover:not(:disabled) {
    transform: translateY(-1px);
    filter: brightness(1.05);
  }
  .selbar__toggle:disabled {
    background: var(--gray-400);
    cursor: not-allowed;
    opacity: 0.7;
  }
  .selbar__toggle:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 3px;
  }
  .selbar[data-mode="compare"] .selbar__toggle {
    background: transparent;
    color: var(--white);
    border: 1px solid rgba(255,255,255,0.3);
  }
  .selbar[data-mode="compare"] .selbar__toggle .selbar__arrow {
    transform: rotate(180deg);
  }

  /* Hueco bajo el main para que la selbar no tape contenido */
  main#main { padding-bottom: calc(5.5rem + env(safe-area-inset-bottom, 0px)); }

  @media (max-width: 640px) {
    .selbar { padding: 0.55rem 0.75rem; }
    .selbar__inner { gap: 0.5rem; }
    .selbar__count { display: none; }
    .selbar__clear { padding: 0.3rem 0.55rem; font-size: 0.72rem; }
    .selbar__toggle { padding: 0.45rem 0.9rem; font-size: 0.82rem; }
    .selchip { max-width: 170px; }
    .selchip__name { max-width: 90px; }
    .selchip__photo { width: 24px; height: 24px; }
  }
</style>
