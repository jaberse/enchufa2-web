---
// src/components/comparador/SelectionBar.astro
// Barra inferior sticky con los 4 slots de selección y el botón "Comparar".
// Visible solo en modo catálogo: muestra los coches que el usuario ha ido
// marcando y le permite lanzar la comparativa cuando tenga al menos 2.
//
// Los slots se rellenan desde src/lib/comparador/client.mjs (renderSelectionBar).
// data-selbar-slot=0..3 identifica cada uno; data-selbar-clear y
// data-selbar-compare son los CTAs.

interface Slot {
  slug?: string;
  nombre?: string;
  foto?: string;
}

interface Props {
  /** Slots iniciales (opcional). El cliente los sobrescribe al montar. */
  slots?: Slot[];
}

const { slots = [] } = Astro.props;
// Asegura 4 slots aunque no llegue ninguno.
const padded: Slot[] = [0, 1, 2, 3].map((i) => slots[i] ?? {});
---

<aside
  class="selbar"
  data-selbar
  aria-label="Coches seleccionados para comparar"
>
  <div class="selbar__inner">
    <div class="selbar__slots" data-selbar-slots>
      {padded.map((s, i) => (
        <div
          class={`selbar__slot${s.slug ? ' is-filled' : ' is-empty'}`}
          data-selbar-slot={i}
          aria-label={s.slug ? `${s.nombre} · clic para quitar` : `Slot ${i + 1} vacío`}
        >
          {s.slug ? (
            <>
              <figure class="selbar__slot-photo">
                <img
                  src={s.foto || '/comparador/placeholder.svg'}
                  alt={s.nombre || ''}
                  loading="lazy"
                  decoding="async"
                />
              </figure>
              <span class="selbar__slot-name">{s.nombre}</span>
              <button
                type="button"
                class="selbar__slot-x"
                aria-label={`Quitar ${s.nombre}`}
                data-selbar-remove={i}
              >×</button>
            </>
          ) : (
            <span class="selbar__slot-placeholder" aria-hidden="true">+</span>
          )}
        </div>
      ))}
    </div>
    <div class="selbar__actions">
      <button
        type="button"
        class="selbar__clear"
        data-selbar-clear
        disabled
      >Limpiar</button>
      <button
        type="button"
        class="selbar__compare"
        data-selbar-compare
        disabled
      >
        <span class="selbar__compare-lbl">Comparar</span>
        <span class="selbar__compare-n" data-selbar-n>0</span>
        <span class="selbar__compare-arrow" aria-hidden="true">→</span>
      </button>
    </div>
  </div>
</aside>

<style>
  .selbar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 40;
    background: var(--surface);
    border-top: 1px solid var(--border-strong);
    box-shadow: 0 -10px 30px -12px rgba(0, 0, 0, 0.18);
    padding: 0.7rem var(--hub-gutter);
    padding-bottom: calc(0.7rem + env(safe-area-inset-bottom, 0px));
    backdrop-filter: saturate(1.2);
    transition: transform 260ms var(--ease-out-expo);
  }
  .selbar[hidden] { display: none; }
  .selbar.is-hidden { transform: translateY(110%); }

  .selbar__inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
  }
  @media (max-width: 720px) {
    .selbar__inner {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
  }

  .selbar__slots {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .selbar__slot {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.5rem;
    min-height: 48px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: var(--font-sans);
    transition: border-color 140ms, background 140ms;
  }
  .selbar__slot.is-empty {
    border-style: dashed;
    justify-content: center;
    color: var(--text-mute);
  }
  .selbar__slot.is-filled {
    border-color: var(--border-strong);
  }

  .selbar__slot-photo {
    width: 40px;
    height: 30px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
    background: var(--surface-alt);
    position: relative;
    margin: 0;
  }
  .selbar__slot-photo img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 58%;
    transform: scale(1.55);
  }

  .selbar__slot-name {
    flex: 1;
    min-width: 0;
    font-size: 0.8rem;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .selbar__slot-x {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    border-radius: 50%;
    background: transparent;
    color: var(--text-mute);
    border: 1px solid transparent;
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 120ms, color 120ms, border-color 120ms;
  }
  .selbar__slot-x:hover {
    background: var(--surface);
    color: var(--text);
    border-color: var(--border);
  }
  .selbar__slot-x:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 2px;
  }

  .selbar__slot-placeholder {
    font-size: 1.2rem;
    color: var(--text-mute);
    font-weight: 300;
  }

  .selbar__actions {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .selbar__clear {
    padding: 0.5rem 0.85rem;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--text-soft);
    cursor: pointer;
    transition: border-color 140ms, color 140ms;
  }
  .selbar__clear:hover:not(:disabled) {
    border-color: var(--text);
    color: var(--text);
  }
  .selbar__clear:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .selbar__clear:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 2px;
  }

  .selbar__compare {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 1.1rem;
    background: var(--yellow);
    color: var(--black, #111);
    border: 1px solid var(--yellow);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    cursor: pointer;
    transition: transform 140ms, box-shadow 140ms, opacity 140ms;
  }
  .selbar__compare:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 14px -4px rgba(245, 197, 24, 0.5);
  }
  .selbar__compare:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    background: var(--surface);
    color: var(--text-mute);
    border-color: var(--border);
  }
  .selbar__compare:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 3px;
  }
  .selbar__compare-n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 0.35rem;
    background: var(--black, #111);
    color: var(--yellow);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .selbar__compare:disabled .selbar__compare-n {
    background: var(--border);
    color: var(--text-mute);
  }
  .selbar__compare-arrow { font-size: 1rem; line-height: 1; }
</style>
