---
// src/components/comparador/WinnerBanner.astro
// Banner editorial encima del grid. Anuncia al ganador del grupo con
// tipografía serif italic (sin chips llamativos). Sutil por acuerdo con
// Javi: "nada de chip enorme donde ponga 'mejor'".

interface Props {
  /** Nombre del modelo ganador (marca + modelo + variante). */
  ganador: string;
  /** Ahorro absoluto frente al siguiente (positivo). */
  ahorroEur: number;
  /** Nombre del siguiente mejor (para contraste). */
  siguiente?: string;
  /** Escenario activo (p.ej. "5 años · 15.000 km/año"). */
  escenario?: string;
}

const { ganador, ahorroEur, siguiente = '', escenario = '5 años · 15.000 km/año · Madrid' } = Astro.props;

const fmtEur = (n: number) =>
  new Intl.NumberFormat('es-ES', {
    style: 'currency',
    currency: 'EUR',
    maximumFractionDigits: 0,
  }).format(Math.round(n));
---

<aside class="winner" aria-live="polite">
  <p class="winner__eyebrow">Coste total a 5 años</p>
  <p class="winner__line">
    El <strong>{ganador}</strong> sale
    <em>{fmtEur(ahorroEur)} más barato</em>{siguiente && <> que el {siguiente}</>} en el escenario elegido.
  </p>
  <p class="winner__meta">{escenario}</p>
</aside>

<style>
  .winner {
    max-width: var(--max-w);
    margin-inline: auto;
    padding: clamp(1.25rem, 2vw, 1.75rem) var(--page-gutter) clamp(1rem, 1.5vw, 1.25rem);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-align: left;
  }
  .winner__eyebrow {
    margin: 0;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .winner__line {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--text);
  }
  .winner__line strong {
    font-weight: 400;
    color: var(--text);
  }
  .winner__line em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--yellow-text);
    font-size: 1.05em;
  }
  .winner__meta {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }
</style>
