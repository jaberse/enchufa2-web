---
const articles = [
  {
    number: '008',
    title: 'El escalón del Plan Auto+: qué cambia al cruzar 45.000 €',
    excerpt: 'El Plan Auto+ se apaga de golpe a los 45.000 € sin IVA. Cómo funciona el escalón, por qué el iX1 y el iX2 son el caso de libro, y cómo negociarlo.',
    readingTime: '8 min',
    date: 'Abril 2026',
    href: '/articulos/escalon-plan-auto-45k',
  },
  {
    number: '007',
    title: 'Neumáticos para coche eléctrico',
    excerpt: 'Por qué los neumáticos importan más en un eléctrico: desgaste, autonomía, ruido y qué modelos elegir. Con datos de fabricantes.',
    readingTime: '10 min',
    date: 'Marzo 2026',
    href: '/articulos/neumaticos-coche-electrico',
  },
  {
    number: '006',
    title: 'Subvenciones y ayudas para coches eléctricos en España (2026)',
    excerpt: 'Plan Auto+, exenciones fiscales, etiqueta CERO y ahorro real. Solo datos nacionales verificados con fuentes oficiales.',
    readingTime: '9 min',
    date: 'Marzo 2026',
    href: '/articulos/subvenciones-ayudas-ev-2026',
  },
  {
    number: '005',
    title: 'Mantenimiento real de un EV vs combustión',
    excerpt: 'Qué se cambia, cada cuánto y cuánto cuesta. Comparamos el mantenimiento real de un eléctrico con un coche de gasolina con datos.',
    readingTime: '11 min',
    date: 'Marzo 2026',
    href: '/articulos/mantenimiento-ev-vs-combustion',
  },
  {
    number: '004',
    title: 'Cuánto cuesta realmente tener un eléctrico en España',
    excerpt: 'TCO completo: electricidad, seguro, mantenimiento, impuestos y depreciación. Comparamos un eléctrico vs gasolina con datos reales de 2026.',
    readingTime: '12 min',
    date: 'Marzo 2026',
    href: '/articulos/coste-real-electrico',
  },
  {
    number: '003',
    title: 'Cuánto cuesta cargar un coche eléctrico en casa en 2026',
    excerpt: 'Tarifas EV, franjas horarias, comparativa con gasolina y amortización del wallbox. Con datos reales de cada comercializadora.',
    readingTime: '11 min',
    date: 'Marzo 2026',
    href: '/articulos/tarifas-carga-casa',
  },
  {
    number: '002',
    title: 'Carga rápida en España: la guía técnica definitiva',
    excerpt: 'Red de carga, precios por operador, estándares CCS2/MCS, arquitectura 400V vs 800V y regulación AFIR. Todo con datos reales.',
    readingTime: '12 min',
    date: 'Marzo 2026',
    href: '/articulos/carga-rapida-espana',
  },
  {
    number: '001',
    title: 'La guía técnica para cargar la batería de tu eléctrico sin acortarle la vida',
    excerpt: 'NMC vs LFP, temperatura, carga rápida y datos reales de 22.700 vehículos. Todo lo que necesitas saber para que tu batería dure más.',
    readingTime: '14 min',
    date: 'Marzo 2026',
    href: '/articulos/vida-bateria-ev',
  },
];
---

<section class="articles" id="articulos" aria-label="Artículos">
  <div class="page-width">

    <div class="articles-header">
      <span class="t-small reveal" style="color: var(--text-muted)">Conocimiento</span>
      <h2 class="t-heading reveal">Lo que necesitas<br/>saber sobre el EV</h2>
    </div>

    <ul class="articles-list" role="list">
      {articles.map((article) => (
        <li class="article-card reveal">
          <a href={article.href} class="card-link">
            <span class="card-number t-small">{article.number}</span>
            <div class="card-body">
              <h3 class="card-title">{article.title}</h3>
              <p class="card-excerpt t-body">{article.excerpt}</p>
            </div>
            <div class="card-footer">
              <span class="t-small card-meta">{article.date} · {article.readingTime}</span>
              <span class="card-arrow" aria-hidden="true">→</span>
            </div>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .articles {
    padding-block: var(--section-pad);
    background: var(--surface-alt);
  }

  .articles-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }

  .articles-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .article-card {
    background: var(--surface);
  }

  .card-link {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 2rem 2.5rem;
    transition: background 0.2s ease;
    text-decoration: none;
  }

  .card-link:hover {
    background: var(--black);
  }
  .card-link:hover .card-number,
  .card-link:hover .card-title,
  .card-link:hover .card-excerpt,
  .card-link:hover .card-meta {
    color: rgba(250,250,248,0.5);
  }
  .card-link:hover .card-title {
    color: var(--white);
  }
  .card-link:hover .card-arrow {
    color: var(--yellow);
    transform: translateX(4px);
  }

  .card-number {
    color: var(--text-muted);
    font-size: 0.75rem;
    transition: color 0.2s ease;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-title {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    letter-spacing: -0.01em;
    color: var(--text);
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .card-excerpt {
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
    transition: color 0.2s ease;
  }

  .card-footer {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .card-meta {
    color: var(--text-muted);
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .card-arrow {
    font-size: 1.25rem;
    color: var(--text-muted);
    transition: color 0.2s ease, transform 0.25s var(--ease-out-expo);
  }

  @media (max-width: 640px) {
    .card-link {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 1.5rem;
    }
    .card-number { display: none; }
    .card-footer { flex-direction: row; align-items: center; justify-content: space-between; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('#articulos .reveal').forEach((el, i) => {
    gsap.fromTo(el,
      { opacity: 0, y: 30 },
      {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          toggleActions: 'play none none none',
        },
        delay: i * 0.06,
      }
    );
  });
</script>
