---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Search from '../components/Search.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  readingTime: string;
  publishDate: string;
  references?: string;
}

const { title, description, readingTime, publishDate, references } = Astro.props;
---

<Layout title={`${title} — enchufa2`} description={description}>
  <Header />
  <Search />

  <main id="main" class="article-main">

    <!-- Hero del artículo -->
    <div class="article-hero">
      <div class="hero-inner page-width">
        <div class="hero-label t-small">
          <span class="hero-label-line" aria-hidden="true"></span>
          Guía técnica
        </div>

        <h1 class="article-title">{title}</h1>

        <div class="article-meta t-small">
          <span>{publishDate}</span>
          <span aria-hidden="true">·</span>
          <span>{readingTime}</span>
          {references && (
            <>
              <span aria-hidden="true">·</span>
              <span>{references}</span>
            </>
          )}
        </div>
      </div>
    </div>

    <!-- Contenido -->
    <div class="article-body">
      <slot />
    </div>

    <!-- CTA final -->
    <div class="article-cta page-width">
      <div class="cta-card">
        <p class="t-serif">¿Tienes preguntas sobre tu coche eléctrico?</p>
        <a href="/#contacto" class="btn-primary">Hablemos</a>
      </div>
    </div>

    <!-- Volver -->
    <div class="article-back page-width">
      <a href="/" class="back-link t-small">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Volver al inicio
      </a>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  .article-main {
    /* no top padding — hero handles it so no white gap under transparent header */
  }

  /* ─── Hero ─── */
  .article-hero {
    background: var(--black);
    color: var(--white);
    padding-top: calc(4.5rem + clamp(2rem, 4vw, 3.5rem));
    padding-bottom: clamp(2.5rem, 5vw, 4.5rem);
    display: flex;
    align-items: flex-end;
  }

  .hero-inner {
    max-width: 900px;
  }

  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    color: var(--yellow);
    margin-bottom: 1.5rem;
  }
  .hero-label-line {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--yellow);
  }

  .article-title {
    font-family: var(--font-sans);
    font-weight: 200;
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--white);
    max-width: 18ch;
    margin-bottom: 1.5rem;
  }

  .article-meta {
    color: rgba(250,250,248,0.3);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ─── Article deck (editorial subtitle) ─── */
  .article-body :global(.article-deck) {
    font-size: clamp(1.05rem, 1.8vw, 1.15rem);
    line-height: 1.7;
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 2rem;
  }

  /* ─── Stats (styled as elevated cards) ─── */
  .article-body :global(.article-stats) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
    position: relative;
    z-index: 10;
  }
  @media (max-width: 640px) {
    .article-body :global(.article-stats) {
      grid-template-columns: 1fr;
    }
  }
  .article-body :global(.stat) {
    background: var(--surface);
    border-radius: 8px;
    padding: 1.5rem 1.75rem;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 1px 4px rgba(0,0,0,0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .article-body :global(.stat:hover) {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  }
  .article-body :global(.stat-value) {
    font-size: clamp(1.25rem, 3vw, 2.25rem);
    font-weight: 200;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 0.25rem;
    word-break: break-word;
    hyphens: none;
    overflow-wrap: anywhere;
  }
  .article-body :global(.stat-label) {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.45;
  }

  /* ─── Body ─── */
  .article-body {
    max-width: var(--article-max, 960px);
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 4vw, 2.5rem);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  /* Article content styles */
  .article-body :global(h2) {
    font-family: var(--font-sans);
    font-weight: 200;
    font-size: clamp(1.4rem, 2.8vw, 1.9rem);
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--text);
    margin-top: 3.5rem;
    margin-bottom: 1.25rem;
  }

  .article-body :global(h3) {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-top: 2rem;
    margin-bottom: 0.875rem;
  }

  .article-body :global(p) {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1rem, 1.5vw, 1.0625rem);
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  .article-body :global(strong) {
    font-weight: 400;
    color: var(--text);
  }

  .article-body :global(em) {
    font-family: var(--font-serif);
    font-size: 1.05em;
  }

  .article-body :global(sup) {
    font-size: 0.7em;
    color: var(--text-muted);
  }

  /* TLDR box */
  .article-body :global(.tldr) {
    background: var(--surface-alt);
    border-left: 3px solid var(--yellow);
    padding: 1.5rem 1.75rem;
    margin-bottom: 2.5rem;
    border-radius: 0 6px 6px 0;
  }
  .article-body :global(.tldr > strong) {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 0.75rem;
  }
  .article-body :global(.tldr li) {
    font-size: 0.9375rem;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.6;
    font-weight: 300;
  }
  .article-body :global(.tldr li:last-child) { margin-bottom: 0; }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .article-body :global(li) {
    font-weight: 300;
    font-size: clamp(1rem, 1.5vw, 1.0625rem);
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 0.375rem;
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin-block: 2.5rem;
  }

  /* ─── Component table ─── */
  .article-body :global(.component-table) {
    background: var(--surface-alt);
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .article-body :global(.comp-row) {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 1rem;
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .article-body :global(.comp-name) {
    font-weight: 500;
    color: var(--text);
  }
  .article-body :global(.comp-desc) {
    color: var(--text-secondary);
  }

  /* ─── Comparison table ─── */
  .article-body :global(.comparison-table) {
    margin: 2rem 0;
    border-radius: 8px;
    overflow-x: auto;
    border: 1px solid var(--border);
    font-size: 0.875rem;
    -webkit-overflow-scrolling: touch;
  }
  .article-body :global(.ct-row) {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    min-width: 500px;
    border-bottom: 1px solid var(--border);
  }
  .article-body :global(.ct-row:last-child) {
    border-bottom: none;
  }
  .article-body :global(.ct-row > span) {
    padding: 0.75rem 1rem;
    color: var(--text-secondary);
    line-height: 1.45;
  }
  .article-body :global(.ct-header) {
    background: var(--black);
  }
  .article-body :global(.ct-header > span) {
    color: rgba(255,255,255,0.4);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .article-body :global(.ct-nmc) {
    color: rgba(255,255,255,0.9) !important;
  }
  .article-body :global(.ct-lfp) {
    color: var(--yellow) !important;
  }
  .article-body :global(.ct-row > span:first-child) {
    color: var(--text);
    font-weight: 400;
  }
  .article-body :global(.ct-row:not(.ct-header):nth-child(even)) {
    background: var(--surface-alt);
  }

  /* ─── Blockquote ─── */
  .article-body :global(blockquote) {
    border-left: 3px solid var(--yellow);
    padding: 1.25rem 1.75rem;
    margin: 2rem 0;
    background: var(--surface-alt);
    border-radius: 0 6px 6px 0;
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text);
    font-weight: 300;
  }
  .article-body :global(blockquote small) {
    color: var(--text-muted);
    font-size: 0.8rem;
    display: block;
    margin-top: 0.75rem;
  }

  /* ─── Images ─── */
  .article-body :global(figure) {
    margin-block: 2.5rem;
  }
  .article-body :global(figure img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }
  /* SVG charts need a light background in dark mode (hardcoded text colors) */
  :global([data-theme="dark"]) .article-body :global(figure img[src$=".svg"]) {
    background: #FAFAF8;
    padding: 0.5rem;
  }
  .article-body :global(figcaption) {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.75rem;
    line-height: 1.5;
  }

  /* ─── References ─── */
  .article-body :global(.references) {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .article-body :global(.references p) {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 0.4rem;
    line-height: 1.6;
  }
  .article-body :global(.references p:first-child) {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  /* ─── CTA ─── */
  .article-cta {
    max-width: var(--article-max, 960px);
    padding-bottom: clamp(2rem, 4vw, 4rem);
  }

  .cta-card {
    background: var(--black);
    color: var(--white);
    padding: 2.5rem 3rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-card .t-serif {
    color: rgba(250,250,248,0.8);
    font-size: clamp(1rem, 2vw, 1.25rem);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2.25rem;
    background: var(--yellow);
    color: var(--black);
    font-weight: 400;
    font-size: 0.9375rem;
    border-radius: 2px;
    white-space: nowrap;
    transition: transform 0.25s var(--ease-out-expo), box-shadow 0.25s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(245,197,24,0.25);
  }

  /* ─── Back ─── */
  .article-back {
    max-width: var(--article-max, 960px);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }
  .back-link:hover { color: var(--text); }
  .back-link svg {
    transition: transform 0.25s var(--ease-out-expo);
  }
  .back-link:hover svg { transform: translateX(-