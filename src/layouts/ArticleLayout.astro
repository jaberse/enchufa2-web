---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  readingTime: string;
  publishDate: string;
}

const { title, description, readingTime, publishDate } = Astro.props;
---

<Layout title={`${title} — enchufa2`} description={description}>
  <Header />

  <main class="article-main">

    <!-- Hero del artículo -->
    <div class="article-hero">
      <div class="page-width">
        <nav class="article-breadcrumb t-small" aria-label="Breadcrumb">
          <a href="/">Inicio</a>
          <span aria-hidden="true">·</span>
          <a href="/articulos">Artículos</a>
        </nav>

        <h1 class="article-title">{title}</h1>

        <div class="article-meta t-small">
          <span>{publishDate}</span>
          <span aria-hidden="true">·</span>
          <span>{readingTime}</span>
        </div>
      </div>
    </div>

    <!-- Contenido -->
    <div class="article-body">
      <slot />
    </div>

    <!-- CTA final -->
    <div class="article-cta page-width">
      <div class="cta-card">
        <p class="t-serif">¿Tienes preguntas sobre la batería de tu coche eléctrico?</p>
        <a href="/#contacto" class="btn-primary">Hablemos</a>
      </div>
    </div>

    <!-- Volver -->
    <div class="article-back page-width">
      <a href="/" class="back-link t-small">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M13 8H3M7 4L3 8l4 4" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Volver al inicio
      </a>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  .article-main {
    /* no top padding — hero handles it so no white gap under transparent header */
  }

  /* ─── Hero ─── */
  .article-hero {
    background: var(--black);
    color: var(--white);
    /* include header height in top padding so hero starts behind it */
    padding-top: calc(5rem + clamp(3rem, 6vw, 6rem));
    padding-bottom: clamp(3rem, 6vw, 6rem);
  }

  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(250,250,248,0.4);
    margin-bottom: 2rem;
  }
  .article-breadcrumb a {
    transition: color 0.2s ease;
  }
  .article-breadcrumb a:hover { color: rgba(250,250,248,0.8); }

  .article-title {
    font-family: var(--font-sans);
    font-weight: 200;
    font-size: clamp(1.75rem, 4.5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--white);
    max-width: 22ch;
    margin-bottom: 1.5rem;
  }

  .article-meta {
    color: rgba(250,250,248,0.4);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* ─── Body ─── */
  .article-body {
    max-width: 800px;
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 4vw, 2.5rem);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  /* Article content styles */
  .article-body :global(h2) {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1.4rem, 2.5vw, 1.875rem);
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--black);
    margin-top: 3rem;
    margin-bottom: 1.25rem;
  }

  .article-body :global(h3) {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
    color: var(--black);
    margin-top: 2rem;
    margin-bottom: 0.875rem;
  }

  .article-body :global(p) {
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1rem, 1.5vw, 1.0625rem);
    line-height: 1.8;
    color: var(--gray-600);
    margin-bottom: 1.25rem;
  }

  .article-body :global(strong) {
    font-weight: 400;
    color: var(--black);
  }

  .article-body :global(em) {
    font-family: var(--font-serif);
    font-size: 1.05em;
  }

  /* TLDR box */
  .article-body :global(.tldr) {
    background: var(--gray-100);
    border-left: 3px solid var(--yellow);
    padding: 1.5rem 1.75rem;
    margin-bottom: 2.5rem;
    border-radius: 0 2px 2px 0;
  }
  .article-body :global(.tldr p),
  .article-body :global(.tldr li) {
    font-size: 0.9375rem;
    color: var(--black);
    margin-bottom: 0.5rem;
  }
  .article-body :global(.tldr li:last-child) { margin-bottom: 0; }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .article-body :global(li) {
    font-weight: 300;
    font-size: clamp(1rem, 1.5vw, 1.0625rem);
    line-height: 1.8;
    color: var(--gray-600);
    margin-bottom: 0.375rem;
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--gray-100);
    margin-block: 2.5rem;
  }

  /* Images */
  .article-body :global(figure) {
    margin-block: 2.5rem;
  }
  .article-body :global(figure img) {
    width: 100%;
    border-radius: 4px;
    display: block;
  }
  .article-body :global(figcaption) {
    font-size: 0.8125rem;
    color: var(--gray-400);
    margin-top: 0.75rem;
    line-height: 1.5;
  }

  /* References */
  .article-body :global(.references) {
    font-size: 0.8125rem;
    color: var(--gray-400);
    line-height: 1.6;
  }
  .article-body :global(.references p) {
    font-size: 0.8125rem;
    color: var(--gray-400);
    margin-bottom: 0.5rem;
  }

  /* ─── CTA ─── */
  .article-cta {
    max-width: 800px;
    padding-bottom: clamp(2rem, 4vw, 4rem);
  }

  .cta-card {
    background: var(--black);
    color: var(--white);
    padding: 2.5rem 3rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-card .t-serif {
    color: rgba(250,250,248,0.8);
    font-size: clamp(1rem, 2vw, 1.25rem);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2.25rem;
    background: var(--yellow);
    color: var(--black);
    font-weight: 400;
    font-size: 0.9375rem;
    border-radius: 2px;
    white-space: nowrap;
    transition: transform 0.25s var(--ease-out-expo), box-shadow 0.25s ease;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(245,197,24,0.25);
  }

  /* ─── Back ─── */
  .article-back {
    max-width: 800px;
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--gray-400);
    transition: color 0.2s ease;
  }
  .back-link:hover { color: var(--black); }
  .back-link svg {
    transition: transform 0.25s var(--ease-out-expo);
  }
  .back-link:hover svg { transform: translateX(-3px); }
</style>
